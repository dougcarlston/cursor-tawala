<?xml version="1.0" encoding="UTF-8"?>
<project name="Signup Sheet Template w Email" themePath="default" format="1.6">
<forms>
<form name="Form 1" startPoint="true" themePath="default" process="Process 1">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="240" color="000000"><b>Sign up Sheet Template</b></font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><b><i>To use this template, replace the text on this Form with your own text and then click on the Deploy button ( </i></b></font><font face="Arial" size="200" color="000000"><image id="image1" width="22" height="23"><metafileHeader fileType="1" headerSize="9" version="768" fileSize="835" numOfObjects="0" maxRecordSize="813" numOfParams="0"/>
</image></font><font face="Arial" size="200" color="000080"><b><i>)  up above to create a Web page for your new poll.  You will want to delete this instruction box as well.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><b><i>Once you have deployed your Web app, you can get the Web link to the Signup Sheet from your My Tawala page on the Tawala Website.  Send the link to your group or place it on your Website to drive traffic to your sheet.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><b><i>If you want email notification each time someone adds their name to this list, click on 'Process1' in the Project Explorer on the left of the Designer.  Then follow the directions that appear in the Process1 window.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><b><i>If you do NOT want email notification each time someone adds their name to this list, click on the 'Process1' in the Project Explorer on the left of the Designer and delete it by clicking on the Delete button (</i></b></font><font face="Arial" size="200" color="000000"><image id="image2" width="22" height="23"><metafileHeader fileType="1" headerSize="9" version="768" fileSize="843" numOfObjects="0" maxRecordSize="816" numOfParams="0"/>
</image></font><font face="Arial" size="200" color="000080"><b><i> ) above.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name:   </b></font><blank label="a" length="16" required="false" alternateLabel="FirstName"/><font face="Arial" size="200" color="000000"> (first)  </font><blank label="b" length="19" required="false" alternateLabel="LastName"/><font face="Arial" size="200" color="000000"> (last)</font></paragraph></fib>
<fib label="Q2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Contact information:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email:  </font><blank label="a" length="50" required="false" alternateLabel="Email"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Telephone: </font><blank label="b" length="45" required="false" alternateLabel="Tel"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Address: </font><blank label="c" length="48" required="false" alternateLabel="Address"/></paragraph></fib>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><itemization-table version="1"><number-of-columns>5</number-of-columns><column><header>First</header><contents><field name="Record:Form 1:FirstName"/></contents></column><column><header>Last</header><contents><field name="Record:Form 1:LastName"/></contents></column><column><header>Email</header><contents><field name="Record:Form 1:Email"/></contents></column><column><header>Phone</header><contents><field name="Record:Form 1:Tel"/></contents></column><column><header>Address</header><contents><field name="Record:Form 1:Address"/></contents></column><conditions><form name="Form 1"/></conditions></itemization-table></font></paragraph></text>
</items>
</form>
</forms>
<processes>
<process name="Process 1">
<comment>Click on the line below, then insert your email address in place of "&lt;Insert your email address here&gt;."</comment>
<send>
<to addressLiteral="&lt;Insert your email address here&gt;"/>
<subject>New Signup on Signup Sheet</subject>
<body document="NewSignup" reset="false"/>
</send>
</process>
</processes>
<documents>
<document name="NewSignup">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b><field name="Form 1:FirstName"/></b></font><sp/><font face="Arial" size="200" color="000000"><b><field name="Form 1:LastName"/></b></font><sp/><font face="Arial" size="200" color="000000">has joined the signup sheet.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Contact information:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="660"><row><cell width="1425"><division indent="0" align="right"><font face="Arial" size="200" color="000000"><b>Email:</b></font></division></cell><cell width="272"/><cell width="8443"><division indent="0" align="left"><font face="Arial" size="200" color="000000"><field name="Form 1:Email"/></font></division></cell></row><row><cell width="1425"><division indent="0" align="right"><font face="Arial" size="200" color="000000"><b>Telephone:</b></font></division></cell><cell width="272"/><cell width="8443"><division indent="0" align="left"><font face="Arial" size="200" color="000000"><field name="Form 1:Tel"/></font></division></cell></row><row><cell width="1425"><division indent="0" align="right"><font face="Arial" size="200" color="000000"><b>Address:</b></font></division></cell><cell width="272"/><cell width="8443"><division indent="0" align="left"><font face="Arial" size="200" color="000000"><field name="Form 1:Address"/></font></division></cell></row></table>
</xmlData>
</document>
</documents>
