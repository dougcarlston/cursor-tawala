<?xml version="1.0" encoding="UTF-8"?>
<project name="Signup Sheet Template" themePath="default" format="1.6">
<forms>
<form name="Form 1" startPoint="true" themePath="default">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="240" color="000000"><b>Sign up Sheet Template</b></font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><b><i>To use this template, replace the text on this Form with your own text and then click on the Deploy button ( </i></b></font><font face="Arial" size="200" color="000000"><image id="image1" width="22" height="23"><metafileHeader fileType="1" headerSize="9" version="768" fileSize="835" numOfObjects="0" maxRecordSize="813" numOfParams="0"/>
</image></font><font face="Arial" size="200" color="000080"><b><i>)  up above to create a Web page for your new poll.  You will want to delete this instruction box as well.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><b><i>Once you have deployed your Web app, you can get the Web link to the Signup Sheet from your My Tawala page on the Tawala Website.  Send the link to your group or place it on your Website to drive traffic to your sheet.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name:   </b></font><blank label="a" length="16" required="false"/><font face="Arial" size="200" color="000000"> (first)  </font><blank label="b" length="19" required="false"/><font face="Arial" size="200" color="000000"> (last)</font></paragraph></fib>
<fib label="Q2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Contact information:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email:  </font><blank label="a" length="50" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Telephone: </font><blank label="b" length="45" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Address: </font><blank label="c" length="48" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></fib>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><itemization-table version="1"><number-of-columns>5</number-of-columns><column><header>First</header><contents><field name="Record:Form 1:Q1:a"/></contents></column><column><header>Last</header><contents><field name="Record:Form 1:Q1:b"/></contents></column><column><header>Email</header><contents><field name="Record:Form 1:Q2:a"/></contents></column><column><header>Phone</header><contents><field name="Record:Form 1:Q2:b"/></contents></column><column><header>Address</header><contents><field name="Record:Form 1:Q2:c"/></contents></column><conditions><form name="Form 1"/></conditions></itemization-table></font></paragraph></text>
</items>
</form>
