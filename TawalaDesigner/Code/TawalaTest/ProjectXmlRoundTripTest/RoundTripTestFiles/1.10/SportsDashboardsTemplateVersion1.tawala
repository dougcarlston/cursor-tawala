<mc label="Q1" alternateLabel="CoachId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach to edit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
