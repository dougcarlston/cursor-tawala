<process name="Post-CoachRosterNotice">
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q8" value="a"/>
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q4" value="a"/>
</conditions>
<trueSet>
<get recordList="TeamAndCoachList">
<forms>
<form name="Team"/>
<form name="Coach"/>
</forms>
<conditions>
<equals field="TeamAndCoachList:Team:CoachId">
<string field="TeamAndCoachList:Coach:CoachId"/>
</equals>
</conditions></get>
</trueSet>
<falseSet>
<get recordList="TeamAndCoachList">
<forms>
<form name="Team"/>
<form name="Coach"/>
</forms>
<conditions>
<and>
<equals field="TeamAndCoachList:Team:CoachId">
<string field="TeamAndCoachList:Coach:CoachId"/>
</equals>
<mcContains field="CoachRosterNotice:Q7">
<string field="TeamAndCoachList:Coach:CoachId"/>
</mcContains>
</and>
</conditions></get>
</falseSet>
</if>
<foreach record="SuchPair" recordList="TeamAndCoachList">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
<set field="Team" arithmeticAsText="false">
<string field="SuchPair:Team:TeamId"/>
</set>
<set field="CoachID" arithmeticAsText="false">
<string field="SuchPair:Coach:CoachId"/>
</set>
<set field="PlayerFirst" arithmeticAsText="false">
<string field="SuchPair:Coach:FirstName"/>
</set>
<send>
<to addressField="SuchPair:Coach:Email"/>
