<document name="RegClosedDoc">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Unfortunately, registration for the </font><font><field name="League"/></font><sp/><font><field name="SeasonYr"/></font><font> Season has been closed.  If you would like to apply to the League Administrator for a late registration, please contact:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="1170"><row><cell width="9630"><division indent="0" align="left"><font><field name="AdminName"/></font></division></cell></row><row><cell width="9630"><division indent="0" align="left"><font><field name="AdminsPhone"/></font></division></cell></row><row><cell width="9630"><division indent="0" align="left"><font><field name="AdminEmail"/></font></division></cell></row><row><cell width="9630"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><link>
<description>
<string value="Return to Web Home Page"/>
</description>
<url>
<field name="HomeURL"/>
</url>
</link>
</u></font></paragraph>
</xmlData>
</document>
