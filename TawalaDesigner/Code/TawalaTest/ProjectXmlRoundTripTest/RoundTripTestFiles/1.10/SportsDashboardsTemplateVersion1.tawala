<process name="Post-RecruitDB">
<if>
<conditions>
<isBlank field="RecruitmentDB:RecruitmentId" />
</conditions>
<trueSet>
<get recordList="Setup Records">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="SuchRecord" recordList="Setup Records">
<set field="RecruitmentDB:RecruitmentId" arithmeticAsText="false">
<add>
<operand field="SuchRecord:AdminSetup:RecruitmentIdGenerator"/>
<operand value="1"/>
</add>
</set>
<set field="SuchRecord:AdminSetup:RecruitmentIdGenerator" arithmeticAsText="false">
<string field="RecruitmentDB:RecruitmentId"/>
</set>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<equals field="Action">
<string value="AddNonDupes"/>
</equals>
</conditions>
<trueSet>
<if>
<conditions>
<or>
<equals field="From">
<string value="a"/>
</equals>
<equals field="From">
<string value="c"/>
</equals>
</or>
</conditions>
<trueSet>
<get recordList="Record List 113">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Record List 113:Registration:RecruitmentMergeStatus">
<string value="No"/>
</equals>
</conditions></get>
</trueSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="b"/>
</equals>
</conditions>
<trueSet>
<get recordList="Record List 113">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<and>
<equals field="Record List 113:Registration:RecruitmentMergeStatus">
<string value="No"/>
</equals>
<isGreaterThanOrEqualTo field="Record List 113:Registration:RegAgeYr">
<string field="AddRecruitFromReg:Year"/>
</isGreaterThanOrEqualTo>
</and>
</conditions></get>
</trueSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="d"/>
</equals>
</conditions>
<trueSet>
<get recordList="Record List 113">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Record List 113:Registration:RegID">
<string field="RID"/>
</equals>
</conditions></get>
</trueSet>
</if>
<foreach record="SuchNonDupe" recordList="Record List 113">
<set field="RecruitmentDB:FirstName" arithmeticAsText="false">
<string field="SuchNonDupe:Registration:FirstName"/>
</set>
<set field="RecruitmentDB:LastName" arithmeticAsText="false">
<string field="SuchNonDupe:Registration:LastName"/>
</set>
<set field="RecruitmentDB:ParentFirst" arithmeticAsText="false">
<string field="SuchNonDupe:Registration:ParentFirstName"/>
</set>
<set field="RecruitmentDB:Email" arithmeticAsText="false">
<string field="SuchNonDupe:Registration:ParentEmail"/>
</set>
<set field="RecruitmentDB:Email2" arithmeticAsText="false">
<string field="SuchNonDupe:Registration:ParentEmail2"/>
</set>
<set field="RecruitmentDB:Phone" arithmeticAsText="false">
<string field="SuchNonDupe:Registration:Phone1"/>
</set>
<set field="SuchNonDupe:Registration:RecruitmentMergeStatus" arithmeticAsText="true">
<string value="Added"/>
</set>
<set field="SuchNonDupe:Registration:RecruitmentId" arithmeticAsText="false">
<string field="RecruitmentDB:RecruitmentId"/>
</set>
<comment>-- There is only one record in this case</comment>
<if>
<conditions>
<equals field="From">
<string value="d"/>
</equals>
</conditions>
<trueSet>
<show form="CompareNMark"/>
</trueSet>
</if>
<comment>-- It will continue the loop</comment>
<show form="RecruitmentDB"/>
</foreach>
<comment>-- If we are here there are no more records to add. This record is blank and needs to be marked deleted.</comment>
<set field="RecruitmentDB:BadRecord?" arithmeticAsText="false">
<string value="Delete"/>
</set>
<set field="Action" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Message" arithmeticAsText="false">
<string value="Registered players added to recruitment database"/>
</set>
<show document="Message" reset="false"/>
<show form="AddRecruitFromReg"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<isBlank field="RecruitmentDB:FirstName" />
<or>
<isBlank field="RecruitmentDB:LastName" />
<isBlank field="RecruitmentDB:Email" />
</or>
</or>
</conditions>
<trueSet>
<set field="RecruitmentDB:BadRecord?" arithmeticAsText="false">
<string value="Delete"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<doesNotEqual field="Action">
<string value="edit"/>
</doesNotEqual>
</conditions>
<trueSet>
<get recordList="Record List 3">
<forms>
<form name="RecruitmentDB"/>
</forms>
<conditions>
<and>
<equals field="Record List 3:RecruitmentDB:FirstName">
<string field="RecruitmentDB:FirstName"/>
</equals>
<and>
<equals field="Record List 3:RecruitmentDB:LastName">
<string field="RecruitmentDB:LastName"/>
</equals>
<equals field="Record List 3:RecruitmentDB:Email">
<string field="RecruitmentDB:Email"/>
</equals>
</and>
</and>
</conditions></get>
<foreach record="SuchRecord" recordList="Record List 3">
<set field="RecruitmentDB:BadRecord?" arithmeticAsText="false">
<string value="Dupe"/>
</set>
<show form="RecruitDBDupe"/>
</foreach>
<set field="RecruitmentDB:ContactsNo" arithmeticAsText="false">
<string value="0"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="RecruitAudit"/>
</equals>
</conditions>
<trueSet>
<set field="RecruitmentDB:BadRecord?" arithmeticAsText="false">
<string value=" "/>
</set>
<show form="AuditRecruitLoop"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="Action">
<string value="edit"/>
</equals>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Record edited."/>
</set>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value="Record added."/>
</set>
</falseSet>
</if>
<show document="Message" reset="false"/>
<show form="Recruitment"/>
</process>
