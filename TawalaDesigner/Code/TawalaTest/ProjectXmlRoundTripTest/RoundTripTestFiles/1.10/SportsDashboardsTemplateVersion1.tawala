<form name="AdminSetup" startPoint="false" themePath="mvsc" process="Post-AdminSetup" preProcess="Pre-AdminSetup">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Basic Information Setup</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="9F0000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Athletic Director:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name:  </font><blank label="a" length="35" required="false" alternateLabel="AdminsName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email Address:  </font><blank label="b" length="35" required="false" alternateLabel="AdminsEmail"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone Number: </font><blank label="c" length="35" required="false" alternateLabel="AdminPhone"/></paragraph></fib>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Mailing Address:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Street: </font><blank label="a" length="52" required="false" alternateLabel="AdminAddress"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City:     </font><blank label="b" length="52" required="false" alternateLabel="AdminCity"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">State:   </font><blank label="c" length="52" required="false" alternateLabel="AdminST"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Zip: </font><blank label="d" length="52" required="false" alternateLabel="AdminZIP"/></paragraph></fib>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><i>Note: The above address is where waivers and checks will be sent.</i></font></paragraph></text>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>League Information:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">League Name </font><font face="Arial" size="200" color="000000"><i>(e.g. Mill Valley Dirt Bowl)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="20" required="false" alternateLabel="LeagueName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Season </font><font face="Arial" size="200" color="000000"><i>(e.g 2008)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="b" length="20" required="false" alternateLabel="Season"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">URL of the league schedule: </font><blank label="c" length="19" required="false" alternateLabel="ScheduleURL"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">URL of the league Web site: </font><blank label="d" length="19" required="false" alternateLabel="LeagueWebSite"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">URL of the league rules: </font><blank label="e" length="19" required="false" alternateLabel="LeagueRules"/></paragraph></fib>
<text label="T3" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><i>Notes:</i></font><sp/><sp/><sp/><font><i>The Season field above is used to calculate player age, so please enter only a whole number such as "2009"</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><i>Make sure the URLs above start with  </i></font><font>http:// or  https:// </font></paragraph></text>
<fib label="Q4" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Registration Form Text:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registration deadline date: </font><blank label="a" length="17" required="false" alternateLabel="RegFormDeadline"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Header text: </font><blank label="b" length="20" required="false" alternateLabel="RegFormHeader"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Sub-header text </font><font face="Arial" size="200" color="000000"><i>(optional)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="c" length="20" required="false" alternateLabel="RegFormSubHeader"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Additional descriptive text </font><font face="Arial" size="200" color="000000"><i>(optional)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="d" length="19" required="false" alternateLabel="RegFormDescription"/></paragraph></fib>
<text label="T4" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Note: The above Header, Sub-header and descriptive text appear at the top of the Registration Form, and can contain any information you would like to have appear there.</i></font></paragraph></text>
<fib label="Q5" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Age Determination:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Some leagues determine a player's age based on their actual age at the beginning of a particular month.  If your league uses a determination system that determines Player age in such a fashion, please enter the number of the month here </font><font face="Arial" size="200" color="000000"><i>(1= Jan, 2= Feb, etc.):</i></font><sp/><blank label="a" length="5" required="false" alternateLabel="AgeFormula"/></paragraph></fib>
<text label="T5" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Note: If your league uses a more complex formula for determining age, you will have to enter the age field manually in the Registration Form from your MyTawala Project Details page.</i></font></paragraph></text>
<mc label="Q6" alternateLabel="EmailNotificationPreference" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Administrator Email Options:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send me an email notification of each new registration</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send me a single copy of each bulk mailing</font></paragraph></choice></mc>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Registration Form  Setup</font></paragraph></heading>
<text label="T6"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000"><b>Phone Descriptions: </b></font><font color="000000"><i>(Enter name you would like each phone field described as, e.g. Dad's Mobile, Home phone, etc.)</i></font></paragraph></text>
<fib label="Q7" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">    Phone 1: </font><blank label="a" length="20" required="false" alternateLabel="Phone1Label"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">    Phone 2: </font><blank label="b" length="20" required="false" alternateLabel="Phone2Label"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">    Phone 3: </font><blank label="c" length="20" required="false" alternateLabel="Phone3Label"/></paragraph></fib>
<mc label="Q8" alternateLabel="WaiverOptions" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Waivers are included in registration process unless checked here as:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Not required</font></paragraph></choice></mc>
<mc label="Q9" alternateLabel="XtraQs" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000"><b>Optional Questions:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Ask Registrants parish information (for CYO leagues)</font></paragraph></choice></mc>
<text label="T7"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Division Setup:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><itemization-table version="2"><number-of-columns>1</number-of-columns><column><header><string value="Division"/>
</header><contents><field name="Record:Divisions:Name" /></contents></column><conditions><form name="Divisions" /></conditions></itemization-table></font></paragraph></text>
<mc label="Q10" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check here to add, edit or delete divisions</font></paragraph></choice></mc>
<text label="T8"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Grade Setup:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>1</number-of-columns><column><header><string value="Grade"/>
</header><contents><field name="Record:Grade:Name" /></contents></column><conditions><form name="Grade" /></conditions></itemization-table></font></paragraph></text>
<mc label="Q11" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check here to add, edit or delete grade levels</font></paragraph></choice></mc>
<mc label="Q12" alternateLabel="UniformSetup" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Uniform/Jersey Setup:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Show uniform sizes on the registration form</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Players must select a uniform size (only applicable if the previous option is checked)</font></paragraph></choice></mc>
<fib label="Q13" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Text of the question to select the uniform size (e.g. What is your jersey size?):</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="69" required="false" alternateLabel="UniformQuestionText"/></paragraph></fib>
<text label="T9" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press Submit to continue to Page 2 of Setup</font></paragraph></text>
<skipInstructions>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<or>
<isLessThan field="AdminSetup:Season">
<string value="2008"/>
</isLessThan>
<isGreaterThan field="AdminSetup:Season">
<string value="2060"/>
</isGreaterThan>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Season must be a year between 2008 and 2060."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcContains field="AdminSetup:Q10" value="a"/>
<mcContains field="AdminSetup:Q11" value="a"/>
</or>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H3" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Financial Setup</font></paragraph></heading>
<text label="T10"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Fee Structure:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><field name="FeeStructureDescription"/></font></paragraph></text>
<mc label="Q14" alternateLabel="ChangeFee" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check here to set or change fee structure</font></paragraph></choice></mc>
<text label="T11"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="B30000"><i><field name="Message"/></i></font></paragraph></text>
<mc label="Q15" alternateLabel="PaymentMethods" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000"><b>Payment methods: </b></font><font face="Arial" color="000000">(select at least one)</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enable PayPal online payments</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Show instructions on how to pay by check</font></paragraph></choice></mc>
<text label="T12"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Description of charges (will appear on PayPal check out screen):</font></paragraph></text>
<fib label="Q16" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="20" required="false" alternateLabel="ChargeDescription"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></fib>
<text label="T13" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Donation Information:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you select the option below a "Make Donation" link will be display on the player's dashboard.</font><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<mc label="Q17" alternateLabel="EnableDonations" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enable online donations</font></paragraph></choice></mc>
<fib label="Q18" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Text to be displayed on the donation page:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="54" height="7" required="false" alternateLabel="DonationPageMessage"/></paragraph></fib>
<text label="T14" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press Submit to continue to Page 3 of Setup</font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="AdminSetup:PaymentMethods" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You must select a payment method to continue."/>
</set>
<skip to="H3"/>
</trueSet>
</if>
</skipInstructions>
