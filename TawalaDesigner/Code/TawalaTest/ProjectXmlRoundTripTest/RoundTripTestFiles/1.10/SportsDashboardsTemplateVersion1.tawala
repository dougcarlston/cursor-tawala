<string value="Yes"/>
</set>
</falseSet>
</if>
<show form="Coach"/>
</process>
<process name="Post-UtilityToSetPlayerAges">
<comment>-- Current method of calculating Player Age:</comment>
<comment>-- The age of the player as of August 31 of the current Season</comment>
<get recordList="SetupRecords">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="SetupRecord" recordList="SetupRecords">
<set field="SeasonYr" arithmeticAsText="false">
<string field="SetupRecord:AdminSetup:Season"/>
</set>
</foreach>
<get recordList="AllRegistrations">
<forms>
<form name="Registration"/>
</forms>
</get>
<foreach record="RegRecord" recordList="AllRegistrations">
<if>
<conditions>
<isGreaterThan field="RegRecord:Registration:RegAgeMo">
<string value="8"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="RegRecord:Registration:PlayerAge" arithmeticAsText="false">
<sub>
<sub>
<operand field="SeasonYr"/>
<operand field="RegRecord:Registration:RegAgeYr"/>
</sub>
<operand value="1"/>
</sub>
</set>
</trueSet>
<falseSet>
<set field="RegRecord:Registration:PlayerAge" arithmeticAsText="false">
<sub>
<operand field="SeasonYr"/>
<operand field="RegRecord:Registration:RegAgeYr"/>
</sub>
</set>
</falseSet>
</if>
</foreach>
</process>
<process name="Pre-EditOrDeleteRegistration">
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</process>
<process name="Post-DuplicateRegistrationCheck">
<set field="DuplicatesFoundMessage" arithmeticAsText="false">
<string value="No duplicates found."/>
</set>
<get recordList="AllRegistrations">
<forms>
<form name="Registration"/>
</forms>
</get>
<get recordList="AllRegistrations2">
<forms>
<form name="Registration"/>
</forms>
</get>
<foreach record="Record" recordList="AllRegistrations">
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<foreach record="Record2" recordList="AllRegistrations2">
<if>
<conditions>
<and>
<equals field="Record:Registration:FirstName">
<string field="Record2:Registration:FirstName"/>
</equals>
<equals field="Record:Registration:LastName">
<string field="Record2:Registration:LastName"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<isGreaterThan field="Count">
<string value="1"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="DuplicatesFoundMessage" arithmeticAsText="false">
<string value="The following Player names appear more than once in the registration records:"/>
</set>
<set field="PlayerFirst" arithmeticAsText="false">
<string field="Record:Registration:FirstName"/>
</set>
<set field="PlayerLast" arithmeticAsText="false">
<string field="Record:Registration:LastName"/>
</set>
<append document="DuplicateRegistrationReport" appendage="DuplicateRegistrationReportDetail"/>
</trueSet>
</if>
</trueSet>
</if>
</foreach>
</foreach>
<show document="DuplicateRegistrationReport" reset="true"/>
</process>
