<process name="Post-OnlinePayment">
<set field="OnlinePayment:RegID" arithmeticAsText="false">
<string field="PlayerID"/>
</set>
<set field="OnlinePayment:Status" arithmeticAsText="false">
<string value="Initiating"/>
</set>
<set field="OnlinePayment:PaymentDescription" arithmeticAsText="false">
<string field="PaymentChargeDescription"/>
</set>
<set field="OnlinePayment:AmountRequested" arithmeticAsText="false">
<string field="RegistrationFee"/>
</set>
<show document="OnlinePaymentInstructions" reset="false"/>
<if>
<conditions>
<equals field="ShowCheckPaymentInstructions">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="PaymentByCheckInstructions" reset="false"/>
</trueSet>
</if>
<show document="NavigationToPlayerDashboard" reset="false"/>
</process>
<process name="UpdatePaidStatusBasedOnInvoiceStatus">
<get recordList="Unupdated Registrants">
<forms>
<form name="Registration"/>
<form name="OnlinePayment"/>
</forms>
<conditions>
<and>
<isBlank field="Unupdated Registrants:Registration:PaymentReceived" />
<equals field="Unupdated Registrants:Registration:RegID">
<string field="Unupdated Registrants:OnlinePayment:RegID"/>
</equals>
</and>
</conditions></get>
<foreach record="Registrant" recordList="Unupdated Registrants">
<if>
<conditions>
<or>
<equals field="Registrant:OnlinePayment:Status">
<string value="Completed"/>
</equals>
<equals field="Registrant:OnlinePayment:Status">
<string value="Pending"/>
</equals>
</or>
</conditions>
<trueSet>
<set field="Registrant:Registration:PaymentReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="Registrant:Registration:PaidAmount" arithmeticAsText="false">
<string field="Registrant:OnlinePayment:AmountPaid"/>
</set>
<set field="Registrant:Registration:PaymentMethod" arithmeticAsText="false">
<string value="PayPal"/>
</set>
</trueSet>
</if>
</foreach>
</process>
<process name="Post-PaymentReceived">
<show form="PlayerDash"/>
</process>
<process name="Post-IndividualPaymentCancelled">
<show document="OnlinePaymentCancelledConfirmation" reset="false"/>
<if>
<conditions>
<equals field="ShowCheckPaymentInstructions">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="PaymentByCheckInstructions" reset="false"/>
</trueSet>
</if>
<show document="NavigationToPlayerDashboard" reset="false"/>
</process>
<process name="Post-TeamAndCoachMenu">
<get recordList="Record List 102">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="CoachnTeamAssgnmnt" recordList="Record List 102">
<set field="Coaches4Teams" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="CoachnTeamAssgnmnt:AdminSetup:Coach4EachTeam" arithmeticAsText="false">
<string value="Yes"/>
</set>
<get recordList="Record List 103">
<forms>
<form name="Team"/>
</forms>
<conditions>
<isBlank field="Record List 103:Team:CoachId" />
</conditions></get>
<foreach record="SuchLeaderlessTeam" recordList="Record List 103">
<set field="Coaches4Teams" arithmeticAsText="false">
<string value="No"/>
</set>
<set field="CoachnTeamAssgnmnt:AdminSetup:Coach4EachTeam" arithmeticAsText="false">
<string value="No"/>
</set>
</foreach>
</foreach>
<show document="TeamAndCoachMenu" reset="false"/>
</process>
<process name="Post-Team">
<if>
<conditions>
<isNotBlank field="Team:PreviousTeamId" />
</conditions>
<trueSet>
<comment>-- This is the case of editing a team</comment>
<get recordList="TeamPlayers">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="TeamPlayers:Registration:TeamId">
<string field="Team:PreviousTeamId"/>
</equals>
</conditions></get>
<foreach record="SuchPlayer" recordList="TeamPlayers">
<set field="SuchPlayer:Registration:TeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
</foreach>
<get recordList="GroupRegistrationRecords">
<forms>
<form name="GroupRegistration"/>
</forms>
<conditions>
<equals field="Team:PreviousTeamId">
<string field="GroupRegistrationRecords:GroupRegistration:TeamId"/>
</equals>
</conditions></get>
<foreach record="SuchGroup" recordList="GroupRegistrationRecords">
<set field="SuchGroup:GroupRegistration:TeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
</foreach>
</trueSet>
</if>
<set field="Team:PreviousTeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-Coach">
<set field="Coach:FullName" arithmeticAsText="false">
<string field="Coach:FirstName"/>
<string value=" "/>
<string field="Coach:LastName"/>
</set>
<if>
<conditions>
<isBlank field="Coach:CoachId" />
</conditions>
<trueSet>
<comment>-- New record</comment>
<set field="Coach:CoachId" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="PreviousCoaches">
<forms>
<form name="Coach"/>
</forms>
</get>
<foreach record="Record" recordList="PreviousCoaches">
<if>
<conditions>
<isLessThanOrEqualTo field="Coach:CoachId">
<string field="Record:Coach:CoachId"/>
</isLessThanOrEqualTo>
</conditions>
<trueSet>
<set field="Coach:CoachId" arithmeticAsText="false">
<add>
<operand field="Record:Coach:CoachId"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
<comment>-- Signed up a parent volunteer</comment>
<if>
<conditions>
<equals field="ParentCoachSelected">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<comment>-- Mark off the volunteer status in Registration record(s)</comment>
<get recordList="ParentCoachList">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<or>
<equals field="ParentCoachList:Registration:RegID">
<string field="ParentCoaches:Q1"/>
</equals>
<or>
<equals field="ParentCoachList:Registration:ParentEmail">
<string field="Coach:Email"/>
</equals>
<equals field="ParentCoachList:Registration:ParentEmail2">
<string field="Coach:Email"/>
</equals>
</or>
</or>
</conditions></get>
<foreach record="SelectedParent" recordList="ParentCoachList">
<set field="SelectedParent:Registration:CoachVolunteer" arithmeticAsText="false">
<string value="RegisteredCoach"/>
</set>
</foreach>
</trueSet>
</if>
</trueSet>
<falseSet>
<comment>-- The record has been edited</comment>
<get recordList="AllTeamsForThisCoach">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="AllTeamsForThisCoach:Team:CoachId">
<string field="Coach:CoachId"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="AllTeamsForThisCoach">
<set field="SuchTeam:Team:CoachFullName" arithmeticAsText="false">
<string field="Coach:FullName"/>
</set>
</foreach>
</falseSet>
</if>
<if>
<conditions>
<isBlank field="_InviteeID" />
</conditions>
<trueSet>
<comment>-- This is admin adding/editing the record</comment>
<show form="TeamAndCoachMenu"/>
</trueSet>
<falseSet>
<comment>-- The coach editing his record</comment>
<show form="CoachDashboard"/>
</falseSet>
</if>
</process>
<process name="Post-CoachToTeamAssignment">
<get recordList="CoachRecords">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<equals field="CoachRecords:Coach:CoachId">
<string field="CoachToTeamAssignment:CoachId"/>
</equals>
</conditions></get>
<foreach record="Record" recordList="CoachRecords">
<get recordList="TeamRecords">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="TeamRecords:Team:TeamId">
<string field="CoachToTeamAssignment:TeamId"/>
</equals>
</conditions></get>
<foreach record="FoundTeam" recordList="TeamRecords">
<set field="FoundTeam:Team:CoachId" arithmeticAsText="false">
<string field="Record:Coach:CoachId"/>
</set>
<set field="FoundTeam:Team:CoachFullName" arithmeticAsText="false">
<string field="Record:Coach:FullName"/>
</set>
<set field="Record:Coach:Team" arithmeticAsText="false">
<string field="FoundTeam:Team:TeamId"/>
</set>
</foreach>
