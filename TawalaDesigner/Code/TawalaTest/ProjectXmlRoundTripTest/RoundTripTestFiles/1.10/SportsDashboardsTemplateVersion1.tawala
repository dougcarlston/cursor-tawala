<new-window/>
<description>
<string value="Schedule"/>
</description>
<url>
<field name="ScheduleURL"/>
</url>
</link>
</u></font></division></cell><cell width="745"><division indent="0" align="center"><font color="000080"><u><link>
<new-window/>
<description>
<string value="Rules"/>
</description>
<url>
<field name="RulesURL"/>
</url>
</link>
</u></font></division></cell></row><row><cell width="735"></cell><cell width="2345"></cell><cell width="1930"></cell><cell width="2235"></cell><cell width="1650"></cell><cell width="1140"></cell><cell width="745"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2430"><division indent="0" align="right"><font><b>Your Team:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="Team"/></font></division></cell><cell width="2910"><division indent="0" align="right"><font>Payment Status:</font></division></cell><cell width="255"></cell><cell width="2235"><division indent="0" align="left"><font><field name="PaymentStatusMessage"/></font></division></cell></row><row><cell width="2430"><division indent="0" align="right"><font><b>Division:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="DivName"/></font></division></cell><cell width="2910"><division indent="0" align="right"><font>Waiver Status:</font></division></cell><cell width="255"></cell><cell width="2235"><division indent="0" align="left"><font><field name="WaiverStatusMessage"/></font></division></cell></row><row><cell width="2430"><division indent="0" align="right"><font><b>League:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="League"/></font></division></cell><cell width="2910"></cell><cell width="255"></cell><cell width="2235"></cell></row><row><cell width="2430"><division indent="0" align="right"><font><b>Season:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="SeasonYr"/></font></division></cell><cell width="2910"></cell><cell width="255"></cell><cell width="2235"></cell></row><row><cell width="2430"></cell><cell width="272"></cell><cell width="2698"></cell><cell width="2910"></cell><cell width="255"></cell><cell width="2235"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2415"><division indent="0" align="right"><font><b>Coach:</b></font></division></cell><cell width="272"></cell><cell width="2218"><division indent="0" align="left"><font><field name="Coach"/></font></division></cell><cell width="3390"><division indent="0" align="right"><font><b><field name="League"/></b></font><font><b> Athletic Director:</b></font></division></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminName"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Coach's Phone:</b></font></division></cell><cell width="272"></cell><cell width="2218"><division indent="0" align="left"><font><field name="CoachsPhone"/></font></division></cell><cell width="3390"><division indent="0" align="right"><font><b><field name="League"/></b></font><font><b> Phone:</b></font></division></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminsPhone"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Alternate Phone:</b></font></division></cell><cell width="272"></cell><cell width="2218"><division indent="0" align="left"><font><field name="CoachsPhone1"/></font></division></cell><cell width="3390"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminEmail"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="2218"><division indent="0" align="left"><font><field name="CoachsEmail"/></font></division></cell><cell width="3390"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminAdrss"/></font></division></cell></row><row><cell width="2415"></cell><cell width="272"></cell><cell width="2218"></cell><cell width="3390"></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><sp/><font><field name="AdminsZIP"/></font><sp/></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="200" color="000000"><b><field name="CoachFlash"/></b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font face="Arial" size="220" color="004000"><field name="FlashMessage"/></font></paragraph>
</xmlData>
</document>
<document name="PostRegistrationLetterWithPaymentInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="Registration:FirstName"/></font><font> and Parents of </font><font><field name="Registration:FirstName"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You have successfully registered for this season's </font><font><field name="League"/></font><font>.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Don't forget to "sign" your child's Medical Waiver by clicking the Accept button from their Player Dashboard. No player can practice or play until their Medical Waiver has been accepted. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you haven't already paid online, please send a check for $</font><font><field name="RegistrationFee"/></font><font> payable to "</font><font><field name="League"/></font><font>".</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Payments can be mailed to the following address:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><field name="League"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><field name="AdminAdrss"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><field name="AdminsCity"/></font><sp/><font><field name="AdminState"/></font><font>, </font><font><field name="AdminsZIP"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you need any information about the season, you can always look at our Web site.  For dealing </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>with personal information like reviewing or changing your registration info, checking your team </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>roster or schedule and the like, use the link below.  This is your personal link.  Do not share it with </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>others. (You can also get to our Web site from it.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here it is:  </font><font color="000080"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Player's Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To save this link, click on it. A web page will come up, your personal page. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Saving this link depends upon which browser you use:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>If you use Internet Explorer, click on "Favorites" in the Menu Bar at top and </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>then "Add to Favorites."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>If you use Firefox, click on "Bookmarks" in the Menu Bar at top and then </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>"Bookmark this Page."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>If you use Safari, click on "Bookmarks" and then "Add Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You'll get your team roster and schedule by email once they've been completed, but </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>they will also always be available to you on your Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>I'm looking forward to seeing you at the </font><font><field name="League"/></font><font> games this season!</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Yours,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="AdminRegNotification">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>A registration form has been received for </font><font><field name="Registration:FirstName"/></font><sp/><font><field name="Registration:LastName"/></font><font>. Here is the registration info:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="735"><row><cell width="2455"><division indent="0" align="right"><font><b>Player's Name:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:FirstName"/></font><sp/><font><field name="Registration:LastName"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Date of Birth:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:RegAgeMo"/></font><font>/</font><font><field name="Registration:RegAgeDay"/></font><font>/</font><font><field name="Registration:RegAgeYr"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Sex:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Sex"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Parent's Name:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:ParentFirstName"/></font><sp/><font><field name="Registration:ParentLastName"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Address"/></font></division></cell></row><row><cell width="2455"></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:City"/></font><font>, </font><font><field name="Registration:State"/></font><sp/><font><field name="Registration:Zip"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b> Parent's Email:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:ParentEmail"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Additional Email:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:ParentEmail2"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b><field name="Phone1Lab"/></b></font><font><b>:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Phone1"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b><field name="Phone2Lab"/></b></font><font><b>:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Phone2"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b><field name="Phone3Lab"/></b></font><font><b>:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Phone3"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>School:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:School"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Grade:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><display-mcq-label version="1"><field-name>Registration:Grade</field-name><display>label_only</display></display-mcq-label></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Parish </b></font><font><i>(if applicable)</i></font><font><b>:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Parish"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><sp/><sp/><sp/></division></cell><cell width="200"></cell><cell width="7410"></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Division Requested:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:DivisionId"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Previous Division:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:LastDiv"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><sp/><sp/><sp/></division></cell><cell width="200"></cell><cell width="7410"></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Parent willing to coach:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="ParentWillingToCoach"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Player willing to umpire:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="PlayerWillingToUmpire"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><sp/><sp/><sp/></division></cell><cell width="200"></cell><cell width="7410"></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Preferred Coach:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:PreferredCoach"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Preferred Teammantes:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Friend:a"/></font><sp/><sp/><sp/><font><field name="Registration:Friend:b"/></font><sp/><sp/><font><field name="Registration:Friend:c"/></font><sp/></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Uniform Size:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:UniformSize"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><sp/><sp/><sp/></division></cell><cell width="200"></cell><cell width="7410"></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Medical Plan Name:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:MedPlanName"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Plan Number:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:MedPlanNumber"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Doctor's Name:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:DocName"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:DocPhone"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:DocAddress"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">In case of loss, here is the link to </font><font color="000000"><field name="Registration:FirstName"/></font><font color="000000">'s private </font><font color="000080"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Player Dashboard</invitation></u></font><font color="000000">.</font></paragraph>
</xmlData>
</document>
<document name="PlayerDashboardReminder">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="PlayerFirst"/></font><font> and Parents of </font><font><field name="PlayerFirst"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Your personal </font><font><field name="League"/></font><font> link is </font><font color="000080"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="PlayerID"/>
</authenticationTokenValue>here</invitation></u></font><font>.  Clicking on this link will take you to </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>your private </font><font><field name="League"/></font><font> Player Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">To save this link, click on it.  A </font><font color="000000"><field name="League"/></font><font color="000000"> Web page will come up, your personal page. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">Saving this link depends upon which brower you use:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Internet Explorer, click on "Favorites" in the Menu Bar at top and </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">then "Add to Favorites."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Firefox, click on "Bookmarks" in the Menu Bar at top and then </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">"Bookmark this Page."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Safari, click on "Bookmarks" and then "Add Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Be sure to save this link in a safe place.  You can use it to review or </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>change your registration and to see personal information, such as your </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>team assignment and team roster, season schedule and the like.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Yours,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="Message">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="AE0000"><b><i><field name="Message"/></i></b></font></paragraph>
</xmlData>
</document>
<document name="Roster Selection Criteria">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240"><b>Registration Records - Team Rosters</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ShowWaiverPaymentFields" project="">Waivers &amp; Payments</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="ShowCoachVolunteers" project="">Coaching Volunteers</invitation></u></font><sp/><sp/><sp/><font color="000080"><u><invitation form="ShowRosterCriteria" project="">Team Rosters</invitation></u></font><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="ShowContactFields" project="">Contact Info</invitation></u></font><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="ShowMedicalFields" project="">Medical Info</invitation></u></font><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="ShowAllFields" project="">All Fields</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>9</number-of-columns><column><header><string value="Division"/>
</header><contents><field name="Record:Registration:DivisionId" /></contents></column><column><header><string value="Previous Division"/>
</header><contents><field name="Record:Registration:LastDiv" /></contents></column><column><header><string value="Team"/>
</header><contents><field name="Record:Team:TeamId" /></contents></column><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Age"/>
</header><contents><field name="Record:Registration:PlayerAge" /></contents></column><column><header><string value="Uniform"/>
</header><contents><field name="Record:Registration:UniformSize" /></contents></column><column><header><string value="Waiver"/>
