graph><paragraph indent="2160" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions><font><i>One or more individual players</i></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions><font><b><link-to-project-details version="1"><description><string value="Jump to MyTawala"/>
</description><open-preference>current-window</open-preference></link-to-project-details></b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions><font color="000080"><b><u><invitation form="SendDashReminder" project="">Send/View Coach/Player Dashboard</invitation></u></b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions><font color="000000">Toggle Team View on Player Dashes</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2160"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="CoachSetupLetter">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="PlayerFirst"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="CoachRosterNotice:Body"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will be the coach for </font><font><field name="Team"/></font><font>  in this season's </font><font><field name="League"/></font><font> League.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can find important contact information for your team and the League on </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>your personal </font><font><field name="League"/></font><sp/><font color="000080"><u><invitation form="CoachDashboard" project="" private="true"><authenticationTokenValue><string field="CoachID"/>
</authenticationTokenValue>Coach Dashboard</invitation></u></font><font>.  The Dashboard will also permit </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>you to communicate easily with your team members and keep track of various </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>responsibilities during the season.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DashboardLinkVerbiage2"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Once again, in order to gain access to your coaching tools for this season's </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="League"/></font><font>, click on this link:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="CoachDashboard" project="" private="true"><authenticationTokenValue><string field="CoachID"/>
</authenticationTokenValue>Coach Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="CoachRosterNotice:Close"/></font></paragraph>
</xmlData>
</document>
<document name="NoCoachDash">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="AE0000"><b><i>Your Coach Dashboard has not been found.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="AE0000"><b><i>Please notify the </i></b></font><font color="AE0000"><b><i><field name="League"/></i></b></font><font color="AE0000"><b><i> administrator, </i></b></font><font color="AE0000"><b><i><field name="AdminName"/></i></b></font><font color="AE0000"><b><i>, </i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="AE0000"><b><i>at </i></b></font><font color="AE0000"><b><i><field name="AdminEmail"/></i></b></font><font color="AE0000"><b><i>, so that this problem can be tracked</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="AE0000"><b><i>down and fixed.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="AE0000"><b><i>Our apologies.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="AE0000"><b><i>The Tawala Development Team</i></b></font></paragraph>
</xmlData>
</document>
<document name="CoachDashReminder">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="DearSir"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Your Coach's Dashboard for coaching the </font><font><field name="League"/></font><font> team, </font><font><field name="Team"/></font><font>, </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>is </font><font color="000080"><u><invitation form="CoachDashboard" project="" private="true"><authenticationTokenValue><string field="CoachID"/>
</authenticationTokenValue>here</invitation></u></font><font>.  Clicking on this link will take you to your </font><font><field name="Team"/></font><sp/><font><field name="League"/></font><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Coach Dashboard, which contains tools that allow you to keep track of </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>information about your team and to communicate with your players.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">To save this link, click on it.  A </font><font color="000000"><field name="League"/></font><font color="000000"> Web Dashboard page will come up. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">Saving this page depends upon which brower you use:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Internet Explorer, click on "Favorites" in the Menu Bar at top and </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">then "Add to Favorites."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Firefox, click on "Bookmarks" in the Menu Bar at top and then </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">"Bookmark this Page."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Safari, click on "Bookmarks" and then "Add Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Be sure to save this link in a safe place.  You can use it to review or </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>change your registration and to see personal information, such as your </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>team assignment and team roster, season schedule and the like.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Once again, your Dashboard link is:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="CoachDashboard" project="" private="true"><authenticationTokenValue><string field="CoachID"/>
</authenticationTokenValue>Coach Dashboard</invitation></u></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Yours,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="CoachRosterList">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240"><b><field name="Team"/></b></font><font size="240"><b> Roster List</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>11</number-of-columns><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Parent First"/>
</header><contents><field name="Record:Registration:ParentFirstName" /></contents></column><column><header><string value="Parent Last"/>
</header><contents><field name="Record:Registration:ParentLastName" /></contents></column><column><header><field name="Phone1Lab"/>
</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header><field name="Phone2Lab"/>
</header><contents><field name="Record:Registration:Phone2" /></contents></column><column><header><field name="Phone3Lab"/>
</header><contents><field name="Record:Registration:Phone3" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Email 2"/>
</header><contents><field name="Record:Registration:ParentEmail2" /></contents></column><column><header><string value="Birthday"/>
</header><contents><field name="Record:Registration:Birthday" /></contents></column><column><header><string value="Uniform Size"/>
</header><contents><field name="Record:Registration:UniformSize" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:TeamId">
<string field="CurrentTeamId"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph>
</xmlData>
</document>
<document name="OnlinePaymentInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Please pay $</font><font><field name="RegistrationFee"/></font><font> for </font><font><field name="SeasonYr"/></font><sp/><font><field name="League"/></font><font color="000000">.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">You can press the </font><font color="000000"><i>Pay </i></font><font>Now button below to pay using a major credit card or your PayPal account. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can also pay at a later time online from your Player Dashboard (a link will be sent to you by email).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="795"><row><cell width="8430"><division indent="0" align="left"><font color="FF0000">* Note: If you wish to use your credit card, you do </font><font color="FF0000"><b>not</b></font><font color="FF0000"> need to create a PayPal account or log in to PayPal; when you get to the PayPal page, just click on the </font><font color="FF0000"><u>Continue</u></font><font color="FF0000"> link above the credit card icons on the left.</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><paypal-single-item-button version="1"><button-type>pay-logo</button-type><item><field name="OnlinePayment:PaymentDescription"/>
</item><amount><field name="OnlinePayment:AmountRequested"/>
</amount><successful-payment-return-form-name>PlayerDash</successful-payment-return-form-name><cancelled-payment-return-form-name>IndividualPaymentCanceled</cancelled-payment-return-form-name><status-field>Record:OnlinePayment:Status</status-field><amount-field>Record:OnlinePayment:AmountPaid</amount-field><style-option>paypal</style-option></paypal-single-item-button></font></paragraph>
</xmlData>
</document>
<document name="TeamAssignment">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="000000">Team Assignment</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3495"><division indent="0" align="left"><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font></division></cell><cell width="7305"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="C10000"><i>Note: You must press the "Save Changes" button below the Team Assignment table to record your actions.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Use "Drag and Drop" to sort players into teams:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><categorizer version="2"><category-names>Record:Team:TeamId</category-names><category-ids>Record:Team:TeamId</category-ids><category-storage-field>Record:Registration:TeamId</category-storage-field><navigate-to>Team Rosters</navigate-to><number-of-columns>7</number-of-columns><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Age"/>
</header><contents><field name="Record:Registration:PlayerAge" /></contents></column><column><header><string value="Sex"/>
</header><contents><field name="Record:Registration:Sex" /></contents></column><column><header><string value="Coach"/>
</header><contents><field name="Record:Registration:PreferredCoach" /></contents></column><column><header><string value="Preferred Teammates"/>
</header><contents><field name="Record:Registration:FriendsList" /></contents></column><column><header><string value="Division"/>
</header><contents><field name="Record:Registration:DivisionId" /></contents></column><conditions><form name="Team" /><form name="Registration" /><form name="Team Rosters" /></conditions></categorizer></font></paragraph>
</xmlData>
</document>
<document name="PaymentAndWaiverStillNeeded">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="360" color="000000">Step 1 of your registration has been completed.</font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to complete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 2:</b></font><font>  Submit your payment of $</font><font><field name="RegistrationFee"/></font><font> and</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 3:</b></font><font>  Go to your Player Dashboard (a link will be emailed to you). </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>              Select "Waiver", and electronically accept your waiver. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can also change any of your registration information or pay online at a later time from your Player Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="A00000"><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="000080"><b><u><invitation form="OnlinePayment" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Proceed to Step 2</invitation></u></b></font><sp/><sp/></paragraph>
</xmlData>
</document>
<document name="PaymentByCheckInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To pay by check please mail a check for $</font><font><field name="RegistrationFee"/></font><font> to:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><field name="League"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><field name="AdminAdrss"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><font><field name="AdminsZIP"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Make the check payable to </font><font><b><field name="League"/></b></font><font>.</font></paragraph>
</xmlData>
</document>
<document name="OnlinePaymentCancelledConfirmation">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It looks like you were unable to pay online at this time.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can try again later from your Player Dashboard (a link was emailed to you).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph>
</xmlData>
</document>
<document name="TeamAndCoachMenu">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="000000">Teams and Coaches</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="200"></cell><cell width="1855"><division indent="0" align="left"><font color="000080"><u><invitation form="Team" project="">Add a team</invitation></u></font></division></cell><cell width="285"></cell><cell width="1935"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ParentCoaches" project="">Add a coach</invitation></u></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font color="000080"><u><invitation form="CoachToTeamAssignment" project="">Assign coach to team</invitation></u></font></division></cell><cell width="200"></cell><cell width="2752"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Team Rosters" project="">Assign Players to Teams</invitation></u></font></division></cell></row><row><cell width="200"></cell><cell width="1855"><division indent="0" align="left"><font color="000080"><u><invitation form="EditTeam" project="">Edit a team</invitation></u></font></division></cell><cell width="285"></cell><cell width="1935"><division indent="0" align="left"><font color="000080"><u><invitation form="EditCoach" project="">Edit a coach</invitation></u></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font color="000080"><u><invitation form="UnassignCoachFromTeam" project="">Un-assign coach from team</invitation></u></font></division></cell><cell width="200"></cell><cell width="2752"></cell></row><row><cell width="200"></cell><cell width="1855"><division indent="0" align="left"><font color="000080"><u><invitation form="DeleteTeam" project="">Delete a team</invitation></u></font></division></cell><cell width="285"></cell><cell width="1935"><division indent="0" align="left"><font color="000080"><u><invitation form="DeleteCoach" project="">Delete a coach</invitation></u></font></division></cell><cell width="200"></cell><cell width="3325"></cell><cell width="200"></cell><cell width="2752"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font size="240" color="000000"><b>Teams:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><itemization-table version="2"><number-of-columns>2</number-of-columns><column><header><string value="Name"/>
</header><contents><field name="Record:Team:TeamId" /></contents></column><column><header><string value="Coach Name"/>
</header><contents><field name="Record:Team:CoachFullName" /></contents></column><conditions><form name="Team" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font size="240" color="000000"><b>Coaches:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font color="000000"><itemization-table version="2"><number-of-columns>3</number-of-columns><column><header><string value="First Name"/>
</header><contents><field name="Record:Coach:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Coach:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Coach:Email" /></contents></column><conditions><form name="Coach" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="PlayerTeamRoster">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="right"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b><field name="Team"/></b></font><font><b> Player Roster:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>7</number-of-columns><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><field name="Phone1Lab"/>
</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header><field name="Phone2Lab"/>
</header><contents><field name="Record:Registration:Phone2" /></contents></column><column><header><field name="Phone3Lab"/>
</header><contents><field name="Record:Registration:Phone3" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Email 2"/>
</header><contents><field name="Record:Registration:ParentEmail2" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:TeamId">
<string field="PlayerTeamId"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph>
</xmlData>
</document>
<document name="BackToCoachDashLink">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="CoachDashboard" project="">Back to Dashboard</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="PostRegistrationLetterWithoutPaymentInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="Registration:FirstName"/></font><font> and Parents of </font><font><field name="Registration:FirstName"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Thank you for registering for this season's </font><font><field name="League"/></font><font>.  This email is to acknowledge </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>your registration.  However, don't forget -- your registration is not complete until your </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>medical waiver has been signed.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You may find your medical waiver from the link below.  For dealing with personal </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>information like reviewing or changing your registration info, checking your team roster </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>or schedule and the like, you may also use the link below.  This is your personal link.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Do not share it with others.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here it is:  </font><font color="000080"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Player's Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To save this link, click on it.  A </font><font><field name="League"/></font><font> Web page will come up, your personal page. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Saving this link depends upon which browser you use:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>If you use Internet Explorer, click on "Favorites" in the Menu Bar at top and </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>then "Add to Favorites."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>If you use Firefox, click on "Bookmarks" in the Menu Bar at top and then </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>"Bookmark this Page."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>If you use Safari, click on "Bookmarks" and then "Add Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You'll get your team roster and schedule by email once they've been completed, but </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>they will also always be available to you on your Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>I'm looking forward to seeing you at the </font><font><field name="League"/></font><font> games this season!</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Yours,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="InvitationToCompleteRegistration">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>Dear Parents of </font><font><field name="AddPlayerToGroupRegistration:FirstName"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>Coach </font><font><field name="Coach"/></font><font> has listed </font><font><field name="AddPlayerToGroupRegistration:FirstName"/></font><font> as a member of the </font><font><field name="SeasonYr"/></font><sp/><font><field name="League"/></font><font> Team and has pre-paid your child's entry fee. However, each child is still required to register with </font><font><field name="League"/></font><font>. To register, click on the following link and fill out the form. No fee is due, but you will be asked to sign  a Medical Waiver after registration. Please click on the waiver from your child's Dashboard and either sign it by checking the box at the end of the waiver or, if you have been so instructed, print the page on your printer, fill it out and sign it.  Then either mail it to </font><font><field name="League"/></font><font> at </font><font><field name="AdminAdrss"/></font><font>,</font><font><field name="AdminsCity"/></font><sp/><font><field name="AdminState"/></font><sp/><font><field name="AdminsZIP"/></font><font> or have your child bring it along to the first practice or game. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>Remember, no child can play unless we have a completed registration and a signed medical waiver on file! </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>Here's the link: </font><font><field name="AddPlayerToGroupRegistration:FirstName"/></font><font>'s </font><font><u><invitation form="EditMyRegistrationRecord" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Registration Form</invitation></u></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>Yours, </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
