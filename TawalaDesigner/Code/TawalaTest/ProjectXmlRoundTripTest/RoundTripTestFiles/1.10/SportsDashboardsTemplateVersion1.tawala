</set>
<set field="SecondaryCount" arithmeticAsText="false">
<string value="0"/>
</set>
<foreach record="Secondary" recordList="Record List 149">
<set field="SecondaryCount" arithmeticAsText="false">
<add>
<operand field="SecondaryCount"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<and>
<isLessThan field="Count">
<string field="SecondaryCount"/>
</isLessThan>
<and>
<doesNotEqual field="Secondary:Registration:BadEmail?">
<string value="Checked"/>
</doesNotEqual>
<equals field="SearchState">
<string value="Looking for duplicate"/>
</equals>
</and>
</and>
</conditions>
<trueSet>
<if>
<conditions>
<and>
<equals field="Primary:Registration:FirstName">
<string field="Secondary:Registration:FirstName"/>
</equals>
<equals field="Primary:Registration:LastName">
<string field="Secondary:Registration:LastName"/>
</equals>
</and>
