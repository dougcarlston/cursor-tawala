<text label="T5" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press Submit to continue to Page 2 of the registration form.</font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<or>
<isLessThan field="Registration:RegAgeYr">
<string value="100"/>
</isLessThan>
<isBlank field="Registration:RegAgeYr" />
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter year of birth as a four digit number (e.g. &quot;1995&quot;)."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<doesNotEqual field="Registration:ParentEmail">
<string field="Registration:ParentEmailConfirm"/>
</doesNotEqual>
<isBlank field="Registration:ParentEmail" />
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Email address is blank or two copies of email fail to match."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Registration:ParentEmail2" />
</conditions>
<trueSet>
<if>
<conditions>
<doesNotEqual field="Registration:ParentEmail2">
<string field="Registration:ParentEmail2Confirm"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Two copies of additional email fail to match."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<or>
<isBlank field="Registration:FirstName" />
<isBlank field="Registration:LastName" />
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter Player&apos;s First and Last names in the spaces provided."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcDoesNotEqual field="Registration:SexMCQ" value="a"/>
<mcDoesNotEqual field="Registration:SexMCQ" value="b"/>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please mark Player&apos;s sex."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<equals field="FeeStructure">
<string value="Varies by Grade"/>
</equals>
<mcIsBlank field="Registration:Grade" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please select the grade."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<equals field="Divs">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="DivisionQuestionText" arithmeticAsText="false">
<string value="Please indicate the division in which you&apos;d like to play, if possible:"/>
</set>
<set field="LastYearDivsionQuestionText" arithmeticAsText="false">
<string value="If you played last year, please indicate the division in which you played:"/>
</set>
</trueSet>
<falseSet>
<set field="DivisionQuestionText" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="LastYearDivsionQuestionText" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<contains field="ExtraQs">
<string value="a"/>
</contains>
</conditions>
<trueSet>
<skip to="Q6"/>
</trueSet>
</if>
<if>
<conditions>
<doesNotEqual field="Divs">
<string value="Yes"/>
</doesNotEqual>
</conditions>
<trueSet>
