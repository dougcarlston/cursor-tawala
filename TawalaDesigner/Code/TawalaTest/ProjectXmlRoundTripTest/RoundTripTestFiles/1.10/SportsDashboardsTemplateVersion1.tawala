<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AuditRecruitList" startPoint="false" themePath="mvsc" process="Post-AuditRecruitList" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Recruiting List</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility will check the recruiting list for valid emails.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds a record with more than one valid email or none, it will pull up the record and give you a chance to edit it so that it will work with the Tawala utilities.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It is not possible to keep two email addresses in one contact field.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit or delete each record that fails the audit test.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return </font></paragraph></choice></mc>
</items>
</form>
<form name="Team Rosters" startPoint="false" themePath="mvsc" process="Post-TeamRosters">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AuditRecruitLoop" startPoint="false" themePath="mvsc" process="Post-AuditRecruitLoop" preProcess="Pre-AuditRecruitLoop">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Clean Recruitment Records</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><u><invitation form="Preseason" project="">Back to Pre-Season Menu</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="RecruitmentId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the recruitment record:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:FirstName"/>
<string value=" "/>
<field name="Record:RecruitmentDB:LastName"/>
<string value=" (parent: "/>
<field name="Record:RecruitmentDB:ParentFirst"/>
<string value=", email: "/>
<field name="Record:RecruitmentDB:Email"/>
<string value=", phone: "/>
<field name="Record:RecruitmentDB:Email2"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<equals field="Record:RecruitmentDB:BadRecord?">
<string value="Yes"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q2" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the action to perform:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit this record</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete this record</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark as "good" (it will remove this record from this list)</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Break off audit for now (you can always return)</font></paragraph></choice></mc>
</items>
</form>
<form name="ConfirmPaymentAndWaiverReceipts" startPoint="false" themePath="mvsc" process="Post-ConfirmPaymentAndWaiverReceipts" preProcess="UpdatePaidStatusBasedOnInvoiceStatus">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Mark Waiver &amp; Payment Receipts</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q1" alternateLabel="PaymentOrWaiver" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark waiver receipts</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark payment receipts</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Review all records</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Unmark incorrectly marked record</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" />
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<set field="ConfirmPaymentAndWaiverReceipts:PaidAmount" arithmeticAsText="false">
<string field="SignupFeeForIndividual"/>
</set>
<skip to="Payment Receipt Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="c"/>
</conditions>
<trueSet>
<skip to="ReviewRcrds Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="d"/>
</conditions>
<trueSet>
<skip to="Unmark Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="e"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" alternateLabel="WaiverReceiptText"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This is a list of players who have not sent or submitted the waivers.</font></paragraph></text>
<mc label="Q2" alternateLabel="WaiverRegIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check players whose waivers you wish to mark as received:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<isBlank field="Record:Registration:WaiverReceived" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T3" alternateLabel="Payment Receipt Text"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This is a list of players who have not paid.</font></paragraph></text>
<mc label="Q3" alternateLabel="PaymentRegIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check players whom you wish to mark as paid:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<isBlank field="Record:Registration:PaymentReceived" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<fib label="Q4" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Payment amount:  $</font><blank label="a" length="9" required="false" alternateLabel="PaidAmount"/></paragraph></fib>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4" alternateLabel="ReviewRcrds Text"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>11</number-of-columns><column><header><string value="Waiver"/>
</header><contents><field name="Record:Registration:WaiverReceived" /></contents></column><column><header><string value="Payment"/>
</header><contents><field name="Record:Registration:PaymentReceived" /></contents></column><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Parent"/>
</header><contents><field name="Record:Registration:ParentFirstName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Email 2"/>
</header><contents><field name="Record:Registration:ParentEmail2" /></contents></column><column><header><field name="Phone1Lab"/>
</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header><field name="Phone2Lab"/>
</header><contents><field name="Record:Registration:Phone2" /></contents></column><column><header><field name="Phone3Lab"/>
</header><contents><field name="Record:Registration:Phone3" /></contents></column><column><header><string value="Division"/>
</header><contents><field name="Record:Registration:DivisionId" /></contents></column><conditions><form name="Registration" /></conditions></itemization-table></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5" alternateLabel="Unmark Text"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4095"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3480"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3225"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q5" alternateLabel="UnmarkReceipts" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player to unmark either payment receipt or waiver receipt</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<or>
<equals field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
<equals field="Record:Registration:WaiverReceived">
<string value="Yes"/>
</equals>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="Communicator" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-Communicator">
<items>
<skipInstructions>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcIsBlank field="Communicator:Q1" />
</conditions>
<trueSet>
<set field="Communicator:Q1" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
</if>
</skipInstructions>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>This tool permits you to send emails </b></font><font><b><u>only</u></b></font><font><b> to  those players who are assigned to teams and/or their coaches.  </b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>You may also send emails to parents who have volunteered to coach.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to the Recruitment List, use the </font><font color="000080"><u><invitation form="RecruitEmail" project="">Recruitment List Communicator</invitation></u></font><font><b>.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to registered Players before team assignments have been made, use the  </font><font color="000080"><u><invitation form="RegistrantEmail" project="">Pre-season Registrant Communicator</invitation></u></font><font> (which lets you specify those without waivers or payments, for example).</font></paragraph></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="CE0000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">This message is to be sent to:</font><sp/><font face="Arial" size="200" color="000000"><i>(You may ignore this question if you don't use divisions.)</i></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All divisions </font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Only division(s) selected below</font></paragraph></choice></mc>
<mc label="Q2" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All players assigned to teams and their coaches</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All coaches</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Players and coaches from selected teams</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more individual coaches</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more individual registered players</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All parents who have volunteered to serve as coaches</font></paragraph></choice></mc>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(name):</i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="57" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email):</i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject</font><font face="Arial" size="200" color="000000"><i>:</i></font><sp/><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q6" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of Salutation for letter to players</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Dear Parents of Player's first name </font><font face="Arial" size="200" color="000000"><i>("Dear Parents of Jimmy")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't create a personalized salutation</font></paragraph></choice></mc>
<fib label="Q7" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message:  </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<mc label="Q8" alternateLabel="Link" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box to include a link to the player's or coach's </font><font face="Arial" size="200" color="000000"><u>Personal Dashboard</u></font><font face="Arial" size="200" color="000000"> in your message</font></paragraph></choice></mc>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>[A link to the player's or coach's </font><font color="0000FF"><u>Dashboard</u></font><font> may appear here.]</font></paragraph></text>
<fib label="Q9" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing:  </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="Communicator:Q2" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You must select a group or individual to send this message to."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="Divisions"/>
</trueSet>
<falseSet>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="d"/>
</conditions>
<trueSet>
<skip to="CoachTarget"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="e"/>
</conditions>
<trueSet>
<skip to="PlayerTarget"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Communicator:Q2" value="c"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<skip to="TeamIds"/>
</falseSet>
</if>
</skipInstructions>
<mc label="Q10" alternateLabel="Divisions" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to players in the following division(s) only</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Divisions:Name"/>
</display-expression><value-expression><field name="Record:Divisions:DivisionID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Divisions" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="d"/>
</conditions>
<trueSet>
<skip to="DivCoachTarget"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="e"/>
</conditions>
<trueSet>
<skip to="DivPlayerTarget"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Communicator:Q2" value="c"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q11" alternateLabel="TeamIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to players and coach of the following team(s):</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q12" alternateLabel="CoachTarget" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to specific coach or coaches only</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:FullName"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
</sort-expression><record-selector><form name="Coach" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q13" alternateLabel="PlayerTarget" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to specific registered player or players</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<isNotBlank field="Record:Registration:TeamId" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q14" alternateLabel="DivPlayerTarget" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to specific registered player or players</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<and>
<mcContains field="Communicator:Divisions">
<string field="Record:Registration:DivisionId"/>
</mcContains>
<isNotBlank field="Record:Registration:TeamId" />
</and>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q15" alternateLabel="DivCoachTarget" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to specific coach or coaches only</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:CoachFullName"/>
</display-expression><value-expression><field name="Record:Team:CoachId"/>
</value-expression><sort-expression><field name="Record:Team:CoachId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<mcContains field="Communicator:Divisions">
<string field="Record:Team:Division"/>
</mcContains>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q16" alternateLabel="DivTeamIDs" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to players and coach of the following team(s):</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<mcContains field="Communicator:Divisions">
<string field="Record:Team:Division"/>
</mcContains>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="AuditRegForms" startPoint="false" themePath="mvsc" process="Post-AuditRegForms">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Registration Forms</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility will check all the submitted Registration Forms for valid emails.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds one with more than one valid email or none, it will pull up the record and give you a chance to edit it so that it will work with the Tawala utilities.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It is not possible to keep two email addresses in one contact field.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit or delete each record that fails the audit test.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return</font></paragraph></choice></mc>
</items>
</form>
<form name="AuditFormLoop" startPoint="false" themePath="mvsc" process="Post-AuditFormLoop" preProcess="Pre-AuditFormLoop">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Players with Invalid Emails</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><u><invitation form="RegFormMgmt" project="">Back to Player Management</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="RegistrationId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player to audit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Registration" /><conditions>
<equals field="Record:Registration:BadEmail?">
<string value="Yes"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="RegistrantEmail" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-RegistrantEmail">
<items>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="RegistrantEmail:Q1" />
</conditions>
<trueSet>
<set field="RegistrantEmail:Q1" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
</if>
</skipInstructions>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Registered Player Email</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3210"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3660"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This tool will let you send your email to different parts of the Registered Player list, according to your need.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to the Recruitment List, use the </font><font color="000080"><u><invitation form="Recruitment" project="">Recruitment List Management Tool</invitation></u></font><font face="Arial" size="200" color="000000">.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to Players who have already been assigned to Team Rosters or during the regular season, use the </font><font color="000080"><u><invitation form="Communicator" project="">Communicator</invitation></u></font><font> on the Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to Parents who have volunteered to Coach, use the  </font><font color="000080"><u><invitation form="Communicator" project="">Communicator</invitation></u></font><font> on the Dashboard.</font></paragraph></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="CC0000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All registered players, regardless whether waivers or payment have been received</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players for whom waivers have not been received</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players for whom payment has not been received</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players with fully completed forms, waivers &amp; payment</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players in certain grades only</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(name)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q5" alternateLabel="Salutation" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of Salutation:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Dear Parents of Player's first name </font><font face="Arial" size="200" color="000000"><i>("Dear Parents of Jimmy")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't create a personalized salutation</font></paragraph></choice></mc>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>[A link to the player's </font><font color="0000FF"><u>Player Dashboard</u></font><font> will appear here.]</font></paragraph></text>
<fib label="Q7" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing:  </font><blank label="a" length="57" height="5" required="false" alternateLabel="Closing"/></paragraph></fib>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the Submit button to continue.  You will have a chance to review your letter before it is sent.</font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="RegistrantEmail:Q1" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You must select the group to whom you wish to send this message!"/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="RegistrantEmail:Q1" value="e"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q8" alternateLabel="SelectedGrades" onlyone="false" required="false" style="multicolumn"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send message only to registrants in the following grade or grades:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Grade:Name"/>
</display-expression><value-expression><field name="Record:Grade:Name"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Grade" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="RegistrantEmailSend" startPoint="false" themePath="mvsc" process="Post-RegistrantEmailSend">
<items>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="570"><row><cell width="8400"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>From</b></font><font>:  </font><font><field name="RegistrantEmail:FromName"/></font><font> (</font><font><field name="RegistrantEmail:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="8400"></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="RegistrantEmail:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="525"><row><cell width="8415"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="RegistrantEmail:Body"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font>Here is a link to </font><font color="0000FF"><u>your private Dashboard</u></font><font>. </font><font><field name="DashboardLinkVerbiage"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="DashboardLinkVerbiage2"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/><sp/><sp/><sp/></division><division indent="0" align="left"><font><field name="RegistrantEmail:Closing"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Registration Form Management</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="RegistrantEmailSend:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Click Submit to begin sending now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Note: It might take several minutes to send all the emails.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</i></font></paragraph></text>
</items>
</form>
<form name="CoachDashboard" startPoint="false" themePath="mvsc" process="Post-CoachDashboard">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AdminPlayerRegistration" startPoint="false" themePath="mvsc" process="Post-AdminPlayerReg" preProcess="RetrieveAdminSetupVariables">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Register a Player or Group</font></paragraph></heading>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter a Player's registration information directly</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send someone a direct link to the Registration form for them to fill out</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Group registration </font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="AdminPlayerRegistration:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Send email link to Registration Page</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Name and Email of person to whom registration is to be sent:</font></paragraph></text>
<fib label="Q2" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="20" required="false" alternateLabel="FirstName"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(first) </i></font><blank label="b" length="20" required="false" alternateLabel="LastName"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="c" length="48" required="false" alternateLabel="EmailAddress"/><font face="Arial" size="200" color="000000"><i> (email)</i></font></paragraph></fib>
</items>
</form>
<form name="GroupRegistration" startPoint="false" themePath="mvsc" process="Post-GroupRegistration">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Group Registrations</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Existing Group Registrations:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>2</number-of-columns><column><header><string value="Team"/>
</header><contents><field name="Record:GroupRegistration:TeamId" /></contents></column><column><header><string value="Fee ($)"/>
</header><contents><field name="Record:GroupRegistration:RegistrationFee" /></contents></column><conditions><form name="GroupRegistration" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AddPlayerToExistingGroupRegistration" project="">Add a player to an existing group registration</invitation></u></font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To create a new group registration fill out the form below. (</font><font color="000080"><u><invitation form="Team" project="">Add a team</invitation></u></font><font color="000000"> and assign a coach to it first if you don't see the team on the list and then come back to this screen.)</font></paragraph></text>
<mc label="Q1" alternateLabel="TeamId" onlyone="true" required="true"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the team (only teams with assigned coaches are shown):</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Team" /><conditions>
<isNotBlank field="Record:Team:CoachId" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<fib label="Q2" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Team registration fee: $</font><blank label="a" length="20" required="true" alternateLabel="RegistrationFee"/></paragraph></fib>
<field name="GroupRegistrationId"/>
</items>
</form>
<form name="AdminBounceback" startPoint="false" themePath="mvsc" process="Post-AdminBounceback">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="PlayerRegLink" startPoint="false" themePath="mvsc" process="Post-PlayerRegLink">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="Uniforms" startPoint="false" themePath="mvsc" process="Post-Uniforms">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Uniforms/Jerseys</font></paragraph></heading>
<text label="T1"><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Uniforms/Jerseys for all registered players, whether on not they have paid or submitted waivers:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><response-totals-table version="1"><layout-type>vertical</layout-type><field>Record:Registration:UniformSize</field><conditions><form name="Registration" /></conditions></response-totals-table></font></paragraph></text>
<mc label="Q1" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check here to get information only for a specific division</font></paragraph></choice></mc>
<mc label="Q2" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check "Uniforms/Jerseys Ordered" box in status table on Administrator Dashboard?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotContain field="Uniforms:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q3" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Please select division:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Divisions:Name"/>
</display-expression><value-expression><field name="Record:Divisions:DivisionID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Divisions" /></record-selector></dynamic-mcq></data-provider></mc>
<break/>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Uniform/Jersey Sizes for all players in the </font><font><display-mcq-label version="1"><field-name>Uniforms:Q3</field-name><display>label_only</display></display-mcq-label></font><font> division:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><response-totals-table version="1"><layout-type>vertical</layout-type><field>Record:Registration:UniformSize</field><conditions><form name="Registration" /><conditions>
<mcEquals field="Record:Registration:DivisionId">
<string field="Uniforms:Q3"/>
</mcEquals>
</conditions></conditions></response-totals-table></font></paragraph></text>
</items>
</form>
<form name="CommunicatorSend" startPoint="false" themePath="mvsc" process="Post-CommunicatorSend" preProcess="RetrieveAdminSetupVariables">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="720"><row><cell width="8460"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><b>From: </b></font><font><field name="Communicator:FromName"/></font><font> (</font><font><field name="Communicator:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="Communicator:Subject"/></font></division></cell></row></table><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><table indent="705"><row><cell width="8460"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><field name="Communicator:Body"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font color="000000"><i>(If you opted to include a link in your message):</i></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font>[Here is a link to </font><font color="0000FF"><u>your private </u></font><font color="0000FF"><u><field name="League"/></u></font><font color="0000FF"><u> Dashboard</u></font><font>. </font><font><field name="DashboardLinkVerbiage"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><field name="DashboardLinkVerbiage2"/></font><font color="000000">]</font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><field name="Communicator:Close"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="CommunicatorSend:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Click Submit to begin sending now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Note: It might take several minutes to send all the emails.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Do not click Submit a second time! Wait for the Administrator Dashboard page to reappear.</i></font></paragraph></text>
</items>
</form>
