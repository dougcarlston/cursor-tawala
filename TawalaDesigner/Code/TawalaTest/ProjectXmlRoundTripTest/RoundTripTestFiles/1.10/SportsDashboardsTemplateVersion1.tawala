<set field="DivisionsWithMIssingFees" arithmeticAsText="false">
<string value=" "/>
</set>
<get recordList="All Divisions">
<forms>
<form name="Divisions"/>
</forms>
</get>
<foreach record="Record" recordList="All Divisions">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<isLessThan field="Record:Divisions:DivFees">
<string value=".0001"/>
</isLessThan>
</conditions>
<trueSet>
<if>
<conditions>
