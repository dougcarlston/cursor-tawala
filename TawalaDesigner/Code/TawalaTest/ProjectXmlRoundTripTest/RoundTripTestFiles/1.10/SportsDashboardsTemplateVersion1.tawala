<process name="Pre-PlayerCommunicator">
<edit form="PlayerCommunicator" submit="modify">
<conditions>
<equals field="Record:PlayerCommunicator:PlayerIdentification">
<string field="PlayerID"/>
</equals>
</conditions>
</edit>
</process>
<process name="Post-PlayerCommunicator">
<if>
<conditions>
<and>
<doesNotEqual field="FlagC">
<string value="On"/>
</doesNotEqual>
<mcDoesNotEqual field="PlayerCommunicator:Q1" value="d"/>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You have not yet been assigned a team, so this part of Communicator won&apos;t work yet."/>
</set>
<show document="Message" reset="false"/>
<show form="PlayerDash"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcEquals field="PlayerCommunicator:Q1" value="a"/>
<mcEquals field="PlayerCommunicator:Q1" value="b"/>
</or>
</conditions>
<trueSet>
<if>
<conditions>
<isBlank field="PlayerTeamId" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You have not yet been assigned a team, so this part of Communicator won&apos;t work yet."/>
</set>
<show document="Message" reset="false"/>
<show form="PlayerDash"/>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="PlayerCommunicator:Q1" value="c"/>
<equals field="Coach">
<string value="Not yet assigned"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Your coach has not yet been assigned."/>
</set>
<show document="Message" reset="false"/>
<show form="PlayerDash"/>
</trueSet>
</if>
<set field="PlayerCommunicator:PlayerIdentification" arithmeticAsText="false">
<string field="PlayerID"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="a"/>
</conditions>
<trueSet>
<comment>Send message to all teammates</comment>
<set field="ToField" arithmeticAsText="false">
<string value="All my teammates"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear Jimmy,"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="b"/>
</conditions>
<trueSet>
<comment>Send message to some teammates</comment>
<set field="ToField" arithmeticAsText="false">
<string value="Selected Teammates"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear Jimmy,"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="c"/>
</conditions>
<trueSet>
<comment>Send message to my Coach</comment>
<set field="ToField" arithmeticAsText="false">
<string value="Coach "/>
<string field="Coach"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="d"/>
</conditions>
<trueSet>
<comment>Send message to Athletic Director</comment>
<set field="ToField" arithmeticAsText="false">
<string field="AdminName"/>
</set>
</trueSet>
</if>
<set field="MessageBody" arithmeticAsText="false">
<string field="PlayerCommunicator:Body"/>
</set>
<set field="MessageClose" arithmeticAsText="false">
<string field="PlayerCommunicator:Close"/>
</set>
<show form="PlayerCommunicatorSend"/>
</process>
<process name="Post-PlayerCommunicatorSend">
<if>
<conditions>
<mcEquals field="PlayerCommunicatorSend:Q1" value="b"/>
</conditions>
<trueSet>
<show form="PlayerCommunicator"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerCommunicatorSend:Q1" value="c"/>
</conditions>
<trueSet>
<show form="PlayerDash"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="PlayerCommunicatorSend:Q1" value="a"/>
</conditions>
<trueSet>
<show form="PlayerCommunicatorSend"/>
</trueSet>
</if>
<set field="DearSir" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SendCount" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="MessageBody" arithmeticAsText="false">
<string field="PlayerCommunicator:Body"/>
</set>
<set field="MessageClose" arithmeticAsText="false">
<string field="PlayerCommunicator:Close"/>
</set>
<if>
<conditions>
<or>
<mcEquals field="PlayerCommunicator:Q1" value="a"/>
<mcEquals field="PlayerCommunicator:Q1" value="b"/>
</or>
</conditions>
<trueSet>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="a"/>
</conditions>
<trueSet>
<comment>Send to all teammates</comment>
<get recordList="Record List 95">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Record List 95:Registration:TeamId">
<string field="PlayerTeamId"/>
</equals>
</conditions></get>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="b"/>
</conditions>
<trueSet>
<comment>Send Email to selected teammates</comment>
<get recordList="Record List 95">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="PlayerCommunicator:Q5">
<string field="Record List 95:Registration:RegID"/>
</mcContains>
</conditions></get>
</trueSet>
</if>
<foreach record="Teammate" recordList="Record List 95">
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="Teammate:Registration:FirstName"/>
<string value=","/>
</set>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
<send>
<to addressField="Teammate:Registration:ParentEmail"/>
<from addressField="PlayerEmail" aliasField="PlayerFullName"/>
<subject><field name="PlayerCommunicator:PCSubject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<if>
<conditions>
<isNotBlank field="Teammate:Registration:ParentEmail2" />
</conditions>
<trueSet>
<send>
<to addressField="Teammate:Registration:ParentEmail2"/>
<from addressField="PlayerEmail" aliasField="PlayerFullName"/>
<subject><field name="PlayerCommunicator:PCSubject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Email sent to "/>
<string field="SendCount"/>
<string value=" teammates."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="c"/>
</conditions>
<trueSet>
<comment>Send Email to Coach</comment>
<send>
<to addressField="CoachsEmail"/>
<from addressField="PlayerEmail" aliasField="PlayerFullName"/>
<subject><field name="PlayerCommunicator:PCSubject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="Message" arithmeticAsText="false">
<string value="Email sent to Coach "/>
<string field="Coach"/>
<string value="."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="d"/>
</conditions>
<trueSet>
<comment>Send Email to Athletic Director</comment>
<send>
<to addressField="AdminEmail"/>
<from addressField="PlayerEmail" aliasField="PlayerFullName"/>
<subject><field name="PlayerCommunicator:PCSubject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="Message" arithmeticAsText="false">
<string value="Email sent to "/>
<string field="AdminName"/>
<string value="."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<show form="PlayerDash"/>
</process>
