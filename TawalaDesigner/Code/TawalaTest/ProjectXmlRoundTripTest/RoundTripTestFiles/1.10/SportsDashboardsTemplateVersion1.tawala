<foreach record="Primary" recordList="Record List 149">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<equals field="SearchState">
<string value="Looking for primary"/>
</equals>
