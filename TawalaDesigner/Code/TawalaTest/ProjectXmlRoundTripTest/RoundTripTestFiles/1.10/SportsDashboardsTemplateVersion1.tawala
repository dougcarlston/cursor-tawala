<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="CoachId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach to delete:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
