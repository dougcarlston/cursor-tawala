</description><open-preference>current-window</open-preference></link-to-project-details></font></division></cell></row><row><cell width="210"></cell><cell width="3660"><division indent="0" align="center"><font><u><invitation form="AdminSetup" project="">View/Edit Administrator Setup</invitation></u></font></division></cell><cell width="2625"><division indent="0" align="center"><font color="000080"><u><invitation form="Umpires" project="">View Ref/Umpire Data</invitation></u></font></division></cell><cell width="3765"><division indent="0" align="center"><font><u><invitation form="SendDashReminder" project="">Send/View Coach/Player Dashboard</invitation></u></font></division></cell></row><row><cell width="210"></cell><cell width="3660"><division indent="0" align="center"><font color="000080"><u><invitation form="CloseRegistration" project="">Close/Reopen Registration Period</invitation></u></font></division></cell><cell width="2625"><division indent="0" align="center"><font><u><invitation form="AdminSiteMap" project="">Site Map</invitation></u></font></division></cell><cell width="3765"><division indent="0" align="center"><font color="000080"><u><invitation form="TeamViewToggle" project="">Toggle Team View on Player Dashes</invitation></u></font></division></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Links:</b></font></paragraph><table indent="0"><row><cell width="272"></cell><cell width="3628"><division indent="0" align="center"><font color="000080"><u><link>
