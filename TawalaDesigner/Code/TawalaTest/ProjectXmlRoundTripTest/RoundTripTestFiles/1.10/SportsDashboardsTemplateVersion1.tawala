<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Unmark Waiver or Payment Receipts</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4140"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver and Payment Management</invitation></u></font></division></cell><cell width="3420"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current Status:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>5</number-of-columns><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Payment Received"/>
</header><contents><field name="Record:Registration:PaymentReceived" /></contents></column><column><header><string value="Waiver Received"/>
</header><contents><field name="Record:Registration:WaiverReceived" /></contents></column><conditions><form name="Registration" /><conditions>
