</set>
<set field="RegEmail1" arithmeticAsText="true">
<string field="Primary:Registration:ParentEmail2"/>
</set>
<set field="RegPhone1" arithmeticAsText="true">
<string field="Primary:Registration:Phone1"/>
</set>
<set field="RegPhone2" arithmeticAsText="true">
<string field="Primary:Registration:Phone2"/>
</set>
<set field="RegPhone3" arithmeticAsText="true">
<string field="Primary:Registration:Phone3"/>
</set>
<set field="RegSchool" arithmeticAsText="true">
<string field="Primary:Registration:School"/>
</set>
<set field="RegGrade" arithmeticAsText="true">
<string field="Primary:Registration:Grade"/>
</set>
<set field="RegParish" arithmeticAsText="true">
<string value="("/>
<string field="Primary:Registration:Parish"/>
<string value=")"/>
</set>
<set field="RegFriends" arithmeticAsText="true">
