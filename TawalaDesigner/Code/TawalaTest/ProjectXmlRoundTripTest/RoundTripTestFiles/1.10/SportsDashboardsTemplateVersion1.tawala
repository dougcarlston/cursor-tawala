ow><row><cell width="2340"><division indent="0" align="right"><font>Administrator:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminName"/></font></division></cell><cell width="4395"><division indent="0" align="right"><font>All Players assigned:</font></division></cell><cell width="915"><division indent="0" align="right"><font face="Arial" size="200"><field name="AllPlayersAssignedChecked"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Email:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminEmail"/></font></division></cell><cell width="4395"><division indent="0" align="right"><font>Team View on Player Dashboards:</font></division></cell><cell width="915"><division indent="0" align="right"><font face="Arial" size="200"><field name="FlagC"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Phone:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminsPhone"/></font></division></cell><cell width="4395"><division indent="0" align="right"><sp/><font> Registration Period: </font></division></cell><cell width="915"><division indent="0" align="right"><font face="Arial" size="200" color="000000"><field name="RegViewFlag"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Address:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminAdrss"/></font></division></cell><cell width="4395"></cell><cell width="915"></cell></row><row><cell width="2340"></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><font><field name="AdminsZIP"/></font></division></cell><cell width="4395"><division indent="0" align="right"><font color="000000">Fee structure: </font><font color="000000"><field name="FeeStructureDescription"/></font><sp/></division></cell><cell width="915"></cell></row></table><paragraph indent="0" align="right"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3735"><division indent="0" align="left"><font><b>Options:</b></font></division></cell><cell width="285"></cell><cell width="790"><division indent="0" align="right"><font face="Arial" size="180" color="0000A0"><u><invitation form="AdminSetup" project="">edit</invitation></u></font></division></cell><cell width="200"></cell><cell width="4605"><division indent="0" align="center"><font><b>Statistics:</b></font></division></cell><cell width="855"><division indent="0" align="right"><font face="Arial" size="200" color="000080"><u><invitation form="RefreshAdminDash" project="">refresh</invitation></u></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font>Email Notification Options       </font></division></cell><cell width="285"></cell><cell width="790"><division indent="0" align="right"><sp/></division></cell><cell width="200"></cell><cell width="4605"><division indent="0" align="right"><font>Recruiting List:</font></division></cell><cell width="855"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>RecruitmentDB</form-name><conditions><form name="RecruitmentDB" /><conditions>
<and>
<isNotBlank field="Record:RecruitmentDB:FirstName" />
<isNotBlank field="Record:RecruitmentDB:Email" />
</and>
</conditions></conditions></record-count></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font><i>Upon each new registration:</i></font></division></cell><cell width="285"></cell><cell width="790"><division indent="0" align="left"><font face="Arial" size="200"><field name="FlagA"/></font></division></cell><cell width="200"></cell><cell width="4605"><division indent="0" align="right"><font>Registrations:</font></division></cell><cell width="855"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /></conditions></record-count></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font><i>Upon each bulk mailing:</i></font></division></cell><cell width="285"></cell><cell width="790"><division indent="0" align="left"><font face="Arial" size="200"><field name="FlagB"/></font></division></cell><cell width="200"></cell><cell width="4605"><division indent="0" align="right"><font>Waivers turned in:</font></division></cell><cell width="855"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /><conditions>
<isNotBlank field="Record:Registration:WaiverReceived" />
</conditions></conditions></record-count></font></division></cell></row><row><cell width="3735"></cell><cell width="285"></cell><cell width="790"></cell><cell width="200"></cell><cell width="4605"><division indent="0" align="right"><font>Payment received:</font></division></cell><cell width="855"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /><conditions>
<isNotBlank field="Record:Registration:PaymentReceived" />
</conditions></conditions></record-count></font></division></cell></row></table><paragraph indent="0" align="right"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The </font><font color="004000"><b>Toggle Team View on Dashes</b></font><font color="004000"> link at the top of this Dashboard permits you to hide coach and team information</font><sp/><font color="004000">from players until you have had a chance to review different rosters with others.  When this toggle </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">is set to </font><font color="004000"><b>Off</b></font><font color="004000">, the</font><sp/><font color="004000">players cannot see any coach, team or teammate information on their Dashboards, even though</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">you may have</font><sp/><font color="004000">already assigned them to a team.  Once the assignments are fairly final, you should click this link</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">to </font><font color="004000"><b>On</b></font><font color="004000">, which will</font><sp/><font color="004000">populate all of the Player Dashboards with information on their team, division, coach and</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">teammates.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The </font><font color="004000"><b>Close/Re-Open Registration Period </b></font><font color="004000">link on this Dashboard permits you to redirect the Registration link on</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">your Web page to a message stating that registrations for this season have been closed and giving the contact</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">information for the Athletic Director in case a player wants to apply for late registration.  </font><font color="004000"><b>Note: </b></font><font color="004000">The Administrator</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">can still register a player directly from this Dashboard, which will send a link then to the Player, permitting him or</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">her to pay, sign the medical waiver and complete and missing information from the registration.</font></paragraph>
</xmlData>
</document>
