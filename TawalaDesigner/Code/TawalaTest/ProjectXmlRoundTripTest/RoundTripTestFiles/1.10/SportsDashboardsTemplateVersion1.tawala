</set>
<set field="RegAddress1" arithmeticAsText="true">
<string field="Primary:Registration:City"/>
<string value=", "/>
<string field="Primary:Registration:State"/>
<string value=" "/>
<string field="Primary:Registration:Zip"/>
</set>
<set field="RegEmail" arithmeticAsText="true">
