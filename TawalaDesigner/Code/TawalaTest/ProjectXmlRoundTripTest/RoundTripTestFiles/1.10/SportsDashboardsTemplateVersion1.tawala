<if>
<conditions>
<mcEquals field="Registration:SexMCQ" value="a"/>
</conditions>
<trueSet>
<set field="Sx" arithmeticAsText="false">
<string value="Boy"/>
</set>
</trueSet>
<falseSet>
<set field="Sx" arithmeticAsText="false">
<string value="Girl"/>
</set>
</falseSet>
</if>
<set field="ParentWillingToCoach" arithmeticAsText="false">
<string value="No"/>
</set>
<if>
<conditions>
<mcContains field="Registration:WillingToCoachOrUmpire" value="a"/>
</conditions>
<trueSet>
<set field="ParentWillingToCoach" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<set field="PlayerWillingToUmpire" arithmeticAsText="false">
<string value="No"/>
</set>
<if>
<conditions>
<mcContains field="Registration:WillingToCoachOrUmpire" value="b"/>
</conditions>
<trueSet>
<set field="PlayerWillingToUmpire" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Registration:InfoCorrect" arithmeticAsText="false">
<string value=" "/>
</set>
</skipInstructions>
<text label="T9" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240" color="A00000"><b><i>Please review the information below carefully.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="390"><row><cell width="3165"><division indent="0" align="right"><font><b>Name:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:FirstName"/></font><sp/><font><field name="Registration:LastName"/></font><sp/></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Date of Birth:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:RegAgeMo"/></font><font>/</font><font><field name="Registration:RegAgeDay"/></font><font>/</font><font><field name="Registration:RegAgeYr"/></font><sp/></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Sex:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Sx"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Parent's Name:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:ParentFirstName"/></font><sp/><font><field name="Registration:ParentLastName"/></font><sp/></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Address"/></font></division><division indent="0" align="left"><font><field name="Registration:City"/></font><font>, </font><font><field name="Registration:State"/></font><sp/><font><field name="Registration:Zip"/></font><sp/></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Parent's Email(s):</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:ParentEmail"/></font><sp/><font><field name="Registration:ParentEmail2"/></font><sp/></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b><field name="Phone1Lab"/></b></font><font><b>:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Phone1"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b><field name="Phone2Lab"/></b></font><font><b>:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Phone2"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b><field name="Phone3Lab"/></b></font><font><b>:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Phone3"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>School:</b></font><sp/></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:School"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Grade:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><display-mcq-label version="1"><field-name>Registration:Grade</field-name><display>label_only</display></display-mcq-label></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Parish (if applicable):</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Parish"/></font></division></cell></row><row><cell width="3165"></cell><cell width="330"></cell><cell width="6915"></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Division Info:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><i>(2 fields below will be blank if divisions not used)</i></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Division requested:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><display-mcq-label version="1"><field-name>Registration:DivisionId</field-name><display>label_only</display></display-mcq-label></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Previous division:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><display-mcq-label version="1"><field-name>Registration:LastDiv</field-name><display>label_only</display></display-mcq-label></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></division></cell><cell width="330"></cell><cell width="6915"></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Parent is willing to coach:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="ParentWillingToCoach"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Player is willing to umpire:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="PlayerWillingToUmpire"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><sp/><sp/><sp/></division></cell><cell width="330"></cell><cell width="6915"></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Preferred Coach:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:PreferredCoach"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Preferred Teammates:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Friend:a"/></font><sp/><sp/><font><field name="Registration:Friend:b"/></font><sp/><sp/><sp/><font><field name="Registration:Friend:c"/></font><sp/></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Uniform Size:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><display-mcq-label version="1"><field-name>Registration:UniformSize</field-name><display>label_only</display></display-mcq-label></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><sp/><sp/><sp/></division></cell><cell width="330"></cell><cell width="6915"></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Medical Plan:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:MedPlanName"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Plan Number:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:MedPlanNumber"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Doctor's Name:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:DocName"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:DocPhone"/></font></division></cell></row><row><cell width="3165"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="330"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:DocAddress"/></font></division></cell></row></table></text>
<text label="T10"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240" color="A00000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<mc label="Q14" alternateLabel="InfoCorrect" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select an option and click Submit.</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Correct or change the above information.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The above information is correct. Continue to the next step.</font></paragraph></choice></mc>
<text label="T11" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will always be able to change this information later from your Player Dashboard.</font></paragraph></text>
<skipInstructions>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcEquals field="Registration:InfoCorrect" value="a"/>
</conditions>
<trueSet>
<skip to="T2"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Registration:InfoCorrect" value="b"/>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Select an option below and click Submit."/>
</set>
<set field="Registration:InfoCorrect" arithmeticAsText="false">
<string value=" "/>
</set>
<skip to="T9"/>
</trueSet>
</if>
</skipInstructions>
