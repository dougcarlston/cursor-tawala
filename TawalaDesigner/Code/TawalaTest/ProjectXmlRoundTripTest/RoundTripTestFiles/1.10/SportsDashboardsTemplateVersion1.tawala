<document name="Umpires">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Volunteer Referee/Umpires</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>7</number-of-columns><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><field name="Phone1Lab"/>
</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header><field name="Phone2Lab"/>
</header><contents><field name="Record:Registration:Phone2" /></contents></column><column><header><field name="Phone3Lab"/>
</header><contents><field name="Record:Registration:Phone3" /></contents></column><column><header><string value="Team"/>
</header><contents><field name="Record:Registration:TeamId" /></contents></column><conditions><form name="Registration" /><conditions>
<mcContains field="Record:Registration:WillingToCoachOrUmpire" value="b"/>
</conditions></conditions></itemization-table></font></paragraph>
</xmlData>
</document>
<document name="Pre-Season">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Preseason Activities</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="272"></cell><cell width="3608"><division indent="0" align="center"><font color="000080"><u><invitation form="Recruitment" project="">Recruitment List Tools</invitation></u></font></division></cell><cell width="200"></cell><cell width="3810"><division indent="0" align="center"><font color="000080"><u><invitation form="Team Rosters" project="">Assign Players to Teams</invitation></u></font></division></cell><cell width="210"></cell></row><row><cell width="272"></cell><cell width="3608"><division indent="0" align="center"><font color="000080"><u><invitation form="RegFormMgmt" project="">Player Registration Tools</invitation></u></font></division></cell><cell width="200"></cell><cell width="3810"><division indent="0" align="center"><font color="000080"><u><invitation form="Uniforms" project="">Order Jerseys/Uniforms</invitation></u></font></division></cell><cell width="210"></cell></row><row><cell width="272"></cell><cell width="3608"><division indent="0" align="center"><font color="000080"><u><invitation form="TeamAndCoachMenu" project="">Set up Teams and Coaches</invitation></u></font></division></cell><cell width="200"></cell><cell width="3810"><division indent="0" align="center"><font color="000080"><u><invitation form="CoachRosterNotice" project="">Send Dashboards to Coaches </invitation></u></font></division></cell><cell width="210"></cell></row><row><cell width="272"></cell><cell width="3608"></cell><cell width="200"></cell><cell width="3810"></cell><cell width="210"></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The</font><font color="004000"><b> Recruitment List Tools</b></font><font color="004000"> allow you to maintain an email list of potential prospects for your</font><sp/><font color="004000">League.   You can add, edit and delete names from the list, audit the email addresses for validity and send bulk mailings out to this list inviting them to register for your league.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The </font><font color="004000"><b>Player Registration Tools</b></font><font color="004000"> allow you to register a player or a group for your league, edit </font><sp/><font color="004000">or delete player registrations, mark receipt of waivers and payments, audit email addresses</font><sp/><font color="004000">and send bulk messages out to the players and their families.  You can use this tool to send</font><sp/><font color="004000">reminders to those with incomplete registrations as well as to send personal Player dashboards</font><sp/><font color="004000">to those who have lost theirs.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The </font><font color="004000"><b>Set up Teams and Coaches</b></font><font color="004000"> link lets you add, edit or delete team names, gather contact</font><sp/><font color="004000">information on your coaches, and assign coaches to individual teams.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">You may use the </font><font color="004000"><b>Assign Players to Teams</b></font><font color="004000"> link to move players onto teams using a drag-and-drop tool that lets you see basic player information, such as sex, age and friends.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The </font><font color="004000"><b>Order Uniforms</b></font><font color="004000"> link will give you size breakouts for uniforms for all of your registered players.</font><sp/><sp/><font color="004000">If you use divisions, it will break them out by division.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The final link, </font><font color="004000"><b>Send Dashboards to Coaches</b></font><font color="004000">, permits you to send out a bulk mailing to all of</font><sp/><font color="004000">your coaches, giving them their team assignments and providing each with a personal Coach's</font><sp/><font color="004000">Dashboard with a set of tools to help them manage their team.</font></paragraph>
</xmlData>
</document>
<document name="RecruitmentMgmt">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Manage the Recruitment List</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="555"><row><cell width="3358"><division indent="0" align="left"><font><u><invitation form="Show RecruitDB" project="">View recruitment list</invitation></u></font></division></cell><cell width="272"></cell><cell width="3255"><division indent="0" align="left"><font><u><invitation form="AddRecruitRecord" project="">Add a recruitment record</invitation></u></font></division></cell><cell width="3359"><division indent="0" align="left"><font><u><invitation form="RecruitEmail" project="">Send email to recruitment list</invitation></u></font></division></cell></row><row><cell width="3358"><division indent="0" align="left"><font><u><invitation form="AuditRecruitList" project="">Audit recruitment email addresses</invitation></u></font></division></cell><cell width="272"></cell><cell width="3255"><division indent="0" align="left"><font><u><invitation form="EditRecruitment" project="">Edit a recruitment record</invitation></u></font></division></cell><cell width="3359"></cell></row><row><cell width="3358"><division indent="0" align="left"><font><u><invitation form="DuplicateRecruitCheck" project="">Check for duplicate records</invitation></u></font></division></cell><cell width="272"></cell><cell width="3255"><division indent="0" align="left"><font><u><invitation form="DeleteRecruitment" project="">Delete a recruitment record</invitation></u></font></division></cell><cell width="3359"></cell></row><row><cell width="3358"></cell><cell width="272"></cell><cell width="3255"><division indent="0" align="left"><font><u><invitation form="AddRecruitFromReg" project="">Add Records from Registration list</invitation></u></font></division></cell><cell width="3359"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">You can  manage records in the Recruitment List both here and on the Tawala Website in your MyProjects </font><font color="004000"><field name="League"/></font><font color="004000"> Project Detail Page. The recruitment list is called "RecruitmentDB."  It is easier to delete records from the Web page, and you can also import contact lists there.  To import, try clicking on the import icon (</font><font face="Arial" size="200" color="000000"><image id="image6" width="26" height="22"><metafileHeader fileType="1" headerSize="9" version="768" fileSize="933" numOfObjects="0" maxRecordSize="911" numOfParams="0" />
</image></font><font color="004000">) to the right of "RecruitmentDB" file name and select an Excel or .csv file to import. The file must have the correct information in these five fields: </font><font color="004000"><i>Child's First Name, Last Name, Parent's First Name, Parent's Email address, Phone.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><link-to-project-details version="1"><description><string value="Jump to MyTawala Project Detail Page"/>
</description><open-preference>current-window</open-preference></link-to-project-details></u></font></paragraph>
</xmlData>
</document>
<document name="PlayerRegMgmt">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Player Registration Management</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="495"><row><cell width="3105"><division indent="0" align="left"><font color="000080"><u><invitation form="AdminPlayerRegistration" project="">Register a Player or Group</invitation></u></font></division></cell><cell width="3330"><division indent="0" align="left"><font color="000080"><u><invitation form="ShowWaiverPaymentFields" project="">View all registrations</invitation></u></font></division></cell><cell width="3870"><division indent="0" align="left"><font color="000080"><u><invitation form="AuditRegForms" project="">Audit registration email addresses</invitation></u></font></division></cell></row><row><cell width="3105"><division indent="0" align="left"><font color="000080"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Mark waivers and payments</invitation></u></font></division></cell><cell width="3330"><division indent="0" align="left"><font color="000080"><u><invitation form="ViewEditRecord" project="">View/Edit a specific registration</invitation></u></font></division></cell><cell width="3870"><division indent="0" align="left"><font color="000080"><u><invitation form="RegistrantEmail" project="">Communicate with registered players</invitation></u></font></division></cell></row><row><cell width="3105"></cell><cell width="3330"><division indent="0" align="left"><font color="000080"><u><invitation form="DeleteRegistration" project="">Delete a registration</invitation></u></font></division></cell><cell width="3870"><division indent="0" align="left"><font color="000080"><u><invitation form="PaymentReport" project="">Payment report</invitation></u></font></division></cell></row><row><cell width="3105"></cell><cell width="3330"></cell><cell width="3870"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">In </font><font color="004000"><b>Register a Player or Group</b></font><font color="004000">, you may enter registration information directly, send someone a direct link to the registration form for them to fill out, or do a group registration.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">You may use </font><font color="004000"><b>Mark waivers and payments</b></font><font color="004000"> to record the receipt of registration fees and medical waivers.  You may also unmark any items that were previously marked in error.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">You may use </font><font color="004000"><b>View all registrations</b></font><font color="004000"> to access several summary view of all the registrations forms.  You may sort any view by the responses in any column just by clicking on the heading for that column.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>View/Edit a specific registration</b></font><font color="004000"> permits you to access any player's registration form in order to view it or correct information.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Delete a registration </b></font><font color="004000">is useful to remove a record entirely.  The is especially valuable when registrants inadvertently end up with duplicate records in the database. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Audit registration email addresses</b></font><font color="004000"> checks the addresses in all the registrations for validity.  It can catch common typos and misspellings, although it doesn't catch everything.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">With </font><font color="004000"><b>Communicate with registered players</b></font><font color="004000">, you are able to send bulk mailings to all players, to those missing waivers, to those who have not yet paid and to those whose registrations are complete in all respects.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">With </font><font color="004000"><b>Payment report</b></font><font color="004000"> you can see the list of players whose registrations are paid, including the payment amounts and payment methods.</font></paragraph>
</xmlData>
</document>
<document name="Letter w RegLink">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DearSir"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="MessageBody"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To register for the </font><font><field name="SeasonYr"/></font><sp/><font><field name="League"/></font><font>, just </font><font color="000080"><u><invitation form="Registration" project="">click here.</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="MessageClose"/></font></paragraph>
</xmlData>
</document>
<document name="PaymentReport">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280"><b>Payment Report</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Individual Registrations</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>5</number-of-columns><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Paid Amount"/>
</header><contents><field name="Record:Registration:PaidAmount" /></contents></column><column><header><string value="Payment Method"/>
</header><contents><field name="Record:Registration:PaymentMethod" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Total amount: $</font><font><sum version="1"><field>Record:Registration:PaidAmount</field><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions></conditions></sum></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Group Registrations</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>2</number-of-columns><column><header><string value="Team"/>
</header><contents><field name="Record:GroupRegistration:TeamId" /></contents></column><column><header><string value="Group Registration Fee"/>
</header><contents><field name="Record:GroupRegistration:RegistrationFee" /></contents></column><conditions><form name="GroupRegistration" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Total group registrations: $</font><font><sum version="1"><field>Record:GroupRegistration:RegistrationFee</field><conditions><form name="GroupRegistration" /></conditions></sum></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Online Donations</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>4</number-of-columns><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Amount"/>
</header><contents><field name="Record:OnlineDonation:DonationAmount" /></contents></column><column><header><string value="User Notes"/>
</header><contents><field name="Record:OnlineDonation:UserMemo" /></contents></column><conditions><form name="Registration" /><form name="OnlineDonation" /><conditions>
<and>
<equals field="Record:Registration:RegID">
<string field="Record:OnlineDonation:RegID"/>
</equals>
<equals field="Record:OnlineDonation:Status">
<string value="Completed"/>
</equals>
</and>
</conditions></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Total donated: $</font><font><sum version="1"><field>Record:OnlineDonation:DonationAmount</field><conditions><form name="OnlineDonation" /><conditions>
<equals field="Record:OnlineDonation:Status">
<string value="Completed"/>
</equals>
</conditions></conditions></sum></font></paragraph>
</xmlData>
</document>
<document name="OptOut">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="180" color="000000">------------------------------------</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="180">If you would like to be removed from this list, please</font><sp/><font size="180" color="000080"><u><invitation form="OptOut" project="" private="true"><authenticationTokenValue><string field="RecruitID"/>
</authenticationTokenValue>click here</invitation></u></font><font size="180" color="000080">.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="180">If you would like to review or correct the information in your record, please </font><font size="180" color="000080"><u><invitation form="RecruitSelfEdit" project="" private="true"><authenticationTokenValue><string field="RecruitID"/>
</authenticationTokenValue>click here</invitation></u></font><font size="180" color="000080"><u>.</u></font></paragraph>
</xmlData>
</document>
<document name="OptOutThanks">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="B00000"><b><i>Thank you.  Your record has been removed from our mailing list. </i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph>
</xmlData>
</document>
<document name="NavigationToDonationPage">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="375"><row><cell width="10425"><division indent="0" align="left"><font><field name="DonationMessage"/></font></division></cell></row><row><cell width="10425"><division indent="0" align="left"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></division></cell></row><row><cell width="10425"><division indent="0" align="left"><font color="000080"><u><invitation form="OnlineDonation" project="">Make a donation</invitation></u></font></division></cell></row></table>
</xmlData>
</document>
<document name="Donation">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DonationMessage"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><paypal-single-item-button version="1"><button-type>donate-logo</button-type><item><field name="OnlineDonation:DonationDescription"/>
</item><amount><field name="OnlineDonation:DonationAmount"/>
</amount><successful-payment-return-form-name>PlayerDash</successful-payment-return-form-name><cancelled-payment-return-form-name>PlayerDash</cancelled-payment-return-form-name><status-field>Record:OnlineDonation:Status</status-field><amount-field>Record:OnlineDonation:DonationAmount</amount-field><style-option>paypal</style-option></paypal-single-item-button></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="PlayerDash" project="">Return to my Dashboard</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="OnlyPaymentByCheckIsNeeded">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to submit:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Your payment of $</b></font><font><b><field name="RegistrationFee"/></b></font></paragraph>
</xmlData>
</document>
<document name="NavigationToPlayerDashboardAfterRegistration">
<xmlData>
<paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Jump to Player Dashboard</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="EverythingIsReceivedThankYou">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>We have received both your payment and waiver. Thank you!</font></paragraph>
</xmlData>
</document>
<document name="OnlyPaymentIsNeeded">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to submit:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Your payment of $</b></font><font><b><field name="RegistrationFee"/></b></font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="000080"><b><u><invitation form="OnlinePayment" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Proceed to Payment Instructions</invitation></u></b></font><sp/><sp/></paragraph>
</xmlData>
</document>
<document name="WaiverNeededAndPaymentByCheckOnly">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="360" color="000000">Step 1 of your registration has been completed.</font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to complete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 2:</b></font><font> Submit your payment of $</font><font><field name="RegistrationFee"/></font><font> and</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 3:</b></font><font> Click the link to your personal </font><font><field name="League"/></font><font> Dashboard.  Then either "sign" your medical waiver by clicking on the checkbox under the waiver or else print out, complete, sign and mail it in to your Athletic Director, as you are requested.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph>
</xmlData>
</document>
<document name="OnlyWaiverIsNeeded">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to complete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>A signed medical waiver</b></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will find your waiver on your Player Dashboard.  You may "sign" it by checking the check box at the bottom or print it and mail it to the Athletic Director.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="240" color="000000"><b>*NOTE: No child will be allowed to participate without a signed waiver.</b></font></paragraph>
</xmlData>
</document>
<document name="Error Calculating Payment">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>We are sorry! An error occurred when calculating the registration fee. Please contact your league administrator to find out the amount you own.</b></font></paragraph>
</xmlData>
</document>
