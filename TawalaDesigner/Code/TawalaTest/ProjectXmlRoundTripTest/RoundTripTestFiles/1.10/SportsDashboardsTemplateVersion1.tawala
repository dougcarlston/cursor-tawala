<process name="Post-AddRecruitFromReg">
<get recordList="Record List 116">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<isBlank field="Record List 116:Registration:RecruitmentMergeStatus" />
</conditions></get>
<foreach record="BlankComparison" recordList="Record List 116">
<set field="Match" arithmeticAsText="false">
<string value="No"/>
</set>
<get recordList="Record List 117">
<forms>
<form name="RecruitmentDB"/>
</forms>
<conditions>
<and>
<equals field="Record List 117:RecruitmentDB:FirstName">
<string field="BlankComparison:Registration:FirstName"/>
