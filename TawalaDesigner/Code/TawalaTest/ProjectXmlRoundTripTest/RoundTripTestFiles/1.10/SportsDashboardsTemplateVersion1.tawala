<foreach record="SuchRecord" recordList="RegistrationList">
<if>
<conditions>
<mcEquals field="FinishPaymentAndWaiverReceipts:Waiver Received">
<string value="a"/>
</mcEquals>
</conditions>
<trueSet>
<set field="SuchRecord:Registration:WaiverReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
<falseSet>
<set field="SuchRecord:Registration:WaiverReceived" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<mcEquals field="FinishPaymentAndWaiverReceipts:Payment Received">
<string value="a"/>
</mcEquals>
</conditions>
<trueSet>
<set field="SuchRecord:Registration:PaymentReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
<falseSet>
<set field="SuchRecord:Registration:PaymentReceived" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SuchRecord:Registration:PaidAmount" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SuchRecord:Registration:PaymentMethod" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
</foreach>
<show form="ConfirmPaymentAndWaiverReceipts"/>
</process>
