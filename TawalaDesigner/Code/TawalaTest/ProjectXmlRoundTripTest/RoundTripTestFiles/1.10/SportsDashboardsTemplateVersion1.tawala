<mc label="Q9" alternateLabel="WillingToCoachOrUmpire" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Volunteering:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">If </font><font face="Arial" size="200" color="000000"><b>parent</b></font><font face="Arial" size="200" color="000000"> is willing to </font><font face="Arial" size="200" color="000000"><b>coach</b></font><font face="Arial" size="200" color="000000"> a team, please check here.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">If </font><font face="Arial" size="200" color="000000"><b>player</b></font><font face="Arial" size="200" color="000000"> is willing to </font><font face="Arial" size="200" color="000000"><b>referee/umpire</b></font><font face="Arial" size="200" color="000000">, please check here.</font></paragraph></choice></mc>
