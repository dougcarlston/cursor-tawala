<form name="RegistrantDeduping" startPoint="true" themePath="mvsc" process="Post-RegistrantDeduping" preProcess="Pre-RegistrantDeduping">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Registration Deduping Routine</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Compare the data from the following two files:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="center"><font><b>Record #1</b></font></division></cell><cell width="5400"><division indent="0" align="center"><font><b>Record #2</b></font></division></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="1800"><division indent="0" align="right"><font><b>Player Name:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegName"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Player Name:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegName"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Birthday:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegBD"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Birthday:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegBD"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Sex:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegSex"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Sex:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegSex"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Parent:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPName"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Parent:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPName"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegAddress"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegAddress"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegAddress1"/></font></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegAddress1"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegEmail"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegEmail"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegEmail1"/></font></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegEmail1"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Phone #s:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPhone1"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Phone #s:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPhone1"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPhone2"/></font></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPhone2"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPhone3"/></font></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPhone3"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>School:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegSchool"/></font><sp/><font><field name="RegParish"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>School:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegSchool"/></font><sp/><font><field name="SRegParish"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Grade:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegGrade"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Grade:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegGrade"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Friends:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegFriends"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Friends:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegFriends"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Jersey:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegUniform"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Jersey:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegUniform"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><sp/></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Medical Plan:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegMedPlan"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Medical Plan:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegMedPlan"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Doctor:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegDoctor"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Doctor:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegDoctor"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegDocPhone"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegDocPhone"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegDocAddress"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegDocAddress"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><sp/><sp/><sp/></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Team:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegTeam"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Team:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegTeam"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Payment:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPayment"/></font><font> ($</font><font><field name="RegPaidAmount"/></font><font>)</font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Payment:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPayment"/></font><font> ($</font><font><field name="SRegPaidAmt"/></font><font>)</font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Method:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPaymentMethod"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Method:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPaymentMethod"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Waiver:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegWaiver"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Waiver:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegWaiver"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Exception:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegWaiverException"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Exception:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegWaiverException"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><sp/></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Registration ID:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegID"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Registration ID:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegID"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Group ID:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegGroupID"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Group ID:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegGroupdID"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Record 2 is not a duplicate of Record 1.  Leave both in.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete Record #1</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete Record #2</font></paragraph></choice></mc>
</items>
</form>
<form name="CloseRegistration" startPoint="false" themePath="mvsc" process="Post-CloseRegistration">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="RegClosed" startPoint="false" themePath="mvsc" process="Post-RegClosed">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
</forms>
<processes>
<process name="Post-Registration">
<if>
<conditions>
<and>
<doesNotEqual field="BouncebackFlag">
<string value="AdminRegisteringPlayer"/>
</doesNotEqual>
<and>
<equals field="RegViewFlag">
<string value="Closed"/>
</equals>
<isBlank field="_InviteeID" />
</and>
</and>
</conditions>
<trueSet>
<comment>If Registrations closed, shunt off to closed reg message, unless it's an Admin registration or a registered player edit.</comment>
<show form="RegClosed"/>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="Registration:ParentEmail" />
</conditions>
<trueSet>
<comment>-- If the session expires we need to delete the record and start again.</comment>
<set field="SessionExpired" arithmeticAsText="false">
<string value="Yes"/>
</set>
<show form="DeleteEmptyRegistrationRecordsAndRedisplayForm"/>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="SeasonYr" />
</conditions>
<trueSet>
<set field="SeasonYr" arithmeticAsText="false">
<string value="2008"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Registration:RegAgeYr" />
</conditions>
<trueSet>
<if>
<conditions>
<isGreaterThan field="Registration:RegAgeMo">
<string field="FormulaNo"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="Registration:PlayerAge" arithmeticAsText="false">
<sub>
<sub>
<operand field="SeasonYr"/>
<operand field="Registration:RegAgeYr"/>
</sub>
<operand value="1"/>
</sub>
</set>
</trueSet>
<falseSet>
<set field="Registration:PlayerAge" arithmeticAsText="false">
<sub>
<operand field="SeasonYr"/>
<operand field="Registration:RegAgeYr"/>
</sub>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SexMCQ" value="a"/>
</conditions>
<trueSet>
<set field="Registration:Sex" arithmeticAsText="false">
<string value="Boy"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SexMCQ" value="b"/>
</conditions>
<trueSet>
<set field="Registration:Sex" arithmeticAsText="false">
<string value="Girl"/>
</set>
</trueSet>
</if>
<comment>-- if parent has checked the "willing to coach" box</comment>
<if>
<conditions>
<mcContains field="Registration:WillingToCoachOrUmpire" value="a"/>
</conditions>
<trueSet>
<comment>-- and they are not already signed up as a coach</comment>
<get recordList="MatchingCoachList">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<or>
<equals field="MatchingCoachList:Coach:Email">
<string field="Registration:ParentEmail"/>
</equals>
<equals field="MatchingCoachList:Coach:Email">
<string field="Registration:ParentEmail2"/>
</equals>
</or>
</conditions></get>
<foreach record="MatchingCoach" recordList="MatchingCoachList">
<if>
<conditions>
<isNotBlank field="MatchingCoach:Coach:Email" />
</conditions>
<trueSet>
<set field="Registration:CoachVolunteer" arithmeticAsText="false">
<string value="RegisteredCoach"/>
</set>
</trueSet>
</if>
</foreach>
<if>
<conditions>
<doesNotEqual field="Registration:CoachVolunteer">
<string value="RegisteredCoach"/>
</doesNotEqual>
</conditions>
<trueSet>
<comment>-- mark them as "available"</comment>
<set field="Registration:CoachVolunteer" arithmeticAsText="false">
<string value="Available"/>
</set>
</trueSet>
</if>
</trueSet>
<falseSet>
<comment>-- in case they unchecked the previously-checked box</comment>
<set field="Registration:CoachVolunteer" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<isBlank field="Registration:RegID" />
</conditions>
<trueSet>
<get recordList="Record List 18">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="RegNo" recordList="Record List 18">
<set field="RegNo:AdminSetup:PlayerIDGenerator" arithmeticAsText="false">
<add>
<operand field="RegNo:AdminSetup:PlayerIDGenerator"/>
<operand value="1"/>
</add>
</set>
<set field="PlayerID" arithmeticAsText="false">
<string value="player"/>
<string field="RegNo:AdminSetup:PlayerIDGenerator"/>
<string field="Registration:ParentEmail"/>
</set>
<set field="Registration:RegID" arithmeticAsText="false">
<string field="PlayerID"/>
</set>
</foreach>
</trueSet>
</if>
<set field="Registration:Birthday" arithmeticAsText="true">
<string field="Registration:RegAgeMo"/>
<string value="/"/>
<string field="Registration:RegAgeDay"/>
<string value="/"/>
<string field="Registration:RegAgeYr"/>
</set>
<set field="Registration:FriendsList" arithmeticAsText="false">
<string field="Registration:Friend:a"/>
<string value="   "/>
<string field="Registration:Friend:b"/>
<string value="   "/>
<string field="Registration:Friend:c"/>
</set>
<if>
<conditions>
<equals field="WaiverRequired">
<string value="No"/>
</equals>
</conditions>
<trueSet>
<set field="Registration:WaiverReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<set field="PlayerFirst" arithmeticAsText="false">
<string field="Registration:FirstName"/>
</set>
<set field="PlayerLast" arithmeticAsText="false">
<string field="Registration:LastName"/>
</set>
<if>
<conditions>
<equals field="From">
<string value="AdminRegMgmt"/>
</equals>
</conditions>
<trueSet>
<show form="RegFormMgmt"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="RegistrationAudit"/>
</equals>
</conditions>
<trueSet>
<set field="Registration:BadEmail?" arithmeticAsText="false">
<string value=" "/>
</set>
<show form="AuditFormLoop"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="AddPlayerToGroupRegistration"/>
</equals>
</conditions>
<trueSet>
<set field="Registration:GroupRegistrationId" arithmeticAsText="false">
<string field="GroupRegistationId"/>
</set>
<set field="Registration:TeamId" arithmeticAsText="false">
<string field="Team"/>
</set>
<set field="Registration:PaymentReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="Registration:PaidAmount" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="Registration:PaymentMethod" arithmeticAsText="false">
<string value="Group"/>
</set>
<set field="Registration:FirstName" arithmeticAsText="false">
<string field="AddPlayerToGroupRegistration:FirstName"/>
</set>
<set field="Registration:LastName" arithmeticAsText="false">
<string field="AddPlayerToGroupRegistration:LastName"/>
</set>
<set field="Registration:ParentEmail" arithmeticAsText="false">
<string field="AddPlayerToGroupRegistration:Parents&apos; Email"/>
</set>
<send>
<to addressField="AddPlayerToGroupRegistration:Parents&apos; Email"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject><field name="League"/> Registration</subject>
<body document="InvitationToCompleteRegistration" reset="false" showHeader="true"/>
</send>
<show form="AddPlayerToGroupRegistration"/>
</trueSet>
</if>
<show form="RegStep2"/>
</process>
<process name="Post-RegStep2">
<comment>-- Calculate payment information based on fee structure</comment>
<if>
<conditions>
<doesNotEqual field="Registration:PaymentReceived">
<string value="Yes"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="RegistrationFee" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<contains field="FeeStructure">
<string value="Flat Fee"/>
</contains>
</conditions>
<trueSet>
<set field="RegistrationFee" arithmeticAsText="false">
<string field="SignupFeeForIndividual"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="FeeStructure">
<string value="Varies by Division"/>
</equals>
</conditions>
<trueSet>
<get recordList="Selected Division">
<forms>
<form name="Divisions"/>
</forms>
<conditions>
<equals field="Selected Division:Divisions:DivisionID">
<string field="Registration:DivisionId"/>
</equals>
</conditions></get>
<foreach record="Such Division" recordList="Selected Division">
<set field="RegistrationFee" arithmeticAsText="false">
<string field="Such Division:Divisions:DivFees"/>
</set>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<equals field="FeeStructure">
<string value="Varies by Grade"/>
</equals>
</conditions>
<trueSet>
<get recordList="Selected Grade">
<forms>
<form name="Grade"/>
</forms>
<conditions>
<equals field="Selected Grade:Grade:Name">
<string field="Registration:Grade"/>
</equals>
</conditions></get>
<foreach record="Such Grade" recordList="Selected Grade">
<set field="RegistrationFee" arithmeticAsText="false">
<string field="Such Grade:Grade:Fee"/>
</set>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="RegistrationFee" />
</conditions>
<trueSet>
<show document="Error Calculating Payment" reset="false"/>
</trueSet>
</if>
</trueSet>
</if>
<comment>-- Send the welcome letter with the link to the dashboard</comment>
<if>
<conditions>
<isBlank field="Registration:LinkToPlayerDashboardSent" />
</conditions>
<trueSet>
<comment>-- Means that this is not the user editing his/her record from the player dashboard,</comment>
<comment>-- but either the first time registrant or the admin creating the record.</comment>
<if>
<conditions>
<equals field="Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<send>
<to addressField="Registration:ParentEmail"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Registration</subject>
<body document="PostRegistrationLetterWithoutPaymentInstructions" reset="false" showHeader="true"/>
</send>
<if>
<conditions>
<isNotBlank field="Registration:ParentEmail2" />
</conditions>
<trueSet>
<send>
<to addressField="Registration:ParentEmail2"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Registration</subject>
<body document="PostRegistrationLetterWithoutPaymentInstructions" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
</trueSet>
<falseSet>
<send>
<to addressField="Registration:ParentEmail"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Registration</subject>
<body document="PostRegistrationLetterWithPaymentInstructions" reset="false" showHeader="true"/>
</send>
<if>
<conditions>
<isNotBlank field="Registration:ParentEmail2" />
</conditions>
<trueSet>
<send>
<to addressField="Registration:ParentEmail2"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Registration</subject>
<body document="PostRegistrationLetterWithPaymentInstructions" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
</falseSet>
</if>
<get recordList="Registration Records">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Registration Records:Registration:RegID">
<string field="Registration:RegID"/>
</equals>
</conditions></get>
<foreach record="Such Record" recordList="Registration Records">
<set field="Such Record:Registration:LinkToPlayerDashboardSent" arithmeticAsText="false">
<string value="Yes"/>
</set>
</foreach>
<get recordList="Record List 19">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="Selection" recordList="Record List 19">
<if>
<conditions>
<mcContains field="Selection:AdminSetup:EmailNotificationPreference" value="a"/>
</conditions>
<trueSet>
<comment>-- This is needed to prevent a weird bug that causes designer to crash</comment>
<set field="PlayerFullName" arithmeticAsText="false">
<string field="Registration:FirstName"/>
<string value=" "/>
<string field="Registration:LastName"/>
</set>
<send>
<to addressField="AdminEmail"/>
<from addressField="AdminEmail" aliasLiteral="Tawala Automated Email Server"/>
<subject>Registration received for <field name="PlayerFullName"/></subject>
<body document="AdminRegNotification" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<equals field="BouncebackFlag">
<string value="AdminRegisteringPlayer"/>
</equals>
</conditions>
<trueSet>
<comment>-- Admin is registering a player; this passes him right through back to the admin menu</comment>
<show form="AdminBounceback"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<equals field="Registration:PaymentReceived">
<string value="Yes"/>
</equals>
<isNotBlank field="_InviteeID" />
</and>
</conditions>
<trueSet>
<comment>-- This is the user editing his record. If the payment is received - just send him back to the dashboard</comment>
<show form="PlayerDash"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="Registration:WaiverReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="NavigationToPlayerDashboardAfterRegistration" reset="false"/>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="EnableOnlinePayments">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="OnlyPaymentIsNeeded" reset="false"/>
</trueSet>
<falseSet>
<show document="OnlyPaymentByCheckIsNeeded" reset="false"/>
<show document="PaymentByCheckInstructions" reset="false"/>
<show document="NavigationToPlayerDashboardAfterRegistration" reset="false"/>
</falseSet>
</if>
</falseSet>
</if>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="OnlyWaiverIsNeeded" reset="false"/>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="EnableOnlinePayments">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="PaymentAndWaiverStillNeeded" reset="false"/>
</trueSet>
<falseSet>
<show document="WaiverNeededAndPaymentByCheckOnly" reset="false"/>
<show document="PaymentByCheckInstructions" reset="false"/>
<show document="NavigationToPlayerDashboardAfterRegistration" reset="false"/>
</falseSet>
</if>
</falseSet>
</if>
</falseSet>
</if>
