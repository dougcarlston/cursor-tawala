<form name="Coach"/>
</forms>
<conditions>
<equals field="Record List 79:Coach:CoachId">
<string field="CoachToTeamAssignment:Q4"/>
</equals>
</conditions></get>
<foreach record="SuchRecord" recordList="Record List 79">
<get recordList="Record List 80">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="Record List 80:Team:TeamId">
<string field="CoachToTeamAssignment:TeamId"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="Record List 80">
<set field="SuchTeam:Team:CoachId" arithmeticAsText="false">
<string field="SuchRecord:Coach:CoachId"/>
</set>
<set field="SuchTeam:Team:CoachFullName" arithmeticAsText="false">
<string field="SuchRecord:Coach:FullName"/>
</set>
<set field="SuchRecord:Coach:Team" arithmeticAsText="false">
<string field="SuchRecord:Coach:Team"/>
<string value=", "/>
