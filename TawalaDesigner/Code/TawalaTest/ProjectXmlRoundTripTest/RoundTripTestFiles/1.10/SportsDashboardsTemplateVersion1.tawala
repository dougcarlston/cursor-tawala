<form name="ParentCoaches" startPoint="false" themePath="mvsc" process="Post-ParentCoaches" preProcess="Pre-ParentCoaches">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">If you see a list below, it contains parents who have volunteered to coach. Select one to add him/her as a coach.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To add a coach whose name is </font><font face="Arial" size="200" color="000000"><b><i>not</i></b></font><font face="Arial" size="200" color="000000"> on the list, just click Submit without making a selection.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:ParentLastName"/>
<string value=", "/>
<field name="Record:Registration:ParentFirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:ParentLastName"/>
<string value="#"/>
<field name="Record:Registration:ParentFirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<equals field="Record:Registration:CoachVolunteer">
<string value="Available"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="UtilityToSetPlayerAges" startPoint="false" themePath="mvsc" process="Post-UtilityToSetPlayerAges">
<items>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility passes through all the Registration records and calculates the </font><font><i>Player Ages</i></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: You only need to run this if the method of calculation </b></font><font><b><i>Player Age</i></b></font><font><b> has been changed in the Post-Registration  Process.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility fixes up the </font><font><i>Player Age</i></font><font> field in all registrations posted prior to the change.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Click </font><font><b><i>Submit</i></b></font><font> to run the utility.</font></paragraph></text>
</items>
</form>
<form name="DuplicateRegistrationCheck" startPoint="false" themePath="mvsc" process="Post-DuplicateRegistrationCheck">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: Because of various issues with duplicate records, this utility is not currently available via the Administrator's Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It will check for duplicate First and Last Names of players in the registration database. It does not check for duplicate Registration IDs.</font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="ShowAllRosters" startPoint="false" themePath="mvsc" process="Post-ShowAllRosters" preProcess="Pre-ShowAllRosters">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Team"/></font><font> Team Roster:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>7</number-of-columns><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Age"/>
</header><contents><field name="Record:Registration:PlayerAge" /></contents></column><column><header><string value="Uniform"/>
</header><contents><field name="Record:Registration:UniformSize" /></contents></column><column><header><field name="Phone1Lab"/>
</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header><field name="Phone2Lab"/>
</header><contents><field name="Record:Registration:Phone2" /></contents></column><column><header><field name="Phone3Lab"/>
</header><contents><field name="Record:Registration:Phone3" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:TeamId">
<string field="Team"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Uniforms needed for team:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><response-totals-table version="1"><layout-type>horizontal</layout-type><field>Record:Registration:UniformSize</field><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:TeamId">
<string field="Team"/>
</equals>
</conditions></conditions></response-totals-table></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
</items>
</form>
<form name="Divisions" startPoint="false" themePath="mvsc" process="Post-Divisions">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add/Edit Division</font></paragraph></heading>
<fib label="Q1" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Division Name: </font><blank label="a" length="20" required="true" alternateLabel="Name"/></paragraph></fib>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font><i><field name="Message"/></i></font></paragraph></text>
<field name="DivisionID"/>
<field name="DivFees"/>
</items>
</form>
<form name="PlayerCommunicator" startPoint="false" themePath="mvsc" process="Post-PlayerCommunicator" preProcess="Pre-PlayerCommunicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="PlayerDash" project="">Back to Player Dashboard</invitation></u></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To whom do you wish to send this message?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All of my teammates</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Some of my teammates</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">My coach</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The Athletic Director</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="PCSubject"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<and>
<doesNotEqual field="FlagC">
<string value="On"/>
</doesNotEqual>
<mcDoesNotEqual field="PlayerCommunicator:Q1" value="d"/>
</and>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="PlayerCommunicator:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q5" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the player(s) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<equals field="Record:Registration:TeamId">
<string field="PlayerTeamId"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<field name="PlayerIdentification"/>
</items>
</form>
<form name="PlayerCommunicatorSend" startPoint="false" themePath="mvsc" process="Post-PlayerCommunicatorSend">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="630"><row><cell width="10170"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><b>From: </b></font><font><field name="PlayerFirst"/></font><sp/><font><field name="PlayerLast"/></font><font> (</font><font><field name="PlayerEmail"/></font><font>)</font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="CoachCommunicator:Subject"/></font><sp/></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="630"><row><cell width="10170"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><field name="PlayerCommunicator:Body"/></font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><field name="PlayerCommunicator:Close"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send the email out</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Player's Dashboard</font></paragraph></choice></mc>
</items>
</form>
