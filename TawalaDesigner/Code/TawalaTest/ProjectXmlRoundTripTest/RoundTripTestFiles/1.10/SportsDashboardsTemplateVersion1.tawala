<form name="UnassignCoachFromTeam" startPoint="false" themePath="mvsc" process="Post-UnassignCoachFromTeam">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="TeamId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the team to un-assign the coach from:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
<string value=" (Coach: "/>
<field name="Record:Team:CoachFullName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
