<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="CoachCommunicator" startPoint="false" themePath="mvsc" process="Post-CoachCommunicator" preProcess="Pre-CoachCommunicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: If you wish to send a Player his personal Player Dashboard, choose the option "Some of my players" below.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To whom do you wish to send this message?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All of my players</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Some of my players</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more of the other coaches</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The Athletic Director</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message:  </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing:  </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="Link"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="Q8"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Q1" value="d"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q5" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the player(s) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
<string value=" ("/>
<field name="Record:Registration:TeamId"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
<string value=":"/>
<field name="Record:Registration:FirstName"/>
<string value=":"/>
<field name="Record:Registration:LastName"/>
</sort-expression><record-selector><form name="Registration" /><form name="Team" /><conditions>
<and>
<equals field="_InviteeID">
<string field="Record:Team:CoachId"/>
</equals>
<equals field="Record:Registration:TeamId">
<string field="Record:Team:TeamId"/>
</equals>
</and>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q6" alternateLabel="Link" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Do you want to include a link to the Player's Dashboard with your message?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No</font></paragraph></choice></mc>
<mc label="Q7" alternateLabel="Salutation" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of Salutation</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Dear Parents of Player's first name </font><font face="Arial" size="200" color="000000"><i>("Dear Parents of Jimmy")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't create a personalized salutation</font></paragraph></choice></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q8" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the coach(es) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:FullName"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
</sort-expression><record-selector><form name="Coach" /></record-selector></dynamic-mcq></data-provider></mc>
<field name="CoachName"/>
</items>
</form>
<form name="CoachCommunicatorSend" startPoint="false" themePath="mvsc" process="Post-CoachCommunicatorSend">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="705"><row><cell width="10095"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>From: </b></font><font><field name="Coach"/></font><font> (</font><font><field name="CoachsEmail"/></font><font>)</font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="10095"></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="CoachCommunicator:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="705"><row><cell width="10095"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><field name="CoachCommunicator:Body"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><field name="CoachCommunicator:Close"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send the email out</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Coach's Dashboard</font></paragraph></choice></mc>
</items>
</form>
<form name="AddPlayerToGroupRegistration" startPoint="false" themePath="mvsc" process="Post-AddGroupRegistrationPlayer">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add player to group registration</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>List of players added to the group registration for </font><font><field name="Team"/></font><font>:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><number-of-columns>3</number-of-columns><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:GroupRegistrationId">
<string field="GroupRegistationId"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">First Name: </font><blank label="a" length="20" required="true" alternateLabel="FirstName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Last Name: </font><blank label="b" length="20" required="true" alternateLabel="LastName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Parents' Email: </font><blank label="c" length="20" required="true" alternateLabel="Parents&apos; Email"/></paragraph></fib>
</items>
</form>
<form name="EditTeam" startPoint="false" themePath="mvsc" process="Post-TeamEdit">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
