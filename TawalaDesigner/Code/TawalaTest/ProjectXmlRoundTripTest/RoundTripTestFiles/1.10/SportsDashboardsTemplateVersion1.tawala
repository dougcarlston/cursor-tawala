</forms>
<conditions>
<isBlank field="Record List 89:Team:Printed?" />
</conditions></get>
<foreach record="Name" recordList="Record List 89">
<set field="Team" arithmeticAsText="false">
<string field="Name:Team:TeamId"/>
</set>
<set field="Done" arithmeticAsText="false">
<string value="No"/>
</set>
</foreach>
<if>
<conditions>
<equals field="Done">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<get recordList="Record List 91">
<forms>
<form name="Team"/>
</forms>
</get>
<foreach record="Entity" recordList="Record List 91">
