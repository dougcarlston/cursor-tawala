<form name="SendDashReminder" startPoint="false" themePath="mvsc" process="Post-SendDashReminder" preProcess="RetrieveAdminSetupVariables">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Send or View private Dashboard link</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility is designed to permit the Administrator to send Dashboard links out to Players and Coaches who has misplaced theirs.  If a Coach has not previously been sent his Dashboard, it is better to send it out from </font><font color="000080"><u><invitation form="Preseason" project="">Send Dashboards to Coaches</invitation></u></font><font> in the Preseason Menu.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose an action to take:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Send</b></font><font face="Arial" size="200" color="000000"> private Dashboard reminder to </font><font face="Arial" size="200" color="000000"><b>Coach(es)</b></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Send</b></font><font face="Arial" size="200" color="000000"> private Dashboard reminder to </font><font face="Arial" size="200" color="000000"><b>Player(s)</b></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>View </b></font><font face="Arial" size="200" color="000000">a </font><font face="Arial" size="200" color="000000"><b>Coach</b></font><font face="Arial" size="200" color="000000">'s private Dashboard</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>View </b></font><font face="Arial" size="200" color="000000">a </font><font face="Arial" size="200" color="000000"><b>Player</b></font><font face="Arial" size="200" color="000000">'s private Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="T4"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="d"/>
</conditions>
<trueSet>
<skip to="T7"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="SendDashReminder:Q1" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q2" alternateLabel="PlayerIdsForSend" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player(s) to send the dashboard link to:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ["/>
<field name="Record:Registration:ParentEmail"/>
<string value="]"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>A coach must have been assigned a team to appear on list.</i></font></paragraph></text>
<mc label="Q3" alternateLabel="CoachIdsForSend" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach(es) to send dashboard link to:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
<string value=" "/>
<field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
<string value="#"/>
<field name="Record:Coach:FirstName"/>
</sort-expression><record-selector><form name="Coach" /><form name="Team" /><conditions>
<equals field="Record:Coach:CoachId">
<string field="Record:Team:CoachId"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q4" alternateLabel="CoachIdForView" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach whose Dashboard you wish to view:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
<string value=" ["/>
<field name="Record:Team:TeamId"/>
<string value="]"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
<string value="#"/>
<field name="Record:Coach:FirstName"/>
</sort-expression><record-selector><form name="Coach" /><form name="Team" /><conditions>
<equals field="Record:Coach:CoachId">
<string field="Record:Team:CoachId"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<break/>
<text label="T6"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Click the link below to view the selected coach's Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: You will need to use the browser's Back button to return to this page.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="CoachDashboard" project="" private="true"><authenticationTokenValue><string field="SendDashReminder:CoachIdForView"/>
</authenticationTokenValue>Click this link to view the Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The Submit button will return you to the Dashbard links menu.</font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T7"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q5" alternateLabel="PlayerIdForView" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player whose Dashboard you with to view:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ["/>
<field name="Record:Registration:ParentEmail"/>
<string value="]"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /></record-selector></dynamic-mcq></data-provider></mc>
<break/>
<text label="T8"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Click the link below to view the selected player's Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: You will need to use the browser's Back button to return to this page.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="SendDashReminder:PlayerIdForView"/>
</authenticationTokenValue>Click this link to view the Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The Submit button will return you to the Dashbard links menu.</font></paragraph></text>
</items>
