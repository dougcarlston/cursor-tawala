<equals field="Primary:Registration:ParentEmail2">
<string field="Secondary:Registration:ParentEmail2"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="SearchState" arithmeticAsText="false">
<string value="Duplicate found"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<and>
<equals field="Primary:Registration:LastName">
<string field="Secondary:Registration:LastName"/>
</equals>
<equals field="Primary:Registration:RegAgeYr">
<string field="Secondary:Registration:RegAgeYr"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="SearchState" arithmeticAsText="false">
<string value="Duplicate found"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="SearchState">
<string value="Duplicate found"/>
</equals>
</conditions>
<trueSet>
<comment>-- Copy values of the matched record to variables</comment>
<set field="SRegName" arithmeticAsText="false">
<string field="Secondary:Registration:FirstName"/>
<string value=" "/>
<string field="Secondary:Registration:LastName"/>
</set>
<set field="SRegBD" arithmeticAsText="true">
<string field="Secondary:Registration:RegAgeMo"/>
<string value="/"/>
<string field="Secondary:Registration:RegAgeDay"/>
<string value="/"/>
<string field="Secondary:Registration:RegAgeYr"/>
</set>
<set field="SRegSex" arithmeticAsText="true">
<string field="Secondary:Registration:Sex"/>
</set>
<set field="SRegPName" arithmeticAsText="true">
<string field="Secondary:Registration:ParentFirstName"/>
<string value=" "/>
<string field="Secondary:Registration:ParentLastName"/>
</set>
<set field="SRegAddress" arithmeticAsText="true">
<string field="Secondary:Registration:Address"/>
</set>
<set field="SRegAddress1" arithmeticAsText="true">
<string field="Secondary:Registration:City"/>
<string value=", "/>
<string field="Secondary:Registration:State"/>
<string value=" "/>
<string field="Secondary:Registration:Zip"/>
</set>
<set field="SRegEmail" arithmeticAsText="true">
<string field="Secondary:Registration:ParentEmail"/>
</set>
<set field="SRegEmail1" arithmeticAsText="true">
<string field="Secondary:Registration:ParentEmail2"/>
</set>
<set field="SRegPhone1" arithmeticAsText="true">
<string field="Secondary:Registration:Phone1"/>
</set>
<set field="SRegPhone2" arithmeticAsText="true">
<string field="Secondary:Registration:Phone2"/>
</set>
<set field="SRegPhone3" arithmeticAsText="true">
<string field="Secondary:Registration:Phone3"/>
</set>
<set field="SRegSchool" arithmeticAsText="true">
<string field="Secondary:Registration:School"/>
</set>
<set field="SRegGrade" arithmeticAsText="true">
<string field="Secondary:Registration:Grade"/>
</set>
<set field="SRegParish" arithmeticAsText="true">
<string value="("/>
<string field="Secondary:Registration:Parish"/>
<string value=")"/>
</set>
<set field="SRegFriends" arithmeticAsText="true">
<string field="Secondary:Registration:FriendsList"/>
</set>
<set field="SRegUniform" arithmeticAsText="true">
<string field="Secondary:Registration:UniformSize"/>
</set>
<set field="SRegMedPlan" arithmeticAsText="true">
<string field="Secondary:Registration:MedPlanName"/>
<string value=" "/>
<string field="Secondary:Registration:MedPlanNumber"/>
</set>
<set field="SRegDoctor" arithmeticAsText="true">
<string field="Secondary:Registration:DocName"/>
</set>
<set field="SRegDocPhone" arithmeticAsText="true">
<string field="Secondary:Registration:DocPhone"/>
</set>
<set field="SRegDocAddress" arithmeticAsText="true">
<string field="Secondary:Registration:DocAddress"/>
</set>
<set field="SRegTeam" arithmeticAsText="true">
<string field="Secondary:Registration:TeamId"/>
</set>
<set field="SRegPayment" arithmeticAsText="true">
<string field="Secondary:Registration:PaymentReceived"/>
</set>
<set field="SRegWaiver" arithmeticAsText="true">
<string field="Secondary:Registration:WaiverReceived"/>
</set>
<set field="SRegID" arithmeticAsText="true">
<string field="Secondary:Registration:RegID"/>
</set>
<set field="SRegGroupdID" arithmeticAsText="true">
<string field="Secondary:Registration:GroupRegistrationId"/>
</set>
<set field="SRegPaidAmt" arithmeticAsText="true">
<string field="Secondary:Registration:PaidAmount"/>
</set>
<set field="SRegPaymentMethod" arithmeticAsText="true">
<string field="Secondary:Registration:PaymentMethod"/>
</set>
<set field="SRegWaiverException" arithmeticAsText="true">
<string field="Secondary:Registration:WaiverException"/>
</set>
</trueSet>
</if>
</trueSet>
</if>
</foreach>
<if>
<conditions>
<equals field="SearchState">
<string value="Looking for duplicate"/>
</equals>
</conditions>
<trueSet>
<comment>-- No (more) duplicates were found for this primary record</comment>
<foreach record="Record" recordList="Record List 149">
<if>
<conditions>
<equals field="Record:Registration:BadEmail?">
<string value="Checked"/>
</equals>
</conditions>
<trueSet>
<set field="Record:Registration:BadEmail?" arithmeticAsText="false">
<string value=" "/>
</set>
</trueSet>
</if>
</foreach>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<equals field="SearchState">
<string value="Looking for duplicate"/>
</equals>
</conditions>
<trueSet>
<set field="Primary:Registration:BadEmail?" arithmeticAsText="false">
<string value="PrimaryChecked"/>
</set>
<set field="SearchState" arithmeticAsText="false">
<string value="Looking for primary"/>
</set>
</trueSet>
</if>
</foreach>
<if>
<conditions>
<doesNotEqual field="SearchState">
<string value="Duplicate found"/>
</doesNotEqual>
</conditions>
<trueSet>
<get recordList="Record List 152">
<forms>
<form name="Registration"/>
</forms>
</get>
<foreach record="Record" recordList="Record List 152">
<set field="Record:Registration:BadEmail?" arithmeticAsText="false">
<string value=" "/>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="All records in Registration file checked."/>
</set>
<show document="Message" reset="false"/>
<show form="AdminDash"/>
</trueSet>
</if>
</process>
<process name="Post-CloseRegistration">
<get recordList="Record List 156">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="RegCheck" recordList="Record List 156">
<if>
<conditions>
<equals field="RegCheck:AdminSetup:RegistrationStatusFlag">
<string value="Closed"/>
</equals>
</conditions>
<trueSet>
<set field="RegCheck:AdminSetup:RegistrationStatusFlag" arithmeticAsText="false">
<string value="Open"/>
</set>
</trueSet>
<falseSet>
<set field="RegCheck:AdminSetup:RegistrationStatusFlag" arithmeticAsText="false">
<string value="Closed"/>
</set>
</falseSet>
</if>
<set field="RegViewFlag" arithmeticAsText="false">
<string field="RegCheck:AdminSetup:RegistrationStatusFlag"/>
</set>
</foreach>
<append document="ReStatusChangeNotice" appendage="PaymentReport"/>
<send>
<to addressLiteral="billing@tawala.com"/>
<from addressLiteral="Billing@tawala.com" aliasLiteral="Automated Billing Monitor"/>
<subject>Registration status for <field name="League"/> changed to <field name="RegViewFlag"/></subject>
<body document="ReStatusChangeNotice" reset="true" showHeader="true"/>
</send>
<show form="AdminDash"/>
</process>
<process name="Post-RegClosed">
<show document="RegClosedDoc" reset="false"/>
</process>
</processes>
<documents>
<document name="AdminDashboard">
<xmlData>
