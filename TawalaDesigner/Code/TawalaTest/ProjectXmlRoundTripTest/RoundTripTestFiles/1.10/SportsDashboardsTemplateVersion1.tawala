<process name="Post-SendDashReminder">
<if>
<conditions>
<mcIsBlank field="SendDashReminder:Q1" />
</conditions>
<trueSet>
<show form="AdminDash"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="a"/>
</conditions>
<trueSet>
<if>
<conditions>
<mcIsBlank field="SendDashReminder:CoachIdsForSend" />
</conditions>
<trueSet>
<show form="AdminDash"/>
</trueSet>
</if>
<comment>Send Coach reminder</comment>
<get recordList="TeamAndCoachRecords">
<forms>
<form name="Team"/>
<form name="Coach"/>
</forms>
<conditions>
<and>
<mcContains field="SendDashReminder:CoachIdsForSend">
<string field="TeamAndCoachRecords:Coach:CoachId"/>
</mcContains>
<equals field="TeamAndCoachRecords:Team:CoachId">
<string field="TeamAndCoachRecords:Coach:CoachId"/>
</equals>
</and>
</conditions></get>
<foreach record="SuchRecord" recordList="TeamAndCoachRecords">
<set field="Team" arithmeticAsText="false">
<string field="SuchRecord:Team:TeamId"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string field="SuchRecord:Coach:FirstName"/>
</set>
<set field="CoachID" arithmeticAsText="false">
<string field="SuchRecord:Coach:CoachId"/>
</set>
<send>
<to addressField="SuchRecord:Coach:Email"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> <field name="Team"/> Coach Dashboard link</subject>
<body document="CoachDashReminder" reset="false" showHeader="true"/>
</send>
<set field="Message" arithmeticAsText="false">
<string value="Dashboard reminder sent to "/>
<string field="SuchRecord:Coach:FullName"/>
</set>
<show document="Message" reset="false"/>
<show form="AdminDash"/>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="b"/>
</conditions>
<trueSet>
<if>
<conditions>
<mcIsBlank field="SendDashReminder:PlayerIdsForSend" />
</conditions>
<trueSet>
<show form="AdminDash"/>
</trueSet>
</if>
<get recordList="RegistrantList">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="SendDashReminder:PlayerIdsForSend">
<string field="RegistrantList:Registration:RegID"/>
</mcContains>
</conditions></get>
<foreach record="Registrant" recordList="RegistrantList">
<set field="PlayerFirst" arithmeticAsText="false">
<string field="Registrant:Registration:FirstName"/>
</set>
<set field="PlayerLast" arithmeticAsText="false">
<string field="Registrant:Registration:LastName"/>
</set>
<set field="PlayerID" arithmeticAsText="false">
<string field="Registrant:Registration:RegID"/>
</set>
<send>
<to addressField="Registrant:Registration:ParentEmail"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Player Dashboard link</subject>
<body document="PlayerDashboardReminder" reset="false" showHeader="true"/>
</send>
<set field="ToAddress" arithmeticAsText="false">
<string field="Registrant:Registration:ParentEmail"/>
</set>
<if>
<conditions>
<isNotBlank field="Registrant:Registration:ParentEmail2" />
</conditions>
<trueSet>
<send>
<to addressField="Registrant:Registration:ParentEmail2"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Player Dashboard link</subject>
<body document="PlayerDashboardReminder" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value="Dashboard reminder sent to "/>
<string field="PlayerFirst"/>
<string value=" "/>
<string field="PlayerLast"/>
<string value="."/>
</set>
<show document="Message" reset="false"/>
</foreach>
<show form="AdminDash"/>
</trueSet>
</if>
<show form="AdminDash"/>
</process>
