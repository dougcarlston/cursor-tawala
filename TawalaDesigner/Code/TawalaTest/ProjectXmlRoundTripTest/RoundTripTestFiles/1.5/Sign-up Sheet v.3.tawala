<form name="Administration" startPoint="true" themePath="default" process="Show Signatures" preProcess="Pre-Administration">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
</forms>
<processes>
<process name="Show Signatures">
<comment>- get the customization settings</comment>
<get recordList="Setup List">
<forms>
<form name="Customize"/>
</forms>
</get>
<foreach record="Setting" recordList="Setup List">
<set field="ContactType1" arithmeticAsText="false">
<string value="empty"/>
</set>
<set field="ContactType2" arithmeticAsText="false">
<string value="empty"/>
</set>
<set field="ContactType3" arithmeticAsText="false">
<string value="empty"/>
</set>
<set field="SignUpTitle" arithmeticAsText="false">
<string field="Setting:Customize:Title"/>
</set>
<set field="SignUpDescription" arithmeticAsText="false">
<string field="Setting:Customize:Description"/>
</set>
<set field="SignUpFinalRemarks" arithmeticAsText="false">
<string field="Setting:Customize:FinalRemarks"/>
</set>
<comment>- set the appropriate labels for the Contact Info</comment>
<comment>- (note that these settings also control the Skip logic in the Questionnaire Form)</comment>
<if>
<conditions>
<mcContains field="Setting:Customize:ContactInfo" value="a"/>
</conditions>
<trueSet>
<set field="ContactType1" arithmeticAsText="false">
<string value="phone number"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcContains field="Setting:Customize:ContactInfo" value="b"/>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="ContactType1">
<string value="empty"/>
</equals>
</conditions>
<trueSet>
<set field="ContactType1" arithmeticAsText="false">
<string value="email address"/>
</set>
</trueSet>
<falseSet>
<set field="ContactType2" arithmeticAsText="false">
<string value="email address"/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcContains field="Setting:Customize:ContactInfo" value="c"/>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="ContactType1">
<string value="empty"/>
</equals>
</conditions>
<trueSet>
<set field="ContactType1" arithmeticAsText="false">
<string value="mailing address"/>
</set>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="ContactType2">
<string value="empty"/>
</equals>
</conditions>
<trueSet>
<set field="ContactType2" arithmeticAsText="false">
<string value="mailing address"/>
</set>
</trueSet>
<falseSet>
<set field="ContactType3" arithmeticAsText="false">
<string value="mailing address"/>
</set>
</falseSet>
</if>
</falseSet>
</if>
</trueSet>
</if>
<comment>- this flag controls whether Contact Info is displayed to the public in the Sign-up Sheet</comment>
<set field="displayContactInfo" arithmeticAsText="false">
<string value="true"/>
</set>
<if>
<conditions>
<mcEquals field="Setting:Customize:DisplayInfo" value="a"/>
</conditions>
<trueSet>
<set field="displayContactInfo" arithmeticAsText="false">
<string value="false"/>
</set>
</trueSet>
</if>
</foreach>
<comment>- "build" the display document</comment>
<show document="SignUp Header" reset="false"/>
<comment>- note that adminMode overrides the customization display setting</comment>
<comment>- (the Contact Info is always displayed in the Adminstration Report)</comment>
<if>
<conditions>
<and>
<equals field="displayContactInfo">
<string value="false"/>
</equals>
<doesNotEqual field="adminMode">
<string value="true"/>
</doesNotEqual>
</and>
</conditions>
<trueSet>
<show document="Names Only" reset="false"/>
</trueSet>
<falseSet>
<if>
<conditions>
<doesNotEqual field="ContactType3">
<string value="empty"/>
</doesNotEqual>
</conditions>
<trueSet>
<show document="NamesAndInfo3" reset="false"/>
</trueSet>
<falseSet>
<if>
<conditions>
<doesNotEqual field="ContactType2">
<string value="empty"/>
</doesNotEqual>
</conditions>
<trueSet>
<show document="NamesAndInfo2" reset="false"/>
</trueSet>
<falseSet>
<if>
<conditions>
<doesNotEqual field="ContactType1">
<string value="empty"/>
</doesNotEqual>
</conditions>
<trueSet>
<show document="NamesAndInfo1" reset="false"/>
</trueSet>
<falseSet>
<show document="Names Only" reset="false"/>
</falseSet>
</if>
</falseSet>
</if>
</falseSet>
</if>
</falseSet>
</if>
</process>
<process name="Post-SignUp">
<comment>- show the "all done" page to the signer</comment>
<show document="SignUp Finish" reset="false"/>
<if>
<conditions>
<isNotBlank field="SignUpFinalRemarks"/>
</conditions>
<trueSet>
<show document="SignUp Remarks" reset="false"/>
</trueSet>
</if>
<show document="SignUp ViewFinalList" reset="false"/>
</process>
<process name="Post-Customize">
<comment>- show the mocked-up Questionnare to the customizer</comment>
<show document="Confirm Setup" reset="false"/>
<if>
<conditions>
<or>
<mcContains field="Customize:ContactInfo" value="a"/>
<or>
<mcContains field="Customize:ContactInfo" value="b"/>
<mcContains field="Customize:ContactInfo" value="c"/>
</or>
</or>
</conditions>
<trueSet>
<show document="Confirm ContactInfo" reset="false"/>
</trueSet>
</if>
<show document="Confirm Footer" reset="false"/>
</process>
<process name="Pre-Administration">
<comment>- in the Show Signatures Process this flag overrides</comment>
<comment>- the "DisplayInfo" flag from the Customize settings</comment>
<set field="adminMode" arithmeticAsText="false">
<string value="true"/>
</set>
<comment>- a trick to detect when the user got here via the Invitation link</comment>
<comment>- in the SignUp ViewFinalList document; in this case the Administration</comment>
<comment>- Form is being invoked at the end of the Questionnare</comment>
<if>
<conditions>
<equals field="_InviteeID">
<string value="fromSignupSheet"/>
</equals>
</conditions>
<trueSet>
<set field="adminMode" arithmeticAsText="false">
<string value="false"/>
</set>
</trueSet>
</if>
</process>
</processes>
