<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="4320"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/><tabStop position="12960"/><tabStop position="13680"/><tabStop position="14400"/></tabPositions><tab/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font><b><field name="Customize_projectName"/></b></font><font><b> Tasks</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="5760"/><tabStop position="8640"/></tabPositions><font><b>Description</b></font><tab/><font><b>Due </b></font><tab/><font><b>Assigned To</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="4320"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/><tabStop position="12960"/><tabStop position="13680"/><tabStop position="14400"/></tabPositions><font><b>________________________________________________</b></font></paragraph>
</xmlData>
</document>
<document name="Task Completed">
<xmlData>
