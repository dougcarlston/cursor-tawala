<field name="UniformSize"/>
<field name="Birthday"/>
<field name="PlayerAge"/>
<field name="FriendsList"/>
<field name="BadEmail?"/>
<field name="GroupRegistrationId"/>
<field name="LinkToPlayerDashboardSent"/>
<field name="CoachVolunteer"/>
</items>
</form>
<form name="RegStep2" startPoint="false" themePath="dirtbowl2" process="Post-RegStep2">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="BouncebackFlag">
<string value="AdminRegisteringPlayer"/>
</equals>
</conditions>
<trueSet>
<comment>-- Admin is registering a player; this ultimately passes him right through back to the admin menu</comment>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="Registration:WaiverReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<skip to="EverythingIsReceived"/>
</trueSet>
<falseSet>
<skip to="OnlyWaiverIsNeeded"/>
</falseSet>
</if>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="Registration:WaiverReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<skip to="OnlyPaymentIsNeeded"/>
</trueSet>
</if>
</falseSet>
</if>
</skipInstructions>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Step 1 of your registration has been completed.</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to complete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 2:</b></font><font>  Print out, complete, sign and mail a medical waiver; and</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 3:</b></font><font>  Submit your payment of $</font><font><field name="SignupFeeForIndividual"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the </font><font><b>Submit</b></font><font> button below to proceed to </font><font><b>Step 2</b></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="240" color="000000"><b>*NOTE: No child will be allowed to participate without a signed waiver and payment.</b></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T3" alternateLabel="OnlyWaiverIsNeeded" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to complete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>A signed medical waiver</b></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the </font><font><b>Submit</b></font><font> button below to display the waiver, which you need to print out, complete and sign, and mail to the address shown on the waiver.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph></text>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="240" color="000000"><b>*NOTE: No child will be allowed to participate without a signed waiver.</b></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5" alternateLabel="OnlyPaymentIsNeeded" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to submit:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Your payment of $</b></font><font><b><field name="SignupFeeForIndividual"/></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the </font><font><b>Submit</b></font><font> button below to proceed to the payment options.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T6" alternateLabel="EverythingIsReceived"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>We have received both your payment and waiver. Thank you!</font></paragraph></text>
</items>
</form>
<form name="AdminSetup" startPoint="false" themePath="dirtbowl2" process="Post-AdminSetup" preProcess="Pre-AdminSetup">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Dirt Bowl Admin Setup</font></paragraph></heading>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Athletic Director Name:  </font><blank label="a" length="35" required="false" alternateLabel="AdminsName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email Address:  </font><blank label="b" length="35" required="false" alternateLabel="AdminsEmail"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone Number: </font><blank label="c" length="35" required="false" alternateLabel="AdminPhone"/></paragraph></fib>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Dirt Bowl Mailing Address:</b></font></paragraph></text>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Street: </font><blank label="a" length="52" required="false" alternateLabel="AdminAddress"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City:     </font><blank label="b" length="52" required="false" alternateLabel="AdminCity"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">State:   </font><blank label="c" length="52" required="false" alternateLabel="AdminST"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Zip: </font><blank label="d" length="52" required="false" alternateLabel="AdminZIP"/></paragraph></fib>
<text label="T2"><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000"><i>(this is where waivers and checks will be sent)</i></font></paragraph></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>League Information:</b></font></paragraph></text>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">League Name </font><font face="Arial" size="200" color="000000"><i>(e.g. Mill Valley Dirt Bowl)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="20" required="false" alternateLabel="LeagueName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Season </font><font face="Arial" size="200" color="000000"><i>(e.g 2008)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="b" length="20" required="false" alternateLabel="Season"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">URL of the league schedule: </font><blank label="c" length="19" required="false" alternateLabel="ScheduleURL"/></paragraph></fib>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Fee Information:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Signup fee for individual players:</font></paragraph></text>
<fib label="Q4" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">$ </font><blank label="a" length="12" required="false" alternateLabel="IndividualSignupFee"/></paragraph></fib>
<mc label="Q5" alternateLabel="EnablePaypalPayments" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enable PayPal online payments</font></paragraph></choice></mc>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Description of charges (will appear on PayPal check out screen):</font></paragraph></text>
<fib label="Q6" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="20" required="false" alternateLabel="ChargeDescription"/></paragraph></fib>
<mc label="Q7" alternateLabel="EmailNotificationPreference" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Options:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send me an email notification of each new registration</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send me a single copy of each bulk mailing</font></paragraph></choice></mc>
<field name="PlayerIDGenerator"/>
<field name="RecruitmentIdGenerator"/>
<field name="RosterChecked"/>
<field name="TeamCountChecked"/>
<field name="AllPlayersAssignedChecked"/>
<field name="PlayersNotified"/>
<field name="CoachesNotified"/>
<field name="PreSeasonCheckupComplete"/>
<field name="UniformOrdered"/>
</items>
</form>
<form name="Preseason" startPoint="false" themePath="dirtbowl2" process="Post-Preseason">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Preseason Setup</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Recruitment List Management</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Player Registration Management</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Teams &amp; Coaches List Management</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Assign Players to Teams</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Jerseys</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Season Launch Countdown Checkoff</font></paragraph></choice></mc>
</items>
</form>
