></font></division></cell><cell width="200"></cell></row><row><cell width="210"></cell><cell width="1140"></cell><cell width="1170"></cell><cell width="1380"></cell><cell width="2115"></cell><cell width="1650"></cell><cell width="1725"></cell><cell width="526"></cell><cell width="200"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2340"><division indent="0" align="left"><font><b>Basic Info:</b></font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font face="Arial" size="200" color="0000A0"><u><invitation form="AdminSetup" project="">edit</invitation></u></font></division></cell><cell width="4695"><division indent="0" align="center"><font><b>Pre-Season Items Status:     </b></font></division></cell><cell width="765"></cell></row><row><cell width="2340"><division indent="0" align="right"><font>League:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="League"/></font></division></cell><cell width="4695"><division indent="0" align="right"><font>Jerseys ordered:</font></division></cell><cell width="765"><division indent="0" align="right"><font face="Arial" size="200"><field name="UniFlag"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Season:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="SeasonYr"/></font></division></cell><cell width="4695"><division indent="0" align="right"><font>Team &amp; Coach info complete:</font></division></cell><cell width="765"><division indent="0" align="right"><font face="Arial" size="200"><field name="TeamFlag"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminName"/></font></division></cell><cell width="4695"><division indent="0" align="right"><font>All Launch Countdown items completed:</font></division></cell><cell width="765"><division indent="0" align="right"><font face="Arial" size="200"><field name="PreSeasonCheckupComplete"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Email:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminEmail"/></font></division></cell><cell width="4695"></cell><cell width="765"></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Phone:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminsPhone"/></font></division></cell><cell width="4695"></cell><cell width="765"></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Address:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminAdrss"/></font></division></cell><cell width="4695"></cell><cell width="765"></cell></row><row><cell width="2340"></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><font><field name="AdminsZIP"/></font></division></cell><cell width="4695"></cell><cell width="765"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3735"><division indent="0" align="left"><font><b>Options:</b></font></division></cell><cell width="255"></cell><cell width="510"><division indent="0" align="center"><font face="Arial" size="180" color="0000A0"><u><invitation form="AdminSetup" project="">edit</invitation></u></font></division></cell><cell width="510"></cell><cell width="4635"><division indent="0" align="center"><font><b>Statistics:</b></font></division></cell><cell width="825"><division indent="0" align="right"><font face="Arial" size="200" color="000080"><u><invitation form="RefreshAdminDash" project="">refresh</invitation></u></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font>Email Notification Options       </font></division></cell><cell width="255"></cell><cell width="510"><division indent="0" align="right"><sp/></division></cell><cell width="510"></cell><cell width="4635"><division indent="0" align="right"><font>Recruiting List:</font></division></cell><cell width="825"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>RecruitmentDB</form-name><conditions><form name="RecruitmentDB" /><conditions>
