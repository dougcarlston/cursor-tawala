<form name="Uniforms" startPoint="false" themePath="dirtbowl2" process="Post-Uniforms">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Jersey Sizes for all fully registered players:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000"><response-totals-table version="1"><layout-type>vertical</layout-type><field>Record:Registration:ShirtSize</field><conditions><form name="Registration" /><conditions>
<and>
<equals field="Record:Registration:WaiverReceived">
<string value="Yes"/>
</equals>
<equals field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</and>
</conditions></conditions></response-totals-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /><conditions>
<and>
<mcIsBlank field="Record:Registration:ShirtSize" />
<and>
<equals field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
<equals field="Record:Registration:WaiverReceived">
<string value="Yes"/>
</equals>
</and>
</and>
</conditions></conditions></record-count></font><font face="Arial" size="200" color="000000"> player(s) didn't specify jersey sizes.</font></paragraph></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Jersey Sizes for all registered players, whether on not they have paid or submitted waivers:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000"><response-totals-table version="1"><layout-type>vertical</layout-type><field>Record:Registration:ShirtSize</field><conditions><form name="Registration" /></conditions></response-totals-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /><conditions>
<mcIsBlank field="Record:Registration:ShirtSize" />
</conditions></conditions></record-count></font><font face="Arial" size="200" color="000000"> player(s) didn't specify jersey sizes.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="true"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check "Jerseys Ordered" box in status table on Administrator Dashboard?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No</font></paragraph></choice></mc>
</items>
</form>
<form name="CommunicatorSend" startPoint="false" themePath="dirtbowl2" process="Post-CommunicatorSend">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="720"><row><cell width="8460"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><b>From: </b></font><font><field name="Communicator:FromName"/></font><font> (</font><font><field name="Communicator:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="Communicator:Subject"/></font></division></cell></row></table><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><table indent="705"><row><cell width="8460"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><field name="Communicator:Body"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font>Here is a link to </font><font color="0000FF"><u>your private Dirt Bowl Dashboard</u></font><font>. </font><font><field name="DashboardLinkVerbiage"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><field name="DashboardLinkVerbiage2"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><field name="Communicator:Close"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="CommunicatorSend:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Click Submit to begin sending now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Note: It might take several minutes to send all the emails.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</i></font></paragraph></text>
</items>
</form>
