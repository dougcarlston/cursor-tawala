<document name="WaiverInstructionHeader1">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="180" color="FF0000"><b><i>Use your browser's Print function to print out this form now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="160"><i>Then complete it, sign it and mail it to:   </i></font><font size="160"><b>Dirt Bowl, </b></font><font size="160"><b><field name="AdminAdrss"/></b></font><font size="160"><b>, </b></font><font size="160"><b><field name="AdminsCity"/></b></font><font size="160"><b>, </b></font><font size="160"><b><field name="AdminState"/></b></font><sp/><font size="160"><b><field name="AdminsZIP"/></b></font></paragraph>
</xmlData>
</document>
<document name="WaiverInstructionHeader2">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="160" color="FF0000"><i>After you have printed out this form, click on the link at the bottom to proceed to Step 3.</i></font></paragraph>
</xmlData>
</document>
