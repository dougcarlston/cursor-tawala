<from addressField="Communicator:FromEmail" aliasLiteral="Dirt Bowl Email Server"/>
<subject><field name="Communicator:Subject"/></subject>
<body document="LetterWithCoachDashboardLink" reset="false"/>
</send>
</foreach>
</trueSet>
</if>
<show form="AdminDash"/>
</process>
<process name="Post-TeamRosters">
<show document="TeamAssignment" reset="false"/>
</process>
<process name="Post-ShowRosterCriteria">
<show document="Roster Selection Criteria" reset="false"/>
</process>
<process name="Post-ShowContactFields">
<show document="Contact Fields" reset="false"/>
</process>
<process name="Post-ShowMedicalFields">
<show document="Medical Info" reset="false"/>
</process>
<process name="Post-ShowWaiverPaymentFields">
<show document="WaiverPaymentRecords" reset="false"/>
</process>
<process name="Post-ShowAllFields">
<show document="All Fields" reset="false"/>
</process>
<process name="Post-SeasonLaunchMgmt">
<if>
<conditions>
<mcEquals field="SeasonLaunchMgmt:Q1">
<string value="a"/>
</mcEquals>
</conditions>
<trueSet>
<if>
<conditions>
<isLessThan field="SeasonLaunchMgmt:MinPlayers">
<string value="1"/>
</isLessThan>
</conditions>
<trueSet>
<show document="Message" reset="false"/>
<set field="Message" arithmeticAsText="false">
<string value="Please enter minimum team size before running this check."/>
</set>
<show document="Message" reset="false"/>
<show form="SeasonLaunchMgmt"/>
</trueSet>
</if>
<set field="RosterChecked" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="TeamCountChecked" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="NumberOfTeamsWithSufficientPlayers" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="TotalTeamCount" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Team List">
<forms>
<form name="Team"/>
</forms>
</get>
<foreach record="NamedTeam" recordList="Team List">
<set field="PlayerCount" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Player List">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Player List:Registration:TeamId">
<string field="NamedTeam:Team:TeamId"/>
</equals>
</conditions></get>
<foreach record="DesignatedPlayer" recordList="Player List">
<set field="PlayerCount" arithmeticAsText="false">
<add>
<operand field="PlayerCount"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<isLessThan field="PlayerCount">
<string field="SeasonLaunchMgmt:MinPlayers"/>
</isLessThan>
</conditions>
<trueSet>
<set field="RosterChecked" arithmeticAsText="false">
<string value="No"/>
</set>
<set field="Message" arithmeticAsText="false">
<string field="NamedTeam:Team:TeamId"/>
<string value=" has only "/>
<string field="PlayerCount"/>
<string value=" players."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
<falseSet>
<set field="NumberOfTeamsWithSufficientPlayers" arithmeticAsText="false">
<add>
<operand field="NumberOfTeamsWithSufficientPlayers"/>
<operand value="1"/>
</add>
</set>
</falseSet>
</if>
<set field="TotalTeamCount" arithmeticAsText="false">
<add>
<operand field="TotalTeamCount"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<isLessThan field="SeasonLaunchMgmt:MinTeamCount">
<string value="1"/>
</isLessThan>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="No minimum number of teams was set."/>
</set>
<show document="Message" reset="false"/>
<set field="TeamCountChecked" arithmeticAsText="false">
<string value="Skipped"/>
</set>
</trueSet>
<falseSet>
<if>
<conditions>
<isLessThan field="NumberOfTeamsWithSufficientPlayers">
<string field="SeasonLaunchMgmt:MinTeamCount"/>
</isLessThan>
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<sub>
<operand field="SeasonLaunchMgmt:MinTeamCount"/>
<operand field="NumberOfTeamsWithSufficientPlayers"/>
</sub>
</set>
<set field="Message" arithmeticAsText="false">
<string value="League must have at least "/>
<string field="Count"/>
<string value=" more teams."/>
</set>
<show document="Message" reset="false"/>
<set field="RosterChecked" arithmeticAsText="false">
<string value="No"/>
</set>
<set field="TeamCountChecked" arithmeticAsText="false">
<string value="No"/>
</set>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value="Number of teams with enough players is sufficient."/>
</set>
<show document="Message" reset="false"/>
<set field="TeamCountChecked" arithmeticAsText="false">
<string value="Yes"/>
</set>
</falseSet>
</if>
</falseSet>
</if>
<get recordList="SetupRecords">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="SetupRecord" recordList="SetupRecords">
<set field="SetupRecord:AdminSetup:TeamCountChecked" arithmeticAsText="false">
<string field="TeamCountChecked"/>
</set>
<set field="SetupRecord:AdminSetup:RosterChecked" arithmeticAsText="false">
<string field="RosterChecked"/>
</set>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SeasonLaunchMgmt:Q1" value="b"/>
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Player List">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<isBlank field="Player List:Registration:TeamId" />
</conditions></get>
<foreach record="UnchosenPlayer" recordList="Player List">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<set field="AllPlayersAssignedChecked" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="Message" arithmeticAsText="false">
<string value="All fully registered players have been assigned to teams."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
<falseSet>
<set field="AllPlayersAssignedChecked" arithmeticAsText="false">
<string value="No"/>
</set>
<show document="Unassigned Players" reset="false"/>
</falseSet>
</if>
<get recordList="SetupRecords">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="SetupRecord" recordList="SetupRecords">
<set field="SetupRecord:AdminSetup:AllPlayersAssignedChecked" arithmeticAsText="false">
<string field="AllPlayersAssignedChecked"/>
</set>
</foreach>
</trueSet>
</if>
<set field="DashboardLinkVerbiage2" arithmeticAsText="true">
<string value="To save the link click on it, and when your Dashboard page comes up in the browser use the browser&apos;s &quot;Favorites&quot; or &quot;Bookmarks&quot; feature to store it."/>
</set>
<if>
<conditions>
<mcEquals field="SeasonLaunchMgmt:Q1" value="c"/>
</conditions>
<trueSet>
<comment>Send team assignment notification to all players</comment>
<if>
<conditions>
<and>
<equals field="AllPlayersAssignedChecked">
<string value="Yes"/>
</equals>
<and>
<equals field="TeamCountChecked">
<string value="Yes"/>
</equals>
<equals field="RosterChecked">
<string value="Yes"/>
</equals>
</and>
</and>
</conditions>
<trueSet>
<set field="DashboardLinkVerbiage" arithmeticAsText="true">
<string value="You can use it to view or change your Registration info / Medical Waiver, check your team roster and contact info, check the schedule, etc. This is your personal link. Do not share it with others."/>
</set>
<show form="PlayerAssignmentEmail"/>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value="Please satisfy first two Launch Countdown checks before sending out notifications."/>
</set>
<show document="Message" reset="false"/>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SeasonLaunchMgmt:Q1" value="d"/>
</conditions>
<trueSet>
<comment>Send roster notices and Coach dashboards to coaches</comment>
<if>
<conditions>
<and>
<equals field="AllPlayersAssignedChecked">
<string value="Yes"/>
</equals>
<and>
<equals field="RosterChecked">
<string value="Yes"/>
</equals>
<equals field="TeamCountChecked">
<string value="Yes"/>
</equals>
</and>
</and>
</conditions>
<trueSet>
<show form="CoachRosterNotice"/>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value="Please satisfy first three Launch Countdown checks before sending out notifications."/>
</set>
<show document="Message" reset="false"/>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SeasonLaunchMgmt:Q1" value="e"/>
</conditions>
<trueSet>
<comment>Mark countdown complete on Dashboard</comment>
<if>
<conditions>
<and>
<equals field="AllPlayersAssignedChecked">
<string value="Yes"/>
</equals>
<and>
<equals field="RosterChecked">
<string value="Yes"/>
</equals>
<and>
<equals field="TeamCountChecked">
<string value="Yes"/>
</equals>
<and>
<equals field="PlayersNotified">
<string value="Yes"/>
</equals>
<equals field="CoachesNotified">
<string value="Yes"/>
</equals>
</and>
</and>
</and>
</and>
</conditions>
<trueSet>
<set field="PreSeasonCheckupComplete" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
<falseSet>
<set field="PreSeasonCheckupComplete" arithmeticAsText="false">
<string value="No"/>
</set>
<set field="Message" arithmeticAsText="true">
<string value="Complete all other Countdown checkoff items before this final item."/>
</set>
<show document="Message" reset="false"/>
</falseSet>
</if>
<get recordList="SetupRecords">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="SetupRecord" recordList="SetupRecords">
<set field="SetupRecord:AdminSetup:PreSeasonCheckupComplete" arithmeticAsText="false">
<string field="PreSeasonCheckupComplete"/>
</set>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcDoesNotEqual field="SeasonLaunchMgmt:Q1" value="b"/>
<equals field="Count">
<string value="0"/>
</equals>
</or>
</conditions>
<trueSet>
<show form="SeasonLaunchMgmt"/>
</trueSet>
</if>
</process>
<process name="Post-PlayerAssignmentEmail">
<if>
<conditions>
<mcEquals field="PlayerAssignmentEmail:Q6" value="a"/>
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="PlayerAndTeamList">
<forms>
<form name="Registration"/>
<form name="Team"/>
</forms>
<conditions>
<equals field="PlayerAndTeamList:Registration:TeamId">
<string field="PlayerAndTeamList:Team:TeamId"/>
</equals>
</conditions></get>
<foreach record="RosterMember" recordList="PlayerAndTeamList">
<set field="PlayerFirst" arithmeticAsText="false">
<string field="RosterMember:Registration:FirstName"/>
</set>
<set field="Team" arithmeticAsText="false">
<string field="RosterMember:Team:TeamId"/>
</set>
<set field="PlayerID" arithmeticAsText="false">
<string field="RosterMember:Registration:RegID"/>
</set>
<set field="Coach" arithmeticAsText="false">
<string field="RosterMember:Team:CoachFullName"/>
</set>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
<send>
<to addressField="RosterMember:Registration:ParentEmail"/>
<from addressField="PlayerAssignmentEmail:FromEmail" aliasField="PlayerAssignmentEmail:FromAdminName"/>
<subject><field name="PlayerAssignmentEmail:Subject"/></subject>
<body document="PlayerAssgnmtLetter" reset="false"/>
</send>
<if>
<conditions>
<isNotBlank field="RosterMember:Registration:ParentEmail2" />
</conditions>
<trueSet>
<send>
<to addressField="RosterMember:Registration:ParentEmail2"/>
<from addressField="PlayerAssignmentEmail:FromEmail" aliasField="PlayerAssignmentEmail:FromAdminName"/>
<subject><field name="PlayerAssignmentEmail:Subject"/></subject>
<body document="PlayerAssgnmtLetter" reset="false"/>
</send>
</trueSet>
</if>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Player assignment notification sent out to "/>
<string field="Count"/>
<string value=" players"/>
</set>
<show document="Message" reset="false"/>
<get recordList="SetupList">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="SetupRecord" recordList="SetupList">
<set field="SetupRecord:AdminSetup:PlayersNotified" arithmeticAsText="false">
<string value="Yes"/>
</set>
<if>
<conditions>
<mcContains field="SetupRecord:AdminSetup:EmailNotificationPreference" value="b"/>
</conditions>
<trueSet>
<send>
<to addressField="SetupRecord:AdminSetup:AdminsEmail"/>
<from addressLiteral="donotreply@tawala.com" aliasLiteral="Dirt Bowl Email Server"/>
<subject><field name="Message"/></subject>
<body document="PlayerAssgnmtLetter" reset="false"/>
</send>
</trueSet>
</if>
</foreach>
<show form="SeasonLaunchMgmt"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerAssignmentEmail:Q6" value="b"/>
</conditions>
<trueSet>
<show form="PlayerAssignmentEmail"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerAssignmentEmail:Q6" value="c"/>
</conditions>
<trueSet>
<show form="SeasonLaunchMgmt"/>
</trueSet>
</if>
<show form="AdminDash"/>
</process>
<process name="Post-CoachRosterNotice">
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q6" value="a"/>
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="TeamAndCoachList">
<forms>
<form name="Team"/>
<form name="Coach"/>
</forms>
<conditions>
<equals field="TeamAndCoachList:Team:CoachId">
<string field="TeamAndCoachList:Coach:CoachId"/>
</equals>
</conditions></get>
<foreach record="SuchPair" recordList="TeamAndCoachList">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
<set field="Team" arithmeticAsText="false">
<string field="SuchPair:Team:TeamId"/>
</set>
<set field="CoachID" arithmeticAsText="false">
<string field="SuchPair:Coach:CoachId"/>
</set>
<set field="PlayerFirst" arithmeticAsText="false">
<string field="SuchPair:Coach:FirstName"/>
</set>
<send>
<to addressField="SuchPair:Coach:Email"/>
<from addressField="CoachRosterNotice:FromEmail" aliasField="CoachRosterNotice:FromAdminName"/>
<subject><field name="CoachRosterNotice:Subject"/></subject>
<body document="CoachSetupLetter" reset="false"/>
</send>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Team roster notification and Dashboard info sent out to "/>
<string field="Count"/>
<string value=" team coaches"/>
</set>
<show document="Message" reset="false"/>
<get recordList="SetupList">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="SetupRecord" recordList="SetupList">
<set field="SetupRecord:AdminSetup:CoachesNotified" arithmeticAsText="false">
<string value="Yes"/>
</set>
<if>
<conditions>
<mcContains field="SetupRecord:AdminSetup:EmailNotificationPreference" value="b"/>
</conditions>
<trueSet>
<send>
<to addressField="SetupRecord:AdminSetup:AdminsEmail"/>
<from addressLiteral="donotreply@tawala.com" aliasLiteral="Dirt Bowl Email Server"/>
<subject><field name="Message"/></subject>
<body document="CoachSetupLetter" reset="false"/>
</send>
</trueSet>
</if>
</foreach>
<show form="SeasonLaunchMgmt"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q6" value="b"/>
</conditions>
<trueSet>
<show form="CoachRosterNotice"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q6" value="c"/>
</conditions>
<trueSet>
<show form="SeasonLaunchMgmt"/>
</trueSet>
</if>
<show form="AdminDash"/>
</process>
<process name="Post-ShowTeamRosters">
<show form="AdminDash"/>
</process>
<process name="Post-ShowCoachTeamRoster">
<show document="BackToCoachDashLink" reset="false"/>
<get recordList="Team List">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="Team List:Team:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="Team List">
<set field="CurrentTeamId" arithmeticAsText="false">
<string field="SuchTeam:Team:TeamId"/>
</set>
<set field="Team" arithmeticAsText="false">
<string field="SuchTeam:Team:TeamId"/>
</set>
<show document="CoachRosterList" reset="false"/>
</foreach>
<show document="BackToCoachDashLink" reset="false"/>
</process>
<process name="Post-OnlinePayment">
<set field="OnlinePayment:RegID" arithmeticAsText="false">
<string field="PlayerID"/>
</set>
<set field="OnlinePayment:Status" arithmeticAsText="false">
<string value="Initiating"/>
</set>
<set field="OnlinePayment:PaymentDescription" arithmeticAsText="false">
<string field="PaymentChargeDescription"/>
</set>
<set field="OnlinePayment:AmountRequested" arithmeticAsText="false">
<string field="SignupFeeForIndividual"/>
</set>
<show document="OnlinePaymentInstructions" reset="false"/>
<show document="PaymentByCheckInstructions" reset="false"/>
<show document="NavigationToPlayerDashboard" reset="false"/>
</process>
<process name="UpdatePaidStatusBasedOnInvoiceStatus">
<get recordList="Unupdated Registrants">
<forms>
<form name="Registration"/>
<form name="OnlinePayment"/>
</forms>
<conditions>
<and>
<isBlank field="Unupdated Registrants:Registration:PaymentReceived" />
<and>
<equals field="Unupdated Registrants:Registration:RegID">
<string field="Unupdated Registrants:OnlinePayment:RegID"/>
</equals>
<equals field="Unupdated Registrants:OnlinePayment:Status">
<string value="Completed"/>
</equals>
</and>
</and>
</conditions></get>
<foreach record="Registrant" recordList="Unupdated Registrants">
<set field="Registrant:Registration:PaymentReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
</foreach>
</process>
<process name="Post-PaymentReceived">
<show form="PlayerDash"/>
</process>
<process name="Post-IndividualPaymentCancelled">
<show document="OnlinePaymentCancelledConfirmation" reset="false"/>
<show document="PaymentByCheckInstructions" reset="false"/>
<show document="NavigationToPlayerDashboard" reset="false"/>
</process>
<process name="Post-TeamAndCoachMenu">
<show document="TeamAndCoachMenu" reset="false"/>
</process>
<process name="Post-Team">
<if>
<conditions>
<isNotBlank field="Team:PreviousTeamId" />
</conditions>
<trueSet>
<comment>-- This is the case of editing a team</comment>
<get recordList="TeamPlayers">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="TeamPlayers:Registration:TeamId">
<string field="Team:PreviousTeamId"/>
</equals>
</conditions></get>
<foreach record="SuchPlayer" recordList="TeamPlayers">
<set field="SuchPlayer:Registration:TeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
</foreach>
<get recordList="GroupRegistrationRecords">
<forms>
<form name="GroupRegistration"/>
</forms>
<conditions>
<equals field="Team:PreviousTeamId">
<string field="GroupRegistrationRecords:GroupRegistration:TeamId"/>
</equals>
</conditions></get>
<foreach record="SuchGroup" recordList="GroupRegistrationRecords">
<set field="SuchGroup:GroupRegistration:TeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
</foreach>
</trueSet>
</if>
<set field="Team:PreviousTeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-Coach">
<set field="Coach:FullName" arithmeticAsText="false">
<string field="Coach:FirstName"/>
<string value=" "/>
<string field="Coach:LastName"/>
</set>
<if>
<conditions>
<isBlank field="Coach:CoachId" />
</conditions>
<trueSet>
<comment>-- New record</comment>
<set field="Coach:CoachId" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="PreviousCoaches">
<forms>
<form name="Coach"/>
</forms>
</get>
<foreach record="Record" recordList="PreviousCoaches">
<if>
<conditions>
<isLessThanOrEqualTo field="Coach:CoachId">
<string field="Record:Coach:CoachId"/>
</isLessThanOrEqualTo>
</conditions>
<trueSet>
<set field="Coach:CoachId" arithmeticAsText="false">
<add>
<operand field="Record:Coach:CoachId"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
<comment>-- Signed up a parent volunteer</comment>
<if>
<conditions>
<equals field="ParentCoachSelected">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<comment>-- Mark off the volunteer status in Registration record(s)</comment>
<get recordList="ParentCoachList">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<or>
<equals field="ParentCoachList:Registration:RegID">
<string field="ParentCoaches:Q1"/>
</equals>
<or>
<equals field="ParentCoachList:Registration:ParentEmail">
<string field="Coach:Email"/>
</equals>
<equals field="ParentCoachList:Registration:ParentEmail2">
<string field="Coach:Email"/>
</equals>
</or>
</or>
</conditions></get>
<foreach record="SelectedParent" recordList="ParentCoachList">
<set field="SelectedParent:Registration:CoachVolunteer" arithmeticAsText="false">
<string value="RegisteredCoach"/>
</set>
</foreach>
</trueSet>
</if>
</trueSet>
<falseSet>
<comment>-- The record has been edited</comment>
<get recordList="AllTeamsForThisCoach">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="AllTeamsForThisCoach:Team:CoachId">
<string field="Coach:CoachId"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="AllTeamsForThisCoach">
<set field="SuchTeam:Team:CoachFullName" arithmeticAsText="false">
<string field="Coach:FullName"/>
</set>
</foreach>
</falseSet>
</if>
<if>
<conditions>
<isBlank field="_InviteeID" />
</conditions>
<trueSet>
<comment>-- This is admin adding/editing the record</comment>
<show form="TeamAndCoachMenu"/>
</trueSet>
<falseSet>
<comment>-- The coach editing his record</comment>
<show form="CoachDashboard"/>
</falseSet>
</if>
</process>
<process name="Post-CoachToTeamAssignment">
<get recordList="CoachRecords">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<equals field="CoachRecords:Coach:CoachId">
<string field="CoachToTeamAssignment:CoachId"/>
</equals>
</conditions></get>
<foreach record="Record" recordList="CoachRecords">
<get recordList="TeamRecords">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="TeamRecords:Team:TeamId">
<string field="CoachToTeamAssignment:TeamId"/>
</equals>
</conditions></get>
<foreach record="FoundTeam" recordList="TeamRecords">
<set field="FoundTeam:Team:CoachId" arithmeticAsText="false">
<string field="Record:Coach:CoachId"/>
</set>
<set field="FoundTeam:Team:CoachFullName" arithmeticAsText="false">
<string field="Record:Coach:FullName"/>
</set>
</foreach>
</foreach>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-EditCoach">
<edit form="Coach" submit="modify">
<conditions>
<equals field="Record:Coach:CoachId">
<string field="EditCoach:CoachId"/>
</equals>
</conditions>
</edit>
<comment>-- If the coach is not selected this statement will get executed</comment>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-DeleteTeam">
<delete><form name="Team"/><conditions>
<equals field="Record:Team:TeamId">
<string field="DeleteTeam:TeamId"/>
</equals>
</conditions></delete>
<get recordList="Player List">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Player List:Registration:TeamId">
<string field="DeleteTeam:TeamId"/>
