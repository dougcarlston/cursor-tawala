</u></font></division></cell><cell width="1695"></cell></row><row><cell width="2670"></cell><cell width="3930"><division indent="0" align="center"><font><field name="WaiverStatusMessage"/></font></division></cell><cell width="795"></cell><cell width="1695"></cell><cell width="1695"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2430"><division indent="0" align="right"><font><b>Your Team:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="Team"/></font></division></cell><cell width="3165"><division indent="0" align="right"><font>Payment Status:</font></division></cell><cell width="210"></cell><cell width="2025"><division indent="0" align="left"><font><field name="PaymentStatusMessage"/></font></division></cell></row><row><cell width="2430"><division indent="0" align="right"><font><b>League:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="League"/></font></division></cell><cell width="3165"></cell><cell width="210"></cell><cell width="2025"></cell></row><row><cell width="2430"><division indent="0" align="right"><font><b>Season:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="SeasonYr"/></font></division></cell><cell width="3165"></cell><cell width="210"></cell><cell width="2025"></cell></row><row><cell width="2430"></cell><cell width="272"></cell><cell width="2698"></cell><cell width="3165"></cell><cell width="210"></cell><cell width="2025"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2415"><division indent="0" align="right"><font><b>Coach:</b></font></division></cell><cell width="272"></cell><cell width="2548"><division indent="0" align="left"><font><field name="Coach"/></font></division></cell><cell width="3345"><division indent="0" align="right"><font><b>Dirt Bowl Athletic Director:</b></font></division></cell><cell width="210"></cell><cell width="2010"><division indent="0" align="left"><font><field name="AdminName"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Coach's Phone:</b></font></division></cell><cell width="272"></cell><cell width="2548"><division indent="0" align="left"><font><field name="CoachsPhone"/></font></division></cell><cell width="3345"><division indent="0" align="right"><font><b>Dirt Bowl Phone:</b></font></division></cell><cell width="210"></cell><cell width="2010"><division indent="0" align="left"><font><field name="AdminsPhone"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Alternate Phone:</b></font></division></cell><cell width="272"></cell><cell width="2548"><division indent="0" align="left"><font><field name="CoachsPhone1"/></font></division></cell><cell width="3345"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="210"></cell><cell width="2010"><division indent="0" align="left"><font><field name="AdminEmail"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="2548"><division indent="0" align="left"><font><field name="CoachsEmail"/></font></division></cell><cell width="3345"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="210"></cell><cell width="2010"><division indent="0" align="left"><font><field name="AdminAdrss"/></font></division></cell></row><row><cell width="2415"></cell><cell width="272"></cell><cell width="2548"></cell><cell width="3345"></cell><cell width="210"></cell><cell width="2010"><division indent="0" align="left"><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><sp/><font><field name="AdminsZIP"/></font><sp/></division></cell></row></table>
