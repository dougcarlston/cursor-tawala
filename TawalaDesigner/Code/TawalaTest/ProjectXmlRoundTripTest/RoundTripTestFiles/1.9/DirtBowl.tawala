<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Recruitment" project="">Back to Recruitment</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">Number of records: </font><font color="000000"><record-count version="3"><form-name>RecruitmentDB</form-name><conditions><form name="RecruitmentDB" /></conditions></record-count></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>6</number-of-columns><column><header>First Name</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header>Last Name</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header>Parent</header><contents><field name="Record:RecruitmentDB:ParentFirst" /></contents></column><column><header>Email</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header>Email 2</header><contents><field name="Record:RecruitmentDB:Email2" /></contents></column><column><header>Phone</header><contents><field name="Record:RecruitmentDB:Phone" /></contents></column><conditions><form name="RecruitmentDB" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Recruitment" project="">Back to Recruitment</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="RecruitDBContacts">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>5</number-of-columns><column><header>First Name</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header>Last Name</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header>Email</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header>Email 2</header><contents><field name="Record:RecruitmentDB:Email2" /></contents></column><column><header># Emails Sent</header><contents><field name="Record:RecruitmentDB:ContactsNo" /></contents></column><conditions><form name="RecruitmentDB" /><conditions>
<isLessThan field="Record:RecruitmentDB:ContactsNo">
<string field="Count"/>
</isLessThan>
</conditions></conditions></itemization-table></font></paragraph>
</xmlData>
</document>
<document name="PlayerDashboard">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="center"><font face="Times New Roman" size="360"><b><field name="PlayerFirst"/></b></font><sp/><sp/><font face="Times New Roman" size="360"><b><field name="PlayerLast"/></b></font><font face="Times New Roman" size="360"><b>'s Dirt Bowl Player Dashboard</b></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2670"><division indent="0" align="center"><font color="000080"><u><link>
<description>
<string value="Home"/>
</description>
<url>
<string value="http://www.dirtbowl.com"/>
</url>
