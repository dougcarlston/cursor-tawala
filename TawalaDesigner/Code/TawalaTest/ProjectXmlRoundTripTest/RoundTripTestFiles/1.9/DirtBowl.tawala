</form>
<form name="Team" startPoint="false" themePath="dirtbowl2" process="Post-Team">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Team Name:  </font><blank label="a" length="20" required="false" alternateLabel="TeamId"/></paragraph></fib>
<field name="CoachId"/>
<field name="CoachFullName"/>
<field name="PreviousTeamId"/>
</items>
</form>
<form name="Coach" startPoint="false" themePath="dirtbowl2" process="Post-Coach" preProcess="Pre-Coach">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Coach Contact Information</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: Use browser Back button to cancel out of this page.</font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="320" color="A00000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">First Name:  </font><blank label="a" length="20" required="false" alternateLabel="FirstName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Last Name:  </font><blank label="b" length="20" required="false" alternateLabel="LastName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="c" length="22" required="false" alternateLabel="Email"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone: </font><blank label="d" length="20" required="false" alternateLabel="Phone1"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Alternate Phone: </font><blank label="e" length="19" required="false" alternateLabel="Phone2"/></paragraph></fib>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Street:  </font><blank label="a" length="20" required="false" alternateLabel="Street"/></paragraph></fib>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City: </font><blank label="a" length="20" required="false" alternateLabel="City"/></paragraph></fib>
<fib label="Q4" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">State: </font><blank label="a" length="6" required="false" alternateLabel="State"/></paragraph></fib>
<fib label="Q5" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Zip: </font><blank label="a" length="6" required="false" alternateLabel="ZIP"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<or>
<isBlank field="Coach:FirstName" />
<or>
<isBlank field="Coach:LastName" />
<isBlank field="Coach:Email" />
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You must enter at least First Name, Last Name and Email"/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<field name="CoachId"/>
<field name="FullName"/>
</items>
</form>
<form name="CoachToTeamAssignment" startPoint="false" themePath="dirtbowl2" process="Post-CoachToTeamAssignment">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="TeamId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the team:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<or>
<isBlank field="Record:Team:CoachId" />
<equals field="Record:Team:CoachId">
<string value=" "/>
</equals>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q2" alternateLabel="CoachId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Coach:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
<string value="#"/>
<field name="Record:Coach:FirstName"/>
</sort-expression><record-selector><form name="Coach" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="EditCoach" startPoint="false" themePath="dirtbowl2" process="Post-EditCoach">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
