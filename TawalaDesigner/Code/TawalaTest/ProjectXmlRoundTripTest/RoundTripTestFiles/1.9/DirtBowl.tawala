<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="RecruitmentDB" startPoint="false" themePath="dirtbowl2" process="Post-RecruitDB">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000"><field name="Action"/></font><font face="Arial" size="360" color="000000"> Recruitment Database</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name: </font><blank label="a" length="20" required="false" alternateLabel="FirstName"/><font face="Arial" size="200" color="000000"> (</font><font face="Arial" size="200" color="000000"><i>first)</i></font><sp/><blank label="b" length="20" required="false" alternateLabel="LastName"/><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph></fib>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Parent's First Name:  </font><blank label="a" length="20" required="false" alternateLabel="ParentFirst"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email Address: </font><blank label="b" length="20" required="false" alternateLabel="Email"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Additional Email Address: </font><blank label="c" length="17" required="false" alternateLabel="Email2"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone Number: </font><blank label="d" length="20" required="false" alternateLabel="Phone"/></paragraph></fib>
<field name="RecruitmentId"/>
<field name="BadRecord?"/>
<field name="ContactsNo"/>
</items>
</form>
<form name="Recruitment" startPoint="false" themePath="dirtbowl2" process="Post-Recruitment">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Manage the Dirt Bowl Recruitment List</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can  manage records in the Recruitment List both here and on the Tawala Website (www.tawala.com) in your MyProjects Dirt Bowl Project Detail Page. The recruitment list is called "RecruitmentDB."  It is easier to delete records from the Web page, and you can also import contact lists there.  To import, try clicking on the import icon (</font><font face="Arial" size="200" color="000000"><image id="image6" width="26" height="22"><metafileHeader fileType="1" headerSize="9" version="768" fileSize="933" numOfObjects="0" maxRecordSize="911" numOfParams="0" />
</image></font><font>) to the right of "RecruitmentDB" file name and select an Excel or .csv file to import. The file must have the correct information in these five fields: </font><font><i>Child's First Name, Last Name, Parent's First Name, Parent's Email address, Phone.</i></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View recruitment list</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add a record</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit a record</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete one or more records</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Audit list for email validity</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send email to list</font></paragraph></choice></mc>
</items>
</form>
<form name="RecruitDBDupe" startPoint="false" themePath="dirtbowl2" process="Post-RecruitDBDupe">
<items>
<text label="T1" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This person appears to be in the recruitment files already.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><itemization-table version="1"><number-of-columns>6</number-of-columns><column><header>First Name</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header>Last Name</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header>Parent</header><contents><field name="Record:RecruitmentDB:ParentFirst" /></contents></column><column><header>Email</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header>Additional Email</header><contents><field name="Record:RecruitmentDB:Email2" /></contents></column><column><header>Phone</header><contents><field name="Record:RecruitmentDB:Phone" /></contents></column><conditions><form name="RecruitmentDB" /><conditions>
<and>
<equals field="Record:RecruitmentDB:FirstName">
<string field="RecruitmentDB:FirstName"/>
</equals>
<and>
<equals field="Record:RecruitmentDB:LastName">
<string field="RecruitmentDB:LastName"/>
</equals>
<equals field="Record:RecruitmentDB:Email">
<string field="RecruitmentDB:Email"/>
</equals>
</and>
</and>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add anyhow?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No</font></paragraph></choice></mc>
</items>
</form>
<form name="RecruitEmail" startPoint="false" themePath="dirtbowl2" dataEntryOnly="true" process="Post-RecruitEmail" preProcess="RetrieveAdminSetupVariables">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Recruitment Email</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3915"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3645"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This tool will let you send your email to your entire recruitment contact list, or only to those you missed the last time around, or just to those who haven't signed up yet.</font></paragraph></text>
<mc label="Q1" alternateLabel="To" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Everyone in the Recruitment Database</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">People who have been contacted fewer than "x" times already</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Everyone in the Recruitment Database who has not yet submitted a registration form</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(name): </i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromAdminName"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email): </i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject:</font><font face="Arial" size="200" color="000000">  </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q5" alternateLabel="Salutation" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of Salutation:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Parents of Child's first name </font><font face="Arial" size="200" color="000000"><i>("Dear Parents of Jimmy")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't create a personalized salutation</font></paragraph></choice></mc>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<fib label="Q7" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Closing"/></paragraph></fib>
<text label="T3" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the Submit button to continue.  You will have a chance to review your letter before it is sent.</font></paragraph></text>
</items>
</form>
<form name="ChooseX" startPoint="false" themePath="dirtbowl2" process="Post-ChooseX">
<items>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You chose to send this letter only to those who have been contacted fewer than "x" times.  Right now, "x" equals </font><font><field name="X"/></font><font>.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">See Recruitment List with number of times each has been contacted</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">See Recruitment List of those contacted fewer than </font><font face="Arial" size="200" color="000000"><field name="X"/></font><font face="Arial" size="200" color="000000"> times</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Change "x" from its current value of </font><font face="Arial" size="200" color="000000"><field name="X"/></font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Review Email and send to those contacted fewer than </b></font><font face="Arial" size="200" color="000000"><b><field name="X"/></b></font><font face="Arial" size="200" color="000000"><b> times</b></font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit Email and options further</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon Email and return to Recruitment Options</font></paragraph></choice><choice label="g"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon Email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="ChooseX:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<fib label="Q2" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Change "x" from </font><font face="Arial" size="200" color="000000"><field name="X"/></font><font face="Arial" size="200" color="000000"> to:  </font><blank label="a" length="5" required="false"/></paragraph></fib>
</items>
</form>
<form name="RecruitEmailSend" startPoint="false" themePath="dirtbowl2" process="Post-RecruitEmailSend">
<items>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="570"><row><cell width="8400"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>From</b></font><font>: </font><font><field name="RecruitEmail:FromAdminName"/></font><font> (</font><font><field name="RecruitEmail:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="8400"></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="RecruitEmail:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="525"><row><cell width="8415"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="RecruitEmail:Body"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="RecruitEmail:Closing"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Recruitment List Management</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="RecruitEmailSend:Q1">
<string value="a"/>
</mcDoesNotEqual>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Click Submit to begin sending now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Note: It might take several minutes to send all the emails.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</i></font></paragraph></text>
</items>
</form>
<form name="PlayerDash" startPoint="false" themePath="dirtbowl2" process="Post-PlayerDash">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="Tools" startPoint="false" themePath="dirtbowl2" process="Post-Tools">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tools</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit Setup Information</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Re-send private Dashboard link to Player or Coach</font></paragraph></choice></mc>
</items>
</form>
<form name="SendDashReminder" startPoint="false" themePath="dirtbowl2" process="Post-SendDashReminder" preProcess="RetrieveAdminSetupVariables">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Send private Dashboard link reminder</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send reminder to </font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">A Coach</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">A Player </font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="T3"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="SendDashReminder:Q1" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q2" alternateLabel="PlayerIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player(s) to send the dashboard link to:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q3" alternateLabel="CoachIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach(s) to send dashboard link to:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
<string value=" ("/>
<field name="Record:Team:TeamId"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
<string value="#"/>
<field name="Record:Coach:FirstName"/>
</sort-expression><record-selector><form name="Coach" /><form name="Team" /><conditions>
<equals field="Record:Coach:CoachId">
<string field="Record:Team:CoachId"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="RegFormManagement" startPoint="false" themePath="dirtbowl2" process="Post-RegistrantManagement">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Player Registration Management</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Register a Player or Group</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View/Edit/Delete Records</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark medical waiver and payment receipts</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Audit records for email validity</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Communicate with registered players</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="RegFormManagement:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">View/edit/delete records</font></paragraph></heading>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View all records</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View/Edit a specific record or medical waiver</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete a registration record</font></paragraph></choice></mc>
</items>
</form>
<form name="AdminSiteMap" startPoint="false" themePath="dirtbowl2" process="Post-AdminSiteMap">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AuditRecruitList" startPoint="false" themePath="dirtbowl2" process="Post-AuditRecruitList" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Recruiting List</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility will check the recruiting list for valid emails.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds a record with more than one valid email or none, it will pull up the record and give you a chance to edit it so that it will work with the Tawala Dirt Bowl utilities.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It is not possible to keep two email addresses in one contact field.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit or delete each record that fails the audit test.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return </font></paragraph></choice></mc>
</items>
</form>
<form name="Team Rosters" startPoint="false" themePath="dirtbowl2" process="Post-TeamRosters">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AuditRecruitLoop" startPoint="false" themePath="dirtbowl2" process="Post-AuditRecruitLoop" preProcess="Pre-AuditRecruitLoop">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Clean Recruitment Records</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><u><invitation form="Preseason" project="">Back to Pre-Season Menu</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="RecruitmentId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the recruitment record:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:FirstName"/>
<string value=" "/>
<field name="Record:RecruitmentDB:LastName"/>
<string value=" (parent: "/>
<field name="Record:RecruitmentDB:ParentFirst"/>
<string value=", email: "/>
<field name="Record:RecruitmentDB:Email"/>
<string value=", phone: "/>
<field name="Record:RecruitmentDB:Email2"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<equals field="Record:RecruitmentDB:BadRecord?">
<string value="Yes"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q2" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the action to perform:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit this record</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete this record</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark as "good" (it will remove this record from this list)</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Break off audit for now (you can always return)</font></paragraph></choice></mc>
</items>
</form>
<form name="ConfirmPaymentAndWaiverReceipts" startPoint="false" themePath="dirtbowl2" process="Post-ConfirmPaymentAndWaiverReceipts" preProcess="UpdatePaidStatusBasedOnInvoiceStatus">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Mark Waiver &amp; Payment Receipts</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q1" alternateLabel="PaymentOrWaiver" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark waiver receipts</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark payment receipts</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Review all records</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Unmark incorrectly marked record</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" />
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="Payment Receipt Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="c"/>
</conditions>
<trueSet>
<skip to="ReviewRcrds Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="d"/>
</conditions>
<trueSet>
<skip to="Unmark Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="e"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" alternateLabel="WaiverReceiptText"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="WaiverRegIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player(s) for whom waivers have been received:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<isBlank field="Record:Registration:WaiverReceived" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T3" alternateLabel="Payment Receipt Text"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q3" alternateLabel="PaymentRegIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player(s) for whom payment has been received:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<isBlank field="Record:Registration:PaymentReceived" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4" alternateLabel="ReviewRcrds Text"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>10</number-of-columns><column><header>Waiver</header><contents><field name="Record:Registration:WaiverReceived" /></contents></column><column><header>Payment</header><contents><field name="Record:Registration:PaymentReceived" /></contents></column><column><header>First</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header>Last</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header>Parent</header><contents><field name="Record:Registration:ParentFirstName" /></contents></column><column><header>Email</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header>Email 2</header><contents><field name="Record:Registration:ParentEmail2" /></contents></column><column><header>Phone 1</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header>Phone 2</header><contents><field name="Record:Registration:Phone2" /></contents></column><column><header>Phone 3</header><contents><field name="Record:Registration:Phone3" /></contents></column><conditions><form name="Registration" /></conditions></itemization-table></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5" alternateLabel="Unmark Text"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4095"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3480"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3225"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q4" alternateLabel="UnmarkReceipts" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player to unmark either payment receipt or waiver receipt</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<or>
<doesNotEqual field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</doesNotEqual>
<doesNotEqual field="Record:Registration:WaiverReceived">
<string value="Yes"/>
</doesNotEqual>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="Communicator" startPoint="false" themePath="dirtbowl2" dataEntryOnly="true" process="Post-Communicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b><i>This tool permits you to send emails to players who are assigned to teams and/or their coaches.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to the Recruitment List, use the </font><font><b>Recruitment List Management Tool </b></font><font><i>(Dashboard:Pre-Season:Recruitment List Management).</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to registered Players before team assignments have been made, use the </font><font><b>Player Registration Management Tool</b></font><sp/><font><i>(Dashboard:Pre-Season:Player Registration Management).</i></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All players assigned to teams and their coaches</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Coaches only</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Just players and coaches from selected teams</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(name):</i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="57" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email):</i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject</font><font face="Arial" size="200" color="000000"><i>:</i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q5" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of Salutation for letter to players</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Dear Parents of Player's first name </font><font face="Arial" size="200" color="000000"><i>("Dear Parents of Jimmy")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't create a personalized salutation</font></paragraph></choice></mc>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message:  </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>[A link to the player's or coach's </font><font color="0000FF"><u>Dashboard</u></font><font> will appear here.]</font></paragraph></text>
<fib label="Q7" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing:  </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="Communicator:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q8" alternateLabel="TeamIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to Players and Coach of the following team(s):</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Team" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="AuditRegForms" startPoint="false" themePath="dirtbowl2" process="Post-AuditRegForms">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Registration Forms</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility will check all the submitted Registration Forms for valid emails.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds one with more than one valid email or none, it will pull up the record and give you a chance to edit it so that it will work with the Tawala Dirt Bowl utilities.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It is not possible to keep two email addresses in one contact field.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit or delete each record that fails the audit test.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return</font></paragraph></choice></mc>
</items>
</form>
<form name="AuditFormLoop" startPoint="false" themePath="dirtbowl2" process="Post-AuditFormLoop" preProcess="Pre-AuditFormLoop">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Players with Invalid Emails</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><u><invitation form="RegFormManagement" project="">Back to Player Management</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="RegistrationId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player to audit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Registration" /><conditions>
<equals field="Record:Registration:BadEmail?">
<string value="Yes"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="RegistrantEmail" startPoint="false" themePath="dirtbowl2" dataEntryOnly="true" process="Post-RegistrantEmail">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Registered Player Email</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3210"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3660"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This tool will let you send your email to different parts of the Registered Player list, according to your need.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to the Recruitment List, use the </font><font><b>Recruitment List Management Tool</b></font><sp/><font><i>(Dashboard:Pre-Season:Recruitment List Management)</i></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want to send email to Players who have already been assigned to Team Rosters or during the regular season, use the </font><font><b>Communicator</b></font><font> on the Dashboard.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All registered players, regardless whether waivers or payment have been received</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players for whom waivers have not been received</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players for whom payment has not been received</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players with fully completed forms, waivers &amp; payment</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(name)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q5" alternateLabel="Salutation" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of Salutation:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Dear Parents of Player's first name </font><font face="Arial" size="200" color="000000"><i>("Dear Parents of Jimmy")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't create a personalized salutation</font></paragraph></choice></mc>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>[A link to the player's </font><font color="0000FF"><u>Player Dashboard</u></font><font> will appear here.]</font></paragraph></text>
<fib label="Q7" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing:  </font><blank label="a" length="57" height="5" required="false" alternateLabel="Closing"/></paragraph></fib>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the Submit button to continue.  You will have a chance to review your letter before it is sent.</font></paragraph></text>
</items>
</form>
<form name="RegistrantEmailSend" startPoint="false" themePath="dirtbowl2" process="Post-RegistrantEmailSend">
<items>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="570"><row><cell width="8400"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>From</b></font><font>:  </font><font><field name="RegistrantEmail:FromName"/></font><font> (</font><font><field name="RegistrantEmail:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="8400"></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="RegistrantEmail:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="525"><row><cell width="8415"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="RegistrantEmail:Body"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font>Here is a link to </font><font color="0000FF"><u>your private Dirt Bowl Dashboard</u></font><font>. </font><font><field name="DashboardLinkVerbiage"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="DashboardLinkVerbiage2"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/><sp/><sp/><sp/></division><division indent="0" align="left"><font><field name="RegistrantEmail:Closing"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Registration Form Management</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="RegistrantEmailSend:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Click Submit to begin sending now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Note: It might take several minutes to send all the emails.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</i></font></paragraph></text>
</items>
