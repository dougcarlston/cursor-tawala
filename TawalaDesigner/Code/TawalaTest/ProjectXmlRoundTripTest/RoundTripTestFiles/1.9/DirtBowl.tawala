<form name="SeasonLaunchMgmt" startPoint="false" themePath="dirtbowl2" process="Post-SeasonLaunchMgmt" preProcess="RetrieveAdminSetupVariables">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Season Launch Countdown</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="600"><row><cell width="510"><division indent="0" align="left"><font><b>1)</b></font></division></cell><cell width="7035"><division indent="0" align="left"><font><b>Required number of teams set up:</b></font></division></cell><cell width="255"></cell><cell width="555"><division indent="0" align="left"><font><field name="TeamCountChecked"/></font></division></cell></row><row><cell width="510"><division indent="0" align="left"><font><b>2)</b></font></division></cell><cell width="7035"><division indent="0" align="left"><font><b>All teams have enough assigned players:</b></font></division></cell><cell width="255"></cell><cell width="555"><division indent="0" align="left"><font><field name="RosterChecked"/></font></division></cell></row><row><cell width="510"><division indent="0" align="left"><font><b>3)</b></font></division></cell><cell width="7035"><division indent="0" align="left"><font><b>All players placed on teams:</b></font></division></cell><cell width="255"></cell><cell width="555"><division indent="0" align="left"><font><field name="AllPlayersAssignedChecked"/></font></division></cell></row><row><cell width="510"><division indent="0" align="left"><font><b>4)</b></font></division></cell><cell width="7035"><division indent="0" align="left"><font><b>Team Assignments sent to players:</b></font></division></cell><cell width="255"></cell><cell width="555"><division indent="0" align="left"><font><field name="PlayersNotified"/></font></division></cell></row><row><cell width="510"><division indent="0" align="left"><font><b>5)</b></font></division></cell><cell width="7035"><division indent="0" align="left"><font><b>Roster lists and dashboards sent to coaches:</b></font></division></cell><cell width="255"></cell><cell width="555"><division indent="0" align="left"><font><field name="CoachesNotified"/></font></division></cell></row><row><cell width="510"><division indent="0" align="left"><font><b>6)</b></font></division></cell><cell width="7035"><division indent="0" align="left"><font><b>Remove unused team names and mark countdown complete</b></font></division></cell><cell width="255"></cell><cell width="555"><division indent="0" align="left"><font><field name="PreSeasonCheckupComplete"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check that required number of teams has been set up and that they have enough players </font><font face="Arial" size="200" color="000000"><b>(Steps 1 &amp; 2)</b></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check that all players have been assigned to teams </font><font face="Arial" size="200" color="000000"><b>(Step 3)</b></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send team assignments to players </font><font face="Arial" size="200" color="000000"><b>(Step 4)</b></font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send roster notices and dashboards to coaches </font><font face="Arial" size="200" color="000000"><b>(Step 5)</b></font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check that all pre-season tasks in countdown are complete </font><font face="Arial" size="200" color="000000"><b>(Step 6)</b></font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="SeasonLaunchMgmt:Q1">
<string value="a"/>
</mcDoesNotEqual>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Check rosters and player lists</font></paragraph></heading>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="SeasonLaunchMgmt" project="">Back to Launch Countdown</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<fib label="Q2" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Minimum number of players permitted on a team:  </font><blank label="a" length="7" required="false" alternateLabel="MinPlayers"/></paragraph></fib>
<fib label="Q3" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Minimum number of fully rostered teams permitted in league:  </font><blank label="a" length="8" required="false" alternateLabel="MinTeamCount"/></paragraph></fib>
</items>
</form>
<form name="PlayerAssignmentEmail" startPoint="false" themePath="dirtbowl2" dataEntryOnly="true" process="Post-PlayerAssignmentEmail">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Team Assignment Notification</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3570"><division indent="0" align="left"><font color="0066CC"><u><invitation form="SeasonLaunchMgmt" project="">Back to Launch Countdown</invitation></u></font></division></cell><cell width="3630"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This tool permits you send a personal email to the parents of each player containing his or her team assignment and coach contact information along with whatever other information you choose to add (such as, for example, a link to the season schedule Web page).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Fill in the blanks below.  The parts of the letter that are composed by the Dirt Bowl program are inserted so you can see how the overall letter will read.</font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(name): </i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromAdminName"/></paragraph></fib>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email): </i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject:  </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear Parents of &lt;First Name of Player&gt;,</font></paragraph></text>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the first part of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Your team this season is &lt;TeamName&gt;, and your coach is &lt;CoachName&gt;.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>[A link to the player's </font><font color="0000FF"><u>Player Dashboard</u></font><font> will appear here.]</font></paragraph></text>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the closing of your message, including your signoff </font><font face="Arial" size="200" color="000000"><i>(e.g. Yours,  Kerry)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<break/>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="SeasonLaunchMgmt" project="">Back to Launch Countdown</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T6" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="555"><row><cell width="10245"><division indent="0" align="left"><font><b>To: </b></font><font> Parents of &lt;Player Name&gt;</font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><b>From</b></font><font>: </font><font><field name="PlayerAssignmentEmail:FromAdminName"/></font><font> (</font><font><field name="PlayerAssignmentEmail:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="PlayerAssignmentEmail:Subject"/></font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font>Dear &lt;Player's First Name&gt;,</font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><field name="PlayerAssignmentEmail:Body"/></font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font>Your team this season is &lt;TeamName&gt;, and your coach is &lt;CoachName&gt;.</font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font>Here is a link to </font><font color="0000FF"><u>your private Dirt Bowl Dashboard.</u></font><sp/><font><field name="DashboardLinkVerbiage"/></font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><field name="DashboardLinkVerbiage2"/></font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><field name="PlayerAssignmentEmail:Close"/></font></division></cell></row></table></text>
<mc label="Q6" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Season Launch Countdown</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="PlayerAssignmentEmail:Q6" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T7" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Click Submit to begin sending now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Note: It might take several minutes to send all the emails.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</i></font></paragraph></text>
</items>
</form>
<form name="CoachRosterNotice" startPoint="false" themePath="dirtbowl2" dataEntryOnly="true" process="Post-CoachRosterNotice">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Coach's Team and Roster Notification</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3555"><division indent="0" align="left"><font color="0066CC"><u><invitation form="SeasonLaunchMgmt" project="">Back to Launch Countdown</invitation></u></font></division></cell><cell width="3645"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This tool permits you to send a personal email to each coach containing his team assignment and Dashboard link.  On his Dashboard, he will find detailed information about his team roster, including contact information for all of the players.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You may also pass along whatever other information you choose (such as, for example, a link to the season schedule Web page)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Fill in the blanks below.  The parts of the letter that are composed by the Dirt Bowl program are inserted so you can see how the overall letter will read.</font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(name): </i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromAdminName"/></paragraph></fib>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email): </i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject:  </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear &lt;First Name of Coach&gt;,</font></paragraph></text>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the first part of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will be the coach for &lt;TeamName&gt; in this season's Dirt Bowl League.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can find important contact information for your team and the League on your personal </font><font color="0000FF"><u>Dirt Bowl Coach Dashboard</u></font><font>.  The Dashboard will also permit you to communicate easily with your team members and keep track of various responsibilities during the season.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DashboardLinkVerbiage2"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Once again, in order to gain access to your coaching tools for this season's Dirt Bowl, click on this link:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF"><u>Dirt Bowl Coach Dashboard</u></font></paragraph></text>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the closing of your message, including your signoff </font><font face="Arial" size="200" color="000000"><i>(e.g. Yours,  Kerry)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<break/>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="SeasonLaunchMgmt" project="">Back to Launch Countdown</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T6" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="540"><row><cell width="10260"><division indent="0" align="left"><font><b>To: </b></font><font>&lt;Coach's Name&gt;</font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><b>From: </b></font><font><field name="CoachRosterNotice:FromAdminName"/></font><font> (</font><font><field name="CoachRosterNotice:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><b>Subject:</b></font><sp/><font><field name="CoachRosterNotice:Subject"/></font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font>Dear &lt;Coach's First Name&gt;,</font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/><sp/><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><field name="CoachRosterNotice:Body"/></font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/><sp/><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font>You will be the coach for &lt;TeamName&gt; in this season's Dirt Bowl League.</font></division><division indent="0" align="left"><sp/></division><division indent="0" align="left"><font>You can find important contact information for your team and the League on your personal </font><font color="0000FF"><u>Dirt Bowl Coach Dashboard</u></font><font>.  The Dashboard will also permit you to communicate easily with your team members and keep track of various responsibilities during the season.</font></division><division indent="0" align="left"><sp/></division><division indent="0" align="left"><font><field name="DashboardLinkVerbiage2"/></font></division><division indent="0" align="left"><sp/></division><division indent="0" align="left"><font>Once again, in order to gain access to your coaching tools for this season's Dirt Bowl, click on this link:</font></division><division indent="720" align="left"><sp/></division><division indent="720" align="left"><font color="0000FF"><u>Dirt Bowl Coach Dashboard</u></font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><field name="CoachRosterNotice:Close"/></font></division></cell></row></table></text>
<mc label="Q6" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send the email out</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Season Launch Countdown</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Administrator Dashboard</font></paragraph></choice></mc>
<text label="T7" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It might take several minutes to send all the emails. Please wait for the next page to appear; do not click "Submit" again! </font></paragraph></text>
</items>
</form>
<form name="ShowTeamRosters" startPoint="false" themePath="dirtbowl2" process="Post-ShowTeamRosters">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Team Rosters</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Team Rosters" project="">Assign Players to Teams</invitation></u></font></division></cell></row></table></text>
<mc label="Q1" alternateLabel="TeamId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select a team to view the roster:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Team" /></record-selector></dynamic-mcq></data-provider></mc>
<break/>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Team Rosters" project="">Assign Players to Teams</invitation></u></font></division></cell></row></table></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>6</number-of-columns><column><header>Team</header><contents><field name="Record:Registration:TeamId" /></contents></column><column><header>First</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header>Last</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header>Parent</header><contents><field name="Record:Registration:ParentFirstName" /></contents></column><column><header>Phone</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header>Jersey Size</header><contents><field name="Record:Registration:UniformSize" /></contents></column><conditions><form name="Registration" /><conditions>
<mcEquals field="ShowTeamRosters:TeamId">
<string field="Record:Registration:TeamId"/>
</mcEquals>
</conditions></conditions></itemization-table></font></paragraph></text>
</items>
</form>
<form name="ShowCoachTeamRoster" startPoint="false" themePath="dirtbowl2" process="Post-ShowCoachTeamRoster">
<items>
