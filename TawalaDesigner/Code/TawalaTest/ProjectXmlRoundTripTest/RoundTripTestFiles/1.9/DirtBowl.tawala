<form name="EditRecruitment" startPoint="false" themePath="dirtbowl2" process="Post-EditRecruitment" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Edit Recruitment Records</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="B40000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria:  </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<comment>-- no space characters allowed; we can't handle substrings for searching on multiple fields</comment>
<if>
<conditions>
<contains field="EditRecruitment:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word, or part of a word to search on. Multiple word searches are not supported."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Edit Recruitment Records</font></paragraph></heading>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3360"><division indent="0" align="left"><font color="0066CC"><u><invitation form="EditRecruitment" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3840"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RecruitmentId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the record to edit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:LastName"/>
<string value=", "/>
<field name="Record:RecruitmentDB:FirstName"/>
<string value=" ("/>
<field name="Record:RecruitmentDB:Email"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentId"/>
</value-expression><sort-expression><field name="Record:RecruitmentDB:LastName"/>
<string value="#"/>
<field name="Record:RecruitmentDB:FirstName"/>
</sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<or>
<contains field="Record:RecruitmentDB:FirstName">
<string field="EditRecruitment:SearchString"/>
</contains>
<or>
<contains field="Record:RecruitmentDB:LastName">
<string field="EditRecruitment:SearchString"/>
</contains>
<contains field="Record:RecruitmentDB:Email">
<string field="EditRecruitment:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="DeleteRecruitment" startPoint="false" themePath="dirtbowl2" process="Post-DeleteRecruitment" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="B40000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria:  </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<comment>-- no space characters allowed; we can't handle substrings for searching on multiple fields</comment>
<if>
<conditions>
<contains field="DeleteRecruitment:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word, or part of a word to search on. Multiple word searches are not supported."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3255"><division indent="0" align="left"><font color="0066CC"><u><invitation form="DeleteRecruitment" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3945"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="5720"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RecruitmentIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the record(s) to delete</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:LastName"/>
<string value=", "/>
<field name="Record:RecruitmentDB:FirstName"/>
<string value=" ("/>
<field name="Record:RecruitmentDB:Email"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentId"/>
</value-expression><sort-expression><field name="Record:RecruitmentDB:LastName"/>
<string value="#"/>
<field name="Record:RecruitmentDB:FirstName"/>
</sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<or>
<contains field="Record:RecruitmentDB:FirstName">
<string field="DeleteRecruitment:SearchString"/>
</contains>
<or>
<contains field="Record:RecruitmentDB:LastName">
<string field="DeleteRecruitment:SearchString"/>
</contains>
<contains field="Record:RecruitmentDB:Email">
<string field="DeleteRecruitment:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="DeleteRecruitment:RecruitmentIds" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H3" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The following recruitment record(s) will be deleted:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>4</number-of-columns><column><header>First Name</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header>Last Name</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header>Email</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header>Email 2</header><contents><field name="Record:RecruitmentDB:Email2" /></contents></column><conditions><form name="RecruitmentDB" /><conditions>
<mcContains field="DeleteRecruitment:RecruitmentIds">
<string field="Record:RecruitmentDB:RecruitmentId"/>
</mcContains>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q3" alternateLabel="Confirm" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes, delete this record(s)</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, I would like to keep them</font></paragraph></choice></mc>
</items>
</form>
<form name="EditRegistration" startPoint="false" themePath="dirtbowl2" process="Post-EditRegistration" preProcess="Pre-EditOrDeleteRegistration">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>View or Edit Player Records</font><font face="Arial" size="200" color="000000"> / Waivers</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="B40000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria:  </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<comment>-- no space characters allowed; we can't handle substrings for searching on multiple fields</comment>
<if>
<conditions>
<contains field="EditRegistration:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word, or part of a word to search on. Multiple word searches are not supported."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>View or Edit Player Records</font><font face="Arial" size="200" color="000000"> / Waivers</font></paragraph></heading>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3390"><division indent="0" align="left"><font color="0066CC"><u><invitation form="EditRegistration" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3810"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RegistrationId" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player to view/edit, then click the SUBMIT button:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<or>
<contains field="Record:Registration:FirstName">
<string field="EditRegistration:SearchString"/>
</contains>
<or>
<contains field="Record:Registration:LastName">
<string field="EditRegistration:SearchString"/>
</contains>
<contains field="Record:Registration:ParentEmail">
<string field="EditRegistration:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="800000"><b>You can use your browser's BACK button to return to this screen if you decide not to edit the record.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="800000"><b>To view the </b></font><font color="800000"><b><i>Medical Waiver</i></b></font><font color="800000"><b> for the player, click the Submit button on the Registration Form and continue past the confirmation page.</b></font></paragraph></text>
</items>
</form>
<form name="DeleteRegistration" startPoint="false" themePath="dirtbowl2" process="Post-DeleteRegistration" preProcess="Pre-EditOrDeleteRegistration">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Player Records</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="B40000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria:  </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<comment>-- no space characters allowed; we can't handle substrings for searching on multiple fields</comment>
<if>
<conditions>
<contains field="DeleteRegistration:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word, or part of a word to search on. Multiple word searches are not supported."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Player Records</font></paragraph></heading>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="DeleteRegistration" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administration Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RegistrationIds" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the records to delete:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<or>
<contains field="Record:Registration:FirstName">
<string field="DeleteRegistration:SearchString"/>
</contains>
<or>
<contains field="Record:Registration:LastName">
<string field="DeleteRegistration:SearchString"/>
</contains>
<contains field="Record:Registration:ParentEmail">
<string field="DeleteRegistration:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="DeleteRegistration:RegistrationIds" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H3" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Player Records</font></paragraph></heading>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The following record(s) will be deleted:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>5</number-of-columns><column><header>First Name</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header>Last Name</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header>Email</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header>Preferred Coach</header><contents><field name="Record:Registration:PreferredCoach" /></contents></column><column><header>Friends</header><contents><field name="Record:Registration:FriendsList" /></contents></column><conditions><form name="Registration" /><conditions>
<mcContains field="DeleteRegistration:RegistrationIds">
<string field="Record:Registration:RegID"/>
</mcContains>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q3" alternateLabel="Confirm" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes, delete the record(s)</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, I made the wrong selection and would like to select other record(s)</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, cancel this action entirely</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="DeleteRegistration:Confirm">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
</items>
</form>
<form name="FinishPaymentAndWaiverReceipts" startPoint="false" themePath="dirtbowl2" process="Post-FinishPaymentAndWaiverReceipt" preProcess="Pre-FinishPaymentAndWaiverReceipt">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Unmark Waiver or Payment Receipts</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4140"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver and Payment Management</invitation></u></font></division></cell><cell width="3420"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormManagement" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current Status:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>5</number-of-columns><column><header>First Name</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header>Last Name</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header>Email</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header>Payment Received</header><contents><field name="Record:Registration:PaymentReceived" /></contents></column><column><header>Waiver Received</header><contents><field name="Record:Registration:WaiverReceived" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:RegID">
<string field="ConfirmPaymentAndWaiverReceipts:UnmarkReceipts"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Uncheck  to unmark or check to mark:</font></paragraph></text>
<mc label="Q1" alternateLabel="Waiver Received" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Waiver received</font></paragraph></choice></mc>
<mc label="Q2" alternateLabel="Payment Received" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Payment received</font></paragraph></choice></mc>
</items>
</form>
<form name="NavigationToPaymentByCheck" startPoint="false" themePath="dirtbowl2" process="Post-NavigationToPaymentByCheck" preProcess="RetrieveAdminSetupVariables">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="RefreshAdminDash" startPoint="false" themePath="dirtbowl2" process="Post-RefreshAdminDash" preProcess="UpdatePaidStatusBasedOnInvoiceStatus">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="ParentCoaches" startPoint="false" themePath="dirtbowl2" process="Post-ParentCoaches">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">If you see a list below, it contains parents who have volunteered to coach. Select one to add him/her as a coach.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To add a coach whose name is </font><font face="Arial" size="200" color="000000"><b><i>not</i></b></font><font face="Arial" size="200" color="000000"> on the list, just click Submit without making a selection.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:ParentLastName"/>
<string value=", "/>
<field name="Record:Registration:ParentFirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:ParentLastName"/>
<string value="#"/>
<field name="Record:Registration:ParentFirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<equals field="Record:Registration:CoachVolunteer">
<string value="Available"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="UtilityToSetPlayerAges" startPoint="false" themePath="dirtbowl2" process="Post-UtilityToSetPlayerAges">
<items>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility passes through all the Registration records and calculates the </font><font><i>Player Ages</i></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: You only need to run this if the method of calculation </b></font><font><b><i>Player Age</i></b></font><font><b> has been changed in the Post-Registration  Process.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility fixes up the </font><font><i>Player Age</i></font><font> field in all registrations posted prior to the change.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Click </font><font><b><i>Submit</i></b></font><font> to run the utility.</font></paragraph></text>
</items>
</form>
<form name="AdminShowWaiver" startPoint="false" themePath="dirtbowl2" process="Post-AdminShowWaiver">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph></text>
<mc label="Q1" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Display the Waiver form for </font><font face="Arial" size="200" color="000000"><field name="Registration:FirstName"/></font><font face="Arial" size="200" color="000000"><field name="Registration:LastName"/></font></paragraph></choice></mc>
</items>
</form>
<form name="DuplicateRegistrationCheck" startPoint="false" themePath="dirtbowl2" process="Post-DuplicateRegistrationCheck">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: Because of various issues with duplicate records, this utility is not currently available via the Administrator's Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It will check for duplicate First and Last Names of players in the registration database. It does not check for duplicate Registration IDs.</font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
</forms>
<processes>
<process name="Post-Registration">
<comment>-- If the session expires we need to re-read the setup variables</comment>
<get recordList="SetupRecords">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="Admin" recordList="SetupRecords">
<set field="AdminName" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminsName"/>
</set>
<set field="AdminEmail" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminsEmail"/>
</set>
<set field="AdminAdrss" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminAddress"/>
</set>
<set field="AdminsCity" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminCity"/>
</set>
<set field="AdminState" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminST"/>
</set>
<set field="AdminsZIP" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminZIP"/>
</set>
<set field="League" arithmeticAsText="false">
<string field="Admin:AdminSetup:LeagueName"/>
</set>
<set field="SeasonYr" arithmeticAsText="false">
<string field="Admin:AdminSetup:Season"/>
</set>
<set field="SignupFeeForIndividual" arithmeticAsText="false">
<string field="Admin:AdminSetup:IndividualSignupFee"/>
</set>
<set field="PaymentChargeDescription" arithmeticAsText="false">
<string field="Admin:AdminSetup:ChargeDescription"/>
</set>
</foreach>
<if>
<conditions>
<isGreaterThan field="Registration:RegAgeMo">
<string value="8"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="Registration:PlayerAge" arithmeticAsText="false">
<sub>
<sub>
<operand field="SeasonYr"/>
<operand field="Registration:RegAgeYr"/>
</sub>
<operand value="1"/>
</sub>
</set>
</trueSet>
<falseSet>
<set field="Registration:PlayerAge" arithmeticAsText="false">
<sub>
<operand field="SeasonYr"/>
<operand field="Registration:RegAgeYr"/>
</sub>
</set>
</falseSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SexMCQ" value="a"/>
</conditions>
<trueSet>
<set field="Registration:Sex" arithmeticAsText="false">
<string value="Boy"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SexMCQ" value="b"/>
</conditions>
<trueSet>
<set field="Registration:Sex" arithmeticAsText="false">
<string value="Girl"/>
</set>
</trueSet>
</if>
<comment>-- if parent has checked the "willing to coach" box</comment>
<if>
<conditions>
<mcContains field="Registration:ParentWillingToCoach" value="a"/>
</conditions>
<trueSet>
<comment>-- and they are not already signed up as a coach</comment>
<get recordList="MatchingCoachList">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<or>
<equals field="MatchingCoachList:Coach:Email">
<string field="Registration:ParentEmail"/>
</equals>
<equals field="MatchingCoachList:Coach:Email">
<string field="Registration:ParentEmail2"/>
</equals>
</or>
</conditions></get>
<foreach record="MatchingCoach" recordList="MatchingCoachList">
<if>
<conditions>
<isNotBlank field="MatchingCoach:Coach:Email" />
</conditions>
<trueSet>
<set field="Registration:CoachVolunteer" arithmeticAsText="false">
<string value="RegisteredCoach"/>
</set>
</trueSet>
</if>
</foreach>
<if>
<conditions>
<doesNotEqual field="Registration:CoachVolunteer">
<string value="RegisteredCoach"/>
</doesNotEqual>
</conditions>
<trueSet>
<comment>-- mark them as "available"</comment>
<set field="Registration:CoachVolunteer" arithmeticAsText="false">
<string value="Available"/>
</set>
</trueSet>
</if>
</trueSet>
<falseSet>
<comment>-- in case they unchecked the previously-checked box</comment>
<set field="Registration:CoachVolunteer" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="a"/>
</conditions>
<trueSet>
<set field="Registration:UniformSize" arithmeticAsText="false">
<string value="Youth L"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="b"/>
</conditions>
<trueSet>
<set field="Registration:UniformSize" arithmeticAsText="false">
<string value="Adult S"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="c"/>
</conditions>
<trueSet>
<set field="Registration:UniformSize" arithmeticAsText="false">
<string value="Adult M"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="d"/>
</conditions>
<trueSet>
<set field="Registration:UniformSize" arithmeticAsText="false">
<string value="Adult L"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="e"/>
</conditions>
<trueSet>
<set field="Registration:UniformSize" arithmeticAsText="false">
<string value="Adult XL"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="Registration:RegID" />
</conditions>
<trueSet>
<get recordList="Record List 18">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="RegNo" recordList="Record List 18">
