<pageHeader><image id="__HEADER__8ca3bbc32315760" width="749" height="104"/></pageHeader><forms>
<form name="Registration" startPoint="true" themePath="dirtbowl2" process="Post-Registration" preProcess="RetrieveAdminSetupVariables">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="PaymentStatus" arithmeticAsText="false">
<string value="PAID"/>
</set>
</trueSet>
<falseSet>
<set field="PaymentStatus" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="AddPlayerToGroupRegistration"/>
</equals>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="B30000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="center"><font face="Arial" size="220" color="CC0000"><b><field name="League"/></b></font></paragraph><paragraph indent="0" align="center"><font face="Arial" size="220" color="CC0000"><b><field name="SeasonYr"/></b></font><font face="Arial" size="220" color="CC0000"><b> Summer Basketball League: Games Only</b></font></paragraph><paragraph indent="0" align="center"><font face="Arial" size="180" color="CC0000"><b>Boys and Girls</b></font></paragraph><paragraph indent="0" align="center"></paragraph><paragraph indent="0" align="center"><font face="Arial" size="160" color="000000"><b>YOU ARE INVITED to participate in the Annual "Dirt Bowl" Basketball League and Tournament!</b></font></paragraph><paragraph indent="0" align="center"><font face="Arial" size="160" color="000000"><b>Information below.  If you are age 8-13, please join us!</b></font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200">Athletic Director: </font><font face="Arial" size="200"><field name="AdminName"/></font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="006A00"><b>Sign up as a team or individually.  If you sign up individually, you will be placed on a team.</b></font></paragraph></text>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2160"><division indent="0" align="left"><font color="000000"><b>Registration:</b></font></division></cell><cell width="1785"></cell><cell width="3315"><division indent="0" align="left"><font color="FF0000"><b>Dirt Bowl</b></font></division></cell><cell width="3810"><division indent="0" align="left"><font color="000000">Due date:</font><font color="000000"><b> April 28, 2008</b></font></division></cell></row><row><cell width="2160"></cell><cell width="1785"></cell><cell width="3315"><division indent="0" align="left"><font><field name="AdminAdrss"/></font></division></cell><cell width="3810"></cell></row><row><cell width="2160"></cell><cell width="1785"></cell><cell width="3315"><division indent="0" align="left"><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><sp/><font><field name="AdminsZIP"/></font></division></cell><cell width="3810"></cell></row><row><cell width="2160"></cell><cell width="1785"></cell><cell width="3315"></cell><cell width="3810"><division indent="0" align="left"><font color="FF0000">Cost per player: </font><font color="FF0000"><b>$</b></font><font color="FF0000"><b><field name="SignupFeeForIndividual"/></b></font><sp/></division></cell></row><row><cell width="2160"></cell><cell width="1785"></cell><cell width="3315"><division indent="0" align="left"><font size="320" color="FF0000"><field name="PaymentStatus"/></font></division></cell><cell width="3810"></cell></row></table></text>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="4896"/><tabStop position="8496"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4896"/><tabStop position="8496"/></tabPositions><tab/><font face="Arial" size="200" color="000000"><i>[First]</i></font><tab/><font face="Arial" size="200" color="000000"><i>[Last]</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name of Registrant: </b></font><tab/><blank label="a" length="18" required="false" alternateLabel="FirstName"/><tab/><blank label="b" length="18" required="false" alternateLabel="LastName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000"><b>Date of Birth: </b></font><font face="Arial" size="200" color="000000"><i>(mm/dd/yyyy)</i></font><tab/><blank label="c" length="5" required="false" alternateLabel="RegAgeMo"/><font face="Arial" size="200" color="000000">/</font><blank label="d" length="5" required="false" alternateLabel="RegAgeDay"/><font face="Arial" size="200" color="000000">/</font><blank label="e" length="8" required="false" alternateLabel="RegAgeYr"/></paragraph></fib>
<mc label="Q2" alternateLabel="SexMCQ" onlyone="true" required="false" style="horizontal"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Sex of Registrant:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Boy</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Girl</font></paragraph></choice></mc>
<fib label="Q3"><paragraph indent="0" align="left"><tabPositions><tabStop position="4896"/><tabStop position="8496"/></tabPositions><tab/><font face="Arial" size="200" color="000000"><i>[First]</i></font><tab/><font face="Arial" size="200" color="000000"><i>[Last]</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000"><b>Parent Name: </b></font><tab/><blank label="a" length="18" required="false" alternateLabel="ParentFirstName"/><tab/><blank label="b" length="18" required="false" alternateLabel="ParentLastName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000">Address: </font><tab/><blank label="c" length="39" required="false" alternateLabel="Address"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000">City:</font><tab/><blank label="d" length="39" required="false" alternateLabel="City"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000">Zip:</font><tab/><blank label="e" length="39" required="false" alternateLabel="Zip"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000"><b><u>Parent</u></b></font><font face="Arial" size="200" color="000000"><b> Email:</b></font><tab/><blank label="f" length="39" required="false" alternateLabel="ParentEmail"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000"><b>Parent Email (again):</b></font><tab/><blank label="g" length="39" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="180" color="000000"><b>Additional Parent Email </b></font><font face="Arial" size="180" color="000000">(optional)</font><font face="Arial" size="180" color="000000"><b>:</b></font><tab/><blank label="h" length="39" required="false" alternateLabel="ParentEmail2"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="180" color="000000"><b>Additional</b></font><font face="Arial" size="200" color="000000"><b> Parent Email (again):</b></font><tab/><blank label="i" length="39" required="false" alternateLabel="ParentEmail2Confirm"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="180" color="000000"><i>(All communications will be by email only)</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000"><b>Parent Phone Numbers (for emergencies):</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000">Phone 1:</font><tab/><blank label="j" length="18" required="false" alternateLabel="Phone1"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000">Phone 2:</font><tab/><blank label="k" length="18" required="false" alternateLabel="Phone2"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000">Phone 3:</font><tab/><blank label="l" length="18" required="false" alternateLabel="Phone3"/></paragraph></fib>
<mc label="Q4" alternateLabel="ParentWillingToCoach" onlyone="false" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">If parent is willing to coach a team, please check here.</font></paragraph></choice></mc>
<fib label="Q5" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Preferences:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Coach Preference (if any)</b></font><font face="Arial" size="200" color="000000">:     </font><blank label="a" length="39" required="false" alternateLabel="PreferredCoach"/></paragraph></fib>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Name of friends you would like on your team:</b></font></paragraph></text>
<fib label="Q6" alternateLabel="Friend" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/></tabPositions><font face="Arial" size="200" color="000000">                                                                    </font><blank label="a" length="39" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/></tabPositions><font face="Arial" size="200" color="000000">                                                                    </font><blank label="b" length="39" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/></tabPositions><font face="Arial" size="200" color="000000">                                                                    </font><blank label="c" length="39" required="false"/></paragraph></fib>
<mc label="Q7" alternateLabel="ShirtSize" onlyone="true" required="false" style="horizontal"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>What is your jersey size?</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Youth large</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Adult small</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Adult medium</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Adult large</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Adult extra large</font></paragraph></choice></mc>
<text label="T6" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Medical Information:</b></font></paragraph></text>
<fib label="Q8" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/></tabPositions><font face="Arial" size="200" color="000000"><b>Plan Name: </b></font><tab/><blank label="a" length="39" required="false" alternateLabel="MedPlanName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/></tabPositions><font face="Arial" size="200" color="000000"><b>Plan Number: </b></font><tab/><blank label="b" length="39" required="false" alternateLabel="MedPlanNumber"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/></tabPositions><font face="Arial" size="200" color="000000"><b>Child's Physician:</b></font><tab/><blank label="c" length="39" required="false" alternateLabel="DocName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/></tabPositions><font face="Arial" size="200" color="000000"><b>Physician Phone:</b></font><tab/><blank label="d" length="39" required="false" alternateLabel="DocPhone"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/></tabPositions><font face="Arial" size="200" color="000000"><b>Physician Address:</b></font><tab/><blank label="e" length="39" required="false" alternateLabel="DocAddress"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<or>
<doesNotEqual field="Registration:ParentEmail">
<string field="Registration:Q3:g"/>
</doesNotEqual>
<isBlank field="Registration:ParentEmail" />
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Email address is blank or two copies of email fail to match."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Registration:ParentEmail2" />
</conditions>
<trueSet>
<if>
<conditions>
<doesNotEqual field="Registration:ParentEmail2">
<string field="Registration:ParentEmail2Confirm"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Two copies of additional email fail to match."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<or>
<isBlank field="Registration:FirstName" />
<isBlank field="Registration:LastName" />
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter Registrant&apos;s First and Last names in the spaces provided."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcDoesNotEqual field="Registration:SexMCQ" value="a"/>
<mcDoesNotEqual field="Registration:SexMCQ" value="b"/>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please mark Registrant&apos;s sex."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<isLessThan field="Registration:RegAgeYr">
<string value="100"/>
</isLessThan>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter year of birth as a four digit number (e.g. &quot;1995&quot;)."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="Registration:ShirtSize" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please indicate your jersey size."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SexMCQ" value="a"/>
</conditions>
<trueSet>
<set field="Sx" arithmeticAsText="false">
<string value="Boy"/>
</set>
</trueSet>
<falseSet>
<set field="Sx" arithmeticAsText="false">
<string value="Girl"/>
</set>
</falseSet>
</if>
<set field="Jersey" arithmeticAsText="false">
<string value="Youth large"/>
</set>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="b"/>
</conditions>
<trueSet>
<set field="Jersey" arithmeticAsText="false">
<string value="Adult small"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="c"/>
</conditions>
<trueSet>
<set field="Jersey" arithmeticAsText="false">
<string value="Adult medium"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="d"/>
</conditions>
<trueSet>
<set field="Jersey" arithmeticAsText="false">
<string value="Adult large"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:ShirtSize" value="e"/>
</conditions>
<trueSet>
<set field="Jersey" arithmeticAsText="false">
<string value="Adult extra large"/>
</set>
</trueSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Registration:InfoCorrect" arithmeticAsText="false">
<string value=" "/>
</set>
</skipInstructions>
<text label="T7" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240" color="A00000"><b><i>Please review the information below carefully.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="390"><row><cell width="3210"><division indent="0" align="right"><font><b>Name:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:FirstName"/></font><sp/><font><field name="Registration:LastName"/></font><sp/></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Date of Birth:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:RegAgeMo"/></font><font>/</font><font><field name="Registration:RegAgeDay"/></font><font>/</font><font><field name="Registration:RegAgeYr"/></font><sp/></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Sex:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Sx"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Parent's Name:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:ParentFirstName"/></font><sp/><font><field name="Registration:ParentLastName"/></font><sp/></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Address"/></font></division><division indent="0" align="left"><font><field name="Registration:City"/></font><font>, CA </font><font><field name="Registration:Zip"/></font><sp/></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Parent's Email(s):</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:ParentEmail"/></font><sp/><font><field name="Registration:ParentEmail2"/></font><sp/></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Phone1:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Phone1"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Phone2:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Phone2"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Phone3:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Phone3"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Preferred Coach:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:PreferredCoach"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Preferred Teammates:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:Friend:a"/></font><sp/><font><field name="Registration:Friend:b"/></font><sp/><font><field name="Registration:Friend:c"/></font><sp/></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Jersey Size:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Jersey"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><sp/><sp/><sp/></division></cell><cell width="285"></cell><cell width="6915"></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Medical Plan:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:MedPlanName"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Plan Number:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:MedPlanNumber"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Doctor's Name:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:DocName"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:DocPhone"/></font></division></cell></row><row><cell width="3210"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="285"></cell><cell width="6915"><division indent="0" align="left"><font><field name="Registration:DocAddress"/></font></division></cell></row></table></text>
<text label="T8"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240" color="A00000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<mc label="Q9" alternateLabel="InfoCorrect" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select an option and click Submit.</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Correct or change the above information.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The above information is correct. Continue to the next step.</font></paragraph></choice></mc>
<skipInstructions>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcEquals field="Registration:InfoCorrect" value="a"/>
</conditions>
<trueSet>
<skip to="T2"/>
</trueSet>
<falseSet>
<if>
<conditions>
<mcDoesNotEqual field="Registration:InfoCorrect" value="b"/>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Select an option below and click Submit."/>
</set>
<set field="Registration:InfoCorrect" arithmeticAsText="false">
<string value=" "/>
</set>
<skip to="T7"/>
</trueSet>
</if>
</falseSet>
</if>
