</and>
</conditions></conditions></record-count></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font><i>Upon each new registration:</i></font></division></cell><cell width="255"></cell><cell width="510"><division indent="0" align="left"><font face="Arial" size="200"><field name="FlagA"/></font></division></cell><cell width="510"></cell><cell width="4635"><division indent="0" align="right"><font>Registrations:</font></division></cell><cell width="825"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /></conditions></record-count></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font><i>Upon each bulk mailing:</i></font></division></cell><cell width="255"></cell><cell width="510"><division indent="0" align="left"><font face="Arial" size="200"><field name="FlagB"/></font></division></cell><cell width="510"></cell><cell width="4635"><division indent="0" align="right"><font>Waivers turned in:</font></division></cell><cell width="825"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /><conditions>
<isNotBlank field="Record:Registration:WaiverReceived" />
</conditions></conditions></record-count></font></division></cell></row><row><cell width="3735"></cell><cell width="255"></cell><cell width="510"></cell><cell width="510"></cell><cell width="4635"><division indent="0" align="right"><font>Payment received:</font></division></cell><cell width="825"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /><conditions>
<isNotBlank field="Record:Registration:PaymentReceived" />
</conditions></conditions></record-count></font></division></cell></row></table>
