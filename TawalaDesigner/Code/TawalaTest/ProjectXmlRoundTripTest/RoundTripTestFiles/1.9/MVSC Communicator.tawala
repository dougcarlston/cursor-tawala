<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Query"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="c"/>
</equals>
</conditions></conditions></record-count></font><sp/><font><field name="AnsC"/></font><sp/></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>2</number-of-columns><column><header>Name</header><contents><field name="Record:DataBase:Name" /></contents></column><column><header>Email</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /><conditions>
