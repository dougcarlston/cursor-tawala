<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T6"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Query"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>a = "</font><font><field name="AnsA"/></font><font face="Arial" size="200" color="000000">"</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>b = "</font><font><field name="AnsB"/></font><font face="Arial" size="200" color="000000">" </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>c = "</font><font><field name="AnsC"/></font><font face="Arial" size="200" color="000000">"</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>3</number-of-columns><column><header>Name</header><contents><field name="Record:DataBase:Name" /></contents></column><column><header>Email</header><contents><field name="Record:DataBase:Email Address" /></contents></column><column><header>Response</header><contents><field name="Record:DataBase:Response" /></contents></column><conditions><form name="DataBase" /></conditions></itemization-table></font><sp/></paragraph></text>
</items>
</form>
<form name="Utilities" startPoint="false" themePath="mvsc" process="Post-Utilities">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">List Management</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View the list</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add a record to the list</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit/delete record</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Audit emails for validity</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Main Menu</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Utilities:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="Q2"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Utilities:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>You may sort the list by clicking on either heading.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>2</number-of-columns><column><header>Name</header><contents><field name="Record:DataBase:Name" /></contents></column><column><header>Email</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /></conditions></itemization-table></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>Press Submit to return to main List Management menu.</i></font></paragraph></text>
<skipInstructions>
<skip to="T1"/>
</skipInstructions>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter </font><font face="Arial" size="200" color="000000"><b><i>part or all of the email</i></b></font><font face="Arial" size="200" color="000000"> of the record you want to edit or delete: </font><font face="Arial" size="200" color="000000"><i>(leave blank to see entire list)</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="20" required="false" alternateLabel="TargetEmail"/></paragraph></fib>
</items>
</form>
<form name="MessageUnsent" startPoint="false" themePath="mvsc" process="Post-MessageUnsent">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="950000"><i>Your previous message has not yet been sent.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="950000"><i>Here is what it looks like:</i></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2685"><division indent="0" align="right"><font><b>To:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="Recipient"/></font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>From:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="FromN"/></font><font> (</font><font><field name="FromE"/></font><font>)</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>Date:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font>Today</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>Subject:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="Sub"/></font></division></cell></row><row><cell width="2685"></cell><cell width="272"></cell><cell width="7843"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><font><field name="BodyStart"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="Query"/></font></division><division indent="720" align="left"><font><field name="AnsA"/></font></division><division indent="720" align="left"><font><field name="AnsB"/></font></division><division indent="720" align="left"><font><field name="AnsC"/></font></division></cell></row><row><cell width="10800"></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="BodyClose"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Are you sure that you want to abandon this effort and start over?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes, throw this email message away</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, I want to edit or send this email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Just return me to the Main Menu please</font></paragraph></choice></mc>
</items>
</form>
<form name="MessageAlreadySent" startPoint="false" themePath="mvsc" process="Post-MessageAlreadySent">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="950000"><i>Your previous message has already been sent out at least once.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="950000"><i>Here is what it looks like.</i></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2685"><division indent="0" align="right"><font><b>To:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="Recipient"/></font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>From:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="FromN"/></font><font> (</font><font><field name="FromE"/></font><font>)</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>Date:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font>Today</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>Subject:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="Sub"/></font></division></cell></row><row><cell width="2685"></cell><cell width="272"></cell><cell width="7843"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><font><field name="BodyStart"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="Query"/></font></division><division indent="720" align="left"><font><field name="AnsA"/></font></division><division indent="720" align="left"><font><field name="AnsB"/></font></division><division indent="720" align="left"><font><field name="AnsC"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="BodyClose"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Are you sure that you want to send or edit it again? </font><font face="Arial" size="200" color="000000"><i>(Responses will be added to previous ones in reports)</i></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, that wasn't my intent.  Please return to Main Menu.</font></paragraph></choice></mc>
</items>
</form>
<form name="Thanks" startPoint="false" themePath="mvsc" process="Post-Thanks" preProcess="Pre-Thanks">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Thank you for sending us your response!</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b><i>We do have one other request.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the information we have for you in our records.  Would you please </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>help us keep it up to date?</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To change or add information just fill in the appropriate field and press </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Submit </font><font><i>(leave alone to keep as is)</i></font></paragraph></text>
<fib label="Q1" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name:</b></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="20" required="false" alternateLabel="NewName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Email: </b></font><blank label="b" length="20" required="false" alternateLabel="NewEmail"/></paragraph></fib>
</items>
</form>
<form name="EditDelete" startPoint="false" themePath="mvsc" process="Post-EditDelete">
<items>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark record that you wish to edit or delete:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:DataBase:Name"/>
<string value="    ("/>
<field name="Record:DataBase:Email Address"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:DataBase:Email Address"/>
</value-expression><record-selector><form name="DataBase" /><conditions>
<contains field="Record:DataBase:Email Address">
<string field="Target"/>
</contains>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="EditDelete1" startPoint="false" themePath="mvsc" process="Post-EditDelete1" preProcess="Pre-EditDelete1">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>2</number-of-columns><column><header>Name</header><contents><field name="Record:DataBase:Name" /></contents></column><column><header>Email</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Email Address">
<string field="EditDelete:Q1"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit this record</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete this record</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="EditDelete1:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="T3"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="EditDelete1:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the information in the record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To change or add information, just fill in the appropriate field and press Submit </font><font><i>(leave alone to keep as is)</i></font></paragraph></text>
<fib label="Q2" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name:  </b></font><sp/><blank label="a" length="20" required="false" alternateLabel="AltName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Email:   </b></font><blank label="b" length="20" required="false" alternateLabel="AltEmail"/></paragraph></fib>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the record to be deleted:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>2</number-of-columns><column><header>Name</header><contents><field name="Record:DataBase:Name" /></contents></column><column><header>Email</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Email Address">
<string field="EditDelete:Q1"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q3" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Are you sure?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, leave as is</font></paragraph></choice></mc>
</items>
</form>
<form name="Audit1" startPoint="false" themePath="mvsc" process="Post-Audit1">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Audit Emails</font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility checks the entire contact list for valid email addresses.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds a record with more than one valid email or with none, it will give you a chance to edit it so that it will work properly with the Communicator.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit, delete or pass each record that fails the audit test.</font></paragraph></text>
<text label="T3" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: Some good emails may be marked as questionable, particularly ones from unusual domains.  Do </font><font><b>NOT</b></font><font> assume that a flagged record is bad until you check it manually.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return</font></paragraph></choice></mc>
</items>
</form>
<form name="Audit2" startPoint="false" themePath="mvsc" process="Post-Audit2" preProcess="Pre-Audit2">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Audit Emails</font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Audit has flagged </font><font><field name="Count"/></font><font> record(s) as suspicious.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This record was flagged:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Name:</b></font><sp/><sp/><font><field name="Recipient"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Email:   </b></font><font><field name="Email"/></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit this record</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete this record</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark this email as valid</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Break off Audit for now, leaving this record unchanged</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Audit2:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="T4"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Audit2:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Edit Record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To change or add information, just fill in the appropriate field and press Submit </font><font><i>(leave a field alone to keep as is)</i></font></paragraph></text>
<fib label="Q2" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name:</b></font><font face="Arial" size="200" color="000000">  </font><blank label="a" length="20" required="false" alternateLabel="ChangeName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Email:</b></font><font face="Arial" size="200" color="000000">  </font><blank label="b" length="20" required="false" alternateLabel="ChangeEmail"/></paragraph></fib>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Record to delete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Name:</b></font><sp/><sp/><font><field name="Recipient"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Email:</b></font><sp/><sp/><font><field name="Email"/></font></paragraph></text>
<mc label="Q3" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Are you sure?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, leave as is</font></paragraph></choice></mc>
</items>
</form>
</forms>
<processes>
<process name="Post-Start">
<if>
<conditions>
<mcEquals field="Start:Q1" value="a"/>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="PrevMessage">
<string value="No"/>
</equals>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="No prior communication found."/>
</set>
<show document="Message" reset="false"/>
<show form="Start"/>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="PrevMsgSent">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
