<?xml version="1.0" encoding="utf-8" ?>
<project name="MVSC Communicator" themePath="mvsc" format="1.9" designerBuild="194">
<pageHeader><image id="__HEADER__8ca678329f626b0" width="691" height="78"/></pageHeader><styles fibItemStyle="leftAlignLabelsJustified" /><forms>
<form name="Start" startPoint="true" themePath="mvsc" process="Post-Start" preProcess="Pre-Start">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Communicator</font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility allows you to:</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>-- create a message to send out to the entire MVSC contact list, </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>-- add an optional multiple choice question to that communication, </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>-- review the responses you receive to that question.</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>-- use list management tools to add, edit, delete or audit email records for validity.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current Status:</font></paragraph><table indent="660"><row><cell width="4168"><division indent="0" align="left"><font color="6380B6"><i>Names in Contact Data Base:</i></font></division></cell><cell width="272"></cell><cell width="5700"><division indent="0" align="left"><font color="6380B6"><i><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /></conditions></record-count></i></font></division></cell></row><row><cell width="4168"><division indent="0" align="left"><font color="6380B6"><i>Current Communication in Memory?</i></font></division></cell><cell width="272"></cell><cell width="5700"><division indent="0" align="left"><font color="6380B6"><b><i><field name="PrevMessage"/></i></b></font></division></cell></row><row><cell width="4168"><division indent="0" align="left"><font color="6380B6"><i>Number of responses to current message:</i></font></division></cell><cell width="272"></cell><cell width="5700"><division indent="0" align="left"><font color="6380B6"><i><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<isNotBlank field="Record:DataBase:Response" />
</conditions></conditions></record-count></i></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Review and send current communication to list</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Review responses from current communication</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Compose new communication to send to list </font><font face="Arial" size="200" color="000000"><b><i>(Warning:</i></b></font><font face="Arial" size="200" color="000000"><i> Deletes  prior message and response data)</i></font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">List Management Tools </font><font face="Arial" size="200" color="000000"><i>(View, Add, Edit, Delete and Audit records)</i></font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Quit</font></paragraph></choice></mc>
</items>
</form>
<form name="DataBase" startPoint="false" themePath="mvsc" dataSourceName="MVSC Email List" process="Post-DataBase">
<items>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Add Name to List:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name: </font><blank label="a" length="20" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="b" length="20" required="false"/></paragraph></fib>
<field name="Name"/>
<field name="Email Address"/>
<field name="Response"/>
<field name="BadEmail?"/>
</items>
</form>
<form name="Composer" startPoint="false" themePath="mvsc" process="Post-Composer">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Composer</font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Compose or review your message below, then press the Submit button.  You will still have an opportunity after that to abandon or modify the message before it is sent.</font></paragraph></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>To:</b></font><font face="Arial" size="200" color="000000"> (</font><font face="Arial" size="200" color="000000"><i>e.g. Friends of Mill Valley Soccer Club</i></font><font face="Arial" size="200" color="000000">) </font><blank label="a" length="27" required="false" alternateLabel="To"/></paragraph></fib>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>From:</b></font><sp/><font face="Arial" size="200" color="000000"><i>(Name)</i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="27" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>From:</b></font><sp/><font face="Arial" size="200" color="000000"><i>(Email)</i></font><sp/><blank label="a" length="27" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Subject:</b></font><sp/><blank label="a" length="27" required="false" alternateLabel="Subject"/></paragraph></fib>
<fib label="Q5" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Body of Message:</b></font><sp/><blank label="a" length="61" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<fib label="Q6" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Closing:</b></font><font face="Arial" size="200" color="000000"> (</font><font face="Arial" size="200" color="000000"><i>e.g. Yours truly, Jack</i></font><font face="Arial" size="200" color="000000">) </font><blank label="a" length="61" height="5" required="false" alternateLabel="Closing"/></paragraph></fib>
<break/>
<text label="T3" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Your message will look like this:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2775"><division indent="0" align="right"><font><b>To:</b></font></division></cell><cell width="390"></cell><cell width="7635"><division indent="0" align="left"><font><field name="Composer:To"/></font></division></cell></row><row><cell width="2775"><division indent="0" align="right"><font><b>From:</b></font></division></cell><cell width="390"></cell><cell width="7635"><division indent="0" align="left"><font color="000000"><field name="Composer:FromName"/></font><font> (</font><font><field name="Composer:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="2775"><division indent="0" align="right"><font><b>Date:</b></font></division></cell><cell width="390"></cell><cell width="7635"><division indent="0" align="left"><font>Today</font></division></cell></row><row><cell width="2775"><division indent="0" align="right"><font><b>Subject:</b></font></division></cell><cell width="390"></cell><cell width="7635"><division indent="0" align="left"><font><field name="Composer:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><font><field name="Composer:Body"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="Composer:Closing"/></font></division></cell></row><row><cell width="10800"></cell></row></table></text>
<mc label="Q7" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Include a question with the message   </font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this message </font><font face="Arial" size="200" color="000000"><b>without a question attached</b></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit this message further</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Main Menu </font><font face="Arial" size="200" color="000000"><b>without</b></font><font face="Arial" size="200" color="000000"> sending this message for the present</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Composer:Q7" value="c"/>
</conditions>
<trueSet>
<skip to="T1"/>
</trueSet>
</if>
</skipInstructions>
<field name="QuestionAdded?"/>
<field name="Sent?"/>
</items>
</form>
<form name="AddQuestion" startPoint="false" themePath="mvsc" process="Post-AddQuestion" preProcess="Pre-AddQuestion">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Multiple Choice Question</font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Please enter Question here: </font><blank label="a" length="55" required="false" alternateLabel="Question"/></paragraph></fib>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Response Choices: </font><font face="Arial" size="200" color="000000"><i>(leave blank any you don't need)</i></font><sp/><blank label="a" length="20" required="false" alternateLabel="A"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="b" length="20" required="false" alternateLabel="B"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="c" length="20" required="false" alternateLabel="C"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<or>
<isBlank field="AddQuestion:Question" />
<isBlank field="AddQuestion:A" />
</or>
</conditions>
<trueSet>
<skip to="Q3"/>
</trueSet>
</if>
</skipInstructions>
<break/>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Your message will now look like this:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2775"><division indent="0" align="right"><font><b>To:</b></font></division></cell><cell width="390"></cell><cell width="7635"><division indent="0" align="left"><font><field name="Composer:To"/></font></division></cell></row><row><cell width="2775"><division indent="0" align="right"><font><b>From:</b></font></division></cell><cell width="390"></cell><cell width="7635"><division indent="0" align="left"><font><field name="Composer:FromName"/></font><font> (</font><font><field name="Composer:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="2775"><division indent="0" align="right"><font><b>Date:</b></font></division></cell><cell width="390"></cell><cell width="7635"><division indent="0" align="left"><font>Today</font></division></cell></row><row><cell width="2775"><division indent="0" align="right"><font><b>Subject:</b></font></division></cell><cell width="390"></cell><cell width="7635"><division indent="0" align="left"><font><field name="Composer:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><font><field name="Composer:Body"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="AddQuestion:Question"/></font></division></cell></row><row><cell width="10800"><division indent="720" align="left"><font><field name="AddQuestion:A"/></font></division><division indent="720" align="left"><font><field name="AddQuestion:B"/></font></division><division indent="720" align="left"><font><field name="AddQuestion:C"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="Composer:Closing"/></font></division></cell></row></table></text>
<mc label="Q3" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this message as is</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the message further</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the question further</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Main Menu </font><font face="Arial" size="200" color="000000"><b>without</b></font><font face="Arial" size="200" color="000000"> sending this message for the present</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="AddQuestion:Q3" value="c"/>
</conditions>
<trueSet>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="AddQuestion:Q3" />
</conditions>
<trueSet>
<skip to="T2"/>
</trueSet>
</if>
</skipInstructions>
</items>
</form>
<form name="GetResponse1" startPoint="false" themePath="mvsc" process="Post-Response1">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="SendEmail" startPoint="false" themePath="mvsc" process="Post-SendEmail">
<items>
<text label="T1" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note:</b></font><font> If you are sending a large number of emails, the process can take a few minutes.  Please wait until you are returned to the Main Menu upon completion.  Do not click the back arrow, as it may interfere with the successful completion of the mailing.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press </font><font><i>Submit</i></font><font> to begin the mailing.</font></paragraph></text>
</items>
</form>
