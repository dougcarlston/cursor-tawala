<form name="Report" startPoint="false" themePath="mvsc" process="Post-Report">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Start" project="">Return to Main Menu</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>Here are the results from the most recent question:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><field name="Query"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="a"/>
</equals>
</conditions></conditions></record-count></font><sp/><sp/><font><field name="AnsA"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="b"/>
</equals>
</conditions></conditions></record-count></font><sp/><sp/><font><field name="AnsB"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="c"/>
</equals>
</conditions></conditions></record-count></font><sp/><sp/><font><field name="AnsC"/></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>See list of individuals who answered:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">"</font><font face="Arial" size="200" color="000000"><field name="AnsA"/></font><font face="Arial" size="200" color="000000">"</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">"</font><font face="Arial" size="200" color="000000"><field name="AnsB"/></font><font face="Arial" size="200" color="000000">"</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">"</font><font face="Arial" size="200" color="000000"><field name="AnsC"/></font><font face="Arial" size="200" color="000000">"</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>See all responses in a single table</i></font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Report:Q1" value="d"/>
</conditions>
<trueSet>
<skip to="T6"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Report:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Report:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="T4"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Report:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Query"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="a"/>
</equals>
</conditions></conditions></record-count></font><sp/><sp/><font><field name="AnsA"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>2</number-of-columns><column><header>Name</header><contents><field name="Record:DataBase:Name" /></contents></column><column><header>Email</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="a"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
