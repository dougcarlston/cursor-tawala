</forms>
<processes>
<process name="Post-Registration">
<if>
<conditions>
<isBlank field="Registration:Name" />
</conditions>
<trueSet>
<comment>-- Session expired in the process of confirmation</comment>
<set field="Message" arithmeticAsText="false">
<string value="Your session has expired. Please try again."/>
</set>
</trueSet>
</if>
<set field="Registration:TotalAmount" arithmeticAsText="false">
<string value="0"/>
</set>
<if>
<conditions>
<mcEquals field="Registration:FirstCamp">
<string value="a"/>
</mcEquals>
</conditions>
<trueSet>
<set field="Registration:TotalAmount" arithmeticAsText="false">
<add>
<operand field="Registration:TotalAmount"/>
<operand value="290"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:FirstCamp">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<set field="Registration:TotalAmount" arithmeticAsText="false">
<add>
<operand field="Registration:TotalAmount"/>
<operand value="415"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:FirstCamp">
<string value="c"/>
</mcEquals>
</conditions>
<trueSet>
<set field="Registration:TotalAmount" arithmeticAsText="false">
<add>
<operand field="Registration:TotalAmount"/>
<operand value="210"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SecondCamp">
<string value="a"/>
</mcEquals>
</conditions>
<trueSet>
<set field="Registration:TotalAmount" arithmeticAsText="false">
<add>
<operand field="Registration:TotalAmount"/>
<operand value="290"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SecondCamp">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<set field="Registration:TotalAmount" arithmeticAsText="false">
<add>
<operand field="Registration:TotalAmount"/>
<operand value="415"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SecondCamp">
<string value="c"/>
</mcEquals>
</conditions>
<trueSet>
<set field="Registration:TotalAmount" arithmeticAsText="false">
<add>
<operand field="Registration:TotalAmount"/>
<operand value="210"/>
</add>
</set>
</trueSet>
</if>
<show document="OnlinePaymentInstructions" reset="false"/>
<show document="CheckPaymentInstructions" reset="false"/>
</process>
<process name="Post-PaymentSuccessful">
<show document="PaymentSuccessful" reset="false"/>
</process>
<process name="Post-PaymentCancelled">
<show document="PaymentCancelled" reset="false"/>
<show document="CheckPaymentInstructions" reset="false"/>
</process>
<process name="PostOverview">
<show document="Overview" reset="false"/>
</process>
<process name="Post-Administration">
<show document="RegistrationReport" reset="false"/>
</process>
<process name="Post Waiver">
<show document="Waiver Form" reset="false"/>
</process>
</processes>
<documents>
<document name="OnlinePaymentInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Step 2 - Payment</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can pay using a major credit card or your own PayPal account if you have one.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">You do </font><font color="000000"><b>NOT</b></font><font color="000000"> need to have a Paypal account to pay online. All that is required is a major credit card.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">If you wish to pay online, you will need to do so now as you will not be able to return to this page.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will be charged $</font><font><field name="Registration:TotalAmount"/></font><font> . The charge will appear on your credit card statment as "MVSC".</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><paypal-single-item-button version="1"><button-type>pay-logo</button-type><item><string value="MVSC/Rick Fullerton&apos;s Soccer Camps"/>
</item><amount><field name="Registration:TotalAmount"/>
</amount><successful-payment-return-form-name>PaymentSuccessful</successful-payment-return-form-name><cancelled-payment-return-form-name>PaymentCancelled</cancelled-payment-return-form-name><status-field>Record:Registration:PaymentStatus</status-field><amount-field>Record:Registration:PaidAmount</amount-field><style-option>tawala</style-option></paypal-single-item-button></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">For Siblings - Please register and pay separately. Thank You.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you prefer to pay by check:</font></paragraph>
</xmlData>
</document>
<document name="PaymentSuccessful">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Thank you! </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You have Registered Successfully and Paid Online.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="Waiver" project="">Step 3</invitation></u></font><font color="000000"> - Print Waiver to Bring to First Day of Camp</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Or,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="Overview" project="">Return</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph>
</xmlData>
</document>
<document name="PaymentCancelled">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It appears you could not pay online or canceled the online payment.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>No problem, please pay by check:</font></paragraph>
</xmlData>
</document>
<document name="Overview">
<xmlData>
<paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font size="280"><b><i>Welcome from the Camp Director</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear Soccer Enthusiast,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>We invite you to join us for one or two weeks of fun-filled soccer instruction.  We have an incredible staff with some of MVSC's most experienced Competitive Team Coaches.  Our goal is to provide every camp participant with an exciting and unforgettable soccer experience.  Camps are intended for players ages 6-14, including recreational and competitive levels of play.  Emphasis will be on learning and enjoying soccer through a combination of fun exercises and games, in a safe, healthy environment.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>We hope to see you this summer!</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>Rick Fullerton, Camp Director</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><font>* Director, Coaching and Player Development, MVSC</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><font>* Co-Director of Coaching, Marin FC</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><font>* USSF A Licensed</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><font>* NSCAA Premier Diploma</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><font>* Former Assistant Coach, UC Berkeley Division 1 Men's Team</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><font>* 12 years Coaching youth teams in Mill Valley and Marin County, including 3 State Cup Champions and 1 National Finalist</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><font>* Colorado High School Player of the Year</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><font>* Yale University, Division 1 Men's Team, 3rd leading point-getter (combination of points and assists) in  school history</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font color="000000">Camp Dates and Locations:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font color="000000">July 14-18 at Alto Field</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font color="000000">August 18-22 at Hauke South</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font><b><u>Information for Both Camps</u></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2700"><division indent="0" align="right"><font>Time:</font></division></cell><cell width="272"></cell><cell width="5128"><division indent="0" align="left"><font>Full Day: 9am - 3pm</font></division></cell><cell width="2700"></cell></row><row><cell width="2700"></cell><cell width="272"></cell><cell width="5128"><division indent="0" align="left"><font>Half Day: 9am - 12pm</font></division></cell><cell width="2700"></cell></row><row><cell width="2700"></cell><cell width="272"></cell><cell width="5128"></cell><cell width="2700"></cell></row><row><cell width="2700"><division indent="0" align="right"><font>Eligibility:</font></division></cell><cell width="272"></cell><cell width="5128"><division indent="0" align="left"><font>Boys and Girls, ages 6-14</font></division></cell><cell width="2700"></cell></row><row><cell width="2700"></cell><cell width="272"></cell><cell width="5128"></cell><cell width="2700"></cell></row><row><cell width="2700"><division indent="0" align="right"><font>Cost:</font></division></cell><cell width="272"></cell><cell width="5128"><division indent="0" align="left"><font>Full-day Camp, $290 (onsite $300)</font></division></cell><cell width="2700"></cell></row><row><cell width="2700"></cell><cell width="272"></cell><cell width="5128"><division indent="0" align="left"><font>Half-day Camp, $210 (onsite $220)</font></division></cell><cell width="2700"></cell></row><row><cell width="2700"></cell><cell width="272"></cell><cell width="5128"></cell><cell width="2700"></cell></row><row><cell width="2700"><division indent="0" align="right"><font>Extended Care:</font></division></cell><cell width="272"></cell><cell width="5128"><division indent="0" align="left"><font>Available from 3:00 - 5:00, $125 per session</font></division></cell><cell width="2700"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Check in and registration begins at 8:30am.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>*Refunds must be submitted in writing. There is a $30 administrative fee for cancellation.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>To Enroll - Register Online Here</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Step 1 - Fill out Online Registration Form</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Step 2 - Pay Online with Credit Card or Mail in a Check</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Step 3 - Print Waiver and Bring Signed Waiver to First Day of Camp</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="Registration" project="">Click Here to Go to Steps 1 and 2 - Online Registration and Payment</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You Need to Bring a Signed Waiver to the First Day of Camp.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="Waiver" project="">Click Here for the Waiver Form</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Thank you very much.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Rick Fullerton: 415-380-1803</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><link>
<description>
<string value="fullertonsoccer@yahoo.com"/>
</description>
<url>
<string value="mailto:fullertonsoccer@yahoo.com?subject=Summer Camp"/>
</url>
</link>
</u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Mill Valley Soccer Club</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>P.O. Box 138</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Mill Valley, CA 94942</font></paragraph>
</xmlData>
</document>
<document name="CheckPaymentInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Please make checks payable to </font><font><b>MVSC</b></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Mail to:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>MVSC Fullerton Summer Camps</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">Attn: Frank Bonardi</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>P.O. Box 138</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Mill Valley, CA 94942</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">Billing Questions: Frank Bonardi at futsal4u@hotmail.com</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="Overview" project="">Return</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="RegistrationReport">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>All Registrations To-Date:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="1"><number-of-columns>16</number-of-columns><column><header>Name</header><contents><field name="Record:Registration:Name" /></contents></column><column><header>Address</header><contents><field name="Record:Registration:Address" /></contents></column><column><header>City, State, ZIP</header><contents><field name="Record:Registration:CityStateZip" /></contents></column><column><header>Home Phone</header><contents><field name="Record:Registration:HomePhone" /></contents></column><column><header>Emergency Phone</header><contents><field name="Record:Registration:EmergencyPhone" /></contents></column><column><header>Email</header><contents><field name="Record:Registration:Email" /></contents></column><column><header>DOB</header><contents><field name="Record:Registration:DOB" /></contents></column><column><header>Grade</header><contents><field name="Record:Registration:Grade" /></contents></column><column><header>Age</header><contents><field name="Record:Registration:Age" /></contents></column><column><header>Level</header><contents><field name="Record:Registration:Level" /></contents></column><column><header>T Size</header><contents><field name="Record:Registration:T-shirt Size" /></contents></column><column><header>First Camp Choice</header><contents><field name="Record:Registration:FirstCamp" /></contents></column><column><header>Second Camp Choice</header><contents><field name="Record:Registration:SecondCamp" /></contents></column><column><header>Payment Status</header><contents><field name="Record:Registration:PaymentStatus" /></contents></column><column><header>Total</header><contents><field name="Record:Registration:TotalAmount" /></contents></column><column><header>Paid Amount</header><contents><field name="Record:Registration:PaidAmount" /></contents></column><conditions><form name="Registration" /></conditions></itemization-table></font></paragraph>
</xmlData>
</document>
<document name="Waiver Form">
<xmlData>
<paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font size="280"><b>Parental Consent and Medical Waiver</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>I hereby grant permission for my child to participate in MVSC/Rick Fullerton's Soccer Camps. I relieve and do not hold liable MVSC, or its employees for claims from any damage or injuries received while my child participates in MVSC/Rick Fullerton Summer Camps. In the event that I cannot be reached in emergency, I hereby consent to any examination, x-ray, medication, anesthetic, medical and surgical treatment that may be rendered, based on the recommendation of the nearest physician and medical facility.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>_____________________________________________</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Child or Player Name (print name)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>_____________________________________________</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Parent/Guardian (print name)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>_____________________________________________</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Parent/Guardian (signature)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>________________________</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Date</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000"><b>PLEASE PRINT THIS FORM, SIGN IT, AND BRING IT TO THE FIRST DAY OF CAMP.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">IT IS FOR OUR CHILDREN'S SAFETY. THANK YOU.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="Overview" project="">Return</invitation></u></font></paragraph>
</xmlData>
</document>
</documents>
