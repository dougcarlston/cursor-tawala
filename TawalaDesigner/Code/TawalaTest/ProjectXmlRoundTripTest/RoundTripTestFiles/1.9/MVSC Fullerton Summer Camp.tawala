<?xml version="1.0" encoding="utf-8" ?>
<project name="MVSC Fullerton Summer Camp" themePath="mvsc" format="1.9" designerBuild="194">
<pageHeader><image id="__HEADER__8ca82f8451fc9ec" width="620" height="76"/></pageHeader><forms>
<form name="Registration" startPoint="false" themePath="mvsc" process="Post-Registration">
<items>
<heading label="H1" alternateLabel="RegistrationHeader" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Rick Fullerton Summer Camp</font></paragraph></heading>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Registration Form</font></paragraph></heading>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240" color="FF0000"><field name="Message"/></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Player's Name: </font><blank label="a" length="20" required="false" alternateLabel="Name"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Address: </font><blank label="b" length="15" required="false" alternateLabel="Address"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City, State,  Zip Code: </font><blank label="c" length="10" required="false" alternateLabel="CityStateZip"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Home Phone: </font><blank label="d" length="25" required="false" alternateLabel="HomePhone"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Cell Phone/Emergency Contact Phone: </font><blank label="e" length="19" required="false" alternateLabel="EmergencyPhone"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="f" length="22" required="false" alternateLabel="Email"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Confirm Email: </font><blank label="g" length="21" required="false" alternateLabel="ConfirmEmail"/></paragraph></fib>
<fib label="Q2" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Date of Birth: </font><blank label="a" length="12" required="false" alternateLabel="DOB"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000">Grade in Fall: </font><blank label="b" length="8" required="false" alternateLabel="Grade"/><font face="Arial" size="200" color="000000"> Age: </font><blank label="c" length="5" required="false" alternateLabel="Age"/></paragraph></fib>
<mc label="Q3" alternateLabel="Level" onlyone="true" required="false" style="horizontal"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Playing Level:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Rec</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Class 3</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Class 1</font></paragraph></choice></mc>
<mc label="Q4" alternateLabel="T-shirt Size" onlyone="true" required="false" style="horizontal"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">T-shirt Size:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Youth S</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Youth M</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Youth L</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Adult S</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Adult M</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Adult L</font></paragraph></choice></mc>
<mc label="Q5" alternateLabel="FirstCamp" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><u>Day Camp, July 14-18 at Alto Field (80 Lomita in Mill Valley)</u></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Full Day (9am - 3pm) -- $290</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Full Day with Extended Care (9am - 5pm) -- $415</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Half Day (9am - 12pm) -- $210</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">None</font></paragraph></choice></mc>
<mc label="Q6" alternateLabel="SecondCamp" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><u>Day Camp, August 18-22 at Hauke South (Hamilton Drive at Rogue Moraes in Mill Valley)</u></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Full Day (9am - 3pm) -- $290</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Full Day with Extended Care (9am - 5pm) -- $415</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Half Day (9am - 12pm) -- $210</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">None</font></paragraph></choice></mc>
<field name="PaymentStatus"/>
<field name="TotalAmount"/>
<field name="PaidAmount"/>
<skipInstructions>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<or>
<mcIsBlank field="Registration:FirstCamp" />
<mcEquals field="Registration:FirstCamp">
<string value="d"/>
</mcEquals>
</or>
</conditions>
<trueSet>
<set field="FirstCampIsSelected" arithmeticAsText="false">
<string value="No"/>
</set>
</trueSet>
<falseSet>
<set field="FirstCampIsSelected" arithmeticAsText="false">
<string value="Yes"/>
</set>
</falseSet>
</if>
<if>
<conditions>
<or>
<mcIsBlank field="Registration:SecondCamp" />
<mcEquals field="Registration:SecondCamp">
<string value="d"/>
</mcEquals>
</or>
</conditions>
<trueSet>
<set field="SecondCampIsSelected" arithmeticAsText="false">
<string value="No"/>
</set>
</trueSet>
<falseSet>
<set field="SecondCampIsSelected" arithmeticAsText="false">
<string value="Yes"/>
</set>
</falseSet>
</if>
<if>
<conditions>
<and>
<equals field="FirstCampIsSelected">
<string value="No"/>
</equals>
<equals field="SecondCampIsSelected">
<string value="No"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please select at least one camp."/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="Registration:Email" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Email is required."/>
</set>
</trueSet>
<falseSet>
<if>
<conditions>
<doesNotEqual field="Registration:Email">
<string field="Registration:ConfirmEmail"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please make sure email and confirmation email match."/>
</set>
</trueSet>
</if>
</falseSet>
</if>
<if>
<conditions>
<isBlank field="Registration:Name" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Player Name required."/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Message" />
</conditions>
<trueSet>
<skip to="RegistrationHeader"/>
</trueSet>
</if>
<comment>-- I just crazy to do all these assignments. A function may help here. Just bypass confirmation screen for now.</comment>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H3" alternateLabel="ConfirmationHeader" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Review Registration Information</font></paragraph></heading>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3600"><division indent="0" align="right"><font>Player's Name:</font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><field name="Registration:Name"/></font></division></cell></row><row><cell width="3600"><division indent="0" align="right"><font>Address:</font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><field name="Registration:Address"/></font><font>, </font><font><field name="Registration:CityStateZip"/></font><sp/></division></cell></row><row><cell width="3600"><division indent="0" align="right"><font>Home Phone:</font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><field name="Registration:HomePhone"/></font></division></cell></row><row><cell width="3600"><division indent="0" align="right"><font>Cell Phone/Emergency Contact Phone:</font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><field name="Registration:EmergencyPhone"/></font></division></cell></row><row><cell width="3600"><division indent="0" align="right"><font>Email:</font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><field name="Registration:Email"/></font></division></cell></row><row><cell width="3600"><division indent="0" align="right"><font>Date of Birth:</font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><field name="Registration:DOB"/></font></division></cell></row><row><cell width="3600"><division indent="0" align="right"><font>Grade in Fall:</font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><field name="Registration:Grade"/></font></division></cell></row><row><cell width="3600"><division indent="0" align="right"><font>Age:</font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><field name="Registration:Age"/></font></division></cell></row><row><cell width="3600"><division indent="0" align="right"><font>Playing Level:</font></division></cell><cell width="272"></cell><cell width="6928"></cell></row><row><cell width="3600"><division indent="0" align="right"><font>T-shirt Size:</font></division></cell><cell width="272"></cell><cell width="6928"></cell></row><row><cell width="3600"><division indent="0" align="right"><font>July 14-18 Camp Choice:</font></division></cell><cell width="272"></cell><cell width="6928"></cell></row><row><cell width="3600"><division indent="0" align="right"><font>August 18-22 Camp Choice:</font></division></cell><cell width="272"></cell><cell width="6928"></cell></row></table></text>
<mc label="Q7" alternateLabel="Confirm" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">My information is correct. Proceed to payment.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">I would like to update this information.</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Registration:Confirm">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="RegistrationHeader"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="Registration:Confirm" />
</conditions>
<trueSet>
<skip to="ConfirmationHeader"/>
</trueSet>
</if>
</skipInstructions>
</items>
</form>
