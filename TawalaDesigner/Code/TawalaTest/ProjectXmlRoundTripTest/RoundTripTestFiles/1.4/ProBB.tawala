<process name="UrScore">
<get recordList="Record List 1">
<forms>
<form name="Entry"/>
</forms>
<conditions>
<and>
<equals field="Record List 1:Entry:tname">
<string field="UrScore:t2name"/>
</equals>
<equals field="Record List 1:Entry:Week">
<string field="UrScore:Swk"/>
</equals>
</and>
</conditions></get>
<foreach record="Record1" recordList="Record List 1">
<set field="UrScore" arithmeticAsText="false">
<string field="Record1:Entry:Score"/>
</set>
<set field="UrScore1" arithmeticAsText="false">
<string field="Record1:Entry:PScore"/>
</set>
<set field="UrScore2" arithmeticAsText="false">
<string field="Record1:Entry:MScore"/>
</set>
<append document="UrSkor" appendage="VUrSkor"/>
</foreach>
<show document="UrSkor" reset="true"/>
<show form="ToolsBridge"/>
</process>
<process name="UrTeam">
<get recordList="Record List 2">
<forms>
<form name="Entry"/>
</forms>
<conditions>
<and>
<equals field="Record List 2:Entry:tname">
<string field="UrTeam:T3Name"/>
</equals>
<equals field="Record List 2:Entry:Week">
<string field="UrTeam:Twk"/>
</equals>
</and>
</conditions></get>
<foreach record="Record2" recordList="Record List 2">
<set field="UrP1" arithmeticAsText="false">
<string field="Record2:Entry:P1"/>
</set>
<set field="UrP2" arithmeticAsText="false">
<string field="Record2:Entry:P2"/>
