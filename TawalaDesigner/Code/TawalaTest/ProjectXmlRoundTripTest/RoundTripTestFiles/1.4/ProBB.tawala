<form name="ScoringFAQ" startPoint="true" themePath="default" process="FAQ">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">The scoring mechanisms in this game are still being studied. If you have suggestions, please e-mail them to softalk@mac.com</font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Scoring in the Standard game.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="1245"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Points</font></division></cell><cell width="7395"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Category</font></division></cell></row><row><cell width="1245"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="7395"><division indent="0" align="left"><font face="Arial" size="200" color="000000">each point scored</font></division></cell></row><row><cell width="1245"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1.1</font></division></cell><cell width="7395"><division indent="0" align="left"><font face="Arial" size="200" color="000000">each rebound</font></division></cell></row><row><cell width="1245"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="7395"><division indent="0" align="left"><font face="Arial" size="200" color="000000">each assist</font></division></cell></row><row><cell width="1245"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1.1</font></division></cell><cell width="7395"><division indent="0" align="left"><font face="Arial" size="200" color="000000">each steal</font></division></cell></row><row><cell width="1245"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1.1</font></division></cell><cell width="7395"><division indent="0" align="left"><font face="Arial" size="200" color="000000">each block</font></division></cell></row><row><cell width="1245"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1.1 deducted</font></division></cell><cell width="7395"><division indent="0" align="left"><font face="Arial" size="200" color="000000">each turnover</font></division></cell></row></table></text>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Scoring in the Pro game</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">The Pro game is scored by summing the points accrued in the Standard and Master games.</font></paragraph></text>
<text label="T4"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Scoring in the Master game.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">For shooting, rebounds and assists, there are two components to the bonus awarded or the penalty assessed. One component is the quality of the stat and the second component is the frequency with which the stat was obtained. See the details in each category below.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Bonuses for steals and blocks are awarded based on the number achieved. Turnover penalties are assessed based on the number lost.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Bonus for a game-winning shot is a one-time thing.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">The penalties for fouls vary with the infraction.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">This is really all the information you need. Everything below is tedious detail, there so you can immerse yourself in the game if you desire.</font></paragraph></text>
<text label="T5"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>2-point shooting</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">The following minimums apply to this category: Players must play a minimum of 15 minutes to earn bonuses. Player must have a minimum of 4 attempts before they are assessed penalties. Players are awarded basic bonuses for high accuracy and additional bonuses for the rate at which they made shots. Players are assessed penalties for low accuracy and are assessed further penalties for the rate at which they tossed up bad shots. Players who have not earned an accuracy bonuse or have not been assessed an accuracy penalties are not eligible for points based on the rate at which they made or missed shots.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Accuracy Bonus</font></division></cell><cell width="6480"/></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">50%-59.9% shooting accuracy or 1-1 or 2-2</font></division></cell></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">60%-69.9% shooting accuracy</font></division></cell></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">70% or higher shooting accuracy</font></division></cell></row><row><cell width="2160"/><cell width="6480"/></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Accuracy Penalty</font></division></cell><cell width="6480"/></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">40%-30.1% shooting accuracy</font></division></cell></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">30%-20.1% shooting accuracy</font></division></cell></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">20% or lower shooting accuracy</font></division></cell></row><row><cell width="2160"/><cell width="6480"/></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus or Penalty</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">40.1%-49.9% shooting accuracy</font></division></cell></row><row><cell width="2160"/><cell width="6480"/></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Minutes Bonus/Penalty</font></division></cell><cell width="6480"/></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 make or 1 miss per every 8-10 minutes</font></division></cell></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 make or 1 miss per every 4.1-7.9 minutes</font></division></cell></row><row><cell width="2160"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6480"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 make or 1 miss per every 4 or fewer minutes</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 15 against the Lakers, LeBron James shot 10-15 inside the arc in 40 minutes. His accuracy of 67% earns him 2 bonus points and his rate of makes per minute played of 1 in 4 earns him 3 more bonus points, for a total of 5 bonus points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">In the same game, Larry Hughes went 4-13 in 42 minutes. His accuracy of 31% costs him 1 penalty point and his rate of misses of 1 every 4.67 minutes costs him 2 more penalty points, for a total of 3 penalty points.</font></paragraph></text>
<text label="T6"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>3-point shooting</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">The following minimums apply to this category: Players must play a minimum of 15 minutes to earn bonuses. Player must have a minimum of 3 attempts before they are assessed penalties. Players are awarded basic bonuses for high accuracy and additional bonuses for the rate at which they made shots. Players are assessed penalties for low accuracy and are assessed further penalties for the rate at which they tossed up bad shots. Players who have not earned an accuracy bonuse or have not been assessed an accuracy penalties are not eligible for points based on the rate at which they made or missed shots.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Accuracy Bonus</font></division></cell><cell width="6360"/></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">40%-49.8% shooting accuracy or 1-1</font></division></cell></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">50-59.9 shooting accuracy or 2-2</font></division></cell></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">60% or higher shooting accuracy</font></division></cell></row><row><cell width="2280"/><cell width="6360"/></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Accuracy Penalty</font></division></cell><cell width="6360"/></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">20.1%-25% shooting accuracy</font></division></cell></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">15.1%-20% shooting accuracy</font></division></cell></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">15% or lower shooting accuracy </font></division></cell></row><row><cell width="2280"/><cell width="6360"/></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus or Penalty</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">25.1%-39.9%</font></division></cell></row><row><cell width="2280"/><cell width="6360"/></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Minutes Bonus/Penalty</font></division></cell><cell width="6360"/></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 make or 1 miss per every 8-10 minutes</font></division></cell></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 make or 1 miss per every 4.1-7.9 minutes</font></division></cell></row><row><cell width="2280"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6360"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 make or 1 miss per every 4 or fewer minutes</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 15 against the Mavericks, Tracy McGrady went 3-6 behind the arc in 40 minutes. His 50% accuracy earns him 2 bonus points and his 1 make every 13.3 minutes earns him 1 bonus point for  a total of 3 bonus points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">That same night against the Lakers, Larry Hughes went 1-5 in 42 minutes. His 20% accuracy costs him 2 penalty points and his 1 miss every 10.5 minutes costs him another penalty point for a total of 3 penalty points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">That same night against the Cavaliers, Kobe Bryant went 2-7 behind the arc in 41 minutes. His 28.6% accuracy gave him no bonus or penalty.</font></paragraph></text>
<text label="T7"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Free Throws</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Except as otherwise noted, a player must have 4 attempts to qualify for bonuses/penalties in this category. Players are award bonus points for high accuracy and assessed penalties for low accuracy. Players can earn additional bonuses or be assessed additional pealties based on the number of attempts they make. If no bonus or penalty for accuracy is earned, no points are awarded for number of attempts.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Accuracy Bonus</font></division></cell><cell width="6240"/></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">75%-79.9% shooting accuracy or 2-2 or 3-3</font></division></cell></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">80%-84.9% shooting accuracy</font></division></cell></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">85% or higher shooting accuracy</font></division></cell></row><row><cell width="2400"/><cell width="6240"/></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Accuracy Penalty</font></division></cell><cell width="6240"/></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">60%-65% shooting accuracy or 0-2 or 0-3</font></division></cell></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">50.1%-59.9% shooting accuracy</font></division></cell></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">50% or lower shooting accuracy</font></division></cell></row><row><cell width="2400"/><cell width="6240"/></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus or Penalty</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">65.1%-74.9%</font></division></cell></row><row><cell width="2400"/><cell width="6240"/></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Attempts Bonus/Penalty</font></division></cell><cell width="6240"/></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">4-7 attempts</font></division></cell></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">8-11 attempts</font></division></cell></row><row><cell width="2400"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6240"><division indent="0" align="left"><font face="Arial" size="200" color="000000">12 or more attempts</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 15 against the Cavaliers, Kobe Bryant went 14-15 at the free throw line. His 93% accuracy earns him 3 bonus points and the fact that he earned that bonus while shooting 12 or more free throws earns him another 3 bonus points for a total of 6.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">In that same game, Larry Hughes went 3-10. His 30% accuracy costs him 3 penalty points and his 10 attempts costs him 2 more penalty points for a total of 5 penalty points.</font></paragraph></text>
<text label="T8"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Rebounds for power forwards and centers</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Rebounding is a main function of these players and they are scored on a separate, more stringent basis. Players must play a minimum of 15 minutes to be eligible for bonuses/penalties in this category. Basic bonuses/penalties are awarded/assessed on the rate (rebounds/minute) at which rebounds are grabbed. Additional bonuses/penalties accrue based on the number of minutes played.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Rebound Bonus</font></division></cell><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 3.26-3.50 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 3.01-3.25 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 3 or fewer minutes</font></division></cell></row><row><cell width="2130"/><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Rebound Penalty</font></division></cell><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 4.5-4.99 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 5.0-5.99 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 6 or more minutes</font></division></cell></row><row><cell width="2130"/><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus/Penalty</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 3.51-4.49 minutes</font></division></cell></row><row><cell width="2130"/><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Minutes Bonus/Penalty</font></division></cell><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">15-25 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">26-35 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">36 or more minutes</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Raptors, Mikki Moore had 4 rebounds in 31 minutes. His rate of 1 rebound every 8.25 minutes costs him 3 penalty points. His playing time of 31 minutes costs him 2 more penalty points for a total of 5 penalty points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Wizards, Samuel Dalembert had 17 rebounds in 40 minutes. His rate of 1 rebound every 2.35 minutes earns him 3 bonus points and his 40 minutes of playing time earns him an additional 3 bonus points for a total of 6 bonus points.</font></paragraph></text>
<text label="T9"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Rebounds for small forwards</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Small forwards are often defending on the wings, but they are expected to carry some of the rebounding burden, so they are scored separately. Players must play a minimum of 15 minutes to be eligible for bonuses/penalties in this category. Basic bonuses/penalties are awarded/assessed on the rate (rebounds/minute) at which rebounds are grabbed. Additional bonuses/penalties accrue based on the number of minutes played.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Rebound Bonus</font></division></cell><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 5.1-5.5 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 4.1-5 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 4 or fewer minutes</font></division></cell></row><row><cell width="2130"/><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Rebound Penalty</font></division></cell><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 7.5-8.4 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 8.5-9.9 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 10 or more minutes</font></division></cell></row><row><cell width="2130"/><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus/Penalty</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 5.6-7.4 minutes</font></division></cell></row><row><cell width="2130"/><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Minutes Bonus/Penalty</font></division></cell><cell width="6510"/></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">15-25 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">26-35 minutes</font></division></cell></row><row><cell width="2130"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6510"><division indent="0" align="left"><font face="Arial" size="200" color="000000">36 or more minutes</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Hornets, Ron Artest got 5 rebounds in 30 minutes. His rate of 1 rebound every 6 minutes did not earn him a bonus or cost him a penalty.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Raptors, Bostjan Nachbar had 8 rebounds in 33 minutes. His rate of 1 rebound every 4.25 minutes earns him 2 bonus points. His playing time of 33 minutes also earns him 2 bonus points for a total of 4 bonus points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">In the same game, Andres Bargnani got 0 rebounds in 31 minutes. He gets a rebound penalty of 3 and a minutes penalty of 2 for a total of 5 penalty points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph></text>
<text label="T10"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Rebounds for guards</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Guards generally are defending away from the basket and have fewer opportunities for rebounds, so they are scored separately. Players must play a minimum of 15 minutes to be eligible for bonuses/penalties in this category. Basic bonuses/penalties are awarded/assessed on the rate (rebounds/minute) at which rebounds are grabbed. Additional bonuses/penalties accrue based on the number of minutes played.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Rebound Bonus</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 8.1-10 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 6.1-8 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 6 or fewer minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Rebound Penalty</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 12.1-13 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 13.1-15 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 15.1 or more minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus/Penalty</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 rebound per every 10.1-12 minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Minutes Bonus/Penalty</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">15-25 minutes for bonus points, 15 or more minutes for penalty points</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">26-35 minutes for bonus points only</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">36 or more minutes for bonus points only</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Bulls, Raymond Felton got 3 rebounds in 41 minutes. His rate of 1 rebound every 13.67 minutes costs him 2 penalty points. His playing time of 41 minutes costs him 1 penalty point for a total of 3 penalty points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">In that same game, Chris Duhon got 3 rebounds in 27 minutes. His rate of 1 rebound every 9 minutes earns him 1 bonus point and his playing time of 27 minutes earns him 2 more bonus points for a total of 3 bonus points.</font></paragraph></text>
<text label="T11"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Assists for power forwards and centers</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">"Bigs" are not expected to distribute the ball, so they are scored separately. Players must play a minimum of 15 minutes to be eligible for bonuses/penalties in this category Basic bonuses/penalties are awarded/assessed on the rate (assists/minute) at which assists are delivered. Additional bonuses/penalties accrue based on the number of minutes played.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Assists Bonus</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 13-18.9 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 8.1-12.9 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 8 or few minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Assists Penalty</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 32-39.9 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 40-48 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 48.1 or more minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus/Penalty</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 19-31.9 minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Minutes Bonus/Penalty</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">15-25 minutes for bonus points, 15 or more minutes for penalty points</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">26-35 minutes for bonus points only</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">36 or more minutes for bonus points only</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions> </paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Celtics, Andrew Bogut had 7 assists in 40 minutes. His rate of 1 assist every 5.7 minutes earns him 3 bonus points. His 40 minutes played earns him an additional 3 bonus poins for a total of 6 bonus points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">In that same game, Brian Scalabrine had 0 assists in 20 minutes. Because his 20 minutes played falls into the no bonus/penalty area, he gets no points and loses no points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Bulls, Emeka Okafor had 1 assist in 42 minutes. His rate of 1 in 42 costs him 2 penalty points and his minutes played costs him 1 more penalty point for a total of 3 penalty points.</font></paragraph></text>
<text label="T12"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Assists for small forwards and shooting guards</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Wing players are expected to distribute the ball better than "bigs," but not as well as point guards, so they get scored separately. Players must play a minimum of 15 minutes to be eligible for bonuses/penalties in this category. Basic bonuses and penalties are awarded/assessed on the rate (assists per minute) at which assists are delivered. Additional bonuses/penalties accrus based on the number of minutes played.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Assists Bonus</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 8.5-10 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 6.5-8.4 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 6.4 or fewer minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Assists Penalty</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 14.1-17 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 17.1-24 minutes</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 24.1 or more minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus/Penalty</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 10.1-14 minutes</font></division></cell></row><row><cell width="2145"/><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Minutes Bonus/Penalty</font></division></cell><cell width="6495"/></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">15-25 minutes played</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">26-35 minutes played</font></division></cell></row><row><cell width="2145"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6495"><division indent="0" align="left"><font face="Arial" size="200" color="000000">36 or more minutes played</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Bucks, Paul Pierce collected 4 assists in 36 minutes. His rate of 1 assist every 9 minutes earns him 1 bonus point and his 36 minutes earns him 3 more bonus oints for a total of 4 bonus points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">In that same game, Wally Szczerbiak had 1 assist in 26 minutes. That costs him 3 penalty points for assists and 2 more penalty points for the 26 minutes played for a total of 5 penalty points.</font></paragraph></text>
<text label="T13"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Assists for point guards</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Point guards are the primary assist deliverers and are scored separately from other players. Players must play a minimum of 15 minutes to be eligible for bonuses/penalties in this category. Basic bonuses and penalties are awarded/assessed on the rate (assists per minute) at which assists are delivered. Additional bonuses/penalties accrue based on the number of minutes played.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Assists Bonus</font></division></cell><cell width="6600"/></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 4.6-5 minutes</font></division></cell></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 4.1-4.5 minutes</font></division></cell></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 4 or fewer minutes</font></division></cell></row><row><cell width="2040"/><cell width="6600"/></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Assists Penalty</font></division></cell><cell width="6600"/></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 6.5-9 minutes</font></division></cell></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 9.1-13 minutes</font></division></cell></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist per every 13.1 or more minutes</font></division></cell></row><row><cell width="2040"/><cell width="6600"/></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">No Bonus/Penalty</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1 assist every 5.1-6.5 minutes</font></division></cell></row><row><cell width="2040"/><cell width="6600"/></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">Minute Bonus/Penalty</font></division></cell><cell width="6600"/></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">1</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">15-25 minutes played</font></division></cell></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">2</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">26-35 minutes played</font></division></cell></row><row><cell width="2040"><division indent="0" align="left"><font face="Arial" size="200" color="000000">3</font></division></cell><cell width="6600"><division indent="0" align="left"><font face="Arial" size="200" color="000000">36 or more minutes played</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><i>Examples:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">On February 14 against the Nets, T.J. Ford had 8 assists in 29 minutes. His rate of 1 assist every 3.63 minutes earns him 3 bonus points. His 29 minutes earns him 2 more bonus points for a total of 5 bonus points.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">That same night against the Celtics, Mo Williams had 4 assists in 43 minutes. His rate of 1 assist every 10.75 minutes costs him 2 penalty points and his 43 minutes played costs him 3 more penalty points for a total of 5 penalty points.</font></paragraph></text>
<text label="T14"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Steals Bonus</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Bonuses for steals are awarded on the total number.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions