</forms>
<processes>
<process name="Pre-Questionnaire">
<comment>Set up variables for display in the Form</comment>
<get recordList="Settings">
<forms>
<form name="Customize"/>
</forms>
</get>
<foreach record="Setting" recordList="Settings">
<set field="Title" arithmeticAsText="false">
<string field="Setting:Customize:EventTitle"/>
</set>
<set field="Description" arithmeticAsText="false">
<string field="Setting:Customize:EventDescription"/>
</set>
<set field="Choice01" arithmeticAsText="false">
<string field="Setting:Customize:Date01"/>
</set>
<set field="Choice02" arithmeticAsText="false">
<string field="Setting:Customize:Date02"/>
</set>
<set field="Choice03" arithmeticAsText="false">
<string field="Setting:Customize:Date03"/>
</set>
<set field="Choice04" arithmeticAsText="false">
<string field="Setting:Customize:Date04"/>
</set>
<set field="Choice05" arithmeticAsText="false">
<string field="Setting:Customize:Date05"/>
</set>
<set field="Choice06" arithmeticAsText="false">
<string field="Setting:Customize:Date06"/>
</set>
<set field="Choice07" arithmeticAsText="false">
<string field="Setting:Customize:Date07"/>
</set>
<set field="Choice08" arithmeticAsText="false">
<string field="Setting:Customize:Date08"/>
</set>
<set field="Choice09" arithmeticAsText="false">
<string field="Setting:Customize:Date09"/>
</set>
<set field="Choice10" arithmeticAsText="false">
<string field="Setting:Customize:Date10"/>
</set>
<set field="ClosingRemarks" arithmeticAsText="false">
<string field="Setting:Customize:Remarks"/>
</set>
<set field="ShowReportToUser" arithmeticAsText="false">
<string value="false"/>
</set>
<if>
<conditions>
<mcEquals field="Setting:Customize:PublicReport" value="b"/>
</conditions>
<trueSet>
<set field="ShowReportToUser" arithmeticAsText="false">
<string value="true"/>
</set>
</trueSet>
</if>
</foreach>
</process>
<process name="Post-Administration">
<comment>Note: this is necessary to link choices back to the</comment>
<comment>Customization record for the Popular Choice display function</comment>
<get recordList="Settings">
<forms>
<form name="Customize"/>
</forms>
</get>
<foreach record="Setting" recordList="Settings">
<set field="Title" arithmeticAsText="false">
<string field="Setting:Customize:EventTitle"/>
</set>
<set field="Choice01" arithmeticAsText="false">
<string field="Setting:Customize:Date01"/>
</set>
<set field="Choice02" arithmeticAsText="false">
<string field="Setting:Customize:Date02"/>
</set>
<set field="Choice03" arithmeticAsText="false">
<string field="Setting:Customize:Date03"/>
</set>
<set field="Choice04" arithmeticAsText="false">
<string field="Setting:Customize:Date04"/>
</set>
<set field="Choice05" arithmeticAsText="false">
<string field="Setting:Customize:Date05"/>
</set>
<set field="Choice06" arithmeticAsText="false">
<string field="Setting:Customize:Date06"/>
</set>
<set field="Choice07" arithmeticAsText="false">
<string field="Setting:Customize:Date07"/>
</set>
<set field="Choice08" arithmeticAsText="false">
<string field="Setting:Customize:Date08"/>
</set>
<set field="Choice09" arithmeticAsText="false">
<string field="Setting:Customize:Date09"/>
</set>
<set field="Choice10" arithmeticAsText="false">
<string field="Setting:Customize:Date10"/>
</set>
</foreach>
<show document="Report" reset="false"/>
</process>
<process name="Post-Customize">
<comment>Note: All this is necessary to display feedback in the Customization Review document</comment>
<comment>We ought to be able to implement a Function to do much of this work</comment>
<if>
<conditions>
<isNotBlank field="Customize:Date01"/>
</conditions>
<trueSet>
<set field="DisplayChoice" arithmeticAsText="false">
<string field="Customize:Date01"/>
</set>
<append document="ReviewAbleList" appendage="ReviewChoice"/>
<append document="ReviewPreferredList" appendage="ReviewChoice"/>
</trueSet>
</if>
<if>
