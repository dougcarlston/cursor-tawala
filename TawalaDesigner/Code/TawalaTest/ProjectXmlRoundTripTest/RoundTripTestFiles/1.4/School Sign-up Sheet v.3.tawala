</skipInstructions>
<fib label="Q4"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Please provide the following contact information:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Your </font><font face="Arial" size="200" color="000000"><field name="ContactType1"/></font><font face="Arial" size="200" color="000000">:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><blank label="a" length="41" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Your </font><font face="Arial" size="200" color="000000"><field name="ContactType2"/></font><font face="Arial" size="200" color="000000">:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><blank label="b" length="41" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Your </font><font face="Arial" size="200" color="000000"><field name="ContactType3"/></font><font face="Arial" size="200" color="000000">:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><blank label="c" length="41" required="false"/></paragraph></fib>
</items>
</form>
<form name="Administration" startPoint="true" themePath="default" process="Show Signatures">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
</forms>
<processes>
<process name="Show Signatures">
<get recordList="Setup List">
<forms>
<form name="Customize"/>
</forms>
</get>
<foreach record="Setting" recordList="Setup List">
<set field="ContactType1" arithmeticAsText="false">
<string value="empty"/>
</set>
<set field="ContactType2" arithmeticAsText="false">
<string value="empty"/>
</set>
<set field="ContactType3" arithmeticAsText="false">
<string value="empty"/>
</set>
<set field="SignUpTitle" arithmeticAsText="false">
<string field="Setting:Customize:Title"/>
</set>
<set field="SignUpDescription" arithmeticAsText="false">
<string field="Setting:Customize:Description"/>
</set>
<set field="SignUpFinalRemarks" arithmeticAsText="false">
<string field="Setting:Customize:FinalRemarks"/>
</set>
<if>
<conditions>
<mcContains field="Setting:Customize:ContactInfo" value="a"/>
</conditions>
<trueSet>
<set field="ContactType1" arithmeticAsText="false">
<string value="phone number"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcContains field="Setting:Customize:ContactInfo" value="b"/>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="ContactType1">
<string value="empty"/>
</equals>
</conditions>
<trueSet>
<set field="ContactType1" arithmeticAsText="false">
<string value="email address"/>
</set>
</trueSet>
<falseSet>
<set field="ContactType2" arithmeticAsText="false">
<string value="email address"/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcContains field="Setting:Customize:ContactInfo" value="c"/>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="ContactType1">
<string value="empty"/>
</equals>
</conditions>
<trueSet>
<set field="ContactType1" arithmeticAsText="false">
<string value="mailing address"/>
</set>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="ContactType2">
<string value="empty"/>
</equals>
</conditions>
<trueSet>
<set field="ContactType2" arithmeticAsText="false">
<string value="mailing address"/>
</set>
</trueSet>
<falseSet>
<set field="ContactType3" arithmeticAsText="false">
<string value="mailing address"/>
</set>
</falseSet>
</if>
</falseSet>
</if>
</trueSet>
</if>
</foreach>
<show document="SignUp Header" reset="false"/>
<if>
<conditions>
<doesNotEqual field="ContactType3">
<string value="empty"/>
</doesNotEqual>
</conditions>
<trueSet>
<show document="NamesAndInfo3" reset="false"/>
</trueSet>
<falseSet>
<if>
<conditions>
<doesNotEqual field="ContactType2">
<string value="empty"/>
</doesNotEqual>
</conditions>
<trueSet>
<show document="NamesAndInfo2" reset="false"/>
</trueSet>
<falseSet>
<if>
<conditions>
<doesNotEqual field="ContactType1">
<string value="empty"/>
</doesNotEqual>
</conditions>
<trueSet>
<show document="NamesAndInfo1" reset="false"/>
</trueSet>
<falseSet>
<show document="Names Only" reset="false"/>
</falseSet>
</if>
</falseSet>
</if>
</falseSet>
</if>
</process>
<process name="Post-SignUp">
<show document="SignUp Finish" reset="false"/>
<if>
<conditions>
<isNotBlank field="SignUpFinalRemarks"/>
</conditions>
<trueSet>
<show document="SignUp Remarks" reset="false"/>
</trueSet>
</if>
<show document="SignUp ViewFinalList" reset="false"/>
</process>
<process name="Post-Customize">
<show document="Confirm Setup" reset="false"/>
<if>
<conditions>
<or>
<mcContains field="Customize:ContactInfo" value="a"/>
<or>
<mcContains field="Customize:ContactInfo" value="b"/>
<mcContains field="Customize:ContactInfo" value="c"/>
</or>
</or>
</conditions>
<trueSet>
<show document="Confirm ContactInfo" reset="false"/>
</trueSet>
</if>
<show document="Confirm Footer" reset="false"/>
</process>
</processes>
<documents>
