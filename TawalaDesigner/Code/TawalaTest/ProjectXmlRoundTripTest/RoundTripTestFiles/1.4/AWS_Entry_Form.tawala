<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Please review your entry for accuracy.</b></font><font face="Arial" size="200" color="000000"> When you are satisfied, press SUBMIT and labels for the back of your paintings will be prepared.</font></paragraph></text>
</items>
</form>
<form name="Receipt" startPoint="false" themePath="litegreen" process="Receipt">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">OK. We've prepared your receipt to allow you to pick up your paintings after the show. Please press SUBMIT</font></paragraph></text>
</items>
</form>
<form name="Admin" startPoint="true" themePath="litegreen" process="Admin">
<items>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">You can</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Get a list of entrants</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Get the entry of a specific entrant</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Get all the entries</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Get the wall labels</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Admin:Q1">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="Q2"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<fib label="Q2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Which entrant's entry do you wish to see? </font><blank label="a" length="37" required="false" alternateLabel="Entrant"/></paragraph></fib>
</items>
</form>
<form name="Bridge" startPoint="false" themePath="litegreen" process="Bridge">
<items>
<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">You can</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Return to Admin</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Exit</font></paragraph></choice></mc>
</items>
</form>
<form name="Reprint" startPoint="false" themePath="litegreen" process="Reprint">
<items>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Enter your name exactly as you entered it on the entry form </font><blank label="a" length="22" required="false" alternateLabel="ename"/></paragraph></fib>
<mc label="Q2" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Do you want to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Reprint labels for the back of your paintings</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Reprint your receipt</font></paragraph></choice></mc>
</items>
</form>
</forms>
<processes>
<process name="Router">
<if>
<conditions>
<mcEquals field="Router:Q1" value="a"/>
</conditions>
<trueSet>
<show form="GeneralInfo"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Router:Q1" value="b"/>
</conditions>
<trueSet>
<show form="StartEntry"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Router:Q1" value="c"/>
</conditions>
<trueSet>
<show form="Reprint"/>
</trueSet>
</if>
</process>
<process name="GenInfo">
<if>
<conditions>
<mcEquals field="GeneralInfo:Q1" value="a"/>
</conditions>
<trueSet>
<show form="StartEntry"/>
</trueSet>
</if>
</process>
<process name="Begin">
<if>
<conditions>
<mcEquals field="StartEntry:Q2" value="a"/>
</conditions>
<trueSet>
<show form="EnterWorks"/>
</trueSet>
</if>
</process>
<process name="GetData">
<set field="contact" arithmeticAsText="false">
<string field="StartEntry:email"/>
</set>
<show document="Labels" reset="false"/>
<show form="Receipt"/>
</process>
<process name="Receipt">
<show document="Receipt" reset="false"/>
</process>
<process name="Admin">
<if>
<conditions>
<mcEquals field="Admin:Q1" value="a"/>
</conditions>
<trueSet>
<get recordList="Record List 1">
<forms>
<form name="EnterWorks"/>
</forms>
</get>
<foreach record="Record1" recordList="Record List 1">
<set field="Entered" arithmeticAsText="false">
<string field="Record1:EnterWorks:Name"/>
</set>
<append document="Holder" appendage="VEntrants"/>
</foreach>
<show document="Holder" reset="true"/>
<show form="Bridge"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Admin:Q1" value="b"/>
</conditions>
<trueSet>
<get recordList="Record List 2">
<forms>
<form name="EnterWorks"/>
</forms>
<conditions>
<equals field="Record List 2:EnterWorks:Name">
<string field="Admin:Entrant"/>
</equals>
</conditions></get>
<foreach record="Record2" recordList="Record List 2">
<set field="1email" arithmeticAsText="false">
<string field="Record2:EnterWorks:contact"/>
</set>
<set field="1Name" arithmeticAsText="false">
<string field="Record2:EnterWorks:Name"/>
</set>
<set field="1st" arithmeticAsText="false">
<string field="Record2:EnterWorks:st"/>
</set>
<set field="1city" arithmeticAsText="false">
<string field="Record2:EnterWorks:city"/>
</set>
<set field="1zip" arithmeticAsText="false">
<string field="Record2:EnterWorks:zip"/>
</set>
<set field="1phone" arithmeticAsText="false">
<string field="Record2:EnterWorks:phone"/>
</set>
<set field="1w1" arithmeticAsText="false">
<string field="Record2:EnterWorks:w1"/>
</set>
<set field="1c1" arithmeticAsText="false">
<string field="Record2:EnterWorks:c1"/>
</set>
<set field="1p1" arithmeticAsText="false">
<string field="Record2:EnterWorks:p1"/>
</set>
<set field="1w11" arithmeticAsText="false">
<string field="Record2:EnterWorks:w11"/>
</set>
<set field="1c11" arithmeticAsText="false">
<string field="Record2:EnterWorks:c11"/>
</set>
<set field="1p11" arithmeticAsText="false">
<string field="Record2:EnterWorks:p11"/>
</set>
<set field="1w12" arithmeticAsText="false">
<string field="Record2:EnterWorks:w12"/>
</set>
<set field="1c12" arithmeticAsText="false">
<string field="Record2:EnterWorks:c12"/>
</set>
<set field="1p12" arithmeticAsText="false">
<string field="Record2:EnterWorks:p12"/>
</set>
<set field="1w13" arithmeticAsText="false">
<string field="Record2:EnterWorks:w13"/>
</set>
<set field="1c13" arithmeticAsText="false">
<string field="Record2:EnterWorks:c13"/>
</set>
<set field="1p13" arithmeticAsText="false">
<string field="Record2:EnterWorks:p13"/>
</set>
<append document="Holder" appendage="V1Entry"/>
</foreach>
<show document="Holder" reset="true"/>
<show form="Bridge"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Admin:Q1" value="c"/>
</conditions>
<trueSet>
<get recordList="Record List 3">
<forms>
<form name="EnterWorks"/>
</forms>
</get>
<foreach record="Record3" recordList="Record List 3">
<set field="aemail" arithmeticAsText="false">
<string field="Record3:EnterWorks:contact"/>
</set>
<set field="aname" arithmeticAsText="false">
<string field="Record3:EnterWorks:Name"/>
</set>
<set field="ast" arithmeticAsText="false">
<string field="Record3:EnterWorks:st"/>
</set>
<set field="acity" arithmeticAsText="false">
<string field="Record3:EnterWorks:city"/>
</set>
<set field="azip" arithmeticAsText="false">
<string field="Record3:EnterWorks:zip"/>
</set>
<set field="aphone" arithmeticAsText="false">
<string field="Record3:EnterWorks:phone"/>
</set>
<set field="aw1" arithmeticAsText="false">
<string field="Record3:EnterWorks:w1"/>
</set>
<set field="ac1" arithmeticAsText="false">
<string field="Record3:EnterWorks:c1"/>
</set>
<set field="ap1" arithmeticAsText="false">
<string field="Record3:EnterWorks:p1"/>
</set>
<set field="aw11" arithmeticAsText="false">
<string field="Record3:EnterWorks:w11"/>
</set>
<set field="ac11" arithmeticAsText="false">
