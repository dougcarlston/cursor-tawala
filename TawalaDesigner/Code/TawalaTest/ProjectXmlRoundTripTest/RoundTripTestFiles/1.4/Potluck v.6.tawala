<form name="Potluck Organizer" startPoint="true" themePath="basicyellow" process="mainMenu-post" preProcess="mainMenu-pre">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="008000"><i>Fill in the form below to let us know if you can make it and if so what you will bring</i></font><font face="Verdana" size="200" color="0000FF"><i>:</i></font></paragraph></text>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000"><b>Name</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><blank label="a" length="35" required="true" alternateLabel="attendeeName"/></paragraph></fib>
<mc label="Q2" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000"><b>Will you be able to come to the potluck?</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000">No</font></paragraph></choice></mc>
<fib label="Q3"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000"><b>How many of you will be coming?</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><blank label="a" length="6" required="false" alternateLabel="numAdults"/><font face="Verdana" size="200" color="000000"> (Adults)        </font><blank label="b" length="6" required="false" alternateLabel="numKids"/><font face="Verdana" size="200" color="000000"> (Kids)</font></paragraph></fib>
<fib label="Q4"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000"><b>Potluck Contribution</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><blank label="a" length="35" required="false" alternateLabel="contribution"/></paragraph></fib>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="808080"><i>Click the submit button to enter your information. When you're done you can close this window</i></font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Potluck Organizer:Q2" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000">You entered the following information:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="270"><row><cell width="2010"><division indent="0" align="left"><font face="Verdana" size="200" color="000000">Name</font></division></cell><cell width="5130"><division indent="0" align="left"><font face="Verdana" size="200" color="000000"><field name="Potluck Organizer:attendeeName"/></font></division></cell></row><row><cell width="2010"><division indent="0" align="left"><font face="Verdana" size="200" color="000000">Number of Adults</font></division></cell><cell width="5130"><division indent="0" align="left"><font face="Verdana" size="200" color="000000"><field name="Potluck Organizer:numAdults"/></font></division></cell></row><row><cell width="2010"><division indent="0" align="left"><font face="Verdana" size="200" color="000000">Number of Kids</font></division></cell><cell width="5130"><division indent="0" align="left"><font face="Verdana" size="200" color="000000"><field name="Potluck Organizer:numKids"/></font></division></cell></row><row><cell width="2010"><division indent="0" align="left"><font face="Verdana" size="200" color="000000">Dish</font></division></cell><cell width="5130"><division indent="0" align="left"><font face="Verdana" size="200" color="000000"><field name="Potluck Organizer:contribution"/></font></division></cell></row></table></text>
<mc label="Q5" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000">Is this information correct</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000">Yes, save this information</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000">No, I want to change what I entered</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Potluck Organizer:Q5">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="T1"/>
</trueSet>
</if>
</skipInstructions>
</items>
</form>
<form name="Administration" startPoint="true" themePath="basicyellow" process="admin-post">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
</forms>
<processes>
<process name="mainMenu-pre">
<set field="potluckIntroduction" arithmeticAsText="false">
<string value="Please customize this application by running Setup"/>
</set>
<set field="potluckHeader" arithmeticAsText="false">
<string value="Your Title Goes Here"/>
</set>
<set field="showWhosNotComing" arithmeticAsText="false">
<string value="true"/>
</set>
<get recordList="Setup Record List">
<forms>
<form name="Setup"/>
</forms>
</get>
<foreach record="SetupRec" recordList="Setup Record List">
<if>
<conditions>
<isNotBlank field="SetupRec:Setup:SetupBody"/>
</conditions>
<trueSet>
<set field="potluckIntroduction" arithmeticAsText="false">
<string field="SetupRec:Setup:SetupBody"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="SetupRec:Setup:eventHeader"/>
</conditions>
<trueSet>
<set field="potluckHeader" arithmeticAsText="false">
<string field="SetupRec:Setup:eventHeader"/>
</set>
</trueSet>
</if>
<set field="potluckDateTime" arithmeticAsText="false">
<string field="SetupRec:Setup:eventDateTime"/>
</set>
<set field="potluckLocation" arithmeticAsText="false">
<string field="SetupRec:Setup:eventLocation"/>
</set>
<if>
<conditions>
<mcEquals field="SetupRec:Setup:showNotComing">
<string value="a"/>
</mcEquals>
</conditions>
<trueSet>
<set field="showWhosNotComing" arithmeticAsText="false">
<string value="true"/>
</set>
</trueSet>
<falseSet>
<set field="showWhosNotComing" arithmeticAsText="false">
<string value="false"/>
</set>
</falseSet>
</if>
</foreach>
<show document="Header" reset="true"/>
<show document="introduction" reset="true"/>
<show document="attendeeCount" reset="false"/>
<show document="WhosComing" reset="true"/>
<if>
<conditions>
<equals field="showWhosNotComing">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<show document="WhosNot" reset="true"/>
</trueSet>
</if>
</process>
<process name="setup-post">
<show document="Confirm Setup" reset="false"/>
<if>
<conditions>
<mcEquals field="Setup:showNotComing" value="a"/>
</conditions>
<trueSet>
<show document="Confirm NotComing" reset="false"/>
</trueSet>
</if>
<show document="Confirm Form" reset="false"/>
</process>
<process name="mainMenu-post">
<if>
<conditions>
<mcEquals field="Potluck Organizer:Q2" value="a"/>
</conditions>
<trueSet>
<show document="ThankYou Coming" reset="false"/>
</trueSet>
<falseSet>
<show document="ThankYou NotComing" reset="false"/>
</falseSet>
</if>
</process>
<process name="admin-post">
<get recordList="Record List">
<forms>
<form name="Setup"/>
</forms>
</get>
<foreach record="Record" recordList="Record List">
<set field="potluckHeader" arithmeticAsText="false">
<string field="Record:Setup:eventHeader"/>
</set>
</foreach>
<show document="Admin Header" reset="false"/>
<show document="attendeeCount" reset="false"/>
<show document="WhosComing" reset="false"/>
<show document="WhosNot" reset="false"/>
</process>
</processes>
<documents>
<document name="Header">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="360" color="000000"><b><field name="potluckHeader"/></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000"><b>When:  </b></font><sp/><font face="Verdana" size="200" color="000000"><field name="potluckDateTime"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000"><b>Where:  </b></font><font face="Verdana" size="200" color="000000"><field name="potluckLocation"/></font></paragraph>
</xmlData>
</document>
<document name="WhosComing">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Verdana" size="200" color="000000"><b>People planning on coming and what they're bringing:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><itemization-table version="1"><column><header>Name</header><contents><field name="Record:Potluck Organizer:attendeeName"/></contents></column><column><header>Dish</header><contents><field name="Record:Potluck Organizer:contribution"/></contents></column><conditions><form name="Potluck Organizer"/><conditions>
