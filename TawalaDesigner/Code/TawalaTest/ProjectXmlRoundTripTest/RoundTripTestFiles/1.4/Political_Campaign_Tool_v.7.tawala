</if>
<if>
<conditions>
<isNotBlank field="Supporter:Coffee Schedule:Week3SaName"/>
</conditions>
<trueSet>
<set field="Week3SaName" arithmeticAsText="false">
<string field="Supporter:Coffee Schedule:Week3SaName"/>
</set>
<set field="Week3SaEmail" arithmeticAsText="false">
<string field="Supporter:Coffee Schedule:Email"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Supporter:Coffee Schedule:Week4TuName"/>
</conditions>
<trueSet>
<set field="Week4TuName" arithmeticAsText="false">
<string field="Supporter:Coffee Schedule:Week4TuName"/>
</set>
<set field="Week4TuEmail" arithmeticAsText="false">
<string field="Supporter:Coffee Schedule:Email"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Supporter:Coffee Schedule:Week4ThName"/>
</conditions>
<trueSet>
<set field="Week4ThName" arithmeticAsText="false">
<string field="Supporter:Coffee Schedule:Week4ThName"/>
</set>
<set field="Week4ThEmail" arithmeticAsText="false">
<string field="Supporter:Coffee Schedule:Email"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Supporter:Coffee Schedule:Week4SaName"/>
</conditions>
<trueSet>
<set field="Week4SaName" arithmeticAsText="false">
<string field="Supporter:Coffee Schedule:Week4SaName"/>
</set>
<set field="Week4SaEmail" arithmeticAsText="false">
<string field="Supporter:Coffee Schedule:Email"/>
</set>
</trueSet>
</if>
</foreach>
<show document="Coffee Program" reset="true"/>
</trueSet>
</if>
<if>
<conditions>
<mcContains field="Administration:Q1" value="c"/>
</conditions>
<trueSet>
<set field="CheckTotal" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="CCTotal" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="TotalFunds" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Contributors">
<forms>
<form name="Financial"/>
</forms>
</get>
<foreach record="Moneybags" recordList="Contributors">
<set field="TotalFunds" arithmeticAsText="false">
<add>
<operand field="TotalFunds"/>
<operand field="Moneybags:Financial:Amt"/>
</add>
</set>
<if>
<conditions>
<doesNotEqual field="Moneybags:Financial:Amt">
<string value="0"/>
</doesNotEqual>
</conditions>
<trueSet>
<if>
<conditions>
<mcEquals field="Moneybags:Financial:CheckorCard" value="a"/>
</conditions>
<trueSet>
<set field="CheckTotal" arithmeticAsText="false">
<add>
<operand field="CheckTotal"/>
<operand field="Moneybags:Financial:Amt"/>
</add>
</set>
<set field="CL1" arithmeticAsText="false">
<string field="Moneybags:Financial:Amt"/>
</set>
<set field="CL2" arithmeticAsText="false">
<string field="Moneybags:Financial:FullName"/>
</set>
<append document="Check Pledge Summary" appendage="CMLine"/>
</trueSet>
<falseSet>
<set field="CCTotal" arithmeticAsText="false">
<add>
<operand field="CCTotal"/>
<operand field="Moneybags:Financial:Amt"/>
</add>
</set>
<set field="ContributorLine" arithmeticAsText="false">
<string field="Moneybags:Financial:Amt"/>
</set>
<set field="ContributorLine2" arithmeticAsText="false">
<string field="Moneybags:Financial:FullName"/>
</set>
<set field="CL1" arithmeticAsText="false">
<string field="Moneybags:Financial:CreditCard"/>
</set>
<set field="CL2" arithmeticAsText="false">
<string field="Moneybags:Financial:Month"/>
</set>
<set field="CL3" arithmeticAsText="false">
<string field="Moneybags:Financial:Year"/>
</set>
<append document="CreditCard Summary" appendage="CCLine"/>
</falseSet>
</if>
</trueSet>
</if>
</foreach>
<show document="Check Pledge Summary" reset="true"/>
<show document="CreditCard Summary" reset="true"/>
</trueSet>
</if>
</process>
</processes>
