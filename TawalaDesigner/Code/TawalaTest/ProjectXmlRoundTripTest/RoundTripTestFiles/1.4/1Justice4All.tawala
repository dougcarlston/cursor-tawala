<?xml version="1.0" encoding="UTF-8"?>
<project name="1Justice4All" themePath="default" format="1.4">
<forms>
<form name="Chooser" startPoint="true" themePath="default" process="NameEm">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">In this Fearless Fantasy game, Justices earn points for their activity. Points are awarded as follows: </font><font face="Arial" size="200" color="000000"><b>Slip opinions:</b></font><font face="Arial" size="200" color="000000"> 1 point for a vote with the majority, 3 points for writing the majority opinion, 2 points for writing a concurring opinion joined by one or more Justices, 2 points for writing a dissenting opinion joined by one or more Justices, 1 point for writing a concurring opinion or a dissenting opinion in which no other Justice joins. </font><font face="Arial" size="200" color="000000"><b>Term opinions relating to orders:</b></font><font face="Arial" size="200" color="000000">1 point. </font><font face="Arial" size="200" color="000000"><b>Term In-Chambers opinions:</b></font><font face="Arial" size="200" color="000000"> 1 point. You choose one Justice as your representative and a second Justice to serve as your tiebreaker.</font></paragraph></text>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Enter your e-mail address </font><blank label="a" length="24" required="true" alternateLabel="email"/></paragraph></fib>
<fib label="Q2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Choose an Alias for your entry in the Leaderboard </font><blank label="a" length="16" required="true" alternateLabel="alias"/></paragraph></fib>
