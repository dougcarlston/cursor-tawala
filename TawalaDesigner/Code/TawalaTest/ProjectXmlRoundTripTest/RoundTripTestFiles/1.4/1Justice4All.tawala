<process name="Mover">
<if>
<conditions>
<mcEquals field="DataEntry:Q7" value="a"/>
</conditions>
<trueSet>
<show form="DataEntry"/>
</trueSet>
<falseSet>
<show form="Calculate"/>
</falseSet>
</if>
</process>
<process name="FindEm">
<get recordList="Record List 5">
<forms>
<form name="Chooser"/>
</forms>
<conditions>
<equals field="Record List 5:Chooser:email">
<string field="Iforget:email1"/>
</equals>
</conditions></get>
<foreach record="User" recordList="Record List 5">
<set field="UrAlias" arithmeticAsText="false">
<string field="User:Chooser:alias"/>
</set>
<append document="AliasDoc" appendage="VAliasDoc"/>
</foreach>
<send>
<to addressField="Iforget:email1"/>
<cc addressLiteral="softalk@sbcglobal.net"/>
<subject>Your One Justice For All alias</subject>
<body document="AliasDoc" reset="true"/>
</send>
</process>
<process name="ShowEm">
<if>
<conditions>
<mcEquals field="Unknown Field" value="b"/>
</conditions>
<trueSet>
<show document="Thanks" reset="false"/>
</trueSet>
</if>
</process>
<process name="Shorten">
<get recordList="Record List 6">
<forms>
<form name="Chooser"/>
</forms>
</get>
<foreach record="member" recordList="Record List 6">
<send>
<to addressField="member:Chooser:email"/>
<cc addressLiteral="softalk@sbcglobal.net"/>
<subject>1Justice4All scores and rule change</subject>
<body document="RulesDoc" reset="true"/>
</send>
</foreach>
</process>
<process name="RankEm">
<get recordList="Record List 7">
<forms>
<form name="Calculate"/>
</forms>
</get>
