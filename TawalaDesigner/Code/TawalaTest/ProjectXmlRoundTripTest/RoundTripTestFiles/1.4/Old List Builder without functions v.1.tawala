<?xml version="1.0" encoding="UTF-8"?>
<project name="Group List Builder" themePath="basicblue" format="1.4">
<forms>
<form name="Setup" startPoint="true" themePath="basicblue" process="Process 1">
<items>
<text label="T1"><paragraph indent="0" align="center"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Comic Sans MS" size="320" color="000000"><b>Viral List Builder</b></font></paragraph></text>
<text label="T2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="D90000"><i>This Web app builds an email mailing list for your organization</i></font>  <font face="Arial" size="220" color="D90000"><i>It sends a request to all known members, asking each  to look at the list and add missing names. </i></font>  <font face="Arial" size="220" color="D90000"><i>It works like a chain letter, sending the same  request to the added names until the list is complete.</i></font></paragraph></text>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">1. Organization Name:  </font><blank label="a" length="39" required="false" alternateLabel="Organization"/></paragraph></fib>
<fib label="Q2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">2. Enter text for an email describing what you are doing and why:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions> <blank label="a" length="102" height="4" required="false" alternateLabel="BodyText"/></paragraph></fib>
<fib label="Q3"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">3. Name of person signing the letter: </font><blank label="a" length="25" required="false" alternateLabel="Signer"/></paragraph></fib>
<text label="T3"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">-----------------------------------------------------------------------------------------------------------------------------------------------------</font></paragraph></text>
<mc label="Q4" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">To make this work you must have at least one or two people in the group for whom you have email addresses.  Are you ready to proceed?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">No, I don't have those yet.</font></paragraph></choice></mc>
</items>
</form>
<form name="Main" startPoint="true" themePath="basicblue" process="Process 2" preProcess="Process 4">
<items>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">Enter the name and email address of a group member not yet on the list:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">Name: </font><blank label="a" length="21" required="false" alternateLabel="First"/><font face="Arial" size="220" color="000000"> (First) </font><blank label="b" length="24" required="false" alternateLabel="Last"/><font face="Arial" size="220" color="000000"> (Last)</font></paragraph></fib>
<fib label="Q2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">Email address:</font><font face="Arial" size="220" color="000000"> </font><blank label="a" length="34" required="false" alternateLabel="Email"/></paragraph></fib>
<mc label="Q3" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">I want to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">Add another name</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="000000">Quit</font></paragraph></choice></mc>
</items>
</form>
<form name="Administrator" startPoint="true" themePath="basicblue" preProcess="Process 5">
</form>
</forms>
<processes>
<process name="Process 1">
<if>
<conditions>
<mcEquals field="Setup:Q4" value="b"/>
</conditions>
<trueSet>
<show document="Try later" reset="false"/>
</trueSet>
</if>
<set field="OurGroup" arithmeticAsText="false">
<string field="Setup:Organization"/>
</set>
<set field="Secretary" arithmeticAsText="false">
<string field="Setup:Signer"/>
</set>
<set field="OurText" arithmeticAsText="false">
<string field="Setup:BodyText"/>
</set>
<show form="Main"/>
</process>
<process name="Process 2">
<set field="FirstName" arithmeticAsText="false">
<string field="Main:First"/>
</set>
<set field="PersonsName" arithmeticAsText="false">
<string field="Main:First"/>
<string value=" "/>
<string field="Main:Last"/>
</set>
<set field="PersonsEmail" arithmeticAsText="false">
<string field="Main:Email"/>
</set>
<send>
<to addressField="PersonsEmail"/>
<subject>Email List for our group</subject>
<body document="Solicitation" reset="true"/>
</send>
<if>
<conditions>
<mcEquals field="Main:Q3" value="a"/>
</conditions>
<trueSet>
<show form="Main"/>
</trueSet>
</if>
<show document="Thank you" reset="false"/>
</process>
<process name="Process 5">
<get recordList="HeaderInfo">
<forms>
<form name="Setup"/>
</forms>
</get>
<foreach record="HeaderItem" recordList="HeaderInfo">
<if>
<conditions>
<isNotBlank field="HeaderItem:Setup:Organization"/>
</conditions>
<trueSet>
<set field="OurGroup" arithmeticAsText="false">
<string field="HeaderItem:Setup:Organization"/>
</set>
<set field="OurText" arithmeticAsText="false">
<string field="HeaderItem:Setup:BodyText"/>
</set>
</trueSet>
</if>
</foreach>
<append document="ListToDate" appendage="ListHeader"/>
<get recordList="RecordFinal">
<forms>
<form name="Main"/>
</forms>
</get>
<foreach record="ItemX" recordList="RecordFinal">
<set field="PersonsName" arithmeticAsText="false">
<string field="ItemX:Main:First"/>
<string value=" "/>
<string field="ItemX:Main:Last"/>
</set>
<set field="PersonsEmail" arithmeticAsText="false">
<string field="ItemX:Main:Email"/>
</set>
<append document="ListToDate" appendage="ListCM"/>
</foreach>
<show document="ListToDate" reset="true"/>
</process>
<process name="Process 4">
<get recordList="Record List 2">
<forms>
<form name="Setup"/>
</forms>
</get>
<foreach record="Datum" recordList="Record List 2">
<set field="OurGroup" arithmeticAsText="false">
<string field="Datum:Setup:OurGroup"/>
</set>
<set field="OurText" arithmeticAsText="false">
<string field="Datum:Setup:OurText"/>
</set>
<set field="Secretary" arithmeticAsText="false">
<string field="Datum:Setup:Secretary"/>
</set>
</foreach>
<show document="ReportHeader" reset="false"/>
<append document="ListToDate" appendage="ListHeader"/>
<get recordList="Record List 1">
<forms>
<form name="Main"/>
</forms>
</get>
<foreach record="Candidate" recordList="Record List 1">
<set field="PersonsName" arithmeticAsText="false">
<string field="Candidate:Main:First"/>
<string value=" "/>
<string field="Candidate:Main:Last"/>
</set>
<set field="PersonsEmail" arithmeticAsText="false">
<string field="Candidate:Main:PersonsEmail"/>
</set>
<append document="ListToDate" appendage="ListCM"/>
</foreach>
<append document="Solicitation" appendage="ListToDate"/>
<show document="ListToDate" reset="true"/>
</process>
</processes>
<documents>
<document name="Try later">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="FF0000"><i>Please re-run </i></font><font face="Arial" size="220" color="FF0000"><b><i>Setup</i></b></font><font face="Arial" size="220" color="FF0000"><i> once you have gathered </i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="FF0000"><i>at least a couple of email addresses from your group.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="FF0000"><i>The more emails you have to start with, the more successful this</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="FF0000"><i>process will be.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="220" color="FF0000"><i>Thank you.</i></font></paragraph>
</xmlData>
</document>
<document name="ListHeader">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font face="Arial" size="200" color="000000"><b>Name</b></font></division></cell><cell width="5400"><division indent="0" align="left"><font face="Arial" size="200" color="000000"><b>Email Address</b></font></division></cell></row></table>
</xmlData>
</document>
<document name="ListCM">
<xmlData>
<table indent="0"><row><cell width="5400"><division indent="0" align="left"><font face="Arial" size="200" color="000000"><field name="PersonsName"/></font></division></cell><cell width="5400"><division indent="0" align="left"><font face="Arial" size="200" color="000000"><field name="PersonsEmail"/></font></division></cell></row></table>
</xmlData>
</document>
<document name="Thank you">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Thank you.  To get the most current list of email addresses for </font><font face="Arial" size="200" color="000000"><field name="OurGroup"/></font><font face="Arial" size="200" color="000000">, bookmark the following link:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000080"><u><invitation form="Administrator" project="">Current Email Address List</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph>
</xmlData>
</document>
<document name="Solicitation">
<xmlData>
