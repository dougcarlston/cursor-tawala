<form name="Administration" startPoint="true" themePath="default" process="Pre-Administration">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
</forms>
<processes>
<process name="Post-StartQuestionnaire">
<comment>get the display parameters for the current questionnaire</comment>
<get recordList="Setup Records">
<forms>
<form name="Customize"/>
</forms>
</get>
<foreach record="SetupRecord" recordList="Setup Records">
<set field="QuestionnaireTitle" arithmeticAsText="false">
<string field="SetupRecord:Customize:TitleText"/>
</set>
<set field="Question" arithmeticAsText="false">
<string field="SetupRecord:Customize:QuestionText"/>
</set>
<set field="NumberOfChoices" arithmeticAsText="false">
<string field="SetupRecord:Customize:NumberOfChoices"/>
</set>
<set field="Choice 1" arithmeticAsText="false">
<string field="SetupRecord:Customize:Choice1"/>
</set>
<set field="Choice 2" arithmeticAsText="false">
<string field="SetupRecord:Customize:Choice2"/>
</set>
<set field="Choice 3" arithmeticAsText="false">
<string field="SetupRecord:Customize:Choice3"/>
</set>
<set field="Choice 4" arithmeticAsText="false">
<string field="SetupRecord:Customize:Choice4"/>
</set>
<set field="IncludeName" arithmeticAsText="false">
<string value="false"/>
</set>
<if>
<conditions>
<mcEquals field="SetupRecord:Customize:AskForNames" value="a"/>
</conditions>
<trueSet>
<set field="IncludeName" arithmeticAsText="false">
<string value="true"/>
</set>
</trueSet>
</if>
</foreach>
<if>
<conditions>
<equals field="IncludeName">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<show form="Questionnaire_Name"/>
</trueSet>
</if>
<show form="Questionnaire"/>
</process>
<process name="Post-Customize">
<set field="NumberOfChoices" arithmeticAsText="false">
<string value="0"/>
</set>
<if>
<conditions>
<mcEquals field="Customize:AskForNames" value="a"/>
</conditions>
<trueSet>
<append document="Confirm Customization" appendage="Confirm Name"/>
</trueSet>
</if>
<append document="Confirm Customization" appendage="Confirm Question"/>
<if>
<conditions>
<isNotBlank field="Customize:Choice1"/>
</conditions>
<trueSet>
<set field="choiceLabel" arithmeticAsText="false">
<string value="   a)  "/>
</set>
<set field="choiceText" arithmeticAsText="false">
<string field="Customize:Choice1"/>
</set>
<append document="Confirm Customization" appendage="Confirm Choice"/>
<set field="NumberOfChoices" arithmeticAsText="false">
<add>
<operand field="NumberOfChoices"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<isNotBlank field="Customize:Choice2"/>
</conditions>
<trueSet>
<set field="choiceLabel" arithmeticAsText="false">
<string value="   b)  "/>
</set>
<set field="choiceText" arithmeticAsText="false">
<string field="Customize:Choice2"/>
</set>
<append document="Confirm Customization" appendage="Confirm Choice"/>
<set field="NumberOfChoices" arithmeticAsText="false">
<add>
<operand field="NumberOfChoices"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<isNotBlank field="Customize:Choice3"/>
</conditions>
<trueSet>
<set field="choiceLabel" arithmeticAsText="false">
<string value="   c)  "/>
</set>
<set field="choiceText" arithmeticAsText="false">
<string field="Customize:Choice3"/>
</set>
<append document="Confirm Customization" appendage="Confirm Choice"/>
<set field="NumberOfChoices" arithmeticAsText="false">
<add>
<operand field="NumberOfChoices"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<isNotBlank field="Customize:Choice4"/>
</conditions>
<trueSet>
<set field="choiceLabel" arithmeticAsText="false">
<string value="   d)  "/>
</set>
<set field="choiceText" arithmeticAsText="false">
<string field="Customize:Choice4"/>
</set>
<append document="Confirm Customization" appendage="Confirm Choice"/>
<set field="NumberOfChoices" arithmeticAsText="false">
<add>
<operand field="NumberOfChoices"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</trueSet>
</if>
</trueSet>
<falseSet>
<show document="Choice Count Error" reset="false"/>
<show form="Customize"/>
</falseSet>
</if>
</trueSet>
<falseSet>
<show document="Choice Count Error" reset="false"/>
<show form="Customize"/>
</falseSet>
</if>
<comment>"clear" previous submissions to keep them from being counted in results</comment>
<if>
<conditions>
<mcEquals field="Customize:AskForNames" value="a"/>
</conditions>
<trueSet>
<get recordList="recordsWithName">
<forms>
<form name="Questionnaire_Name"/>
</forms>
</get>
<foreach record="nameRecord" recordList="recordsWithName">
<set field="nameRecord:Questionnaire_Name:activeRecord" arithmeticAsText="false">
<string value="0"/>
</set>
</foreach>
</trueSet>
<falseSet>
<get recordList="records">
<forms>
<form name="Questionnaire"/>
</forms>
</get>
<foreach record="record" recordList="records">
<set field="record:Questionnaire:activeRecord" arithmeticAsText="false">
<string value="0"/>
</set>
</foreach>
</falseSet>
</if>
<append document="Confirm Customization" appendage="Confirm Footer"/>
<show document="Confirm Customization" reset="true"/>
</process>
<process name="Post_Questionnaire">
<comment>flag to include this record in all results counts</comment>
<set field="activeRecord" arithmeticAsText="false">
<string value="1"/>
</set>
<show document="Questionnaire Done" reset="false"/>
</process>
<process name="Post_Qustionnaire_Name">
<comment>flag to include this record in all results counts</comment>
<set field="activeRecord" arithmeticAsText="false">
<string value="1"/>
</set>
<show document="Questionnaire Done" reset="false"/>
</process>
<process name="Pre-Administration">
<get recordList="Settings">
<forms>
<form name="Customize"/>
</forms>
</get>
<foreach record="Setting" recordList="Settings">
<set field="QuestionnaireTitle" arithmeticAsText="false">
<string field="Setting:Customize:TitleText"/>
</set>
<set field="Question" arithmeticAsText="false">
<string field="Setting:Customize:QuestionText"/>
</set>
<set field="NumberOfChoices" arithmeticAsText="false">
<string field="Setting:Customize:NumberOfChoices"/>
</set>
<set field="Choice 1" arithmeticAsText="false">
<string field="Setting:Customize:Choice1"/>
</set>
<set field="Choice 2" arithmeticAsText="false">
<string field="Setting:Customize:Choice2"/>
</set>
<set field="Choice 3" arithmeticAsText="false">
<string field="Setting:Customize:Choice3"/>
</set>
<set field="Choice 4" arithmeticAsText="false">
<string field="Setting:Customize:Choice4"/>
</set>
<set field="IncludeName" arithmeticAsText="false">
<string value="false"/>
</set>
<if>
<conditions>
<mcEquals field="Setting:Customize:AskForNames" value="a"/>
</conditions>
<trueSet>
