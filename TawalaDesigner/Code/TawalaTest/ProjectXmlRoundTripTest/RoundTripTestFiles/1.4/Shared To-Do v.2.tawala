"10800"/><tabStop position="11520"/><tabStop position="12240"/></tabPositions><font face="Arial" size="200" color="000000">Your name:</font><tab/><font face="Arial" size="200" color="000000"><b><field name="OrganizerName"/></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/></tabPositions><font face="Arial" size="200" color="000000">Email:</font><tab/><font face="Arial" size="200" color="000000"><b><field name="OrganizerEmail"/></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/></tabPositions><font face="Arial" size="200" color="000000">Notify on sign up?</font><tab/><font face="Arial" size="200" color="000000"><b><field name="NotifyOrganizerOnSignup"/></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/></tabPositions><font face="Arial" size="200" color="000000">Notify on task completion?</font><tab/><font face="Arial" size="200" color="000000"><b><field name="NotifyOrganizerOnCompletion"/></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><tab/><tab/><font face="Arial" size="200" color="000000">Next:</font><sp/><font face="Arial" size="280" color="000080"><u><invitation form="task" project="">set up the tasks</invitation></u></font><font face="Arial" size="200" color="000000">.</font></paragraph>
