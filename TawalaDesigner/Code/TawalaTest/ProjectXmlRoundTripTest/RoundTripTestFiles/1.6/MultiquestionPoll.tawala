<mc label="Q1" onlyone="true" required="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>View poll</b></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>See totals from specific question</b></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>See detail results from specific question</b></font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>See totals from all multiple-choice questions</b></font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>See detail results from all questions</b></font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Show correlation detail for up to first ten questions</b></font></paragraph></choice></mc>
<fib label="Q2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Question number (for specific question options):</b></font><font face="Arial" size="200" color="000000"/><blank label="a" length="10" required="false"/></paragraph></fib>
</items>
</form>
<form name="SpecifyQuestion" startPoint="false" themePath="default" process="Post-SpecifyQuestion" preProcess="DisplayPollQuestions">
<items>
<fib label="Q1"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000"><b>Question number: </b></font><sp/><sp/><blank label="a" length="10" required="false"/></paragraph></fib>
</items>
</form>
<form name="TotalQuestion" startPoint="false" themePath="default" process="Post-TotalQuestion">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="DetailQuestion" startPoint="false" themePath="default" process="Post-DetailQuestion">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AllDetailQs" startPoint="false" themePath="default" process="Post-AllDetailQs">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="Correlation" startPoint="false" themePath="default" process="Post-Correlation">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
</forms>
<processes>
<process name="Post-Setup">
<comment>- delete previous poll data</comment>
<delete><form name="Create Poll"/></delete>
<delete><form name="PollLoop"/></delete>
<comment>- variables for display in Final Poll and PollPost documents</comment>
<set field="PollTitle" arithmeticAsText="false">
<string field="Setup:Title"/>
</set>
<set field="PollDate" arithmeticAsText="false">
<string field="Setup:Date"/>
</set>
<set field="PollPre" arithmeticAsText="false">
<string field="Setup:PreInstructions"/>
</set>
<set field="PollPost" arithmeticAsText="false">
<string field="Setup:PostInstructions"/>
</set>
<if>
<conditions>
<mcContains field="Setup:Q5" value="a"/>
</conditions>
<trueSet>
<comment>- flag used in Post-PollLoop process</comment>
<set field="Setup:ShowPoll" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
<falseSet>
<set field="Setup:ShowPoll" arithmeticAsText="false">
<string value="No"/>
</set>
</falseSet>
</if>
<set field="QNumber" arithmeticAsText="false">
<string value="0"/>
</set>
<show form="Create Poll"/>
</process>
<process name="Post-CreatePoll">
<set field="Create Poll:QuestionNumber" arithmeticAsText="false">
<string field="QNumber"/>
</set>
<if>
<conditions>
<mcEquals field="Create Poll:Q2" value="a"/>
</conditions>
<trueSet>
<comment>- set the question type in the stored record for this question</comment>
<set field="Create Poll:Type" arithmeticAsText="false">
<string value="MCQ"/>
</set>
<if>
<conditions>
<mcEquals field="Create Poll:Q5" value="a"/>
</conditions>
<trueSet>
<comment>- customizer wants to add another question</comment>
<show document="Poll So Far" reset="false"/>
<show form="Create Poll"/>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Create Poll:Q2" value="b"/>
</conditions>
<trueSet>
<comment>- set the question type in the stored record for this question</comment>
<set field="Create Poll:Type" arithmeticAsText="false">
<string value="FIB"/>
</set>
<if>
<conditions>
<mcEquals field="Create Poll:Q3" value="a"/>
</conditions>
<trueSet>
<comment>- customizer wants to add another question</comment>
<show document="Poll So Far" reset="false"/>
<show form="Create Poll"/>
</trueSet>
</if>
</trueSet>
</if>
<comment>- customizer is done adding questions</comment>
<show document="Final Poll Header" reset="false"/>
<set field="Create Poll:TotalQuestions" arithmeticAsText="false">
<string field="QNumber"/>
</set>
<show form="Setup Finish"/>
</process>
<process name="DisplayPollQuestions">
<comment>- get the list of questions</comment>
<get recordList="Record List 1">
<forms>
<form name="Create Poll"/>
</forms>
</get>
<foreach record="Question" recordList="Record List 1">
<comment>- question number and question text variable for display</comment>
<set field="QNumber" arithmeticAsText="false">
<string field="Question:Create Poll:QuestionNumber"/>
</set>
<set field="Q" arithmeticAsText="false">
<string field="Question:Create Poll:Q1:a"/>
</set>
<if>
<conditions>
<equals field="Question:Create Poll:Type">
<string value="FIB"/>
</equals>
</conditions>
<trueSet>
<comment>- append the question to the Final Poll doc</comment>
<append document="Final Poll" appendage="FIB"/>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="Question:Create Poll:Type">
<string value="MCQ"/>
</equals>
</conditions>
<trueSet>
<comment>- accumulate choice text, appending each one to Final Poll doc</comment>
<set field="A" arithmeticAsText="false">
<string field="Question:Create Poll:Q4:a"/>
</set>
<set field="B" arithmeticAsText="false">
<string field="Question:Create Poll:Q4:b"/>
</set>
<if>
<conditions>
<isBlank field="Question:Create Poll:Q4:c"/>
</conditions>
<trueSet>
<append document="Final Poll" appendage="MCQ2"/>
</trueSet>
<falseSet>
<set field="C" arithmeticAsText="false">
<string field="Question:Create Poll:Q4:c"/>
</set>
<if>
<conditions>
<isBlank field="Question:Create Poll:Q4:d"/>
</conditions>
<trueSet>
<append document="Final Poll" appendage="MCQ3"/>
</trueSet>
<falseSet>
<set field="D" arithmeticAsText="false">
<string field="Question:Create Poll:Q4:d"/>
</set>
<append document="Final Poll" appendage="MCQ4"/>
</falseSet>
</if>
</falseSet>
</if>
</trueSet>
<falseSet>
<comment>- clear choice text so it won't display where not appropriate</comment>
<set field="A" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="B" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="C" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="D" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
</falseSet>
</if>
</foreach>
<set field="QNumber" arithmeticAsText="false">
<add>
<operand field="QNumber"/>
<operand value="1"/>
</add>
</set>
<comment>- show the assembled document</comment>
<show document="Final Poll" reset="true"/>
</process>
<process name="Post-SetupFinish">
<show document="Setup End" reset="false"/>
</process>
<process name="DisplayPollHeader">
<comment>- set the display variables for Final Poll and PostPoll documents</comment>
<get recordList="Record List 2">
<forms>
<form name="Setup"/>
</forms>
</get>
<foreach record="Configuration" recordList="Record List 2">
<if>
<conditions>
<isNotBlank field="Configuration:Setup:Title"/>
</conditions>
<trueSet>
<set field="PollTitle" arithmeticAsText="false">
<string field="Configuration:Setup:Title"/>
</set>
<set field="PollDate" arithmeticAsText="false">
<string field="Configuration:Setup:Date"/>
</set>
<set field="PollPre" arithmeticAsText="false">
<string field="Configuration:Setup:PreInstructions"/>
</set>
<set field="PollPost" arithmeticAsText="false">
<string field="Configuration:Setup:PostInstructions"/>
</set>
<set field="PollShow" arithmeticAsText="false">
<string field="Configuration:Setup:ShowPoll"/>
</set>
</trueSet>
</if>
</foreach>
<show document="Final Poll" reset="false"/>
</process>
<process name="Post-Main">
<comment>- set up the initial question number and the total question count</comment>
<set field="QNumber" arithmeticAsText="false">
<string value="1"/>
</set>
<set field="QuestionTotal" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 5">
<forms>
<form name="Create Poll"/>
</forms>
</get>
<foreach record="TotalNumber" recordList="Record List 5">
<if>
<conditions>
<isLessThan field="QuestionTotal">
<string field="TotalNumber:Create Poll:TotalQuestions"/>
</isLessThan>
</conditions>
<trueSet>
<set field="QuestionTotal" arithmeticAsText="false">
<string field="TotalNumber:Create Poll:TotalQuestions"/>
</set>
</trueSet>
</if>
</foreach>
<comment>- now show the first question</comment>
<show form="PollLoop"/>
</process>
<process name="Pre-PollLoop">
<comment>- fetch the current question to display in the PollLoop form</comment>
<get recordList="Record List 3">
<forms>
<form name="Create Poll"/>
</forms>
<conditions>
<equals field="Record List 3:Create Poll:QuestionNumber">
<string field="QNumber"/>
</equals>
</conditions></get>
<foreach record="Query" recordList="Record List 3">
<set field="Q" arithmeticAsText="false">
<string field="Query:Create Poll:Q1:a"/>
</set>
<set field="QType" arithmeticAsText="false">
<string field="Query:Create Poll:Type"/>
</set>
<set field="A" arithmeticAsText="false">
<string field="Query:Create Poll:Q4:a"/>
</set>
<set field="B" arithmeticAsText="false">
<string field="Query:Create Poll:Q4:b"/>
</set>
<set field="C" arithmeticAsText="false">
<string field="Query:Create Poll:Q4:c"/>
</set>
<set field="D" arithmeticAsText="false">
<string field="Query:Create Poll:Q4:d"/>
</set>
</foreach>
</process>
<process name="Post-PollLoop">
<comment>- store the user's response</comment>
<if>
<conditions>
<equals field="QType">
<string value="FIB"/>
</equals>
</conditions>
<trueSet>
<set field="PollLoop:Answer" arithmeticAsText="false">
<string field="PollLoop:Q1:a"/>
</set>
</trueSet>
<falseSet>
<set field="PollLoop:Answer" arithmeticAsText="false">
<string field="PollLoop:Q2"/>
</set>
</falseSet>
</if>
<comment>- set up for the next question</comment>
<set field="PollLoop:QuestionNumber" arithmeticAsText="false">
<string field="QNumber"/>
</set>
<set field="PollLoop:Question" arithmeticAsText="false">
<string field="Q"/>
</set>
<set field="PollLoop:ChoiceA" arithmeticAsText="false">
<string field="A"/>
</set>
<set field="PollLoop:ChoiceB" arithmeticAsText="false">
<string field="B"/>
</set>
<set field="PollLoop:ChoiceC" arithmeticAsText="false">
<string field="C"/>
</set>
<set field="PollLoop:ChoiceD" arithmeticAsText="false">
<string field="D"/>
</set>
<set field="PollLoop:Type" arithmeticAsText="false">
<string field="QType"/>
</set>
<set field="QNumber" arithmeticAsText="false">
<add>
<operand field="QNumber"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<isLessThanOrEqualTo field="QNumber">
<string field="QuestionTotal"/>
</isLessThanOrEqualTo>
</conditions>
<trueSet>
<comment>- and present it to the user</comment>
<show form="PollLoop"/>
</trueSet>
</if>
<comment>- we end up here if there are no more questions</comment>
<set field="QNumber" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="Record List 8">
<forms>
<form name="Setup"/>
</forms>
</get>
<foreach record="Choice" recordList="Record List 8">
<comment>- if customizer has set flag to allow the user to see the results</comment>
<if>
<conditions>
<isNotBlank field="Choice:Setup:ShowPoll"/>
</conditions>
<trueSet>
<set field="PollShow" arithmeticAsText="false">
<string field="Choice:Setup:ShowPoll"/>
</set>
</trueSet>
</if>
</foreach>
<show document="PollPost" reset="false"/>
<if>
<conditions>
<equals field="PollShow">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<comment>- show them</comment>
<show form="DisplayResults"/>
</trueSet>
</if>
</process>
<process name="Post-DisplayResults">
<set field="QNumber" arithmeticAsText="false">
<string value="1"/>
</set>
<comment>- get all the users' responses and do the calcualtions to display the results</comment>
<get recordList="Record List 4">
<forms>
<form name="PollLoop"/>
</forms>
</get>
<foreach record="Query" recordList="Record List 4">
<if>
<conditions>
<and>
<equals field="QNumber">
<string field="Query:PollLoop:QuestionNumber"/>
</equals>
<equals field="Query:PollLoop:Type">
<string value="MCQ"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="TotA" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="TotB" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="TotC" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="TotD" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="Q" arithmeticAsText="false">
<string field="Query:PollLoop:Question"/>
</set>
<set field="A" arithmeticAsText="false">
<string field="Query:PollLoop:ChoiceA"/>
</set>
<set field="B" arithmeticAsText="false">
<string field="Query:PollLoop:ChoiceB"/>
</set>
<set field="C" arithmeticAsText="false">
<string field="Query:PollLoop:ChoiceC"/>
</set>
<set field="D" arithmeticAsText="false">
<string field="Query:PollLoop:ChoiceD"/>
</set>
<set field="TotalResponses" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 9">
<forms>
<form name="PollLoop"/>
</forms>
<conditions>
<and>
<equals field="QNumber">
<string field="Record List 9:PollLoop:QuestionNumber"/>
</equals>
<equals field="Record List 9:PollLoop:Type">
<string value="MCQ"/>
</equals>
</and>
</conditions></get>
<foreach record="Response" recordList="Record List 9">
<set field="TotalResponses" arithmeticAsText="false">
<add>
<operand field="TotalResponses"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<contains field="Response:PollLoop:Answer">
<string value="a"/>
</contains>
</conditions>
<trueSet>
<set field="TotA" arithmeticAsText="false">
<add>
<operand field="TotA"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<contains field="Response:PollLoop:Answer">
<string value="b"/>
</contains>
</conditions>
<trueSet>
<set field="TotB" arithmeticAsText="false">
<add>
<operand field="TotB"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<contains field="Response:PollLoop:Answer">
<string value="c"/>
</contains>
</conditions>
<trueSet>
<set field="TotC" arithmeticAsText="false">
<add>
<operand field="TotC"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<contains field="Response:PollLoop:Answer">
<string value="d"/>
</contains>
</conditions>
<trueSet>
<set field="TotD" arithmeticAsText="false">
<add>
<operand field="TotD"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
<set field="PercentA" arithmeticAsText="false">
<div>
<mul>
<operand field="TotA"/>
<operand value="100"/>
</mul>
<operand field="TotalResponses"/>
</div>
</set>
<set field="PercentB" arithmeticAsText="false">
<div>
<mul>
<operand field="TotB"/>
<operand value="100"/>
</mul>
<operand field="TotalResponses"/>
</div>
</set>
<set field="PercentC" arithmeticAsText="false">
<div>
<mul>
<operand field="TotC"/>
<operand value="100"/>
</mul>
<operand field="TotalResponses"/>
</div>
</set>
<set field="PercentD" arithmeticAsText="false">
<div>
<mul>
<operand field="TotD"/>
<operand value="100"/>
</mul>
<operand field="TotalResponses"/>
</div>
</set>
<set field="PercentA" arithmeticAsText="false">
<string field="PercentA"/>
<string value="%"/>
</set>
<set field="PercentB" arithmeticAsText="false">
<string field="PercentB"/>
<string value="%"/>
</set>
<set field="PercentC" arithmeticAsText="false">
<string field="PercentC"/>
<string value="%"/>
</set>
<set field="PercentD" arithmeticAsText="false">
<string field="PercentD"/>
<string value="%"/>
</set>
<if>
<conditions>
<isBlank field="C"/>
</conditions>
<trueSet>
<set field="TotC" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="PercentC" arithmeticAsText="false">
<string value=" "/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="D"/>
</conditions>
<trueSet>
<set field="TotD" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="PercentD" arithmeticAsText="false">
<string value=" "/>
</set>
</trueSet>
</if>
<append document="TotalResults" appendage="ResultsCM"/>
</trueSet>
</if>
<set field="QNumber" arithmeticAsText="false">
<add>
<operand field="QNumber"/>
<operand value="1"/>
</add>
</set>
</foreach>
<comment>- show the results doc</comment>
<show document="TotalResults" reset="true"/>
<if>
<conditions>
<equals field="Admin">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<comment>- if we got here via the Administration form, redisplay it</comment>
<set field="Admin" arithmeticAsText="false">
<string value="No"/>
</set>
<show form="Administration"/>
</trueSet>
</if>
</process>
<process name="Post-Administration">
<comment>- process the Administrator's choice from the Form</comment>
<if>
<conditions>
<mcEquals field="Administration:Q1" value="a"/>
</conditions>
<trueSet>
<comment>- View poll</comment>
<get recordList="Record List 10">
<forms>
<form name="Create Poll"/>
</forms>
</get>
<foreach record="QAdmin" recordList="Record List 10">
<set field="QNumber" arithmeticAsText="false">
<string field="QAdmin:Create Poll:QuestionNumber"/>
</set>
<set field="Q" arithmeticAsText="false">
<string field="QAdmin:Create Poll:Q1:a"/>
</set>
<if>
<conditions>
<equals field="QAdmin:Create Poll:Type">
<string value="FIB"/>
</equals>
</conditions>
<trueSet>
<append document="Final Poll" appendage="FIB"/>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="QAdmin:Create Poll:Type">
<string value="MCQ"/>
</equals>
</conditions>
<trueSet>
<set field="A" arithmeticAsText="false">
<string field="QAdmin:Create Poll:Q4:a"/>
</set>
<set field="B" arithmeticAsText="false">
<string field="QAdmin:Create Poll:Q4:b"/>
</set>
<if>
<conditions>
<isBlank field="QAdmin:Create Poll:Q4:c"/>
</conditions>
<trueSet>
<append document="Final Poll" appendage="MCQ2"/>
</trueSet>
<falseSet>
<set field="C" arithmeticAsText="false">
<string field="QAdmin:Create Poll:Q4:c"/>
</set>
<if>
<conditions>
<isBlank field="QAdmin:Create Poll:Q4:d"/>
</conditions>
<trueSet>
<append document="Final Poll" appendage="MCQ3"/>
</trueSet>
<falseSet>
<set field="D" arithmeticAsText="false">
<string field="QAdmin:Create Poll:Q4:d"/>
</set>
