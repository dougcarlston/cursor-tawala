<fib label="Q2"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Arial" size="200" color="000000">Enter new data or leave a field blank to leave as is:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/><tabStop position="12960"/><tabStop position="13680"/><tabStop position="14400"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/><tabStop position="12960"/><tabStop position="13680"/><tabStop position="14400"/></tabPositions><font face="Arial" size="200" color="000000"><b>Change " </b></font><font face="Arial" size="200" color="000000"><b><field name="First"/></b></font><font face="Arial" size="200" color="000000"><b>" to:</b></font><sp/><tab/><blank label="a" length="28" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/><tabStop position="12960"/><tabStop position="13680"/><tabStop position="14400"/></tabPositions><font face="Arial" size="200" color="000000"><b>Change "</b></font><font face="Arial" size="200" color="000000"><b><field name="Last"/></b></font><font face="Arial" size="200" color="000000"><b>" to:</b></font><tab/><blank label="b" length="28" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/><tabStop position="10800"/><tabStop position="11520"/><tabStop position="12240"/><tabStop position="12960"/><tabStop position="13680"/><tabStop position="14400"/></tabPositions><font face="Arial" size="200" color="000000"><b>Change "</b></font><font face="Arial" size="200" color="000000"><b><field name="Contact"/></b></font><font face="Arial" size="200" color="000000"><b>" to: </b></font><tab/><blank label="c" length="28" required="false"/></paragraph></fib>
</items>
