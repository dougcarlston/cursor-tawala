</forms>
<processes>
<process name="Process 1">
<if>
<conditions>
<mcEquals field="Main:MenuChoice" value="a"/>
</conditions>
<trueSet>
<show document="Add a name" reset="false"/>
<show form="Main"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcEquals field="Main:MenuChoice" value="h"/>
<or>
<mcEquals field="Main:MenuChoice">
<string value="e"/>
</mcEquals>
<or>
<mcEquals field="Main:MenuChoice">
<string value="f"/>
</mcEquals>
<mcEquals field="Main:MenuChoice">
<string value="g"/>
</mcEquals>
</or>
</or>
</or>
</conditions>
<trueSet>
<show document="Header" reset="false"/>
</trueSet>
</if>
<get recordList="Record List 1">
<forms>
<form name="BBSharedEmailList" externalSharedData="true"/>
</forms>
</get>
<foreach record="Person" recordList="Record List 1">
<if>
<conditions>
<and>
<mcEquals field="Main:MenuChoice">
<string value="b"/>
</mcEquals>
<equals field="Main:SearchEmail">
<string field="Person:BBSharedEmailList:Email"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="Person:BBSharedEmailList:publishName" arithmeticAsText="false">
<string value="false"/>
</set>
<set field="Person:BBSharedEmailList:DisplayEmail" arithmeticAsText="true">
<string value="** deleted **"/>
</set>
<set field="Person:BBSharedEmailList:duplicateRecord" arithmeticAsText="false">
<string value="true"/>
</set>
<show document="DeleteConfirm" reset="false"/>
</trueSet>
</if>
<set field="FirstName" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:First"/>
</set>
<set field="LastName" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:Last"/>
</set>
<set field="Email" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:Email"/>
</set>
<set field="DupRecord" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:duplicateRecord"/>
</set>
<set field="DisplayEmail" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:DisplayEmail"/>
</set>
<set field="PubName" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:publishName"/>
</set>
<if>
<conditions>
<and>
<mcEquals field="Main:MenuChoice">
<string value="c"/>
</mcEquals>
<equals field="Main:SearchEmail">
<string field="Email"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="First" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:First"/>
</set>
<set field="Last" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:Last"/>
</set>
<set field="Contact" arithmeticAsText="false">
<string field="Person:BBSharedEmailList:Email"/>
</set>
<show form="Edit Item"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="Main:MenuChoice" value="d"/>
<isNotBlank field="Main:SearchEmail" />
</and>
</conditions>
<trueSet>
<get recordList="Record List 7">
<forms>
<form name="BBSharedEmailList" externalSharedData="true"/>
</forms>
<conditions>
<and>
<equals field="Record List 7:BBSharedEmailList:Email">
<string field="Main:SearchEmail"/>
</equals>
<equals field="Record List 7:BBSharedEmailList:DisplayEmail">
<string value="** unconfirmed **"/>
</equals>
</and>
</conditions></get>
<foreach record="UnconfirmedPerson" recordList="Record List 7">
<set field="UnconfirmedPerson:BBSharedEmailList:DisplayEmail" arithmeticAsText="false">
<string field="UnconfirmedPerson:BBSharedEmailList:Email"/>
</set>
<set field="UnconfirmedPerson:BBSharedEmailList:publishName" arithmeticAsText="false">
<string value="true"/>
</set>
<show document="Confirmation" reset="false"/>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Main:MenuChoice" value="e"/>
</conditions>
<trueSet>
<show document="Show Table" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="Main:MenuChoice" value="f"/>
<equals field="DisplayEmail">
<string value="** unconfirmed **"/>
</equals>
</and>
</conditions>
<trueSet>
<show document="Show Table" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="Main:MenuChoice" value="g"/>
<equals field="PubName">
<string value="false"/>
</equals>
</and>
</conditions>
<trueSet>
<show document="Show Table" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="Main:MenuChoice">
<string value="h"/>
</mcEquals>
<and>
<doesNotEqual field="DisplayEmail">
<string value="** unconfirmed **"/>
</doesNotEqual>
<doesNotEqual field="DisplayEmail">
<string value="** deleted **"/>
</doesNotEqual>
</and>
</and>
</conditions>
<trueSet>
<show document="Show Table" reset="false"/>
</trueSet>
</if>
</foreach>
<show form="Main"/>
</process>
<process name="Process 2">
<if>
<conditions>
<mcEquals field="Edit Item:Q1" value="a"/>
</conditions>
<trueSet>
<get recordList="Record List 2">
<forms>
<form name="BBSharedEmailList" externalSharedData="true"/>
</forms>
<conditions>
<and>
<equals field="Record List 2:BBSharedEmailList:Email">
<string field="Contact"/>
</equals>
<doesNotEqual field="Record List 2:BBSharedEmailList:duplicateRecord">
<string value="Wrong"/>
</doesNotEqual>
</and>
</conditions></get>
<foreach record="TestCase" recordList="Record List 2">
<if>
<conditions>
<isNotBlank field="Edit Item:Q2:a" />
</conditions>
<trueSet>
<set field="TestCase:BBSharedEmailList:First" arithmeticAsText="false">
<string field="Edit Item:Q2:a"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Edit Item:Q2:b" />
</conditions>
<trueSet>
<set field="TestCase:BBSharedEmailList:Last" arithmeticAsText="false">
<string field="Edit Item:Q2:b"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Edit Item:Q2:c" />
</conditions>
<trueSet>
<set field="TestCase:BBSharedEmailList:Email" arithmeticAsText="false">
<string field="Edit Item:Q2:c"/>
</set>
</trueSet>
</if>
<set field="TestCase:BBSharedEmailList:DisplayEmail" arithmeticAsText="false">
<string field="TestCase:BBSharedEmailList:Email"/>
</set>
<get recordList="Record List 3">
<forms>
<form name="BBSharedEmailList" externalSharedData="true"/>
</forms>
<conditions>
<equals field="Record List 3:BBSharedEmailList:duplicateRecord">
<string value="Wrong"/>
</equals>
</conditions></get>
<foreach record="SuchItem" recordList="Record List 3">
<set field="SuchItem:BBSharedEmailList:duplicateRecord" arithmeticAsText="false">
<string value="false"/>
</set>
</foreach>
<show form="Main"/>
</foreach>
</trueSet>
<falseSet>
<get recordList="Record List 5">
<forms>
<form name="BBSharedEmailList" externalSharedData="true"/>
</forms>
<conditions>
<and>
<equals field="Record List 5:BBSharedEmailList:First">
<string field="First"/>
</equals>
<and>
<equals field="Record List 5:BBSharedEmailList:Last">
<string field="Last"/>
</equals>
<equals field="Record List 5:BBSharedEmailList:Email">
<string field="Contact"/>
</equals>
</and>
</and>
</conditions></get>
<foreach record="Such" recordList="Record List 5">
<set field="Such:BBSharedEmailList:duplicateRecord" arithmeticAsText="false">
<string value="Wrong"/>
</set>
</foreach>
<get recordList="Record List 6">
<forms>
<form name="BBSharedEmailList" externalSharedData="true"/>
</forms>
<conditions>
<and>
<equals field="Record List 6:BBSharedEmailList:Email">
<string field="Contact"/>
</equals>
<doesNotEqual field="Record List 6:BBSharedEmailList:duplicateRecord">
<string value="Wrong"/>
</doesNotEqual>
</and>
</conditions></get>
<foreach record="DataCase" recordList="Record List 6">
<set field="First" arithmeticAsText="false">
<string field="DataCase:BBSharedEmailList:First"/>
</set>
<set field="Last" arithmeticAsText="false">
<string field="DataCase:BBSharedEmailList:Last"/>
</set>
<set field="Contact" arithmeticAsText="false">
<string field="DataCase:BBSharedEmailList:Email"/>
</set>
</foreach>
<show form="Edit Item"/>
</falseSet>
</if>
<show document="NoMatch" reset="false"/>
<get recordList="Record List 4">
<forms>
<form name="BBSharedEmailList" externalSharedData="true"/>
</forms>
<conditions>
<equals field="Record List 4:BBSharedEmailList:duplicateRecord">
<string value="Wrong"/>
</equals>
</conditions></get>
<foreach record="SuchCase" recordList="Record List 4">
<set field="SuchCase:BBSharedEmailList:duplicateRecord" arithmeticAsText="false">
<string value="false"/>
</set>
</foreach>
<show form="Main"/>
</process>
</processes>
