<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font face="Comic Sans MS" size="220" color="000000">Thank you.  To see the current list for </font><font face="Comic Sans MS" size="220" color="000000"><field name="OurGroup"/></font><sp/><font face="Comic Sans MS" size="220" color="000080"><u><invitation form="Administration" project="" private="true"><authenticationTokenValue><string value="fromQuestionnaire"/>
</authenticationTokenValue>click here</invitation></u></font><font face="Arial" size="200" color="000000">.</font></paragraph>
