<form name="Entry"/>
</forms>
<conditions>
<and>
<equals field="Record List 18:Entry:Stage">
<string field="LiveLdBd:stage"/>
</equals>
<isLessThan field="Record List 18:Entry:Mscore">
<string field="mSkor5"/>
</isLessThan>
</and>
</conditions></get>
<foreach record="Record18" recordList="Record List 18">
<set field="Record18:Entry:Rank" arithmeticAsText="true">
<string value="---"/>
</set>
<set field="Record18:Entry:Prank" arithmeticAsText="true">
<string value="---"/>
</set>
</foreach>
