</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tawala ASP Order Form Administrator</font></paragraph></heading>
<fib label="Q2" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send order to:  </font><blank label="a" length="20" required="false" alternateLabel="First"/><sp/><sp/><font face="Arial" size="200" color="000000"><i>(first)  </i></font><blank label="b" length="18" required="false" alternateLabel="Last"/><sp/><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph></fib>
<fib label="Q3" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">at this email: </font><blank label="a" length="55" required="false" alternateLabel="CustomerEmail"/></paragraph></fib>
<fib label="Q4" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Today's date </font><font face="Arial" size="200" color="000000"><i>(mm/dd/yyyy):</i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="20" required="false" alternateLabel="PODate"/></paragraph></fib>
<fib label="Q5" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Organization: </font><blank label="a" length="55" required="false" alternateLabel="Organization"/></paragraph></fib>
<fib label="Q6" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Product/Services Description: </font><blank label="a" length="55" required="false" alternateLabel="ProdDesc"/></paragraph></fib>
<fib label="Q7" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Sent by </font><font face="Arial" size="200" color="000000"><i>(name)</i></font><sp/><blank label="a" length="55" required="false" alternateLabel="SentName"/></paragraph></fib>
<fib label="Q8" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>(email)</i></font><sp/><blank label="a" length="55" required="false" alternateLabel="SentEmail"/></paragraph></fib>
<fib label="Q9" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Message body </font><font face="Arial" size="200" color="000000"><i>(omit Salutation and Close)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="53" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<mc label="Q10" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Copy me on this order</font></paragraph></choice></mc>
<fib label="Q11" alternateLabel="CCs" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send additional copies of order to the following email(s): </font><blank label="a" length="20" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="b" length="20" required="false"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="c" length="20" required="false"/></paragraph></fib>
<mc label="Q12" alternateLabel="Price" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Purchase price:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Flat Fee</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Fee per registrant</font></paragraph></choice></mc>
<skipInstructions>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcIsBlank field="Administration:Price" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You must select a price!"/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Administration:Price" value="b"/>
</conditions>
<trueSet>
<skip to="Q14"/>
</trueSet>
</if>
</skipInstructions>
<fib label="Q13" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Flat Fee:  $ </font><blank label="a" length="20" required="false" alternateLabel="FlatFee"/></paragraph></fib>
<skipInstructions>
<skip to="H3"/>
</skipInstructions>
<fib label="Q14" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Fee per registrant: $ </font><blank label="a" length="20" required="false" alternateLabel="FeePerPlayer"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Administration:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H3" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tawala ASP Order Form Administrator</font></paragraph></heading>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is how your message will look:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="450"><row><cell width="2940"><division indent="0" align="right"><font><b>To:</b></font></division></cell><cell width="272"></cell><cell width="7138"><division indent="0" align="left"><font><field name="Administration:First"/></font><sp/><font><field name="Administration:Last"/></font><font> (</font><font><field name="Administration:CustomerEmail"/></font><font>)</font></division></cell></row><row><cell width="2940"><division indent="0" align="right"><font><b>From:</b></font></division></cell><cell width="272"></cell><cell width="7138"><division indent="0" align="left"><font><field name="Administration:SentName"/></font><font>  (</font><font><field name="Administration:SentEmail"/></font><font>)</font></division></cell></row><row><cell width="2940"><division indent="0" align="right"><font><b>Date:</b></font></division></cell><cell width="272"></cell><cell width="7138"><division indent="0" align="left"><font>Today</font></division></cell></row><row><cell width="2940"><division indent="0" align="right"><font><b>Subject:</b></font></division></cell><cell width="272"></cell><cell width="7138"><division indent="0" align="left"><font><field name="Administration:Organization"/></font><font> Tawala SportsDashboards Purchase Order</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="420"><row><cell width="10380"><division indent="0" align="left"><font>Dear </font><font><field name="Administration:First"/></font><font><i>,</i></font></division></cell></row><row><cell width="10380"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10380"><division indent="0" align="left"><font><field name="Administration:Body"/></font></division></cell></row><row><cell width="10380"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10380"><division indent="0" align="left"><font>Yours,</font></division></cell></row><row><cell width="10380"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10380"><division indent="0" align="left"><font><field name="Administration:SentName"/></font></division></cell></row><row><cell width="10380"><division indent="0" align="left"><font><field name="Administration:SentEmail"/></font></division></cell></row></table></text>
<mc label="Q15" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send the message</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit message further</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon message</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Administration:Q15" value="b"/>
</conditions>
<trueSet>
<skip to="H2"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Administration:Q15" value="c"/>
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H4" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tawala ASP Order Form Administrator</font></paragraph></heading>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Purchase orders sent:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="PO #"/>
</header><contents><field name="Record:Administration:ID" /></contents></column><column><header><string value="Date"/>
</header><contents><field name="Record:Administration:PODate" /></contents></column><column><header><string value="Organization"/>
</header><contents><field name="Record:Administration:Organization" /></contents></column><column><header><string value="Description"/>
</header><contents><field name="Record:Administration:ProdDesc" /></contents></column><column><header><string value="First"/>
</header><contents><field name="Record:Administration:First" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Administration:Last" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Administration:CustomerEmail" /></contents></column><column><header><string value="Price"/>
</header><contents><field name="Record:Administration:QuotedPrice" /></contents></column><conditions><form name="Administration" /><conditions>
<isNotBlank field="Record:Administration:ID" />
</conditions></conditions></itemization-table></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H5" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tawala ASP Order Form Administrator</font></paragraph></heading>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Completed Agreements received:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="PO Number"/>
</header><contents><field name="Record:OrderForm:PurchaseNumber" /></contents></column><column><header><string value="Date"/>
</header><contents><field name="Record:OrderForm:Date" /></contents></column><column><header><string value="Organization"/>
</header><contents><field name="Record:OrderForm:OrgName" /></contents></column><column><header><string value="Contact"/>
</header><contents><field name="Record:OrderForm:Contact" /></contents></column><column><header><string value="Description"/>
</header><contents><field name="Record:OrderForm:Description" /></contents></column><column><header><string value="Price"/>
</header><contents><field name="Record:OrderForm:QuotedPrice" /></contents></column><column><header><string value="Address"/>
</header><contents><field name="Record:OrderForm:Address" /></contents></column><column><header><string value="Phone"/>
</header><contents><field name="Record:OrderForm:Phone" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:OrderForm:Email" /></contents></column><conditions><form name="OrderForm" /></conditions></itemization-table></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H6" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tawala ASP Order Form Administrator</font></paragraph></heading>
<mc label="Q16" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Agreement to delete:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:OrderForm:OrgName"/>
<string value=" ("/>
<field name="Record:OrderForm:Contact"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:OrderForm:PurchaseNumber"/>
</value-expression><sort-expression><field name="Record:OrderForm:OrgName"/>
</sort-expression><record-selector><form name="OrderForm" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="Administration:Q16" />
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H7" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tawala ASP Order Form Administrator</font></paragraph></heading>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Delete </font><font><display-mcq-label version="1"><field-name>Administration:Q16</field-name><display>label_only</display></display-mcq-label></font></paragraph></text>
<mc label="Q17" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Are you sure?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No</font></paragraph></choice></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H8" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tawala ASP Order Form Administrator</font></paragraph></heading>
<mc label="Q18" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Which PO do you want to resend?</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Administration:First"/>
<string value=" "/>
<field name="Record:Administration:Last"/>
<string value=" (Invoice #"/>
<field name="Record:Administration:ID"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Administration:ID"/>
</value-expression><sort-expression><field name="Record:Administration:ID"/>
</sort-expression><record-selector><form name="Administration" /><conditions>
<isNotBlank field="Record:Administration:ID" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H9" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Tawala ASP Order Form Administrator</font></paragraph></heading>
<text label="T6" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To view reports, just press Submit.  To send a report, add email address:</font></paragraph></text>
<fib label="Q19" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email:</font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="20" required="false"/></paragraph></fib>
<field name="QuotedPrice"/>
<field name="ID"/>
<field name="AgreementRecd"/>
</items>
</form>
<form name="PasswordEntry" startPoint="false" themePath="litegreen" process="Process 5">
<items>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter Password: </font><blank label="a" length="20" required="false" alternateLabel="password"/></paragraph></fib>
</items>
</form>
</forms>
<processes>
<process name="Process 1">
<set field="OrderForm:Date" arithmeticAsText="true">
<string field="OrderForm:Month"/>
<string value="/"/>
<string field="OrderForm:Day"/>
<string value="/20"/>
<string field="OrderForm:Year"/>
</set>
<if>
<conditions>
<mcContains field="OrderForm:Signature" value="a"/>
</conditions>
<trueSet>
<get recordList="Record List 1">
<forms>
<form name="Administration"/>
</forms>
<conditions>
<equals field="Record List 1:Administration:ID">
<string field="_InviteeID"/>
</equals>
</conditions></get>
<foreach record="SignedRecord" recordList="Record List 1">
<set field="SignedRecord:Administration:AgreementRecd" arithmeticAsText="false">
<string field="_InviteeID"/>
</set>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<equals field="AdminEntry">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="OrderForm:PurchaseNumber" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="AdminEntry" arithmeticAsText="false">
<string value=" "/>
</set>
<get recordList="Record List 5">
<forms>
<form name="OrderForm"/>
</forms>
</get>
<foreach record="RecordedEntry" recordList="Record List 5">
<if>
<conditions>
<isGreaterThanOrEqualTo field="RecordedEntry:OrderForm:PurchaseNumber">
<string field="OrderForm:PurchaseNumber"/>
</isGreaterThanOrEqualTo>
</conditions>
<trueSet>
<set field="OrderForm:PurchaseNumber" arithmeticAsText="false">
<add>
<operand field="RecordedEntry:OrderForm:PurchaseNumber"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
<set field="Check" arithmeticAsText="false">
<string value="No"/>
</set>
<get recordList="Record List 6">
<forms>
<form name="Administration"/>
</forms>
<conditions>
<and>
<equals field="Record List 6:Administration:Organization">
<string field="OrderForm:OrgName"/>
</equals>
<equals field="Record List 6:Administration:ProdDesc">
<string field="OrderForm:Description"/>
</equals>
</and>
</conditions></get>
<foreach record="Duplicate" recordList="Record List 6">
<set field="Check" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="Duplicate:Administration:AgreementRecd" arithmeticAsText="false">
<string field="OrderForm:PurchaseNumber"/>
</set>
</foreach>
<if>
<conditions>
<equals field="Check">
<string value="No"/>
</equals>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="No match found for this received PO in list of PO&apos;s sent.  Check Org name and Description."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<show form="Administration"/>
</trueSet>
</if>
<show document="Thankyou" reset="false"/>
</process>
<process name="Process 2">
<if>
<conditions>
<mcEquals field="Administration:Price" value="b"/>
</conditions>
<trueSet>
<set field="Administration:QuotedPrice" arithmeticAsText="false">
<string value="$"/>
<string field="Administration:FeePerPlayer"/>
<string value=" Dollars per Registrant"/>
</set>
</trueSet>
<falseSet>
<set field="Administration:QuotedPrice" arithmeticAsText="false">
<string value="$"/>
<string field="Administration:FlatFee"/>
<string value=" Dollars"/>
</set>
</falseSet>
</if>
<comment>Send  a purchase order link to a new customer</comment>
<if>
<conditions>
<mcEquals field="Administration:Q1" value="a"/>
</conditions>
<trueSet>
<set field="Administration:ID" arithmeticAsText="false">
<string value="1000"/>
</set>
<get recordList="Record List 3">
<forms>
<form name="Administration"/>
</forms>
</get>
<foreach record="IDNo" recordList="Record List 3">
<if>
<conditions>
<isLessThanOrEqualTo field="Administration:ID">
<string field="IDNo:Administration:ID"/>
</isLessThanOrEqualTo>
</conditions>
<trueSet>
<set field="Administration:ID" arithmeticAsText="false">
<add>
<operand field="IDNo:Administration:ID"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
<set field="CEmail" arithmeticAsText="false">
<string field="Administration:CustomerEmail"/>
</set>
<set field="COrg" arithmeticAsText="false">
<string field="Administration:Organization"/>
</set>
<set field="CFirst" arithmeticAsText="false">
<string field="Administration:First"/>
</set>
<set field="CLast" arithmeticAsText="false">
<string field="Administration:Last"/>
</set>
<set field="Cbody" arithmeticAsText="false">
<string field="Administration:Body"/>
</set>
<set field="CSentName" arithmeticAsText="false">
<string field="Administration:SentName"/>
</set>
<set field="CSentEmail" arithmeticAsText="false">
<string field="Administration:SentEmail"/>
</set>
<set field="CID" arithmeticAsText="false">
<string field="Administration:ID"/>
</set>
<send>
<to addressField="CEmail"/>
<from addressField="CSentEmail" aliasField="CSentName"/>
<subject><field name="COrg"/> Tawala SportsDashboards Purchase Order</subject>
<body document="Email" reset="false" showHeader="true"/>
</send>
<set field="Message" arithmeticAsText="false">
<string value="Purchase Order sent."/>
</set>
<show document="Message" reset="false"/>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcContains field="Administration:Q10" value="a"/>
</conditions>
<trueSet>
<send>
<to addressField="CSentEmail"/>
<from addressLiteral="donotreply@tawala.com" aliasLiteral="Tawala SportsDashboard Services"/>
<subject>PO sent to <field name="Administration:First"/> <field name="Administration:Last"/></subject>
<body document="Email" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Administration:CCs:a" />
</conditions>
<trueSet>
<send>
<to addressField="Administration:CCs:a"/>
<from addressLiteral="donotreply@tawala.com" aliasLiteral="Tawala SportsDashboard Services"/>
<subject>PO sent to <field name="Administration:First"/> <field name="Administration:Last"/></subject>
<body document="Email" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Administration:CCs:b" />
</conditions>
<trueSet>
<send>
<to addressField="Administration:CCs:b"/>
<from addressLiteral="donotreply@tawala.com" aliasLiteral="Tawala SportsDashboard Services"/>
<subject>PO sent to <field name="Administration:First"/> <field name="Administration:Last"/></subject>
<body document="Email" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Administration:CCs:c" />
</conditions>
<trueSet>
<send>
<to addressField="Administration:CCs:c"/>
<from addressLiteral="donotreply@tawala.com" aliasLiteral="Tawala SportsDashboard Services"/>
<subject>PO sent to <field name="Administration:First"/> <field name="Administration:Last"/></subject>
<body document="Email" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
</trueSet>
</if>
<comment>Add a purchase order to database</comment>
<if>
<conditions>
<mcEquals field="Administration:Q1" value="b"/>
</conditions>
<trueSet>
<set field="AdminEntry" arithmeticAsText="false">
<string value="Yes"/>
</set>
<show form="OrderForm"/>
</trueSet>
</if>
<comment>Send a copy of purchase order to a customer</comment>
<if>
<conditions>
<mcEquals field="Administration:Q1" value="e"/>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="No purchase order selected."/>
</set>
<get recordList="Record List 4">
<forms>
<form name="Administration"/>
</forms>
<conditions>
<equals field="Record List 4:Administration:ID">
<string field="Administration:Q18"/>
</equals>
</conditions></get>
<foreach record="Such" recordList="Record List 4">
<set field="CFirst" arithmeticAsText="false">
<string field="Such:Administration:First"/>
</set>
<set field="Cbody" arithmeticAsText="false">
<string field="Such:Administration:Body"/>
</set>
<set field="CSentName" arithmeticAsText="false">
<string field="Such:Administration:SentName"/>
</set>
<set field="CSentEmail" arithmeticAsText="false">
<string field="Such:Administration:SentEmail"/>
</set>
<set field="CID" arithmeticAsText="false">
<string field="Such:Administration:ID"/>
</set>
<send>
<to addressField="Such:Administration:CustomerEmail"/>
<from addressField="CSentEmail" aliasField="CSentName"/>
<subject>Duplicate Copy - Tawala Dashboards Purchase Order Form</subject>
<body document="Email" reset="false" showHeader="true"/>
</send>
<set field="Message" arithmeticAsText="false">
<string value="Copy of purchase order to "/>
<string field="Such:Administration:First"/>
<string value=" "/>
<string field="Such:Administration:Last"/>
<string value=" sent."/>
</set>
</foreach>
</trueSet>
</if>
<comment>Send purchase order report to someone</comment>
<if>
<conditions>
<mcEquals field="Administration:Q1" value="f"/>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<isNotBlank field="Administration:Q19:a" />
</conditions>
<trueSet>
<send>
<to addressField="Administration:Q19:a"/>
<from addressLiteral="donotreply@tawala.com" aliasLiteral="Tawala SportsDashboards Automated Monitoring"/>
<subject>Purchase Order Report</subject>
<body document="Report" reset="false" showHeader="true"/>
</send>
<set field="Message" arithmeticAsText="false">
<string value="Purchase order report sent to "/>
<string field="Administration:Q19:a"/>
</set>
<show form="Administration"/>
</trueSet>
<falseSet>
<show document="Return" reset="false"/>
<show document="Report" reset="false"/>
<show document="Return" reset="false"/>
</falseSet>
</if>
</trueSet>
</if>
<comment>Delete a PO from database</comment>
<if>
<conditions>
<and>
<mcEquals field="Administration:Q1" value="g"/>
<mcEquals field="Administration:Q17" value="a"/>
</and>
</conditions>
<trueSet>
<delete><form name="OrderForm"/><conditions>
<mcEquals field="Administration:Q16">
<string field="Record:OrderForm:PurchaseNumber"/>
</mcEquals>
</conditions></delete>
<set field="Message" arithmeticAsText="false">
<string value="Record Deleted."/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Administration:Q1" value="f"/>
</conditions>
<trueSet>
<show form="Administration"/>
</trueSet>
</if>
</process>
<process name="Process 3">
<if>
<conditions>
<equals field="AdminEntry">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="OrderForm:QuotedPrice" arithmeticAsText="false">
<string field="Administration:QuotedPrice"/>
</set>
</trueSet>
<falseSet>
<get recordList="Record List 2">
<forms>
<form name="Administration"/>
</forms>
<conditions>
<equals field="Record List 2:Administration:ID">
<string field="_InviteeID"/>
</equals>
</conditions></get>
<foreach record="SuchCustomer" recordList="Record List 2">
<set field="OrderForm:OrgName" arithmeticAsText="false">
<string field="SuchCustomer:Administration:Organization"/>
</set>
<set field="OrderForm:Email" arithmeticAsText="false">
<string field="SuchCustomer:Administration:CustomerEmail"/>
</set>
<set field="OrderForm:Description" arithmeticAsText="false">
<string field="SuchCustomer:Administration:ProdDesc"/>
</set>
<set field="OrderForm:Contact" arithmeticAsText="false">
<string field="SuchCustomer:Administration:First"/>
<string value=" "/>
<string field="SuchCustomer:Administration:Last"/>
</set>
<set field="Rate" arithmeticAsText="false">
<string field="SuchCustomer:Administration:QuotedPrice"/>
</set>
<set field="OrderForm:QuotedPrice" arithmeticAsText="false">
<string field="Rate"/>
</set>
<set field="OrderForm:PurchaseNumber" arithmeticAsText="false">
<string field="SuchCustomer:Administration:ID"/>
</set>
</foreach>
</falseSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</process>
<process name="Process 4">
<delete><form name="Administration"/><conditions>
<mcDoesNotEqual field="Record:Administration:Q1" value="a"/>
</conditions></delete>
<if>
<conditions>
<doesNotEqual field="checkid">
<string value="OK"/>
</doesNotEqual>
</conditions>
<trueSet>
<show form="PasswordEntry"/>
</trueSet>
</if>
</process>
<process name="Process 5">
<if>
<conditions>
<equals field="PasswordEntry:password">
<string value="Luwatuwa"/>
</equals>
</conditions>
<trueSet>
<set field="checkid" arithmeticAsText="false">
<string value="OK"/>
</set>
<show form="Administration"/>
</trueSet>
</if>
<show form="PasswordEntry"/>
</process>
</processes>
<documents>
<document name="Email">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="CFirst"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Cbody"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Best regards,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="CSentName"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="CSentEmail"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is your link: </font><font color="000080"><u><invitation form="OrderForm" project="" private="true"><authenticationTokenValue><string field="CID"/>
</authenticationTokenValue>Tawala SportsDashboards Online Purchase Order</invitation></u></font></paragraph>
</xmlData>
