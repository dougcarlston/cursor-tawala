<form name="Communicator" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-Communicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This tool permits you to send emails to some or all of the people that have registered.  The groupings created below can be changed if they are not the best for your purposes.</font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Administration" project="">Cancel</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="Recipient" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Send this email to:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All registered leagues</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more leagues based on payment criteria</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more leagues based on District</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Leagues containing one or more specific divisions</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more leagues selected from a list </font></paragraph></choice></mc>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>From:</b></font><sp/><font face="Arial" size="200" color="000000"><i>(Name)</i></font><sp/><blank label="a" length="20" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>From:</b></font><sp/><font face="Arial" size="200" color="000000"><i>(Email)</i></font><sp/><blank label="a" length="20" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Subject:</b></font><sp/><blank label="a" length="20" required="false" alternateLabel="Subject"/></paragraph></fib>
<fib label="Q5" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Body of message</b></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="49" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T3" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press Submit to continue.  You will have an opportunity to review your message before it is sent.</font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="c"/>
</conditions>
<trueSet>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="d"/>
</conditions>
<trueSet>
<skip to="T6"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="e"/>
</conditions>
<trueSet>
<skip to="T7"/>
</trueSet>
</if>
</skipInstructions>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Administration" project="">Cancel</invitation></u></font></paragraph></text>
<mc label="Q6" alternateLabel="PaymentCriteria" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark the payment status of recipients of this message: </font><font face="Arial" size="200" color="000000"><i>(You may mark more than one.)</i></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:PaymentStatus"/>
</display-expression><value-expression><field name="Record:Registration:PaymentStatus"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Registration" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Administration" project="">Cancel</invitation></u></font></paragraph></text>
<mc label="Q7" alternateLabel="DistrictCriteria" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark the District(s) of recipients of this message: </font><font face="Arial" size="200" color="000000"><i>(You may mark more than one.)</i></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:District"/>
</display-expression><value-expression><field name="Record:Registration:District"/>
</value-expression><sort-expression><field name="Record:Registration:District"/>
</sort-expression><record-selector><form name="Registration" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T6" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Administration" project="">Cancel</invitation></u></font></paragraph></text>
<mc label="Q8" alternateLabel="DivisionCriteria" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark the division(s) whose leagues will receive this message:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">SweeTees</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Darlings</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Angels</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Ponytails</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Belles</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Debs</font></paragraph></choice></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T7" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Administration" project="">Cancel</invitation></u></font></paragraph></text>
<mc label="Q9" alternateLabel="LeagueCriteria" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark the league(s) of recipients of this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:Franchise"/>
<string value="  (URL:"/>
<field name="Record:Registration:LeagueURL"/>
<string value=" Email:"/>
<field name="Record:Registration:LeagueEmailAddress"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:Franchise"/>
</value-expression><sort-expression><field name="Record:Registration:Franchise"/>
</sort-expression><record-selector><form name="Registration" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="CommunicatorSend" startPoint="false" themePath="mvsc" process="Post-CommunicatorSend">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Administration" project="">Cancel</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="555"><row><cell width="10245"><division indent="0" align="left"><font><b>To: </b></font><font><display-mcq-label version="1"><field-name>Communicator:Recipient</field-name><display>label_only</display></display-mcq-label></font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><b>From:</b></font><sp/><font><field name="Communicator:FromName"/></font><font>  (</font><font><field name="Communicator:FromEmail"/></font><font><i>)</i></font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="Communicator:Subject"/></font><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10245"><division indent="0" align="left"><font><field name="Communicator:Body"/></font></division></cell></row></table></text>
<mc label="Q1" alternateLabel="Action" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Main Menu</font></paragraph></choice></mc>
</items>
</form>
</forms>
<processes>
<process name="Pre-Registration">
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</process>
<process name="Post-Registration">
<if>
<conditions>
<isBlank field="Registration:Franchise" />
</conditions>
<trueSet>
<set field="TempNo" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="Record List 2">
<forms>
<form name="Administration"/>
</forms>
</get>
<foreach record="Number" recordList="Record List 2">
<if>
<conditions>
<isGreaterThan field="Number:Administration:TempFranchise">
<string field="TempNo"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="TempNo" arithmeticAsText="false">
<add>
<operand field="Number:Administration:TempFranchise"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
<set field="Administration:TempFranchise" arithmeticAsText="false">
<string field="TempNo"/>
</set>
<set field="Registration:Franchise" arithmeticAsText="false">
<string value="Temp"/>
<string field="TempNo"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:LateFee" value="a"/>
</conditions>
<trueSet>
<set field="Total" arithmeticAsText="false">
<add>
<operand field="Total"/>
<operand value="50"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="Admin">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="Admin" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Administration:DeleteOrEditCrit" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Administration:SelectFromFilteredForms" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Administration:SelectFromAllForms" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Message" arithmeticAsText="false">
<string value="Registration edited."/>
</set>
<show document="Message" reset="false"/>
<show form="Administration"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:Continue?" value="a"/>
</conditions>
<trueSet>
<show document="Paypal" reset="false"/>
</trueSet>
<falseSet>
<set field="Registration:Selected" arithmeticAsText="false">
<string value="Delete"/>
</set>
</falseSet>
</if>
</process>
<process name="Post-Failure">
<show document="Paypal" reset="false"/>
</process>
<process name="Pre-Success">
<send>
<to addressField="Registration:LeagueEmailAddress"/>
<from addressLiteral="do_not_reply@tawala.com" aliasLiteral="Dixie Softball, Inc."/>
<subject>Franchise Registration Confirmation</subject>
<body document="Confirmation" reset="false" showHeader="true"/>
</send>
</process>
<process name="Pre-Admin">
<delete><form name="Registration"/><conditions>
<equals field="Record:Registration:Selected">
<string value="Delete"/>
</equals>
</conditions></delete>
<edit form="Administration" submit="modify">
</edit>
</process>
<process name="Post-Admin">
<comment>Put temporary ID's in Franchise box if blank</comment>
<get recordList="Record List 2">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<isBlank field="Record List 2:Registration:Franchise" />
</conditions></get>
<foreach record="Blank" recordList="Record List 2">
<set field="TempNo" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="Record List 2">
<forms>
<form name="Administration"/>
</forms>
</get>
<foreach record="Number" recordList="Record List 2">
<if>
<conditions>
<isGreaterThan field="Number:Administration:TempFranchise">
<string field="TempNo"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="TempNo" arithmeticAsText="false">
<add>
<operand field="Number:Administration:TempFranchise"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
<set field="Administration:TempFranchise" arithmeticAsText="false">
<string field="TempNo"/>
</set>
<set field="Blank:Registration:Franchise" arithmeticAsText="false">
<string value="Temp"/>
<string field="TempNo"/>
</set>
</foreach>
</foreach>
<if>
<conditions>
<mcEquals field="Administration:MenuOption" value="b"/>
</conditions>
<trueSet>
<comment>Delete a registration</comment>
<if>
<conditions>
<isBlank field="Administration:DeleteOrEditCrit" />
</conditions>
<trueSet>
<delete><form name="Registration"/><conditions>
<equals field="Record:Registration:Franchise">
<string field="Administration:SelectFromAllForms"/>
</equals>
</conditions></delete>
</trueSet>
<falseSet>
<delete><form name="Registration"/><conditions>
<equals field="Record:Registration:Franchise">
<string field="Administration:SelectFromFilteredForms"/>
</equals>
</conditions></delete>
</falseSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value="Record deleted"/>
</set>
<show document="Message" reset="false"/>
<set field="Administration:MenuOption" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Administration:DeleteOrEditCrit" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Administration:SelectFromFilteredForms" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Administration:SelectFromAllForms" arithmeticAsText="false">
<string value=" "/>
</set>
</trueSet>
</if>
<set field="Administration:ViewAllOrSome" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Administration:ChangeFields" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcEquals field="Administration:MenuOption" value="c"/>
</conditions>
<trueSet>
<comment>Edit a registration</comment>
<set field="Administration:MenuOption" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Admin" arithmeticAsText="false">
<string value="Yes"/>
</set>
<if>
<conditions>
<isBlank field="Administration:DeleteOrEditCrit" />
</conditions>
<trueSet>
<edit form="Registration" submit="modify">
<conditions>
<equals field="Record:Registration:Franchise">
<string field="Administration:SelectFromAllForms"/>
</equals>
</conditions>
</edit>
</trueSet>
<falseSet>
<edit form="Registration" submit="modify">
<conditions>
<equals field="Record:Registration:Franchise">
<string field="Administration:SelectFromFilteredForms"/>
</equals>
</conditions>
</edit>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Administration:MenuOption" value="d"/>
</conditions>
<trueSet>
<comment>Change registrant's payment status manually</comment>
<if>
<conditions>
<isBlank field="Administration:DeleteOrEditCrit" />
</conditions>
<trueSet>
<get recordList="Record List 3">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Record List 3:Registration:Franchise">
<string field="Administration:SelectFromAllForms"/>
</equals>
</conditions></get>
</trueSet>
<falseSet>
<get recordList="Record List 3">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Record List 3:Registration:Franchise">
<string field="Administration:SelectFromFilteredForms"/>
</equals>
</conditions></get>
</falseSet>
</if>
<foreach record="Alteration" recordList="Record List 3">
<if>
<conditions>
<mcEquals field="Administration:UpdatePmtStatus" value="a"/>
</conditions>
<trueSet>
<set field="Alteration:Registration:PaymentStatus" arithmeticAsText="true">
<string value="Paid"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Administration:UpdatePmtStatus" value="b"/>
</conditions>
<trueSet>
<set field="Alteration:Registration:PaymentStatus" arithmeticAsText="false">
<string value="Unpaid"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcIsNotBlank field="Administration:UpdatePmtStatus" />
</conditions>
<trueSet>
<if>
<conditions>
<isNotBlank field="Administration:UpdatePmtAmount" />
</conditions>
<trueSet>
<set field="Alteration:Registration:PaymentAmount" arithmeticAsText="false">
<string field="Administration:UpdatePmtAmount"/>
</set>
</trueSet>
<falseSet>
<set field="Alteration:Registration:PaymentAmount" arithmeticAsText="false">
<string value="0"/>
</set>
</falseSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value="Payment status for Franchise #"/>
<string field="Alteration:Registration:Franchise"/>
<string value=" marked as "/>
<string field="Alteration:Registration:PaymentStatus"/>
<string value=". Amount = $"/>
<string field="Alteration:Registration:PaymentAmount"/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Administration:MenuOption" value="e"/>
</conditions>
<trueSet>
<comment>Send email to registrants</comment>
<set field="Administration:MenuOption" arithmeticAsText="false">
<string value=" "/>
</set>
<show form="Communicator"/>
</trueSet>
</if>
<set field="Administration:MenuOption" arithmeticAsText="false">
<string value=" "/>
</set>
<show form="Administration"/>
</process>
<process name="Post-Communicator">
<show form="CommunicatorSend"/>
</process>
<process name="Post-CommunicatorSend">
<if>
<conditions>
<mcEquals field="CommunicatorSend:Action" value="c"/>
</conditions>
<trueSet>
<show form="Administration"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CommunicatorSend:Action" value="b"/>
</conditions>
<trueSet>
<show form="Communicator"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="CommunicatorSend:Action" value="a"/>
</conditions>
<trueSet>
<show form="CommunicatorSend"/>
</trueSet>
</if>
<set field="MessageBody" arithmeticAsText="false">
<string field="Communicator:Body"/>
</set>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="a"/>
</conditions>
<trueSet>
<comment>Send to all registered leagues</comment>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 4">
<forms>
<form name="Registration"/>
</forms>
</get>
<foreach record="League" recordList="Record List 4">
<send>
<to addressField="League:Registration:LeagueEmailAddress"/>
<from addressField="Communicator:FromEmail" aliasField="Communicator:FromName"/>
<subject><field name="Communicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Your email was sent to "/>
<string field="Count"/>
<string value=" leagues."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="b"/>
</conditions>
<trueSet>
<comment>Send message to leagues based on payment criterial</comment>
<if>
<conditions>
<mcIsBlank field="Communicator:PaymentCriteria" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You made no payment criteria selection."/>
</set>
<show document="Message" reset="false"/>
<show form="Communicator"/>
</trueSet>
</if>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 5">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="Communicator:PaymentCriteria">
<string field="Record List 5:Registration:PaymentStatus"/>
</mcContains>
</conditions></get>
<foreach record="Payee" recordList="Record List 5">
<send>
<to addressField="Payee:Registration:LeagueEmailAddress"/>
<from addressField="Communicator:FromEmail" aliasField="Communicator:FromName"/>
<subject><field name="Communicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Your email was sent to "/>
<string field="Count"/>
<string value=" leagues matching your payment criteria. "/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="c"/>
</conditions>
<trueSet>
<comment>Send message to leagues based on District</comment>
<if>
<conditions>
<mcIsBlank field="Communicator:DistrictCriteria" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You made no District criteria selection."/>
</set>
<show document="Message" reset="false"/>
<show form="Communicator"/>
</trueSet>
</if>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 6">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="Communicator:DistrictCriteria">
<string field="Record List 6:Registration:District"/>
</mcContains>
</conditions></get>
<foreach record="LeagueInDistrict" recordList="Record List 6">
<send>
<to addressField="LeagueInDistrict:Registration:LeagueEmailAddress"/>
<from addressField="Communicator:FromEmail" aliasField="Communicator:FromName"/>
<subject><field name="Communicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Your email was sent to "/>
<string field="Count"/>
<string value=" leagues in the selected District(s)."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="d"/>
</conditions>
<trueSet>
<comment>Send message to leagues containing specific divisions</comment>
<if>
<conditions>
<mcIsBlank field="Communicator:DivisionCriteria" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You made no division criteria selection."/>
</set>
<show document="Message" reset="false"/>
<show form="Communicator"/>
</trueSet>
</if>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 7">
<forms>
<form name="Registration"/>
</forms>
</get>
<foreach record="Uncleared" recordList="Record List 7">
<set field="Uncleared:Registration:Selected" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<and>
<mcContains field="Communicator:DivisionCriteria" value="a"/>
<isGreaterThan field="Uncleared:Registration:SweeTees">
<string value="0"/>
</isGreaterThan>
</and>
</conditions>
<trueSet>
<set field="Uncleared:Registration:Selected" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcContains field="Communicator:DivisionCriteria" value="b"/>
<isGreaterThan field="Uncleared:Registration:Darlings">
<string value="0"/>
</isGreaterThan>
</and>
</conditions>
<trueSet>
<set field="Uncleared:Registration:Selected" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcContains field="Communicator:DivisionCriteria" value="c"/>
<isGreaterThan field="Uncleared:Registration:Angels">
<string value="0"/>
</isGreaterThan>
</and>
</conditions>
<trueSet>
<set field="Uncleared:Registration:Selected" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcContains field="Communicator:DivisionCriteria" value="d"/>
<isGreaterThan field="Uncleared:Registration:Ponytails">
<string value="0"/>
</isGreaterThan>
</and>
</conditions>
<trueSet>
<set field="Uncleared:Registration:Selected" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcContains field="Communicator:DivisionCriteria" value="e"/>
<isGreaterThan field="Uncleared:Registration:Belles">
<string value="0"/>
</isGreaterThan>
</and>
</conditions>
<trueSet>
<set field="Uncleared:Registration:Selected" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcContains field="Communicator:DivisionCriteria" value="f"/>
<isGreaterThan field="Uncleared:Registration:Debs">
<string value="0"/>
</isGreaterThan>
</and>
</conditions>
<trueSet>
<set field="Uncleared:Registration:Selected" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
</foreach>
<get recordList="Record List 8">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Record List 8:Registration:Selected">
<string value="Yes"/>
</equals>
</conditions></get>
<foreach record="Selection" recordList="Record List 8">
<send>
<to addressField="Selection:Registration:LeagueEmailAddress"/>
<from addressField="Communicator:FromEmail" aliasField="Communicator:FromName"/>
<subject><field name="Communicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Your email was sent to "/>
<string field="Count"/>
<string value=" leagues containing selected divisions."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Recipient" value="e"/>
</conditions>
<trueSet>
<comment>Send emails to specific, selected leagues</comment>
<if>
<conditions>
<mcIsBlank field="Communicator:LeagueCriteria" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You selected no leagues to receive this message."/>
</set>
<show document="Message" reset="false"/>
<show form="Communicator"/>
</trueSet>
</if>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 9">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="Communicator:LeagueCriteria">
<string field="Record List 9:Registration:Franchise"/>
</mcContains>
</conditions></get>
<foreach record="League" recordList="Record List 9">
<send>
<to addressField="League:Registration:LeagueEmailAddress"/>
<from addressField="Communicator:FromEmail" aliasField="Communicator:FromName"/>
<subject><field name="Communicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Your email has been sent to the "/>
<string field="Count"/>
<string value=" league(s) you selected."/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<show form="Administration"/>
</process>
</processes>
<documents>
<document name="Paypal">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To make your payment by credit card or Paypal, click on the button below.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will be sent a copy of this transaction at your League email address.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><paypal-single-item-button version="1"><button-type>pay</button-type><item><string value="Dixie Softball Annual Franchise Fees"/>
</item><amount><field name="Total"/>
</amount><successful-payment-return-form-name>Success</successful-payment-return-form-name><cancelled-payment-return-form-name>Failure</cancelled-payment-return-form-name><status-field>Record:Registration:PaymentStatus</status-field><amount-field>Record:Registration:PaymentAmount</amount-field><style-option>tawala</style-option></paypal-single-item-button></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph>
</xmlData>
</document>
<document name="Confirmation">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Registration Confirmation</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dixie Softball, Inc. confirms the receipt of your franchise payment of $</font><font><field name="Registration:PaymentAmount"/></font><font> in payment of state and national fees for the 2009 season.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph>
</xmlData>
</document>
<document name="Message">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="C00000"><b><i><field name="Message"/></i></b></font></paragraph>
</xmlData>
</document>
<document name="Letter">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="MessageBody"/></font></paragraph>
</xmlData>
</document>
