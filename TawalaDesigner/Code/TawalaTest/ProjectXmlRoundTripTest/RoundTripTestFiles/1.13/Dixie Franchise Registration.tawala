<form name="Success" startPoint="false" themePath="mvsc" preProcess="Pre-Success">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Your payment has been received.  An email confirming receipt of your payment will be sent to your email address.</font></paragraph></text>
</items>
</form>
<form name="Failure" startPoint="false" themePath="mvsc" process="Post-Failure">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Your payment transaction was not successful.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press Submit to try again.</font></paragraph></text>
</items>
</form>
<form name="Administration" startPoint="true" themePath="mvsc" process="Post-Admin" preProcess="Pre-Admin">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Administrator Menu</font></paragraph></heading>
<mc label="Q1" alternateLabel="MenuOption" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Review registrations</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Remove a registration</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit a registration</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Change a registrant's payment status manually</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email message to registrants</font></paragraph></choice></mc>
<skipInstructions>
<set field="Administration:DeleteOrEditCrit" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcEquals field="Administration:MenuOption" value="b"/>
</conditions>
<trueSet>
<set field="Action" arithmeticAsText="false">
<string value="delete"/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcEquals field="Administration:MenuOption" value="c"/>
<mcEquals field="Administration:MenuOption" value="d"/>
</or>
</conditions>
<trueSet>
<set field="Action" arithmeticAsText="false">
<string value="edit"/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Administration:MenuOption" value="e"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Administration" project="">Cancel</invitation></u></font></paragraph></text>
<mc label="Q2" alternateLabel="ViewAllOrSome" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">See Information on all registrations</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">See a specific registration or group of registrations</font></paragraph></choice></mc>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Fields with a check mark in front of them will be displayed:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><display-mcq-label version="1"><field-name>Administration:DisplayFields</field-name><display>all_choices</display></display-mcq-label></font></paragraph></text>
<mc label="Q3" alternateLabel="ChangeFields" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check here to add or remove fields to be displayed</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotContain field="Administration:ChangeFields" value="a"/>
</conditions>
<trueSet>
<if>
<conditions>
<mcEquals field="Administration:ViewAllOrSome" value="b"/>
</conditions>
<trueSet>
<skip to="Q5"/>
</trueSet>
<falseSet>
<skip to="T3"/>
</falseSet>
</if>
</trueSet>
</if>
</skipInstructions>
<mc label="Q4" alternateLabel="DisplayFields" onlyone="false" required="false" style="multicolumn" columnCount="3" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Please check the registration fields that you'd like to see displayed:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">League Name</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">League Address</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Franchise #</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">District #</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Team Counts</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">President Name</font></paragraph></choice><choice label="g"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">President Address</font></paragraph></choice><choice label="h"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">President Phone</font></paragraph></choice><choice label="i"><paragraph indent="0" align="left"><tabPositions>