<equals field="Record:Registration:PaymentStatus">
<string value="Unpaid"/>
</equals>
</conditions></conditions></sum></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Total team counts:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="1543"><division indent="0" align="center"><font>SweeTees</font></division></cell><cell width="1543"><division indent="0" align="center"><font>Darlings</font></division></cell><cell width="1543"><division indent="0" align="center"><font>Angels</font></division></cell><cell width="1543"><division indent="0" align="center"><font>Ponytails</font></division></cell><cell width="1543"><division indent="0" align="center"><font>Belles</font></division></cell><cell width="1543"><division indent="0" align="center"><font>Debs</font></division></cell></row><row><cell width="1543"><division indent="0" align="center"><font><sum version="1"><field>Record:Registration:SweeTees</field><conditions><form name="Registration" /></conditions></sum></font></division></cell><cell width="1543"><division indent="0" align="center"><font><sum version="1"><field>Record:Registration:Darlings</field><conditions><form name="Registration" /></conditions></sum></font></division></cell><cell width="1543"><division indent="0" align="center"><font><sum version="1"><field>Record:Registration:Angels</field><conditions><form name="Registration" /></conditions></sum></font></division></cell><cell width="1543"><division indent="0" align="center"><font><sum version="1"><field>Record:Registration:Ponytails</field><conditions><form name="Registration" /></conditions></sum></font></division></cell><cell width="1543"><division indent="0" align="center"><font><sum version="1"><field>Record:Registration:Belles</field><conditions><form name="Registration" /></conditions></sum></font></division></cell