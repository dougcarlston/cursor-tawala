<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="C00000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>League Name:</b></font><sp/><blank label="a" length="20" required="false" alternateLabel="LeagueName"/></paragraph></fib>
<fib label="Q2" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>League Address:</b></font><sp/><blank label="a" length="20" required="false" alternateLabel="LeagueAddress"/></paragraph></fib>
<fib label="Q3" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>City, State Zip:</b></font><sp/><blank label="a" length="20" required="false" alternateLabel="LeagueCityStateZip"/></paragraph></fib>
<fib label="Q4" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Email:</b></font><sp/><blank label="a" length="20" required="false" alternateLabel="LeagueEmailAddress"/><font face="Arial" size="200" color="000000">  </font><font color="000000"><i>Note: Your order confirmation will be sent to this email address.</i></font></paragraph></fib>
<fib label="Q5" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Email (a</b></font><font face="Arial" size="200" color="000000"><b><i>gain):</i></b></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="20" required="false" alternateLabel="EmailAddressConfirmation"/><font face="Arial" size="200" color="000000">  </font><font color="000000"><i>Please type it carefully and enter it again here to prevent error.</i></font></paragraph></fib>
<fib label="Q6" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Franchise #:</b></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font face="Arial" size="200" color="000000"><b>S-</b></font><blank label="a" length="20" required="false" alternateLabel="Franchise"/></paragraph></fib>
<fib label="Q7" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>District #:</b></font><sp/><blank label="a" length="20" required="false" alternateLabel="District"/></paragraph></fib>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Please enter number of teams:</b></font></paragraph></text>
<fib label="Q8" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>SweeTees: </i></font><blank label="a" length="4" required="false" alternateLabel="SweeTees"/><font face="Arial" size="200" color="000000"><i> @ $10 per team plus $25 State Fee</i></font></paragraph></fib>
<fib label="Q9" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>Darlings: </i></font><blank label="a" length="4" required="false" alternateLabel="Darlings"/><font face="Arial" size="200" color="000000"><i> @ $15 per team plus $25 State Fee</i></font></paragraph></fib>
<fib label="Q10" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>Angels: </i></font><blank label="a" length="4" required="false" alternateLabel="Angels"/><font face="Arial" size="200" color="000000"><i> @ $15 per team plus $25 State Fee</i></font></paragraph></fib>
<fib label="Q11" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>Ponytails: </i></font><blank label="a" length="4" required="false" alternateLabel="Ponytails"/><font face="Arial" size="200" color="000000"><i> @ $15 per team plus $25 State Fee</i></font></paragraph></fib>
<fib label="Q12" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>Belles: </i></font><blank label="a" length="4" required="false" alternateLabel="Belles"/><font face="Arial" size="200" color="000000"><i> @ $15 per team plus $25 State Fee</i></font></paragraph></fib>
<fib label="Q13" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>Debs: </i></font><blank label="a" length="4" required="false" alternateLabel="Debs"/><font face="Arial" size="200" color="000000"><i> @ $15 per team plus $25 State Fee</i></font></paragraph></fib>
<text label="T5" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press Submit to total your order and to continue to the rest of the Franchise Registration form.</font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<or>
<isBlank field="Registration:LeagueName" />
<or>
<isBlank field="Registration:LeagueAddress" />
<or>
<isBlank field="Registration:LeagueCityStateZip" />
<or>
<isBlank field="Registration:LeagueEmailAddress" />
<or>
<isBlank field="Registration:Franchise" />
<isBlank field="Registration:District" />
</or>
</or>
</or>
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You must provide information for League Name, Address and Email, Franchise and District."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<doesNotEqual field="Registration:LeagueEmailAddress">
<string field="Registration:EmailAddressConfirmation"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="League Email address fields do not match. Please correct."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<doesNotContain field="Registration:LeagueEmailAddress">
<string value="@"/>
</doesNotContain>
<or>
<doesNotContain field="Registration:LeagueEmailAddress">
<string value="."/>
</doesNotContain>
<or>
<contains field="Registration:LeagueEmailAddress">
<string value=" "/>
</contains>
<contains field="Registration:LeagueEmailAddress">
<string value=","/>
</contains>
</or>
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="League Email address is invalid. Please correct."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<set field="NatFeeS" arithmeticAsText="false">
<mul>
<operand field="Registration:SweeTees"/>
<operand value="10"/>
</mul>
</set>
<set field="NatFeeD" arithmeticAsText="false">
<mul>
<operand field="Registration:Darlings"/>
<operand value="15"/>
</mul>
</set>
<set field="NatFeeA" arithmeticAsText="false">
<mul>
<operand field="Registration:Angels"/>
<operand value="15"/>
</mul>
</set>
<set field="NatFeeP" arithmeticAsText="false">
<mul>
<operand field="Registration:Ponytails"/>
<operand value="15"/>
</mul>
</set>
<set field="NatFeeB" arithmeticAsText="false">
<mul>
<operand field="Registration:Belles"/>
<operand value="15"/>
</mul>
</set>
<set field="NatFeeDeb" arithmeticAsText="false">
<mul>
<operand field="Registration:Debs"/>
<operand value="15"/>
</mul>
</set>
<if>
<conditions>
<isGreaterThan field="Registration:SweeTees">
<string value="0"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="TotS" arithmeticAsText="false">
<add>
<mul>
<operand field="Registration:SweeTees"/>
<operand value="10"/>
</mul>
<operand value="25"/>
</add>
</set>
</trueSet>
<falseSet>
<set field="TotS" arithmeticAsText="false">
<string value="0"/>
</set>
</falseSet>
</if>
<if>
<conditions>
<isGreaterThan field="Registration:Darlings">
<string value="0"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="TotD" arithmeticAsText="false">
<add>
<mul>
<operand field="Registration:Darlings"/>
<operand value="15"/>
</mul>
<operand value="25"/>
</add>
</set>
</trueSet>
<falseSet>
<set field="TotD" arithmeticAsText="false">
<string value="0"/>
</set>
</falseSet>
</if>
<if>
<conditions>
<isGreaterThan field="Registration:Angels">
<string value="0"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="TotA" arithmeticAsText="false">
<add>
<mul>
<operand field="Registration:Angels"/>
<operand value="15"/>
</mul>
<operand value="25"/>
</add>
</set>
</trueSet>
<falseSet>
<set field="TotA" arithmeticAsText="false">
<string value="0"/>
</set>
</falseSet>
</if>
<if>
<conditions>
<isGreaterThan field="Registration:Ponytails">
<string value="0"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="TotP" arithmeticAsText="false">
<add>
<mul>
<operand field="Registration:Ponytails"/>
<operand value="15"/>
</mul>
<operand value="25"/>
</add>
</set>
</trueSet>
<falseSet>
<set field="TotP" arithmeticAsText="false">
<string value="0"/>
</set>
</falseSet>
</if>
<if>
<conditions>
<isGreaterThan field="Registration:Belles">
<string value="0"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="TotB" arithmeticAsText="false">
<add>
<mul>
<operand field="Registration:Belles"/>
<operand value="15"/>
</mul>
<operand value="25"/>
</add>
</set>
</trueSet>
<falseSet>
<set field="TotB" arithmeticAsText="false">
<string value="0"/>
</set>
</falseSet>
</if>
<if>
<conditions>
<isGreaterThan field="Registration:Debs">
<string value="0"/>
</isGreaterThan>
</conditions>
<trueSet>
<set field="TotDebs" arithmeticAsText="false">
<add>
<mul>
<operand field="Registration:Debs"/>
<operand value="15"/>
</mul>
<operand value="25"/>
</add>
</set>
</trueSet>
<falseSet>
<set field="TotDebs" arithmeticAsText="false">
<string value="0"/>
</set>
</falseSet>
</if>
<set field="Total" arithmeticAsText="false">
<add>
<add>
<add>
<add>
<add>
<operand field="TotA"/>
<operand field="TotB"/>
</add>
<operand field="TotD"/>
</add>
<operand field="TotDebs"/>
</add>
<operand field="TotP"/>
</add>
<operand field="TotS"/>
</add>
</set>
<set field="Total" arithmeticAsText="false">
<add>
<operand field="Total"/>
<operand value="10"/>
</add>
</set>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
