<mc label="Q9" alternateLabel="UpdatePmtStatus" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark the registration for Franchise #</font><font face="Arial" size="200" color="000000"><field name="TargetFranchise"/></font><font face="Arial" size="200" color="000000"> as:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Paid</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Unpaid</font></paragraph></choice></mc>
<fib label="Q10" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Show the paid/unpaid amount as: </font><blank label="a" length="8" required="false" alternateLabel="UpdatePmtAmount"/><sp/><sp/><font face="Arial" size="200" color="000000"><i>(enter only the numeric amount, without dollar sign or commas, e.g. </i></font><font face="Arial" size="200" color="000000"><b><i>1250.00</i></b></font><font face="Arial" size="200" color="000000"><i>)</i></font></paragraph></fib>
<field name="TempFranchise"/>
</items>
