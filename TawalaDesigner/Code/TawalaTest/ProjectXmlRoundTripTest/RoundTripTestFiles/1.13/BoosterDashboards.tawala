<string field="Each Team:ManageLeadership:LeadershipGroupName"/>
</set>
</foreach>
<delete><form name="LeaderTitles"/><conditions>
<or>
<isBlank field="Record:LeaderTitles:LeaderTitle" />
<equals field="Record:LeaderTitles:LeaderTitle">
<string value="Delete"/>
</equals>
</or>
</conditions></delete>
<delete><form name="LeaderNames"/><conditions>
<mcIsBlank field="Record:LeaderNames:PositionChoices" />
</conditions></delete>
</process>
<process name="Post-Leaders">
<get recordList="Record List 5">
<forms>
<form name="LeaderTitles"/>
</forms>
<conditions>
<equals field="LeaderTitles:LeaderTitle">
<string field="Record List 5:LeaderTitles:LeaderTitle"/>
</equals>
</conditions></get>
<foreach record="Duplicate" recordList="Record List 5">
<set field="LeaderTitles:LeaderTitle" arithmeticAsText="false">
<string value="Delete"/>
</set>
</foreach>
<if>
<conditions>
<and>
<isBlank field="LeaderTitles:PositionIDNumber" />
<doesNotEqual field="LeaderTitles:LeaderTitle">
<string value="Delete"/>
</doesNotEqual>
</and>
</conditions>
<trueSet>
<set field="LeaderTitles:PositionIDNumber" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="Record List 9">
<forms>
<form name="LeaderTitles"/>
</forms>
</get>
<foreach record="Name" recordList="Record List 9">
<if>
<conditions>
<isGreaterThanOrEqualTo field="Name:LeaderTitles:PositionIDNumber">
<string field="LeaderTitles:PositionIDNumber"/>
</isGreaterThanOrEqualTo>
</conditions>
<trueSet>
<set field="LeaderTitles:PositionIDNumber" arithmeticAsText="false">
<add>
<operand field="Name:LeaderTitles:PositionIDNumber"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
</trueSet>
</if>
<show form="ManageLeadership"/>
</process>
<process name="Post-ManageLeaderNames">
<if>
<conditions>
<mcEquals field="ManageLeaderNames:Q1" value="a"/>
</conditions>
<trueSet>
