<process name="Post-Registration">
<comment>Add member ID</comment>
<if>
<conditions>
<isBlank field="Registration:MemberID" />
</conditions>
<trueSet>
<get recordList="Record List 30">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="RegNo" recordList="Record List 30">
<set field="RegNo:AdminSetup:MemberIDGenerator" arithmeticAsText="false">
<add>
<operand field="RegNo:AdminSetup:MemberIDGenerator"/>
<operand value="1"/>
</add>
</set>
<set field="Registration:MemberID" arithmeticAsText="false">
<string value="Member"/>
<string field="RegNo:AdminSetup:MemberIDGenerator"/>
<string field="Registration:PEmail"/>
</set>
</foreach>
<set field="DearSir" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="MessageBody" arithmeticAsText="false">
<string value="Thank you for joining the "/>
<string field="Club"/>
<string value=".  Your registration has been received."/>
</set>
<set field="Role" arithmeticAsText="false">
<string value="private membership"/>
</set>
<set field="MessageClose" arithmeticAsText="false">
<string field="AdmnsNm"/>
</set>
<set field="InviteeLink" arithmeticAsText="false">
<string field="Registration:MemberID"/>
</set>
<set field="Registration:Link Received" arithmeticAsText="false">
<string value="Yes"/>
</set>
<send>
<to addressField="Registration:PEmail"/>
<from addressField="AdmnsEmail" aliasField="AdmnsNm"/>
<cc addressField="Registration:P1Email"/>
<subject>Your <field name="Club"/> <field name="Role"/> Dashboard link</subject>
<body document="DashboardLetter" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
<comment>Add registrant to recruitment database if not already there</comment>
<set field="Skip" arithmeticAsText="false">
<string value="No"/>
</set>
<get recordList="Record List 72">
<forms>
<form name="RecruitmentDB"/>
</forms>
</get>
<foreach record="currentRecord" recordList="Record List 72">
<if>
<conditions>
<and>
<equals field="currentRecord:RecruitmentDB:FirstName">
<string field="Registration:FirstNme"/>
</equals>
<equals field="currentRecord:RecruitmentDB:LastName">
<string field="Registration:LastNme"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="Skip" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<or>
<equals field="currentRecord:RecruitmentDB:Email">
<string field="Registration:PEmail"/>
</equals>
<equals field="currentRecord:RecruitmentDB:Email">
<string field="Registration:P1Email"/>
</equals>
</or>
</conditions>
<trueSet>
<set field="Skip" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<or>
<equals field="currentRecord:RecruitmentDB:Phone">
<string field="Registration:Phone1"/>
</equals>
<or>
<equals field="currentRecord:RecruitmentDB:Phone">
<string field="Registration:Phone2"/>
</equals>
<equals field="currentRecord:RecruitmentDB:Phone">
<string field="Registration:Phone3"/>
</equals>
</or>
</or>
</conditions>
<trueSet>
<set field="Skip" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
</foreach>
<if>
<conditions>
<equals field="Skip">
<string value="No"/>
</equals>
</conditions>
<trueSet>
<set field="Action" arithmeticAsText="false">
<string value="AddNonDupes"/>
</set>
<show form="RecruitmentDB"/>
</trueSet>
</if>
<show form="RegistrationThanks"/>
</process>
<process name="Pre-MasterAdminDash">
