<text label="T3" style="normal"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Club"/></font><font> Membership</font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="1800"></cell><cell width="272"></cell><cell width="3328"></cell><cell width="3328"></cell><cell width="272"></cell><cell width="1800"></cell></row><row><cell width="1800"></cell><cell width="272"></cell><cell width="3328"></cell><cell width="3328"></cell><cell width="272"></cell><cell width="1800"></cell></row><row><cell width="1800"></cell><cell width="272"></cell><cell width="3328"></cell><cell width="3328"></cell><cell width="272"></cell><cell width="1800"></cell></row><row><cell width="1800"></cell><cell width="272"></cell><cell width="3328"></cell><cell width="3328"></cell><cell width="272"></cell><cell width="1800"></cell></row></table></text>
<fib label="Q2" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="3311"/><tabStop position="6336"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name: </b></font><blank label="a" length="20" required="false" alternateLabel="FirstNme"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(first) </i></font><blank label="b" length="20" required="false" alternateLabel="LastNme"/><font face="Arial" size="200" color="000000"> (last)</font></paragraph></fib>
<fib label="Q3" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Email:</b></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="20" required="false" alternateLabel="PEmail"/></paragraph></fib>
<fib label="Q4" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Physical Address</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Street: </font><blank label="a" length="20" required="false" alternateLabel="PStreet"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City: </font><blank label="b" length="20" required="false" alternateLabel="PCity"/><font face="Arial" size="200" color="000000"> State </font><blank label="c" length="3" required="false" alternateLabel="PSt"/><font face="Arial" size="200" color="000000">  Zip </font><blank label="d" length="10" required="false" alternateLabel="PZip"/></paragraph></fib>
<fib label="Q5" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="3311"/><tabStop position="6336"/></tabPositions><font face="Arial" size="200" color="000000"><b>2nd Parent Name: </b></font><blank label="a" length="20" required="false" alternateLabel="FirstNme1"/><sp/><font face="Arial" size="200" color="000000"><i>(first) </i></font><blank label="b" length="20" required="false" alternateLabel="LastNme1"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph><displayConditions>
<equals field="AskSecondParentName">
<string value="Yes"/>
</equals>
</displayConditions></fib>
<fib label="Q6" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>2nd Parent Email:</b></font><sp/><blank label="a" length="20" required="false" alternateLabel="P1Email"/></paragraph><displayConditions>
<equals field="AskSecondParentEmail">
<string value="Yes"/>
</equals>
</displayConditions></fib>
<fib label="Q7" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>2nd Parent Address</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Street: </font><blank label="a" length="20" required="false" alternateLabel="P1Street"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City: </font><blank label="b" length="20" required="false" alternateLabel="P1City"/><font face="Arial" size="200" color="000000"> State </font><blank label="c" length="3" required="false" alternateLabel="P1State"/><font face="Arial" size="200" color="000000">  Zip </font><blank label="d" length="9" required="false" alternateLabel="P1Zip"/></paragraph><displayConditions>
<equals field="AskChildrenNames">
<string value="Yes"/>
</equals>
</displayConditions></fib>
<fib label="Q8" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Phone Numbers</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><field name="PhoneLab1"/></font><sp/><blank label="a" length="20" required="false" alternateLabel="Phone1"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><field name="PhoneLab2"/></font><font face="Arial" size="200" color="000000"> </font><blank label="b" length="20" required="false" alternateLabel="Phone2"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><field name="PhoneLab3"/></font><sp/><blank label="c" length="20" required="false" alternateLabel="Phone3"/></paragraph></fib>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b><field name="GroupCollectiveName"/></b></font><font><b> Options</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Instructions"/></font></paragraph><displayConditions>
<and>
<equals field="GroupsEnabled">
<string value="Yes"/>
</equals>
<equals field="AskVolunteers">
<string value="Volunteers"/>
</equals>
</and>
</displayConditions></text>
<mc label="Q9" alternateLabel="GroupChoices" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Groups:GroupName"/>
</display-expression><value-expression><field name="Record:Groups:GroupIDNumber"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Groups" /></record-selector></dynamic-mcq></data-provider><displayConditions>
<and>
