<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AddRecruitRecord" startPoint="false" themePath="mvsc" process="Post-AddRecruitRecord">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="RecruitDBDupe" startPoint="false" themePath="mvsc">
</form>
<form name="AuditRecruitList" startPoint="false" themePath="mvsc" process="Post-AuditRecruitList" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Recruiting List</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility will check the recruiting list for valid emails.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds a record with more than one valid email or none, it will pull up the record and give you a chance to edit it so that it will work with the Tawala utilities.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It is not possible to keep two email addresses in one contact field.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit or delete each record that fails the audit test.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return</font></paragraph></choice></mc>
</items>
</form>
<form name="ShowRecruitDB" startPoint="false" themePath="mvsc" process="Post-ShowRecruitDB">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="EditRecruitment" startPoint="false" themePath="mvsc" process="Post-EditRecruitment" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Edit Recruitment Records</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="MasterAdminDash" project="">Cancel edit records</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="CC0000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria: </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<contains field="EditRecruitment:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word or part of a word to search on."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Edit Recruitment Records</font></paragraph></heading>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3210"><division indent="0" align="left"><font color="000080"><u><invitation form="EditRecruitment" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3990"><division indent="0" align="left"><font color="000080"><u><invitation form="Recruitment" project="">Return to Recruitment Management</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Master Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select record you wish to edit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:LastName"/>
<string value=", "/>
<field name="Record:RecruitmentDB:FirstName"/>
<string value=" ("/>
<field name="Record:RecruitmentDB:Email"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentID"/>
</value-expression><sort-expression><field name="Record:RecruitmentDB:LastName"/>
<string value="#"/>
<field name="Record:RecruitmentDB:FirstName"/>
</sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<or>
<contains field="Record:RecruitmentDB:FirstName">
<string field="EditRecruitment:SearchString"/>
</contains>
<or>
<contains field="Record:RecruitmentDB:LastName">
<string field="EditRecruitment:SearchString"/>
</contains>
<contains field="Record:RecruitmentDB:Email">
<string field="EditRecruitment:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="DeleteRecruitment" startPoint="false" themePath="mvsc" process="Post-DeleteRecruitment" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="MasterAdminDash" project="">Cancel delete records</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="CC0000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria: </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<contains field="DeleteRecruitment:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word or part of a word to search on."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3120"><division indent="0" align="left"><font color="000080"><u><invitation form="DeleteRecruitment" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="4080"><division indent="0" align="left"><font color="000080"><u><invitation form="Recruitment" project="">Return to Recruitment Management</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RecruitmentIDs" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the record(s) to delete</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:LastName"/>
<string value=", "/>
<field name="Record:RecruitmentDB:FirstName"/>
<string value=" ("/>
<field name="Record:RecruitmentDB:Email"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentID"/>
</value-expression><sort-expression><field name="Record:RecruitmentDB:LastName"/>
<string value="#"/>
<field name="Record:RecruitmentDB:FirstName"/>
</sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<or>
<contains field="Record:RecruitmentDB:FirstName">
<string field="DeleteRecruitment:SearchString"/>
</contains>
<or>
<contains field="Record:RecruitmentDB:LastName">
<string field="DeleteRecruitment:SearchString"/>
</contains>
<contains field="Record:RecruitmentDB:Email">
<string field="DeleteRecruitment:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="DeleteRecruitment:RecruitmentIDs" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H3" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The following recruitment record(s) will be deleted: </font><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header><string value="Phone"/>
</header><contents><field name="Record:RecruitmentDB:Phone" /></contents></column><conditions><form name="RecruitmentDB" /><conditions>
<mcContains field="DeleteRecruitment:RecruitmentIDs">
<string field="Record:RecruitmentDB:RecruitmentID"/>
</mcContains>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q3" alternateLabel="Confirm" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes, delete record(s)</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, do not delete</font></paragraph></choice></mc>
</items>
</form>
<form name="AuditRecruitLoop" startPoint="false" themePath="mvsc" process="Post-AuditRecruitLoop" preProcess="Pre-AuditRecruitLoop">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Clean Recruitment Records</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Registration" project="">Cancel clean recruitment records</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="RecruitmentId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the recruitment record:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:FirstName"/>
<string value=" "/>
<field name="Record:RecruitmentDB:LastName"/>
<string value=". email: "/>
<field name="Record:RecruitmentDB:Email"/>
<string value=", phone: "/>
<field name="Record:RecruitmentDB:Phone"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<equals field="Record:RecruitmentDB:BadRecord?">
<string value="Yes"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q2" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the action to perform:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit this record</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete this record</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark as "good" (it will remove this record from this list)</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Break off audit for now (you can always return)</font></paragraph></choice></mc>
</items>
</form>
<form name="DuplicateRecruitCheck" startPoint="false" themePath="mvsc" process="Post-DuplicateRecruitCheck" preProcess="Pre-DuplicateRecruitCheck">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Compare the data from the two files:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="center"><font><b>Record #1</b></font></division></cell><cell width="5400"><division indent="0" align="center"><font><b>Record #2</b></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="1800"><division indent="0" align="right"><font><b>First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitFirst"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SFirst"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Last:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitLast"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Last:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SLast"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitEmail"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SEmail"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPhone"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SPhone"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Record ID:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitID"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Record ID:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SID"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Record #2 is not a duplicate of Record #1.  Leave both in.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete Record #1</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete Record #2</font></paragraph></choice></mc>
</items>
</form>
<form name="RecruitEmail" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-RecruitEmail" preProcess="Pre-SetupMenu">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Recruitment Email</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3945"><division indent="0" align="left"><font color="000080"><u><invitation form="Recruitment" project="">Return to Recruitment Management</invitation></u></font></division></cell><cell width="3255"><division indent="0" align="left"><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Master Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This communications tool will let you send your email to your entire recruitment contact list, or only to those you missed the last time around, or just to those who haven't signed up yet.</font></paragraph></text>
<mc label="Q1" alternateLabel="To" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Everyone in the recruitment database</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Pople who have been contacted fewer than 'x' times already (you set 'x')</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Everyone in the recruitment database who is not yet a member</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From: </font><font face="Arial" size="200" color="000000"><i>(name)</i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromAdminName"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From: </font><font face="Arial" size="200" color="000000"><i>(email)</i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q5" alternateLabel="Salutation" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Address each recipient by first name</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't create an automatic salutation</font></paragraph></choice></mc>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<mc label="Q7" alternateLabel="Link" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box to include a link to the membership registration form in this message</font></paragraph></choice></mc>
<fib label="Q8" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Closing"/></paragraph></fib>
<text label="T3" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the Submit button to continue.  You will have a chance to review your letter before it is sent.</font></paragraph></text>
</items>
</form>
<form name="ChooseX" startPoint="false" themePath="mvsc" process="Post-ChooseX">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="000080"><u><invitation form="Recruitment" project="">Cancel and return to Recruitment Management</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Master Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You chose to send this letter only to those who have previously been contacted fewer than 'x' times.  Right now, 'x' equals </font><font><field name="X"/></font><font>.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View recruitment list, including past number of contacts</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View list of those contacted fewer than </font><font face="Arial" size="200" color="000000"><field name="X"/></font><font face="Arial" size="200" color="000000"> times</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Change 'x' from its current value of </font><font face="Arial" size="200" color="000000"><field name="X"/></font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Review email and then send to those contacted fewer than </font><font face="Arial" size="200" color="000000"><field name="X"/></font><font face="Arial" size="200" color="000000"> times</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit email and options further</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="ChooseX:Q1">
<string value="c"/>
</mcDoesNotEqual>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Change 'x' from </font><font face="Arial" size="200" color="000000"><field name="X"/></font><font face="Arial" size="200" color="000000"> to:  </font><blank label="a" length="4" required="false" alternateLabel="XValue"/></paragraph></fib>
</items>
</form>
<form name="RecruitEmailSend" startPoint="false" themePath="mvsc" process="Post-RecruitEmailSend" preProcess="Pre-SetupMenu">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">----------------------------------------------------------------------------------------------</font></paragraph><table indent="525"><row><cell width="10275"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font><sp/></division></cell></row><row><cell width="10275"><division indent="0" align="left"><font><b>From:</b></font><sp/><font><field name="RecruitEmail:FromAdminName"/></font><font>  (</font><font><field name="RecruitEmail:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="10275"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="10275"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10275"><division indent="0" align="left"><font><b>Subject:</b></font><sp/><font><field name="RecruitEmail:Subject"/></font><sp/></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="540"><row><cell width="10260"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="10260"></cell></row><row><cell width="10260"><division indent="0" align="left"><font><field name="RecruitEmail:Body"/></font></division></cell></row></table></text>
<text label="T2" style="normal"><table indent="525"><row><cell width="10275"><division indent="0" align="left"><font>To join </font><font><field name="Club"/></font><font> please </font><font color="000080"><u>click here</u></font><font>.</font></division></cell></row></table></text>
<text label="T3" style="normal"><table indent="510"><row><cell width="10290"><division indent="0" align="left"><font><field name="RecruitEmail:Closing"/></font></division></cell></row></table><paragraph indent="0" align="left"></paragraph><paragraph indent="0" align="left"><font color="000000">----------------------------------------------------------------------------------------------</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send out the emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email message further</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Recruitment Management</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="RecruitEmailSend:Q1">
<string value="a"/>
</mcDoesNotEqual>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T4" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Click Submit to begin sending the email out now.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: It might take several minutes to send all the emails, depending on the size of your list.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</font></paragraph></text>
</items>
</form>
<form name="OptOut" startPoint="false" themePath="mvsc" process="Post-OptOut">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="RecruitSelfEdit" startPoint="false" themePath="mvsc" process="Post-RecruitSelfEdit" preProcess="Pre-RecruitSelfEdit">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the information in your file.  Please make any corrections right to the form and then press Submit.  If the information is correct, you need do nothing.</font></paragraph></text>
<fib label="Q1" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name: </font><blank label="a" length="20" required="false" alternateLabel="SEFirst"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(first) </i></font><blank label="b" length="20" required="false" alternateLabel="SELast"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph></fib>
<fib label="Q2" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="a" length="20" required="false" alternateLabel="SEEmail"/></paragraph></fib>
<fib label="Q3" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone: </font><blank label="a" length="20" required="false" alternateLabel="SEPhone"/></paragraph></fib>
</items>
</form>
<form name="Dashboards" startPoint="false" themePath="mvsc" process="Post-Dashboards">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Send/View Private Dashboard</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="MasterAdminDash" project="">Cancel send/view private dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Please note that private Dashboards are sent automatically to each new member of the </font><font><field name="BossGroup"/></font><font>, </font><font><field name="TskLdrCollName"/></font><font> of a </font><font><field name="GroupCollectiveName"/></font><font> or new </font><font><field name="Club"/></font><font> member at the time of their selection.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This section is to be used to permit the re-transmission of Dashboard links to those who have misplaced theirs.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose an action:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>View</b></font><font face="Arial" size="200" color="000000"> the private Dashboard of member of </font><font face="Arial" size="200" color="000000"><b><field name="BossGroup"/></b></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>View</b></font><font face="Arial" size="200" color="000000"> the private Dashboard of the </font><font face="Arial" size="200" color="000000"><field name="TskLdrCollName"/></font><font face="Arial" size="200" color="000000"> of a particular </font><font face="Arial" size="200" color="000000"><b><field name="GroupCollectiveName"/></b></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>View</b></font><font face="Arial" size="200" color="000000"> the private Dashboard a member of </font><font face="Arial" size="200" color="000000"><b><field name="Club"/></b></font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Send</b></font><font face="Arial" size="200" color="000000"> out Dashboard links to one or more members of </font><font face="Arial" size="200" color="000000"><b><field name="BossGroup"/></b></font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Send</b></font><font face="Arial" size="200" color="000000"> out Dashboard links to one, several or every </font><font face="Arial" size="200" color="000000"><field name="TskLdrCollName"/></font><font face="Arial" size="200" color="000000"> of a </font><font face="Arial" size="200" color="000000"><b><field name="GroupCollectiveName"/></b></font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Send</b></font><font face="Arial" size="200" color="000000"> out Dashboard links to one or more specifiedmembers of  </font><font face="Arial" size="200" color="000000"><b><field name="Club"/></b></font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Dashboards:Q1">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Dashboards:Q1">
<string value="c"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="T7"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Dashboards:Q1">
<string value="d"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="T9"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Dashboards:Q1">
<string value="e"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="T10"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Dashboards:Q1">
<string value="f"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="T11"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Dashboards:Q1">
<string value="a"/>
</mcDoesNotEqual>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Dashboards" project="">Return to Send/View Dashboard Menu</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Master Dashboard</invitation></u></font></paragraph></text>
<mc label="Q2" alternateLabel="ViewLeader" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the member of </font><font face="Arial" size="200" color="000000"><field name="BossGroup"/></font><font face="Arial" size="200" color="000000"> whose Dashboard you wish to view:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderNames:First"/>
<string value=" "/>
<field name="Record:LeaderNames:Last"/>
<string value=" ("/>
<field name="Record:LeaderNames:PositionName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:LeaderNames:NameID"/>
</value-expression><sort-expression><field name="Record:LeaderNames:Last"/>
<string value="#"/>
<field name="Record:LeaderNames:First"/>
</sort-expression><record-selector><form name="LeaderNames" /></record-selector></dynamic-mcq></data-provider></mc>
<break/>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Click the link below to view the selected private Dashboard:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: To return to your own Master Dashboard you must bookmark your own link and use that bookmark.  The Back arrow will not work!</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="FF0000"><u>Click this link to view the private Dashboard</u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The Submit button will return you to the Send or View Private Dashboard Menu.</font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Dashboards" project="">Return to Send/View Dashboard Menu</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Master Dashboard</invitation></u></font></paragraph></text>
