<form name="DashboardsEmail" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-DashboardsEmail" preProcess="Pre-SetupMenu">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Dashboard Email</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Dashboards" project="">Cancel and Return to Send/View Dashboard Menu</invitation></u></font><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Master Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This communications tool will let you send you Dashboard links to everyone in your </font><font><field name="Club"/></font><font>, specifically your </font><font><field name="BossGroup"/></font><font>, the </font><font><field name="TskLdrCollName"/></font><font>s of each </font><font><field name="GroupCollectiveName"/></font><font>, and the membership generally.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note that a member of the </font><font><field name="BossGroup"/></font><font> will </font><font><b>not </b></font><font> be included in mass mailings to the </font><font><field name="TskLdrCollName"/></font><font>s or the membership, as member Dashboards are more restricted and have no features that are not also included in the </font><font><field name="BossGroup"/></font><font> Dashboard.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Likewise, a </font><font><field name="TskLdrCollName"/></font><font> will </font><font><b>not</b></font><font> be included in a mass mailing to the membership, as his or her </font><font><field name="GroupCollectiveName"/></font><font> Dashboard will have every feature included in a member's Dashboard, plus other features.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Your message will look like this.  Please fill in the blanks:</i></font></paragraph></text>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>To:</b></font><sp/><font><field name="ToField"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>From:</b></font><sp/><font><field name="AdmnsNm"/></font><font face="Arial" size="200" color="000000"> (</font><font face="Arial" size="200" color="000000"><field name="AdmnsEmail"/></font><font face="Arial" size="200" color="000000">)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Subject:</b></font><sp/><font>Your </font><font><field name="Club"/></font><sp/><font><field name="Role"/></font><font> Dashboard</font></paragraph></text>
<mc label="Q1" alternateLabel="Salutation" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Address each recipient by first name</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't create an automatic salutation</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T5" alternateLabel="Link" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Your personal </font><font><field name="Club"/></font><sp/><font><field name="Role"/></font><sp/><font>Dashboard link is </font><font color="000080"><u>here</u></font><font>.  Clicking on this link will take you to your private </font><font><field name="Club"/></font><sp/><font><field name="Role"/></font><font> Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">To save this link, click on it.  A </font><font color="000000"><field name="Club"/></font><font color="000000"> Web page will come up, your personal page. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">Saving this link depends upon which brower you use:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Internet Explorer, click on "Favorites" in the Menu Bar at top and </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">then "Add to Favorites."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Firefox, click on "Bookmarks" in the Menu Bar at top and then </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">"Bookmark this Page."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Safari, click on "Bookmarks" and then "Add Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Be sure to save this link in a safe place.  You can use it to modify your personal membership information, to communicate with others within the organization and for many other purposes.</font></paragraph></text>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Closing"/></paragraph></fib>
<text label="T6" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the Submit button to continue.  You will have a chance to review your letter before it is sent.  To cancel, use the links at the top of this page.</font></paragraph></text>
</items>
</form>
<form name="DashboardEmailSend" startPoint="false" themePath="mvsc" process="Post-DashboardEmailSend" preProcess="Pre-SetupMenu">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">----------------------------------------------------------------------------------------------</font></paragraph><table indent="675"><row><cell width="10125"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font><sp/></division></cell></row><row><cell width="10125"><division indent="0" align="left"><font><b>From:</b></font><sp/><sp/><font><field name="AdmnsNm"/></font><font> (</font><font><field name="AdmnsEmail"/></font><font>)</font></division></cell></row><row><cell width="10125"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="10125"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10125"><division indent="0" align="left"><font><b>Subject:</b></font><font color="000000">  Your </font><font color="000000"><field name="Club"/></font><sp/><font color="000000"><field name="Role"/></font><font color="000000"> Dashboard</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="675"><row><cell width="10125"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="10125"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10125"><division indent="0" align="left"><font><field name="DashboardsEmail:Body"/></font></division></cell></row></table></text>
<text label="T2" alternateLabel="Link" style="normal"><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>Your personal </font><font><field name="Club"/></font><sp/><font><field name="Role"/></font><sp/><font>Dashboard link is </font><font color="000080"><u>here</u></font><font>.  Clicking on this link will take you to your private </font><font><field name="Club"/></font><sp/><font><field name="Role"/></font><font> Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">To save this link, click on it.  A </font><font color="000000"><field name="Club"/></font><font color="000000"> Web page will come up, your personal page.</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">Saving this link depends upon which brower you use:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="1440" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Internet Explorer, click on "Favorites" in the Menu Bar at top and </font></paragraph><paragraph indent="1440" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">then "Add to Favorites."</font></paragraph><paragraph indent="1440" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Firefox, click on "Bookmarks" in the Menu Bar at top and then </font></paragraph><paragraph indent="1440" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">"Bookmark this Page."</font></paragraph><paragraph indent="1440" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Safari, click on "Bookmarks" and then "Add Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>Be sure to save this link in a safe place.  You can use it to modify your personal membership information, to communicate with others within the organization and for many other purposes.</font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="720" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DashboardsEmail:Closing"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">----------------------------------------------------------------------------------------------</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send out the emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email message further</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to  Send/View Private Dashboard</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Master Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="DashboardEmailSend:Q1">
<string value="a"/>
</mcDoesNotEqual>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T4" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Click Submit to begin sending the email out now.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: It might take several minutes to send all the emails, depending on the size of your list.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</font></paragraph></text>
</items>
</form>
<form name="DashboardRouter" startPoint="false" themePath="mvsc" process="Post-DashboardRouter">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="MembershipDash" startPoint="false" themePath="mvsc" process="Post-MembershipDash" preProcess="Pre-SetupMenu">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="LeadershipDash" startPoint="false" themePath="mvsc" process="Post-LeadershipDash" preProcess="Pre-SetupMenu">
</form>
<form name="CommitteeHeadDash" startPoint="false" themePath="mvsc" process="Post-CommitteeHeadDash" preProcess="Pre-SetupMenu">
</form>
<form name="ManageDBCategories" startPoint="false" themePath="mvsc" process="Post-ManageDBCategories" preProcess="Pre-ManageDBCategories">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Manage Database Categories</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Current Categories:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Category"/>
</header><contents><field name="Record:AddDBCategory:CatName" /></contents></column><conditions><form name="AddDBCategory" /></conditions></itemization-table></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add a category</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit a category</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete a category</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Assign permissions/restrictions to a category</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Setup</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="ManageDBCategories:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="DeleteCategory"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="ManageDBCategories:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q2" alternateLabel="EditCategory" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select a category to edit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:AddDBCategory:CatName"/>
</display-expression><value-expression><field name="Record:AddDBCategory:CatID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="AddDBCategory" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q3" alternateLabel="DeleteCategory" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select a category to delete:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:AddDBCategory:CatName"/>
</display-expression><value-expression><field name="Record:AddDBCategory:CatID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="AddDBCategory" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="AddDBCategory" startPoint="false" themePath="mvsc" process="Post-AddDBCategory">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="Begin">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add/Edit Database Category</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ManageDBCategories" project="">Cancel and return to Manage Categories</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current categories:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Category"/>
</header><contents><field name="Record:AddDBCategory:CatName" /></contents></column><conditions><form name="AddDBCategory" /></conditions></itemization-table></font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Category name: </font><blank label="a" length="20" required="false" alternateLabel="CatName"/></paragraph></fib>
<field name="CatID"/>
</items>
</form>
<form name="DeleteCategoryConfirm" startPoint="false" themePath="mvsc" process="Post-DeleteCategoryConfirm">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>There are </font><font><field name="Count"/></font><font> records in the membership files that are marked as belonging in the category you wish to delete: </font><font><display-mcq-label version="1"><field-name>ManageDBCategories:DeleteCategory</field-name><display>label_only</display></display-mcq-label></font><sp/><font><i>(although some records might have marked more than one category).</i></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">What do you want to do with these records?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Assign these members to a different category, at least if they belong to no other.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Leave the records as they are.  Some may belong to no category.</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete the database records in the category, at least as long as they belong to no other category.</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Cancel the "Delete Category" instruction and return to Category Management.</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="DeleteCategoryConfirm:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q2" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Place these records in the following category:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:AddDBCategory:CatName"/>
</display-expression><value-expression><field name="Record:AddDBCategory:CatID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="AddDBCategory" /><conditions>
<doesNotEqual field="Record:AddDBCategory:CatID">
<string field="ManageDBCategories:DeleteCategory"/>
</doesNotEqual>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="AdminCommunicator" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-AdminCommunicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This tool permits you to select broad categories of people in your database and to send a personal note to each person in the category.  It is NOT the tool to use to communicate with your Recruiting List (to send communications to them, use the </font><font color="000080"><u><invitation form="RecruitEmail" project="">Recruitment List Communicator</invitation></u></font><font color="000000">).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>For example, you might use this Communicator to send a message to:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>* Alumni who have made a financial pledge to </font><font><field name="Club"/></font><font> which they have not yet satisfied.</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>* The </font><font><field name="TskLdrCollName"/></font><font> and members of a </font><font><field name="GroupCollectiveName"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>* One of the leaders of </font><font><field name="Club"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Answer the questions below to build your communication and its targetted audience.  You will have a chance to review both your message and your recipient list before anything is sent out.</font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(name):</i></font><sp/><blank label="a" length="45" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email):</i></font><sp/><blank label="a" length="45" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="45" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q4" alternateLabel="Salutation" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Salutation</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Include a personalized first name salutation </font><font face="Arial" size="200" color="000000"><i>(i.e. Dear Jim,):</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't include a personalized salutation</font></paragraph></choice></mc>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="45" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<mc label="Q6" alternateLabel="Link" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box to include a link to the recipient's personal dashboard, if any, in your message.</font></paragraph></choice></mc>
<fib label="Q7" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing: </font><blank label="a" length="45" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<mc label="Q8" alternateLabel="To" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this message to: </font><font face="Arial" size="200" color="000000"><i>(You may mark more than one)</i></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The </font><font face="Arial" size="200" color="000000"><field name="BossGroup"/></font><font face="Arial" size="200" color="000000"> of </font><font face="Arial" size="200" color="000000"><field name="Club"/></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">A specific </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="200" color="000000"> membership and its </font><font face="Arial" size="200" color="000000"><field name="TskLdrCollName"/></font><sp/></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The </font><font face="Arial" size="200" color="000000"><field name="TskLdrCollName"/></font><font face="Arial" size="200" color="000000"> of one or more </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="200" color="000000">s </font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Everyone in the </font><font face="Arial" size="200" color="000000"><field name="Club"/></font><font face="Arial" size="200" color="000000"> database (or a selection from the entire list)</font></paragraph></choice></mc>
<text label="T3" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You may further limit your recipient list:</font></paragraph></text>
<mc label="Q9" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">1. Only send to those in the following category of records:</font><font face="Arial" size="200" color="000000"><i>(leave blank to send to all categories)</i></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:AddDBCategory:CatName"/>
</display-expression><value-expression><field name="Record:AddDBCategory:CatID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="AddDBCategory" /></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q10" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">2. Check here:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To add other limitations based on criteria tied to dues payments, pledges or other financial or fundraising considerations</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="AdminCommunicator:To" value="b"/>
</conditions>
<trueSet>
<skip to="Group"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AdminCommunicator:To" value="c"/>
</conditions>
<trueSet>
<skip to="GrpLeaders"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AdminCommunicator:To" value="d"/>
</conditions>
<trueSet>
<skip to="Membership"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="AdminCommunicator:To" value="a"/>
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q11" alternateLabel="Leadership" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">You have chosen to send this message to the </font><font face="Arial" size="200" color="000000"><field name="BossGroup"/></font><font face="Arial" size="200" color="000000"> of </font><font face="Arial" size="200" color="000000"><field name="Club"/></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send it to everyone in the </font><font face="Arial" size="200" color="000000"><field name="BossGroup"/></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send it only to selected individuals in the </font><font face="Arial" size="200" color="000000"><field name="BossGroup"/></font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="AdminCommunicator:Leadership" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q12" alternateLabel="SelectLeaders" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Please indicate the members of the </font><font face="Arial" size="200" color="000000"><field name="BossGroup"/></font><font face="Arial" size="200" color="000000"> to whom you wish this message sent:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderNames:First"/>
<string value=" "/>
<field name="Record:LeaderNames:Last"/>
<string value=" ("/>
<field name="Record:LeaderNames:PositionName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:LeaderNames:NameID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="LeaderNames" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="AdminCommunicator:SelectLeaders" />
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q13" alternateLabel="Group" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Please select the </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="200" color="000000"> to which you wish to send this message: </font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Groups:GroupName"/>
</display-expression><value-expression><field name="Record:Groups:GroupIDNumber"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Groups" /></record-selector></dynamic-mcq></data-provider></mc>
