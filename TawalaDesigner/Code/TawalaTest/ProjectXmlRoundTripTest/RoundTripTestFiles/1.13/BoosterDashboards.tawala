<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DearSir"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="MessageBody"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>Your personal </font><font><field name="Club"/></font><sp/><font><field name="Role"/></font><sp/><font>Dashboard link is </font><font color="000080"><u><invitation form="DashboardRouter" project="" private="true"><authenticationTokenValue><string field="InviteeLink"/>
</authenticationTokenValue>here</invitation></u></font><font>.  Clicking on this link will take you to your private </font><font><field name="Club"/></font><sp/><font><field name="Role"/></font><font> Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">To save this link, click on it.  A </font><font color="000000"><field name="Club"/></font><font color="000000"> Web page will come up, your personal page.</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font color="000000">Saving this link depends upon which brower you use:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Internet Explorer, click on "Favorites" in the Menu Bar at top and </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">then "Add to Favorites."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Firefox, click on "Bookmarks" in the Menu Bar at top and then </font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">"Bookmark this Page."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2880"/></tabPositions><font color="000000">If you use Safari, click on "Bookmarks" and then "Add Bookmarks."</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Be sure to save this link in a safe place.  You can use it to modify your personal membership information, to communicate with others within the organization and for many other purposes.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="MessageClose"/></font></paragraph>
</xmlData>
</document>
