<mc label="Q9" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send out Dashboard links to</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">all </font><font face="Arial" size="200" color="000000"><field name="Club"/></font><font face="Arial" size="200" color="000000"> members</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">all </font><font face="Arial" size="200" color="000000"><field name="Club"/></font><font face="Arial" size="200" color="000000"> member who have not yet received a Dashboard link</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">one or more specified members, whether or not they have been sent a Dashboard link before</font></paragraph></choice></mc>
