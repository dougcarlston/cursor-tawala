<process name="Post-PassFail">
<if>
<conditions>
<equals field="Password">
<string field="PassFail:Q1:a"/>
</equals>
</conditions>
<trueSet>
<set field="PasswordOK" arithmeticAsText="false">
<string value="Yes"/>
</set>
<show form="MasterAdminDash"/>
</trueSet>
<falseSet>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</falseSet>
</if>
<if>
<conditions>
<isLessThan field="Count">
<string value="5"/>
</isLessThan>
</conditions>
<trueSet>
<show form="PassFail"/>
</trueSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value="Your correct password has been emailed to you."/>
</set>
<show document="Message" reset="false"/>
<send>
<to addressField="AdmnsEmail"/>
<from addressLiteral="no_reply@tawala.com" aliasLiteral="SportsDashboards Administration"/>
<subject>Your SportsDashboards Password</subject>
<body document="PasswordReminder" reset="false" showHeader="true"/>
</send>
</process>
<process name="Pre-ManageGroups">
<get recordList="Record List 12">
<forms>
<form name="ManageGroups"/>
</forms>
</get>
<foreach record="Group" recordList="Record List 12">
<set field="ManageGroups:VolunteerInstructions" arithmeticAsText="false">
<string field="Group:ManageGroups:VolunteerInstructions"/>
</set>
</foreach>
<if>
<conditions>
<and>
<isNotBlank field="Groups:GroupIDNumber" />
<and>
<doesNotEqual field="Groups:GroupName">
<string value="Delete"/>
</doesNotEqual>
<equals field="FixList">
<string value="Yes"/>
</equals>
</and>
</and>
</conditions>
<trueSet>
<set field="FixList" arithmeticAsText="false">
<string value="No"/>
</set>
<comment>People in committee with name change need to have their committee list updated</comment>
<get recordList="Record List 79">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<contains field="Record List 79:Registration:GroupMembershipIDs">
<string field="Groups:GroupIDNumber"/>
</contains>
</conditions></get>
<foreach record="PersonInChangedGroup" recordList="Record List 79">
<set field="PersonInChangedGroup:Registration:GroupMembershipNames" arithmeticAsText="false">
<string value=" "/>
</set>
<comment>Get all the committee assignments that have his ID</comment>
<get recordList="Record List 80">
<forms>
<form name="Groups"/>
</forms>
<conditions>
<contains field="PersonInChangedGroup:Registration:GroupMembershipIDs">
<string field="Record List 80:Groups:GroupIDNumber"/>
</contains>
</conditions></get>
<foreach record="SuchGroup" recordList="Record List 80">
<if>
<conditions>
<isBlank field="PersonInChangedGroup:Registration:GroupMembershipNames" />
</conditions>
<trueSet>
<set field="PersonInChangedGroup:Registration:GroupMembershipNames" arithmeticAsText="false">
<string field="SuchGroup:Groups:GroupName"/>
</set>
</trueSet>
<falseSet>
<set field="PersonInChangedGroup:Registration:GroupMembershipNames" arithmeticAsText="false">
<string field="PersonInChangedGroup:Registration:GroupMembershipNames"/>
<string value=", "/>
<string field="SuchGroup:Groups:GroupName"/>
</set>
</falseSet>
</if>
</foreach>
</foreach>
</trueSet>
</if>
</process>
<process name="Post-ManageGroups">
<if>
<conditions>
<mcEquals field="ManageGroups:Q2" value="a"/>
</conditions>
<trueSet>
<show form="Groups"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsNotBlank field="ManageGroups:EditCommittee" />
</conditions>
<trueSet>
<edit form="Groups" submit="modify">
<conditions>
<mcEquals field="ManageGroups:EditCommittee">
<string field="Record:Groups:GroupIDNumber"/>
</mcEquals>
</conditions>
</edit>
</trueSet>
</if>
<if>
<conditions>
<mcIsNotBlank field="ManageGroups:RemoveCommittee" />
</conditions>
<trueSet>
<comment>First, delete the right records from Form GroupMemberships</comment>
<delete><form name="Groups"/><conditions>
<mcEquals field="ManageGroups:RemoveCommittee">
<string field="Record:Groups:GroupIDNumber"/>
</mcEquals>
</conditions></delete>
<delete><form name="GroupMemberships"/><conditions>
<equals field="Record:GroupMemberships:GrpID">
<string field="ManageGroups:RemoveCommittee"/>
</equals>
</conditions></delete>
<comment>Next, zero out the Group Membership lists in Registration:GroupMembershipNames and GroupMembershipIDs if among affected people</comment>
<get recordList="Record List 47">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<contains field="Record List 47:Registration:GroupMembershipIDs">
<string field="ManageGroups:RemoveCommittee"/>
</contains>
</conditions></get>
<foreach record="SuchComMember" recordList="Record List 47">
<set field="SuchComMember:Registration:GroupMembershipIDs" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SuchComMember:Registration:GroupMembershipNames" arithmeticAsText="false">
<string value=" "/>
</set>
</foreach>
<comment>Then, we need to create new membership list for each affected registrant in Registrant:Group Membership</comment>
<comment>First, select someone who was on the deleted committee</comment>
<get recordList="Record List 48">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<contains field="Record List 48:Registration:GroupMembershipIDs">
<string field="ManageGroups:RemoveCommittee"/>
