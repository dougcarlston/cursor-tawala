<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3600"><division indent="0" align="left"><font><b>Membership Categories</b></font></division></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font color="000080"><u><invitation form="ManageDBCategories" project="">change category setup</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="FF0000">&lt;CategorySetupError&gt;</font></division></cell></row><row><cell width="3600"></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="3600"></cell><cell width="272"></cell><cell width="6928"><division indent="0" align="left"><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Categories"/>
</header><contents><field name="Record:AddDBCategory:CatName" /></contents></column><conditions><form name="AddDBCategory" /></conditions></itemization-table></font></division></cell></row><row><cell width="3600"></cell><cell width="272"></cell><cell width="6928"></cell></row></table>
</xmlData>
</document>
<document name="SeupMenu-Dues">
<xmlData>
