</header><contents><field name="Record:RecruitmentDB:Phone" /></contents></column><conditions><form name="RecruitmentDB" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Recruitment" project="">Return to Recruitment</invitation></u></font></paragraph>
</xmlData>
