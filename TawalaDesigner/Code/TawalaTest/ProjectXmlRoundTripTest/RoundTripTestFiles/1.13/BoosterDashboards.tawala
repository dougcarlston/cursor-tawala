<if>
<conditions>
<isLessThan field="_InviteeID">
<string value="1000"/>
</isLessThan>
</conditions>
<trueSet>
<comment>It's a leadership Dash</comment>
<show form="LeadershipDash"/>
</trueSet>
</if>
</process>
<process name="Post-MembershipDash">
<comment>First, get the data for the right member</comment>
<set field="MemberFound" arithmeticAsText="false">
<string value="No"/>
</set>
<get recordList="Record List 73">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="_InviteeID">
<string field="Record List 73:Registration:MemberID"/>
</equals>
</conditions></get>
<foreach record="Member" recordList="Record List 73">
<set field="MemberFound" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="MName" arithmeticAsText="false">
<string field="Member:Registration:FirstNme"/>
<string value=" "/>
<string field="Member:Registration:LastNme"/>
</set>
</foreach>
<show document="MemDash-Header" reset="false"/>
</process>
<process name="Post-LeadershipDash">
</process>
<process name="Post-CommitteeHeadDash">
</process>
<process name="Post-AddDBCategory">
<if>
<conditions>
<equals field="Begin">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="NextCat">
<string value="End"/>
</equals>
</conditions>
<trueSet>
<set field="NextCat" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Begin" arithmeticAsText="false">
<string value="No"/>
</set>
<show form="AdminSetup"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="NextCat">
<string value="2"/>
</equals>
</conditions>
<trueSet>
<set field="AddDBCategory:CatName" arithmeticAsText="false">
<string value="Local Business Leaders"/>
</set>
<set field="NextCat" arithmeticAsText="false">
<string value="End"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="NextCat">
<string value="1"/>
</equals>
</conditions>
<trueSet>
<set field="AddDBCategory:CatName" arithmeticAsText="false">
<string value="Alumni"/>
</set>
<set field="NextCat" arithmeticAsText="false">
<string value="2"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="NextCat" />
</conditions>
<trueSet>
<set field="AddDBCategory:CatName" arithmeticAsText="false">
<string value="Parents"/>
</set>
<set field="NextCat" arithmeticAsText="false">
<string value="1"/>
</set>
</trueSet>
</if>
</trueSet>
</if>
<get recordList="Record List 74">
<forms>
<form name="AddDBCategory"/>
</forms>
<conditions>
<equals field="Record List 74:AddDBCategory:CatName">
<string field="AddDBCategory:CatName"/>
</equals>
</conditions></get>
<foreach record="Dupe" recordList="Record List 74">
<set field="AddDBCategory:CatName" arithmeticAsText="false">
<string value="Delete"/>
</set>
</foreach>
<if>
<conditions>
<and>
<isBlank field="AddDBCategory:CatID" />
<doesNotEqual field="AddDBCategory:CatName">
<string value="Delete"/>
</doesNotEqual>
</and>
</conditions>
<trueSet>
<set field="AddDBCategory:CatID" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="Record List 75">
<forms>
<form name="AddDBCategory"/>
</forms>
</get>
<foreach record="CatItem" recordList="Record List 75">
<if>
<conditions>
<isGreaterThanOrEqualTo field="CatItem:AddDBCategory:CatID">
<string field="AddDBCategory:CatID"/>
</isGreaterThanOrEqualTo>
</conditions>
<trueSet>
<set field="AddDBCategory:CatID" arithmeticAsText="false">
<add>
<operand field="CatItem:AddDBCategory:CatID"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<equals field="Begin">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show form="AddDBCategory"/>
</trueSet>
</if>
<show form="ManageDBCategories"/>
</process>
<process name="Pre-ManageDBCategories">
<delete><form name="AddDBCategory"/><conditions>
<or>
<equals field="Record:AddDBCategory:CatName">
<string value="Delete"/>
</equals>
<isBlank field="Record:AddDBCategory:CatName" />
</or>
</conditions></delete>
</process>
<process name="Post-ManageDBCategories">
<if>
<conditions>
<mcEquals field="ManageDBCategories:Q1" value="a"/>
</conditions>
<trueSet>
<show form="AddDBCategory"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="ManageDBCategories:Q1" value="b"/>
<mcIsNotBlank field="ManageDBCategories:EditCategory" />
</and>
</conditions>
<trueSet>
<edit form="AddDBCategory" submit="modify">
<conditions>
<mcEquals field="ManageDBCategories:EditCategory">
<string field="Record:AddDBCategory:CatID"/>
</mcEquals>
</conditions>
</edit>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="ManageDBCategories:Q1" value="c"/>
<mcIsNotBlank field="ManageDBCategories:DeleteCategory" />
</and>
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 76">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="Record List 76:Registration:Categry">
<string field="ManageDBCategories:DeleteCategory"/>
</mcContains>
</conditions></get>
<foreach record="Problem" recordList="Record List 76">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<delete><form name="AddDBCategory"/><conditions>
<equals field="Record:AddDBCategory:CatID">
<string field="ManageDBCategories:DeleteCategory"/>
</equals>
</conditions></delete>
</trueSet>
<falseSet>
<show form="DeleteCategoryConfirm"/>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ManageDBCategories:Q1" value="d"/>
</conditions>
<trueSet>
<comment>Set up Category permissions/restrictions</comment>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ManageDBCategories:Q1" value="e"/>
</conditions>
<trueSet>
<show form="SetupMenu"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ManageDBCategories:Q1" value="f"/>
</conditions>
<trueSet>
<show form="MasterAdminDash"/>
</trueSet>
</if>
<show form="ManageDBCategories"/>
</process>
<process name="Post-DeleteCategoryConfirm">
<if>
<conditions>
<mcEquals field="DeleteCategoryConfirm:Q1" value="d"/>
</conditions>
<trueSet>
<show form="ManageDBCategories"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="DeleteCategoryConfirm:Q1" />
</conditions>
<trueSet>
<show form="DeleteCategoryConfirm"/>
</trueSet>
</if>
<get recordList="Record List 77">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="Record List 77:Registration:Categry">
<string field="ManageDBCategories:DeleteCategory"/>
</mcContains>
</conditions></get>
<if>
<conditions>
<mcEquals field="DeleteCategoryConfirm:Q1" value="a"/>
</conditions>
<trueSet>
<if>
<conditions>
<mcIsNotBlank field="DeleteCategoryConfirm:Q2" />
</conditions>
<trueSet>
<foreach record="Reassignment" recordList="Record List 77">
<if>
<conditions>
<mcEquals field="Reassignment:Registration:Categry">
<string field="ManageDBCategories:DeleteCategory"/>
</mcEquals>
</conditions>
<trueSet>
<set field="Reassignment:Registration:Categry" arithmeticAsText="false">
<string field="DeleteCategoryConfirm:Q2"/>
</set>
</trueSet>
</if>
</foreach>
</trueSet>
<falseSet>
<show form="DeleteCategoryConfirm"/>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="DeleteCategoryConfirm:Q1" value="c"/>
</conditions>
<trueSet>
<delete><form name="Registration"/><conditions>
<mcEquals field="Record:Registration:Categry">
<string field="ManageDBCategories:DeleteCategory"/>
</mcEquals>
</conditions></delete>
</trueSet>
</if>
<delete><form name="AddDBCategory"/><conditions>
<equals field="Record:AddDBCategory:CatID">
<string field="ManageDBCategories:DeleteCategory"/>
</equals>
</conditions></delete>
<show form="ManageDBCategories"/>
</process>
<process name="Post-AdminCommunicator">
<show form="MasterAdminDash"/>
</process>
</processes>
<documents>
<document name="SetupMenu-Header">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10245"><division indent="0" align="left"><font size="360" color="000080"><b><field name="Club"/></b></font><font size="360" color="000080"><b> Setup Review</b></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10230"><division indent="0" align="left"><sp/><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Administrator Dashboard</invitation></u></font><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminSetup" project="">Return to Start of Setup</invitation></u></font><sp/><sp/><sp/><font color="000080"><u><invitation form="RegistrationPreview" project="">Preview Membership/Registration Info</invitation></u></font><sp/><sp/></division></cell></row></table>
