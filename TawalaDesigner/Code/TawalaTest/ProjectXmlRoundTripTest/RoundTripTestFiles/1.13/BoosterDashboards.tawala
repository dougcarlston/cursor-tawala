<get recordList="Record List 31">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<and>
<mcContains field="AssignMembers2Groups:AssignChoices">
<string field="Record List 31:Registration:MemberID"/>
</mcContains>
<isBlank field="Record List 31:Registration:Status" />
</and>
</conditions></get>
<foreach record="NewGroupMember" recordList="Record List 31">
<if>
<conditions>
<doesNotContain field="NewGroupMember:Registration:GroupMembershipIDs">
<string field="AssignMembers2Groups:GroupSelection"/>
</doesNotContain>
</conditions>
<trueSet>
