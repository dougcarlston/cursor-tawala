<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">View Member Profile</font></paragraph></heading>
<text label="T1" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b>Name:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MName"/></font></division></cell></row></table></text>
<text label="T2" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MEmail"/></font></division></cell></row></table></text>
<text label="T3" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MAddress1"/></font></division></cell></row><row><cell width="3075"></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MAddress2"/></font></division></cell></row></table></text>
<text label="T4" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b>Spouse:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MSpouse"/></font></division></cell></row></table><displayConditions>
<equals field="AskSecondParentName">
<string value="Yes"/>
</equals>
</displayConditions></text>
<text label="T5" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b>Spouse's Email:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MSEmail"/></font></division></cell></row></table><displayConditions>
<equals field="AskSecondParentEmail">
<string value="Yes"/>
</equals>
</displayConditions></text>
<text label="T6" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b>Alt Address:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MSAddress1"/></font></division></cell></row><row><cell width="3075"></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MSAddress2"/></font></division></cell></row></table><displayConditions>
<equals field="AskSecondParentAddress">
<string value="Yes"/>
</equals>
</displayConditions></text>
<text label="T7" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b>Phones</b></font></division></cell><cell width="272"></cell><cell width="7453"></cell></row><row><cell width="3075"><division indent="0" align="right"><font><field name="PhoneLab1"/></font><font><b>:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MPhone1"/></font></division></cell></row><row><cell width="3075"><division indent="0" align="right"><font><field name="PhoneLab2"/></font><font><b>:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MPhone2"/></font></division></cell></row><row><cell width="3075"><division indent="0" align="right"><font><field name="PhoneLab3"/></font><font><b>:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MPhone3"/></font></division></cell></row></table></text>
<text label="T8" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b><field name="GroupCollectiveName"/></b></font><font><b> Choices:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MChoices"/></font></division></cell></row></table><displayConditions>
<and>
<equals field="GroupsEnabled">
<string value="Yes"/>
</equals>
<equals field="AskVolunteers">
<string value="Volunteers"/>
</equals>
</and>
</displayConditions></text>
<text label="T9" style="normal"><table indent="0"><row><cell width="3075"><division indent="0" align="right"><font><b><field name="GroupCollectiveName"/></b></font><sp/><font><b>Assignments:</b></font></division></cell><cell width="272"></cell><cell width="7453"><division indent="0" align="left"><font><field name="MGroups"/></font></division></cell></row></table><displayConditions>
<equals field="GroupsEnabled">
<string value="Yes"/>
</equals>
</displayConditions></text>
</items>
</form>
<form name="AdminCommitteeMenu" startPoint="false" themePath="mvsc" process="Post-AdminCommitteeMenu">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Administrator </font><font face="Arial" size="360" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="360" color="000000"> Menu</font></paragraph></heading>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Manage </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="200" color="000000">s</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="200" color="000000"> Data</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Dashboard</font></paragraph></choice></mc>
</items>
</form>
<form name="RecruitmentDB" startPoint="false" themePath="mvsc" process="Post-RecruitmentDB">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="Action">
<string value="AddNonDupes"/>
</equals>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000"><field name="Action"/></font><font face="Arial" size="360" color="000000"> Recruitment Database</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="000080"><u><invitation form="Recruitment" project="">Return to Recruitment Management</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="000080"><u><invitation form="MasterAdminDash" project="">Return to Master Dashboard</invitation></u></font></division></cell></row></table></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name: </font><blank label="a" length="20" required="false" alternateLabel="FirstName"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(first) </i></font><blank label="b" length="20" required="false" alternateLabel="LastName"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph></fib>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email Address: </font><blank label="a" length="20" required="false" alternateLabel="Email"/></paragraph></fib>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone Number: </font><blank label="a" length="20" required="false" alternateLabel="Phone"/></paragraph></fib>
<field name="RecruitmentID"/>
<field name="BadRecord?"/>
<field name="ContactsNo"/>
</items>
</form>
