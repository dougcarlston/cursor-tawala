<form name="ManageLeadership" startPoint="false" themePath="mvsc" process="Post-ManageLeadership" preProcess="Pre-ManageLeadership">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Manage Club Leadership</font></paragraph></heading>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Collective name for entire leadership group: </font><font face="Arial" size="200" color="000000"><i>(e.g. Leadership Circle, Board of Directors, etc.) </i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="44" required="false" alternateLabel="LeadershipGroupName"/></paragraph></fib>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Current leadership titles:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Title"/>
</header><contents><field name="Record:LeaderTitles:LeaderTitle" /></contents></column><conditions><form name="LeaderTitles" /></conditions></itemization-table></font><sp/><sp/><sp/><sp/><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>And assignments to date:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Title"/>
</header><contents><field name="Record:LeaderNames:PositionName" /></contents></column><column><header><string value="First"/>
</header><contents><field name="Record:LeaderNames:First" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:LeaderNames:Last" /></contents></column><column><header><string value="Permissions"/>
</header><contents><field name="Record:LeaderNames:Permissions" /></contents></column><conditions><form name="LeaderNames" /><conditions>
<mcIsNotBlank field="Record:LeaderNames:PositionChoices" />
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q2" onlyone="true" required="false" style="multicolumn"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Create leadership title</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit title</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete title </font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Assign/remove people to/from leadership positions</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Set permissions for each position</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Setup</font></paragraph></choice><choice label="g"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Dashboard </font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="ManageLeadership:Q2" value="c"/>
</conditions>
<trueSet>
<skip to="DeleteLeadership"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="ManageLeadership:Q2" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q3" alternateLabel="EditLeadership" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Select a leadership position to edit:</b></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderTitles:LeaderTitle"/>
</display-expression><value-expression><field name="Record:LeaderTitles:PositionIDNumber"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="LeaderTitles" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q4" alternateLabel="DeleteLeadership" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Select a leadership position to delete:</b></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderTitles:LeaderTitle"/>
</display-expression><value-expression><field name="Record:LeaderTitles:PositionIDNumber"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="LeaderTitles" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="LeaderTitles" startPoint="false" themePath="mvsc" process="Post-Leaders">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add/Edit leadership position</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ManageLeadership" project="">Cancel additional position</invitation></u></font><sp/></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current positions:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Title"/>
</header><contents><field name="Record:LeaderTitles:LeaderTitle" /></contents></column><conditions><form name="LeaderTitles" /></conditions></itemization-table></font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Title of position: </font><blank label="a" length="20" required="false" alternateLabel="LeaderTitle"/></paragraph></fib>
<field name="PositionIDNumber"/>
</items>
</form>
<form name="ManageLeaderNames" startPoint="false" themePath="mvsc" process="Post-ManageLeaderNames">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Assign/edit/remove Individuals in Leadership Roles</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current leadership:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Title"/>
</header><contents><field name="Record:LeaderNames:PositionChoices" /></contents></column><column><header><string value="First"/>
</header><contents><field name="Record:LeaderNames:First" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:LeaderNames:Last" /></contents></column><column><header><string value="Permissions"/>
</header><contents><field name="Record:LeaderNames:Permissions" /></contents></column><conditions><form name="LeaderNames" /></conditions></itemization-table></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font>Note: You may assign more than one person to the same leadership position.  For example, if one position is "Director," you may have more than one person designated as a Director.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Assign</b></font><font face="Arial" size="200" color="000000"> someone to a role</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>View or Modify</b></font><font face="Arial" size="200" color="000000"> someone's profile</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Remove</b></font><font face="Arial" size="200" color="000000"> someone from a role</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Manage Club Leadership</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Setup</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="ManageLeaderNames:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="EditLeader"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="ManageLeaderNames:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q2" alternateLabel="RemoveLeader" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Who do you want to remove from the specified leadership position?</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderNames:First"/>
<string value=" "/>
<field name="Record:LeaderNames:Last"/>
<string value=" ("/>
<field name="Record:LeaderNames:PositionName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:LeaderNames:NameID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="LeaderNames" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q3" alternateLabel="EditLeader" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Whose profile would you like to view or edit?</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderNames:First"/>
<string value=" "/>
<field name="Record:LeaderNames:Last"/>
<string value=" ("/>
<field name="Record:LeaderNames:PositionName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:LeaderNames:NameID"/>
</value-expression><sort-expression><string value=" "/>
</sort-expression><record-selector><form name="LeaderNames" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="SetLeadershipPermissions" startPoint="false" themePath="mvsc" process="Post-SetLeadershipPermissions" preProcess="Pre-SetLeadershipPermissions">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Set Leadership Responsibilities and Permissions</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Most of the rights and privileges of administration are available to all members of the leadership.  However, only the </font><font><b>Setup Administrator</b></font><font> has access to these Setup screen.  And certain other capabilities may be either permitted or denied from this Form.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>In general, if it isn't mentioned below, you may assume that all members of the leadership will have identical permissions.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leaders of committees and other subgroups are dealt with in a separate section from this and are not considered members of the club leadership unless specifically added in this section.</font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Financial Reports</b></font></paragraph></text>
<mc label="Q1" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Which members of the leadership group are to have full access to all financial information?</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderNames:First"/>
<string value=" "/>
<field name="Record:LeaderNames:Last"/>
<string value=" ("/>
<field name="Record:LeaderNames:PositionName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:LeaderNames:NameID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="LeaderNames" /></record-selector></dynamic-mcq></data-provider></mc>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Communications</b></font></paragraph></text>
<mc label="Q2" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Which members of the leadership group may send communications out to the entire membership?</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderNames:First"/>
<string value=" "/>
<field name="Record:LeaderNames:Last"/>
<string value=" ("/>
<field name="Record:LeaderNames:PositionName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:LeaderNames:NameID"/>
</value-expression><sort-expression><string value=" "/>
</sort-expression><record-selector><form name="LeaderNames" /></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q3" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Which members of the leadership group may opt to receive copies of all communications between parties within this application?</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderNames:First"/>
<string value=" "/>
<field name="Record:LeaderNames:Last"/>
<string value=" ("/>
<field name="Record:LeaderNames:PositionName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:LeaderNames:NameID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="LeaderNames" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="LeaderNames" startPoint="false" themePath="mvsc" process="Post-LeaderNames">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Assign Leadership Role</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ManageLeaderNames" project="">Cancel assignment</invitation></u></font><sp/><sp/></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select leader from membership at large</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter leader information directly</font></paragraph></choice></mc>
<mc label="Q2" alternateLabel="PositionChoices" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Which leadership position do you wish to assign this person?</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:LeaderTitles:LeaderTitle"/>
</display-expression><value-expression><field name="Record:LeaderTitles:LeaderTitle"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="LeaderTitles" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<or>
<mcIsBlank field="LeaderNames:PositionChoices" />
<mcIsBlank field="LeaderNames:Q1" />
</or>
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="LeaderNames:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="H2"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Candidate you wish to select as: </font><font><display-mcq-label version="1"><field-name>LeaderNames:PositionChoices</field-name><display>label_only</display></display-mcq-label></font></paragraph></text>
<mc label="Q3" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstNme"/>
<string value=" "/>
<field name="Record:Registration:LastNme"/>
</display-expression><value-expression><field name="Record:Registration:MemberID"/>
</value-expression><sort-expression><field name="Record:Registration:LastNme"/>
</sort-expression><record-selector><form name="Registration" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="LeaderNames:Q3" />
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Assign Leadership Role</font></paragraph></heading>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>For the position of: </font><font><display-mcq-label version="1"><field-name>LeaderNames:PositionChoices</field-name><display>label_only</display></display-mcq-label></font></paragraph></text>
<fib label="Q4" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name: </font><blank label="a" length="17" required="false" alternateLabel="First"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(first) </i></font><blank label="b" length="17" required="false" alternateLabel="Last"/><font face="Arial" size="200" color="000000"> </font><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph></fib>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Contact information:</b></font></paragraph></text>
<fib label="Q5" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Work: </font><blank label="a" length="20" required="false" alternateLabel="PhoneWork"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Home: </font><blank label="b" length="20" required="false" alternateLabel="PhoneHome"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mobile: </font><blank label="c" length="20" required="false" alternateLabel="PhoneCell"/></paragraph></fib>
<fib label="Q6" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="a" length="20" required="false" alternateLabel="Email"/></paragraph></fib>
<fib label="Q7" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Address: </font><blank label="a" length="20" required="false" alternateLabel="Street"/></paragraph></fib>
<fib label="Q8" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">                                       City:   </font><blank label="a" length="19" required="false" alternateLabel="City"/><font face="Arial" size="200" color="000000"> State: </font><blank label="b" length="3" required="false" alternateLabel="State"/><font face="Arial" size="200" color="000000"> Zip: </font><blank label="c" length="4" required="false" alternateLabel="Zip"/></paragraph></fib>
<field name="NameID"/>
<field name="PositionName"/>
<field name="Permissions"/>
<field name="DashboardLink"/>
</items>
</form>
<form name="ManageGroups" startPoint="false" themePath="mvsc" process="Post-ManageGroups" preProcess="Pre-ManageGroups">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Manage </font><font face="Arial" size="360" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="360" color="000000"> List</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Current </b></font><font><b><field name="GroupCollectiveName"/></b></font><font><b> list and leadership:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><field name="GroupCollectiveName"/>
</header><contents><field name="Record:Groups:GroupName" /></contents></column><column><header><field name="TskLdrCollName"/>
</header><contents><field name="Record:Groups:GroupLeaderFirst" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Groups:GroupLeaderLast" /></contents></column><column><header><string value="Phone"/>
</header><contents><field name="Record:Groups:GroupLeaderPhone" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Groups:GroupLeaderEmail" /></contents></column><conditions><form name="Groups" /></conditions></itemization-table></font><sp/></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter directions you would like to have appear on the registration form prior to the </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="200" color="000000"> list for which members will be asked to volunteer:  </font><blank label="a" length="57" height="4" required="false" alternateLabel="VolunteerInstructions"/></paragraph><displayConditions>
<equals field="OnlineReg">
<string value="Yes"/>
</equals>
</displayConditions></fib>
<mc label="Q2" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Create a </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit name of </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Eliminate </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Assign/unassign members to a </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Assign/edit/remove </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font><sp/><font face="Arial" size="200" color="000000"><field name="TskLdrCollName"/></font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Setup</font></paragraph></choice><choice label="g"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="ManageGroups:Q2" value="c"/>
</conditions>
<trueSet>
<skip to="RemoveCommittee"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="ManageGroups:Q2">
<string value="b"/>
</mcDoesNotEqual>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q3" alternateLabel="EditCommittee" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Edit the following </b></font><font face="Arial" size="200" color="000000"><b><field name="GroupCollectiveName"/></b></font><font face="Arial" size="200" color="000000">:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Groups:GroupName"/>
</display-expression><value-expression><field name="Record:Groups:GroupIDNumber"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Groups" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q4" alternateLabel="RemoveCommittee" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Eliminate the following </b></font><font face="Arial" size="200" color="000000"><b><field name="GroupCollectiveName"/></b></font><font face="Arial" size="200" color="000000">:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Groups:GroupName"/>
</display-expression><value-expression><field name="Record:Groups:GroupIDNumber"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Groups" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="Groups" startPoint="false" themePath="mvsc" process="Post-Groups">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add/Edit </font><font face="Arial" size="360" color="000000"><field name="GroupCollectiveName"/></font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ManageGroups" project="">Cancel Add or Edit Group</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current </font><font><field name="GroupCollectiveName"/></font><font> List:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><field name="GroupCollectiveName"/>
</header><contents><field name="Record:Groups:GroupName" /></contents></column><column><header><string value="Leadership First"/>
</header><contents><field name="Record:Groups:GroupLeaderFirst" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Groups:GroupLeaderLast" /></contents></column><column><header><string value="Phone"/>
</header><contents><field name="Record:Groups:GroupLeaderPhone" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Groups:GroupLeaderEmail" /></contents></column><conditions><form name="Groups" /></conditions></itemization-table></font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font><font face="Arial" size="200" color="000000"> name: </font><blank label="a" length="20" required="false" alternateLabel="GroupName"/></paragraph></fib>
<field name="GroupIDNumber"/>
<field name="GroupLeaderFirst"/>
<field name="GroupLeaderLast"/>
<field name="GroupLeaderEmail"/>
<field name="GroupLeaderPhone"/>
