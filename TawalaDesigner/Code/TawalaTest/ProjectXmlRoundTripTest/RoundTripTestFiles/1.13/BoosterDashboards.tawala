<mc label="Q7" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send out Dashboard links to</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">every </font><font face="Arial" size="200" color="000000"><field name="TskLdrCollName"/></font><font face="Arial" size="200" color="000000"> of every </font><font face="Arial" size="200" color="000000"><field name="GroupCollectiveName"/></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">every </font><font face="Arial" size="200" color="000000"><field name="TskLdrCollName"/></font><font face="Arial" size="200" color="000000"> who has not yet received a Dashboard link</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">one or more </font><font face="Arial" size="200" color="000000"><field name="TskLdrCollName"/></font><font face="Arial" size="200" color="000000">s, whether or not they have been sent a Dashboard link before  </font></paragraph></choice></mc>
