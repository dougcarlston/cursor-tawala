<form name="ManageGroupHeads" startPoint="false" themePath="mvsc" process="Post-ManageGroupHeads">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Assign/edit/remove </font><font face="Arial" size="360" color="000000"><field name="TskLdrCollName"/></font><font face="Arial" size="360" color="000000"> of </font><font face="Arial" size="360" color="000000"><field name="GroupCollectiveName"/></font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current leadership:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><field name="GroupCollectiveName"/>
</header><contents><field name="Record:Groups:GroupName" /></contents></column><column><header><string value="First"/>
</header><contents><field name="Record:Groups:GroupLeaderFirst" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Groups:GroupLeaderLast" /></contents></column><column><header><string value="Phone"/>
</header><contents><field name="Record:Groups:GroupLeaderPhone" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Groups:GroupLeaderEmail" /></contents></column><conditions><form name="Groups" /><conditions>
<isNotBlank field="Record:Groups:GroupLeaderLast" />
</conditions></conditions></itemization-table></font><sp/></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: You may assign a person to more than one leadership position.  You may also select your </font><font><field name="TskLdrCollName"/></font><font> from the </font><font><field name="GroupCollectiveName"/></font><font>, from membership at large, or from outside the organization.</font></paragraph></text>
