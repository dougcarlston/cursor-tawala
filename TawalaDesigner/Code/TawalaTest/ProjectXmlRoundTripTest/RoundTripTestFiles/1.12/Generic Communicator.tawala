<form name="Report" startPoint="false" themePath="orangeswirl" process="Post-Report">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Start" project="">Return to Main Menu</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>The last question and the count of responses to each answer was:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><field name="Query"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="a"/>
</equals>
</conditions></conditions></record-count></font><sp/><sp/><font><field name="AnsA"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="b"/>
</equals>
</conditions></conditions></record-count></font><sp/><sp/><font><field name="AnsB"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="c"/>
</equals>
</conditions></conditions></record-count></font><sp/><sp/><font><field name="AnsC"/></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>See list of individuals who answered:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><field name="AnsA"/></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><field name="AnsB"/></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><field name="AnsC"/></font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Report:Q1" value="d"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Report:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Report:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="T4"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Query"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="a"/>
</equals>
</conditions></conditions></record-count></font><sp/><sp/><font><field name="AnsA"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><number-of-columns>2</number-of-columns><column><header><string value="Name"/>
</header><contents><field name="Record:DataBase:FirstName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="a"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Query"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="b"/>
</equals>
</conditions></conditions></record-count></font><sp/><font><field name="AnsB"/></font><sp/></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><number-of-columns>2</number-of-columns><column><header><string value="Name"/>
</header><contents><field name="Record:DataBase:FirstName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="b"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Query"/></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><record-count version="3"><form-name>DataBase</form-name><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="c"/>
</equals>
</conditions></conditions></record-count></font><sp/><font><field name="AnsC"/></font><sp/></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><number-of-columns>2</number-of-columns><column><header><string value="Name"/>
</header><contents><field name="Record:DataBase:FirstName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /><conditions>
<equals field="Record:DataBase:Response">
<string value="c"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
</items>
</form>
<form name="Utilities" startPoint="false" themePath="orangeswirl" process="Post-Utilities">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">List Management</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View the list</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add a record to the list</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit/delete record</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Audit emails for validity</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Main Menu</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Utilities:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="Q2"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Utilities:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>You may sort the list by clicking on any heading.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><number-of-columns>3</number-of-columns><column><header><string value="First"/>
</header><contents><field name="Record:DataBase:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:DataBase:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:DataBase:Email Address" /></contents></column><conditions><form name="DataBase" /></conditions></itemization-table></font></paragraph></text>
<skipInstructions>
<skip to="T1"/>
</skipInstructions>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter part or all of the email of the record you want to edit or delete: </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="20" required="false" alternateLabel="TargetEmail"/></paragraph></fib>
</items>
</form>
<form name="MessageUnsent" startPoint="false" themePath="orangeswirl" process="Post-MessageUnsent">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="950000"><i>Your previous message has not yet been sent.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="950000"><i>Here is what it looks like:</i></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2685"><division indent="0" align="right"><font><b>To:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font>&lt;Receipient&gt;</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>From:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="FromN"/></font><font> (</font><font><field name="FromE"/></font><font>)</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>Date:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font>Today</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>Subject:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="Sub"/></font></division></cell></row><row><cell width="2685"></cell><cell width="272"></cell><cell width="7843"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><font><field name="BodyStart"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="Query"/></font></division><division indent="720" align="left"><font><field name="AnsA"/></font></division><division indent="720" align="left"><font><field name="AnsB"/></font></division><division indent="720" align="left"><font><field name="AnsC"/></font></division></cell></row><row><cell width="10800"></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="BodyClose"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Are you sure that you want to abandon this effort and start over?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes, throw this email message away</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, I want to edit or send this email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Just return me to the Main Menu please</font></paragraph></choice></mc>
</items>
</form>
<form name="MessageAlreadySent" startPoint="false" themePath="orangeswirl" process="Post-MessageAlreadySent">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="950000"><i>Your previous message has already been sent out at least once.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="950000"><i>Here is what it looks like.</i></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2685"><division indent="0" align="right"><font><b>To:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font face="Arial" size="200" color="000000">&lt;Recipient&gt;</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>From:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="FromN"/></font><font> (</font><font><field name="FromE"/></font><font>)</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>Date:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font>Today</font></division></cell></row><row><cell width="2685"><division indent="0" align="right"><font><b>Subject:</b></font></division></cell><cell width="272"></cell><cell width="7843"><division indent="0" align="left"><font><field name="Sub"/></font></division></cell></row><row><cell width="2685"></cell><cell width="272"></cell><cell width="7843"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><font><field name="BodyStart"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="Query"/></font></division><division indent="720" align="left"><font><field name="AnsA"/></font></division><division indent="720" align="left"><font><field name="AnsB"/></font></division><division indent="720" align="left"><font><field name="AnsC"/></font></division></cell></row><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10800"><division indent="0" align="left"><font><field name="BodyClose"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Are you sure that you want to send or edit it again? </font><font face="Arial" size="200" color="000000"><i>(Responses will be added to previous ones in reports)</i></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, that wasn't my intent.  Please return to Main Menu.</font></paragraph></choice></mc>
</items>
</form>
<form name="Thanks" startPoint="false" themePath="orangeswirl" process="Post-Thanks">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Thank you!</font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the information we have for you in our records.  Would you please help us keep it up to date?</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Name: </b></font><font><field name="Recipient"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Email: </b></font><font><field name="Email"/></font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To change or add information just fill in the appropriate field and press Submit </font><font><i>(leave blank to keep as is)</i></font></paragraph></text>
<fib label="Q1" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name:</b></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="20" required="false" alternateLabel="NewFirst"/><sp/><font face="Arial" size="200" color="000000"><i>(first) </i></font><blank label="b" length="20" required="false" alternateLabel="NewLast"/><sp/><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Email: </b></font><blank label="c" length="20" required="false" alternateLabel="NewEmail"/></paragraph></fib>
</items>
</form>
<form name="EditDelete" startPoint="false" themePath="orangeswirl" process="Post-EditDelete">
<items>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark record that you wish to edit or delete:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:DataBase:FirstName"/>
<string value=" "/>
<field name="Record:DataBase:LastName"/>
<string value=" ("/>
<field name="Record:DataBase:Email Address"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:DataBase:Email Address"/>
</value-expression><sort-expression><field name="Record:DataBase:LastName"/>
</sort-expression><record-selector><form name="DataBase" /><conditions>
<contains field="Record:DataBase:Email Address">
<string field="Target"/>
</contains>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q2" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b><i>Edit this record</i></b></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b><i>Delete this record</i></b></font></paragraph></choice></mc>
</items>
</form>
<form name="Audit1" startPoint="false" themePath="orangeswirl" process="Post-Audit1">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Audit Emails</font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility checks the entire contact list for valid email addresses.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds a record with more than one valid email or with none, it will give you a chance to edit it so that it will work properly with the Communicator.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit, delete or pass each record that fails the audit test.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return</font></paragraph></choice></mc>
</items>
</form>
<form name="Audit2" startPoint="false" themePath="orangeswirl" process="Post-Audit2" preProcess="Pre-Audit2">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="320">Audit Emails</font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Possible bad record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Name:</b></font><sp/><sp/><font><field name="Recipient"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Email:   </b></font><font><field name="Email"/></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit this record</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete this record</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark this email as valid</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Break off Audit for now, leaving this record unchanged</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Audit2:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="T4"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Audit2:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Record to edit:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Name:</b></font><sp/><sp/><font><field name="Recipient"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Email:</b></font><sp/><sp/><font><field name="Email"/></font></paragraph></text>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To change or add information, just fill in the appropriate field and press Submit </font><font face="Arial" size="200" color="000000"><i>(leave a field blank to keep as is)</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Name:</b></font><font face="Arial" size="200" color="000000">  </font><blank label="a" length="20" required="false" alternateLabel="ChangeName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Email:</b></font><font face="Arial" size="200" color="000000">  </font><blank label="b" length="20" required="false" alternateLabel="ChangeEmail"/></paragraph></fib>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Record to delete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Name:</b></font><sp/><sp/><font><field name="Recipient"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Email:</b></font><sp/><sp/><font><field name="Email"/></font></paragraph></text>
<mc label="Q3" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Are you sure?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, leave as is</font></paragraph></choice></mc>
</items>
</form>
<form name="OptOut" startPoint="false" themePath="orangeswirl" process="Post-OptOut">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
</forms>
<processes>
<process name="Post-Start">
<set field="PrevMessage" arithmeticAsText="false">
<string value="No"/>
</set>
<set field="PrevMsgSent" arithmeticAsText="false">
<string value="No"/>
</set>
<get recordList="Record List 1">
<forms>
<form name="Composer"/>
</forms>
</get>
<foreach record="Msg" recordList="Record List 1">
<set field="PrevMessage" arithmeticAsText="false">
<string value="Yes"/>
</set>
<if>
<conditions>
<equals field="Msg:Composer:Sent?">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="PrevMsgSent" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<set field="FromN" arithmeticAsText="false">
<string field="Msg:Composer:FromPerson"/>
</set>
<set field="FromE" arithmeticAsText="false">
<string field="Msg:Composer:FromEmail"/>
</set>
<set field="Sub" arithmeticAsText="false">
<string field="Msg:Composer:Subject"/>
</set>
<set field="BodyStart" arithmeticAsText="false">
<string field="Msg:Composer:Body"/>
</set>
<set field="BodyClose" arithmeticAsText="false">
<string field="Msg:Composer:Closing"/>
</set>
<if>
<conditions>
<equals field="Msg:Composer:QuestionAdded?">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<get recordList="Record List 3">
<forms>
<form name="AddQuestion"/>
</forms>
</get>
<foreach record="Q" recordList="Record List 3">
<set field="Query" arithmeticAsText="false">
<string field="Q:AddQuestion:Question"/>
</set>
<set field="AnsA" arithmeticAsText="false">
<string field="Q:AddQuestion:A"/>
</set>
<set field="AnsB" arithmeticAsText="false">
<string field="Q:AddQuestion:B"/>
</set>
<set field="AnsC" arithmeticAsText="false">
<string field="Q:AddQuestion:C"/>
</set>
</foreach>
</trueSet>
<falseSet>
<set field="Query" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="AnsA" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="AnsB" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="AnsC" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
</foreach>
<if>
<conditions>
<mcEquals field="Start:Q1" value="a"/>
</conditions>
<trueSet>
<if>
<conditions>
<equals field="PrevMessage">
<string value="No"/>
</equals>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="No prior communication found."/>
</set>
<show document="Message" reset="false"/>
<show form="Start"/>
</trueSet>
<falseSet>
<if>
<conditions>
<equals field="PrevMsgSent">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show form="MessageAlreadySent"/>
</trueSet>
<falseSet>
<edit form="Composer" submit="modify">
</edit>
</falseSet>
</if>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Start:Q1" value="b"/>
</conditions>
<trueSet>
<if>
<conditions>
<isBlank field="Query" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="There was no question in the last email sent out."/>
</set>
<show document="Message" reset="false"/>
<show form="Start"/>
</trueSet>
</if>
<show form="Report"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Start:Q1" value="c"/>
</conditions>
<trueSet>
<if>
<conditions>
<and>
<equals field="PrevMsgSent">
<string value="No"/>
</equals>
<equals field="PrevMessage">
<string value="Yes"/>
</equals>
</and>
</conditions>
<trueSet>
<show form="MessageUnsent"/>
</trueSet>
</if>
<delete><form name="Composer"/></delete>
<delete><form name="AddQuestion"/></delete>
<get recordList="Record List 4">
<forms>
<form name="DataBase"/>
</forms>
</get>
<foreach record="SuchRecord" recordList="Record List 4">
<set field="SuchRecord:DataBase:Response" arithmeticAsText="false">
<string value=" "/>
</set>
</foreach>
<show form="Composer"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Start:Q1" value="d"/>
</conditions>
<trueSet>
<show form="Utilities"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Start:Q1" value="e"/>
</conditions>
<trueSet>
<show form="Start"/>
</trueSet>
</if>
</process>
<process name="Post-Composer">
<if>
<conditions>
<mcEquals field="Composer:Q6" value="a"/>
</conditions>
<trueSet>
<comment>Send as is</comment>
<set field="Composer:QuestionAdded?" arithmeticAsText="false">
<string value=" "/>
</set>
<show form="SendEmail"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Composer:Q6" value="b"/>
</conditions>
<trueSet>
<comment>Add a question</comment>
<set field="Composer:QuestionAdded?" arithmeticAsText="false">
<string value="Yes"/>
</set>
<show form="AddQuestion"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Composer:Q6" value="d"/>
</conditions>
<trueSet>
<comment>Abandon</comment>
<show form="Start"/>
</trueSet>
</if>
</process>
<process name="Post-AddQuestion">
<get recordList="Record List 11">
<forms>
<form name="Composer"/>
</forms>
</get>
<foreach record="Composition" recordList="Record List 11">
<set field="Composition:Composer:QuestionAdded?" arithmeticAsText="false">
<string value="Yes"/>
</set>
</foreach>
<if>
<conditions>
<mcEquals field="AddQuestion:Q3" value="a"/>
</conditions>
<trueSet>
<show form="SendEmail"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AddQuestion:Q3" value="b"/>
</conditions>
<trueSet>
<edit form="Composer" submit="modify">
</edit>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AddQuestion:Q3" value="d"/>
</conditions>
<trueSet>
<show form="Start"/>
</trueSet>
</if>
</process>
<process name="Post-SendEmail">
<set field="BodyStart" arithmeticAsText="false">
<string field="Composer:Body"/>
</set>
<set field="BodyClose" arithmeticAsText="false">
<string field="Composer:Closing"/>
</set>
<set field="FromN" arithmeticAsText="false">
<string field="Composer:FromPerson"/>
</set>
<set field="FromE" arithmeticAsText="false">
<string field="Composer:FromEmail"/>
</set>
<set field="Sub" arithmeticAsText="false">
<string field="Composer:Subject"/>
</set>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Record List 2">
<forms>
<form name="DataBase"/>
</forms>
</get>
<foreach record="Email" recordList="Record List 2">
<set field="FirstN" arithmeticAsText="false">
<string field="Email:DataBase:FirstName"/>
</set>
<set field="Recipient" arithmeticAsText="false">
<string field="Email:DataBase:Email Address"/>
</set>
<if>
<conditions>
<equals field="Composer:QuestionAdded?">
