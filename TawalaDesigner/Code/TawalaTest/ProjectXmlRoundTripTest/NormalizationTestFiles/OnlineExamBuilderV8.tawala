<document name="End of Exam With Explanation">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240"><field name="Customize_PostInstructions"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240">You correctly answered </font><font size="240"><field name="ScorePercentage"/></font><font size="240">% of questions (</font><font size="240"><field name="Score"/></font><font size="240"> out of </font><font size="240"><field name="QuestionTotal"/></font><font size="240">).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240">Below are the details on how you answered each question:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240"><itemization-table version="2"><show-print-control>false</show-print-control><show-export-control>false</show-export-control><column><header><string value="#"/>
</header><contents><field name="Record:Question:SequenceNumber" /></contents></column><column><header><string value="Question"/>
</header><contents><field name="Record:Question:Question" /></contents></column><column><header><string value="Choices"/>
</header><contents><field name="Record:Question:DisplayChoices" /></contents></column><column><header><string value="Correct Answer"/>
</header><contents><field name="Record:Question:Answer" /></contents></column><column><header><string value="Your Answer"/>
</header><contents><field name="Record:Answer:Answer" /></contents></column><conditions><form name="Question" /><form name="Answer" /><conditions>
<and>
<equals field="Record:Answer:SessionId">
<string field="Exam:id"/>
</equals>
<equals field="Record:Question:QuestionId">
<string field="Record:Answer:QuestionId"/>
</equals>
</and>
</conditions></conditions></itemization-table></font></paragraph>
