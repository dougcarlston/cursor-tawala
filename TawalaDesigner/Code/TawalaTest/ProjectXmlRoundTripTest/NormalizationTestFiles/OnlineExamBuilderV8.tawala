<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240"><field name="Exam:name"/></font><font size="240"> just completed </font><font size="240"><field name="Customize_Title"/></font><font size="240">, answering correctly </font><font size="240"><field name="ScorePercentage"/></font><font size="240">% of questions (</font><font size="240"><field name="Score"/></font><font size="240"> out of </font><font size="240"><field name="QuestionTotal"/></font><font size="240">).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240">To view exam reports or change it's setup go to </font><font size="240" color="000080"><u><invitation form="Administration" project=""><displayText><string value="this link"/>
</displayText></invitation></u></font><font size="240">.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240">Thank you for using Tawala!</font></paragraph>
