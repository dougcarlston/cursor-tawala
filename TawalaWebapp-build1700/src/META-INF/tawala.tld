<?xml version="1.0" encoding="UTF-8"?>
<taglib version="2.0" xmlns="http://java.sun.com/xml/ns/j2ee"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-jsptaglibrary_2_0.xsd">
 <description>Tawala Application JSP Tag Library.</description>
 <display-name>Tawala</display-name>
 <tlib-version>1.1</tlib-version>
 <short-name>Tawala</short-name>
 <uri>http://www.tawala.com/tags</uri>
 <tag>
  <name>linkToRealProject</name>
  <tag-class>com.tawala.web.tags.LinkToRealProject</tag-class>
  <body-content>JSP</body-content>
  <description>Builds a link to a deployed user project.</description>
  <attribute>
   <name>project</name>
   <required>true</required>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
  <attribute>
   <name>form</name>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
  <attribute>
   <name>formName</name>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
 </tag>
 <tag>
  <name>linkToSampleCollectingProject</name>
  <tag-class>com.tawala.web.tags.LinkToSampleCollectingProject</tag-class>
  <body-content>JSP</body-content>
  <description>Builds a link to a sample collecting project.</description>
  <attribute>
   <name>project</name>
   <required>true</required>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
  <attribute>
   <name>form</name>
   <required>true</required>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
 </tag>
 <tag>
  <name>linkToProjectTestDrive</name>
  <tag-class>com.tawala.web.tags.LinkToProjectTestDrive</tag-class>
  <body-content>JSP</body-content>
  <description>Builds a link to a deployed user project.</description>
  <attribute>
   <name>project</name>
   <required>true</required>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
  <attribute>
   <name>form</name>
   <required>true</required>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
 </tag>
 <tag>
  <name>projectManagerPagination</name>
  <tag-class>com.tawala.web.tags.ProjectManagerPaginationTag</tag-class>
  <body-content>JSP</body-content>
  <description>Displays pagination elements on the project manager list.</description>
 </tag>
 <tag>
  <name>loginUrl</name>
  <tag-class>com.tawala.web.tags.LoginLinkTag</tag-class>
  <body-content>JSP</body-content>
  <description>Generates login URL, adding optional "redirect to"
			parameter.</description>
 </tag>
 <tag>
  <name>displayFormSubmissionValue</name>
  <tag-class>com.tawala.web.tags.DisplayFormSubmissionValueTag</tag-class>
  <body-content>JSP</body-content>
  <description>Prints the form submission value, iterating over multiple
			values if needed.</description>
  <attribute>
   <name>submission</name>
   <required>true</required>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
  <attribute>
   <name>fieldReference</name>
   <required>true</required>
   <rtexprvalue>true</rtexprvalue>
  </attribute>
 </tag>
 <function>
  <name>contains</name>
  <function-class>com.tawala.web.tags.Functions</function-class>
  <function-signature>boolean contains(java.util.Set, java.lang.Object)</function-signature>
 </function>
</taglib>
