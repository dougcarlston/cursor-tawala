<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN" "http://www.springframework.org/dtd/spring-beans.dtd">

<beans>
	<bean id="propertyPlaceHolderConfigurer" class="org.springframework.web.context.support.ServletContextPropertyPlaceholderConfigurer">
		<property name="location" value="classpath:lucene-remote-setup.properties" />
		<property name="systemPropertiesModeName" value="SYSTEM_PROPERTIES_MODE_OVERRIDE" />
		<property name="ignoreResourceNotFound" value="true" />
	</bean>
	
	<bean id="projectIndexer" class="com.tawala.search.ProjectIndexerHttpProxy">
		<constructor-arg value="${lucene.url.base.projects}" />
	</bean>
	<bean id="userIndexer" class="com.tawala.search.UserIndexerHttpProxy">
		<constructor-arg value="${lucene.url.base.users}" />
	</bean>
</beans>
