<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.4" xmlns="http://java.sun.com/xml/ns/j2ee"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
 <context-param>
  <param-name>log4j.config.file</param-name>
  <param-value>tawala-log4j.properties</param-value>
 </context-param>
 <!-- Additional parameters for unit tests go here -->
 <listener>
  <listener-class>com.tawala.web.LoggingInitializer</listener-class>
 </listener>
 <listener>
  <listener-class>com.tawala.web.ProjectRuntimeCacheInitializer</listener-class>
 </listener>
 <listener>
  <listener-class>com.tawala.web.LuceneInitializer</listener-class>
 </listener>
 <listener>
  <listener-class>com.tawala.web.ApplicationVariablesInitializer</listener-class>
 </listener>
 <servlet>
<servlet-name>default</servlet-name>
<servlet-class>com.tawala.web.TawalaDefaultServlet</servlet-class>
<load-on-startup>1</load-on-startup>
</servlet>
 <servlet>
<servlet-name>jsp</servlet-name>
<servlet-class>org.apache.jasper.servlet.JspServlet</servlet-class>
<init-param>
<param-name>fork</param-name>
<param-value>false</param-value>
</init-param>
<init-param>
<param-name>xpoweredBy</param-name>
<param-value>false</param-value>
</init-param>
<init-param>
<param-name>compilerTargetVM</param-name>
<param-value>1.5</param-value>
</init-param>
<init-param>
<param-name>compilerSourceVM</param-name>
<param-value>1.5</param-value>
</init-param>
<load-on-startup>3</load-on-startup>
</servlet>
 <servlet>
  <servlet-name>spring</servlet-name>
  <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
  <load-on-startup>1</load-on-startup>
 </servlet>
 <servlet>
  <description>Servlet that initializes the world :-)</description>
  <servlet-name>WorldInitializer</servlet-name>
  <servlet-class>com.tawala.web.WorldInitializer</servlet-class>
  <load-on-startup>2</load-on-startup>
 </servlet>
 <servlet>
  <description>Servlet that sets up some predefined objects. It must be initialized after the Spring dispatcher servlet</description>
  <servlet-name>PredeterminedObjectInitializer</servlet-name>
  <servlet-class>com.tawala.web.PredeterminedObjectInitializer</servlet-class>
  <load-on-startup>3</load-on-startup>
 </servlet>
 <servlet>
  <description>Servlet converts the data.</description>
  <servlet-name>DataConverter</servlet-name>
  <servlet-class>com.tawala.web.DataConverter</servlet-class>
  <load-on-startup>4</load-on-startup>
 </servlet>
 <servlet-mapping>
  <servlet-name>WorldInitializer</servlet-name>
  <url-pattern>/Non-ExistentURLDueToHTTPUnitBug/1</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>DataConverter</servlet-name>
  <url-pattern>/Non-ExistentURLDueToHTTPUnitBug/2</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>PredeterminedObjectInitializer</servlet-name>
  <url-pattern>/Non-ExistentURLDueToHTTPUnitBug/2</url-pattern>
 </servlet-mapping>
 <!-- These mapping are needed to serve references to project images through the project controllers and not default servlet. -->
 <servlet-mapping>
  <servlet-name>spring</servlet-name>
  <url-pattern>/p/*</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>spring</servlet-name>
  <url-pattern>/f/*</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>spring</servlet-name>
  <url-pattern>/r/*</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>spring</servlet-name>
  <url-pattern>/t/*</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>spring</servlet-name>
  <url-pattern>/i/*</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.css</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.jpg</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.gif</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.png</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.ico</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.js</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.txt</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.html</url-pattern>
 </servlet-mapping>
 <!-- Mappings for Flash demos -->
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.htm</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.swf</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>default</servlet-name>
  <url-pattern>*.flv</url-pattern>
 </servlet-mapping>
 <servlet-mapping>
  <servlet-name>spring</servlet-name>
  <url-pattern>/</url-pattern>
 </servlet-mapping>
 <mime-mapping>
<extension>jpg</extension>
<mime-type>image/jpeg</mime-type>
</mime-mapping>
<mime-mapping>
<extension>css</extension>
<mime-type>text/css</mime-type>
</mime-mapping>
<mime-mapping>
<extension>js</extension>
<mime-type>text/javascript</mime-type>
</mime-mapping>

 <error-page>
  <error-code>404</error-code>
  <location>/notfound.jsp</location>
 </error-page>
  <resource-env-ref>
  <description>Tawala Database DataSource</description>
  <resource-env-ref-name>jdbc/tawala</resource-env-ref-name>
  <resource-env-ref-type>javax.sql.DataSource</resource-env-ref-type>
 </resource-env-ref>
</web-app>
