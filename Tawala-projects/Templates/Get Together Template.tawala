<?xml version="1.0" encoding="utf-8" ?>
<project name="Get Together Template" themePath="default" format="1.8" designerBuild="176">
<styles mcItemStyle="vertical" /><forms>
<form name="Survey" startPoint="true" themePath="default" process="Process 1">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Get Together Invitation</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Get Together helps pick the best time or date for an event or a meeting.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Just replace the multiple choice questions below with two of your own describing the event you are inviting people to and the dates you want people to consider.  You can add up to ten choices, although the example below only has five.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Once you are done modifying this form, delete these instructions and replace them with instructions for your invitees.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Then click on the Deploy button ( </font><font face="Arial" size="200" color="000000"><image id="image1" width="22" height="23"><metafileHeader fileType="1" headerSize="9" version="768" fileSize="835" numOfObjects="0" maxRecordSize="813" numOfParams="0" />
</image></font><font>)  up above to create a Web page for your invitation.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Once you have deployed your project to the Web, you can get the Web links to the Get Together invitation  and the Report you'll use to review the results from your My Tawala page on the Tawala Website.  Send the Survey link to your pollees and then use Report to see how they responded.</font></paragraph></text>
<mc label="Q1" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">We'd like to have dinner with you!  Which of the following dates works for you?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 3</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 4</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 6</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 9</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 10</font></paragraph></choice></mc>
<mc label="Q2" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Which date is your top preference?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 3</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 4</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 6</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 9</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">June 10</font></paragraph></choice></mc>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name please: </font><blank label="a" length="29" required="false" alternateLabel="Name"/></paragraph></fib>
</items>
</form>
<form name="Report" startPoint="false" themePath="default">
<items>
<text label="T1"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here are the results so far:</font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><question-correlation-table version="1"><question-field-name>Record:Survey:Q1</question-field-name><display-field-name>Record:Survey:Name</display-field-name><preferred-choice-field-name>Record:Survey:Q2</preferred-choice-field-name><conditions><form name="Survey" /></conditions></question-correlation-table></font></paragraph></text>
</items>
</form>
</forms>
<processes>
<process name="Process 1">
<show form="Report"/>
</process>
</processes>
