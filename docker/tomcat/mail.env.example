# Copy to repo-root `.env.email.local` (gitignored) and fill in the API key:
#   cp docker/tomcat/mail.env.example .env.email.local
#
# Resend SMTP: username is always the literal "resend"; password is your API key.
# Verify doug@carlston.net (or its domain) in the Resend dashboard before live sends.
# See docs/EMAIL_DELIVERY_OPS.md

TAWALA_MAIL_ENABLED=true
TAWALA_MAIL_HOST=smtp.resend.com
TAWALA_MAIL_PORT=587
TAWALA_MAIL_USERNAME=resend
TAWALA_MAIL_PASSWORD=
TAWALA_MAIL_SMTP_AUTH=true
TAWALA_MAIL_SMTP_STARTTLS=true
TAWALA_MAIL_FROM_ADDRESS=doug@carlston.net
TAWALA_MAIL_FROM_NAME=Doug Carlston
TAWALA_MAIL_WORKER_ENABLED=true
