        {
          "type": "text",
          "label": "T1",
          "content": "Individual Results:<div data-doc-blank=\"1\" style=\"color: rgb(0, 0, 0); min-height: 13.7pt;\">​<span class=\"function-token function-table-token\" contenteditable=\"false\" data-function-id=\"itemization-table\" data-function-instance=\"1\" data-function-config=\"{&quot;show-print-control&quot;:&quot;false&quot;,&quot;show-export-control&quot;:&quot;false&quot;,&quot;numberOfColumns&quot;:5,&quot;column&quot;:[{&quot;header&quot;:&quot;Name&quot;,&quot;contents&quot;:&quot;&lt;&lt;Survey:Name&gt;&gt;&quot;},{&quot;header&quot;:&quot;Handedness&quot;,&quot;contents&quot;:&quot;&lt;&lt;Survey:Hand&gt;&gt;&quot;},{&quot;header&quot;:&quot;Hair Color&quot;,&quot;contents&quot;:&quot;&lt;&lt;Survey:Hair&gt;&gt;&quot;},{&quot;header&quot;:&quot;Age&quot;,&quot;contents&quot;:&quot;&lt;&lt;Survey:Age&gt;&gt;&quot;},{&quot;header&quot;:&quot;Marital Status&quot;,&quot;contents&quot;:&quot;&lt;&lt;Survey:Status&gt;&gt;&quot;}],&quot;conditionsRows&quot;:[{&quot;field&quot;:&quot;&quot;,&quot;op&quot;:&quot;equals&quot;,&quot;value&quot;:&quot;&quot;}],&quot;conditionsCombinator&quot;:&quot;and&quot;}\" title=\"MULTIPLE QUESTION LIST\" draggable=\"true\" style=\"color: rgb(0, 0, 0); vertical-align: baseline;\">&lt;&lt;MULTIPLE QUESTION LIST(false, false, ...)&gt;&gt;</span><br></div>"
        },
        {
          "type": "text",
          "label": "T2",
          "content": "Group Results:<div data-doc-blank=\"1\" style=\"font-size: 10pt; color: rgb(0, 0, 0); min-height: 14pt;\">​<span class=\"function-token function-table-token\" contenteditable=\"false\" data-function-id=\"response-totals-table\" data-function-instance=\"2\" data-function-config=\"{&quot;layout-type&quot;:&quot;vertical&quot;,&quot;field&quot;:&quot;Survey:Hand&quot;,&quot;conditionsRows&quot;:[{&quot;field&quot;:&quot;&quot;,&quot;op&quot;:&quot;equals&quot;,&quot;value&quot;:&quot;&quot;}],&quot;conditionsCombinator&quot;:&quot;and&quot;}\" title=\"RESPONSE TOTALS\" draggable=\"true\" style=\"color: rgb(0, 0, 0); vertical-align: baseline;\">&lt;&lt;RESPONSE TOTALS(vertical, Survey:Hand)&gt;&gt;</span><br></div><div data-doc-blank=\"1\" style=\"font-size: 10pt; color: rgb(0, 0, 0); min-height: 14pt;\">​<span class=\"function-token function-table-token\" contenteditable=\"false\" data-function-id=\"response-totals-table\" data-function-instance=\"3\" data-function-config=\"{&quot;layout-type&quot;:&quot;vertical&quot;,&quot;field&quot;:&quot;Survey:Hair&quot;,&quot;conditionsRows&quot;:[{&quot;field&quot;:&quot;&quot;,&quot;op&quot;:&quot;equals&quot;,&quot;value&quot;:&quot;&quot;}],&quot;conditionsCombinator&quot;:&quot;and&quot;}\" title=\"RESPONSE TOTALS\" draggable=\"true\" style=\"color: rgb(0, 0, 0); vertical-align: baseline;\">&lt;&lt;RESPONSE TOTALS(vertical, Survey:Hair)&gt;&gt;</span><br></div><div data-doc-blank=\"1\" style=\"font-size: 10pt; color: rgb(0, 0, 0); min-height: 14pt;\"><b>Age</b>:</div><div data-doc-blank=\"1\" style=\"font-size: 10pt; color: rgb(0, 0, 0); min-height: 14pt;\">​<span class=\"function-token function-table-token\" contenteditable=\"false\" data-function-id=\"simple-list\" data-function-instance=\"4\" data-function-config=\"{&quot;simple-list-field&quot;:&quot;Survey:Age&quot;,&quot;conditionsRows&quot;:[{&quot;field&quot;:&quot;&quot;,&quot;op&quot;:&quot;equals&quot;,&quot;value&quot;:&quot;&quot;}],&quot;conditionsCombinator&quot;:&quot;and&quot;}\" title=\"SINGLE QUESTION LIST\" draggable=\"true\" style=\"color: rgb(0, 0, 0); vertical-align: baseline; font-size: 10pt;\">&lt;&lt;SINGLE QUESTION LIST(Survey:Age)&gt;&gt;</span><br></div><div data-doc-blank=\"1\" style=\"font-size: 10pt; color: rgb(0, 0, 0); min-height: 14pt;\">​<span class=\"function-token function-table-token\" contenteditable=\"false\" data-function-id=\"response-totals-table\" data-function-instance=\"5\" data-function-config=\"{&quot;layout-type&quot;:&quot;vertical&quot;,&quot;field&quot;:&quot;Survey:Status&quot;,&quot;conditionsRows&quot;:[{&quot;field&quot;:&quot;&quot;,&quot;op&quot;:&quot;equals&quot;,&quot;value&quot;:&quot;&quot;}],&quot;conditionsCombinator&quot;:&quot;and&quot;}\" title=\"RESPONSE TOTALS\" draggable=\"true\" style=\"color: rgb(0, 0, 0); vertical-align: baseline;\">&lt;&lt;RESPONSE TOTALS(vertical, Survey:Status)&gt;&gt;</span><br></div>"
        }
