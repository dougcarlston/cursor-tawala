<document name="CoachSetupLetter">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DearSir"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="CoachRosterNotice:Body"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will be the coach for </font><font><field name="Team"/></font><font> in this season's </font><font><field name="League"/></font><font> League.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is a link to your personal </font><font color="000080"><u><invitation form="CoachDashboard" project="" private="true"><authenticationTokenValue><string field="CoachID"/>
</authenticationTokenValue>Coach Dashboard</invitation></u></font><font>. </font><font><field name="DashboardLinkForCoachVerbiage"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font><field name="DashboardLinkSaveVerbiage"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="CoachRosterNotice:Close"/></font></paragraph>
</xmlData>
</document>
<document name="PlayerDashboardReminder">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="PlayerFirst"/></font><font> or Parents of </font><font><field name="PlayerFirst"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the link to your </font><font color="0066CC"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="PlayerID"/>
</authenticationTokenValue>Player Dashboard</invitation></u></font><font> for </font><font><field name="League"/></font><font>. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>From your Player Dashboard you can update your profile information and do other useful things.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You need to keep this link so you can get back to your Dashboard anytime. Either save this email or make sure to save the link in your browser's "Favorites" or "Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Thank you.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Best regards,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="CoachDashReminder">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="DearSir"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the link to your </font><font color="0066CC"><u><invitation form="CoachDashboard" project="" private="true"><authenticationTokenValue><string field="CoachID"/>
</authenticationTokenValue>Coach Dashboard</invitation></u></font><font> for the </font><font><field name="Team"/></font><font> team in </font><font><field name="League"/></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>From your Coach Dashboard you can keep track of information about your team and communicate with your players.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You need to keep this link so you can get back to your Dashboard anytime. Either save this email or make sure to save the link in your browser's "Favorites" or "Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Best regards,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="BackToCoachDashLink">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="AssistantCoachDashReminder">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="DearSir"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the link to your </font><font color="0066CC"><u><invitation form="AssistantCoachDashboard" project="" private="true"><authenticationTokenValue><string field="DashboardLinkID"/>
</authenticationTokenValue>Assistant Coach Dashboard</invitation></u></font><sp/><font>for the </font><font><field name="Team"/></font><font> team in </font><font><field name="League"/></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>From your Assistant Coach Dashboard you can keep track of information about our team and communicate with me and our players.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You need to keep this link so you can get back to your Dashboard anytime. Either save this email or make sure to save the link in your browser's "Favorites" or "Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Best regards,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Coach"/></font></paragraph>
</xmlData>
</document>
<document name="PostRegistrationLetterWithPaymentInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="Registration:FirstName"/></font><font> or Parents of </font><font><field name="Registration:FirstName"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You have successfully registered for </font><font><field name="League"/></font><font>.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you haven't paid, please go to your Player Dashboard using the link below and click "Pay Now" for payment instructions.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the link to your </font><font color="0066CC"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Player Dashboard</invitation></u></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>From your Player Dashboard you can update your profile information and do other useful things.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You need to keep this link so you can get back to your Dashboard anytime. Either save this email or make sure to save the link in your browser's "Favorites" or "Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Thank you.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Best regards,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="PostRegistrationLetterWithoutPaymentInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="Registration:FirstName"/></font><font> or Parents of </font><font><field name="Registration:FirstName"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You have successfully registered for </font><font><field name="League"/></font><font>.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the link to your </font><font color="0066CC"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Player Dashboard</invitation></u></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>From your Player Dashboard you can update your profile information and do other useful things.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You need to keep this link so you can get back to your Dashboard anytime. Either save this email or make sure to save the link in your browser's "Favorites" or "Bookmarks."</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Thank you.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Best regards,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="InvitationToCompleteRegistration">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>Dear </font><font><field name="AddPlayerToGroupRegistration:FirstName"/></font><font> or Parents of </font><font><field name="AddPlayerToGroupRegistration:FirstName"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font><field name="AddPlayerToGroupRegistration:FirstName"/></font><font> is listed as a member of the </font><font><field name="Team"/></font><font> team in </font><font><field name="League"/></font><font>, coached by </font><font><field name="Coach"/></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>The registration fee has has been pre-paid. However, you are still required to register with </font><font><field name="League"/></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font color="0066CC"><u><invitation form="EditMyRegistrationRecord" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Click on this link</invitation></u></font><font> to complete the Registration Form.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Thank you.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions><font>Best regards,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="1440"/><tabStop position="2160"/><tabStop position="2880"/><tabStop position="3600"/><tabStop position="4320"/><tabStop position="5040"/><tabStop position="5760"/><tabStop position="6480"/><tabStop position="7200"/><tabStop position="7920"/><tabStop position="8640"/><tabStop position="9360"/><tabStop position="10080"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="Letter w RegLink">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DearSir"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="MessageBody"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To register for the </font><font><field name="SeasonYr"/></font><sp/><font><field name="League"/></font><font>, just </font><font color="000080"><u><invitation form="Registration" project="">click here.</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="MessageClose"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><link>
<new-window/>
<description>
<string value=""/>
</description>
<url>
<field name="AttachedFile1"/>
</url>
<displayConditions>
<and>
<isNotBlank field="AttachedFile1" />
<doesNotEqual field="AttachedFile1">
<string value="omit"/>
</doesNotEqual>
</and>
</displayConditions></link>
</u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><link>
<new-window/>
<description>
<string value=""/>
</description>
<url>
<field name="AttachedFile2"/>
</url>
<displayConditions>
<and>
<isNotBlank field="AttachedFile2" />
<doesNotEqual field="AttachedFile2">
<string value="omit"/>
</doesNotEqual>
</and>
</displayConditions></link>
</u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><link>
<new-window/>
<description>
<string value=""/>
</description>
<url>
<field name="AttachedFile3"/>
</url>
<displayConditions>
<and>
<isNotBlank field="AttachedFile3" />
<doesNotEqual field="AttachedFile3">
<string value="omit"/>
</doesNotEqual>
</and>
</displayConditions></link>
</u></font></paragraph>
</xmlData>
</document>
<document name="RegFormLink">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear </font><font><field name="AdminPlayerRegistration:FirstName"/></font><font>,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Below is a link to the Registration Form that you can use to register a player for </font><font><field name="League"/></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="Registration" project="">Link to Registration Form</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Best regards,</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="AdminName"/></font></paragraph>
</xmlData>
</document>
<document name="OptOut">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="180" color="000000">------------------------------------</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="180">If you would like to be removed from this list, please</font><sp/><font size="180" color="000080"><u><invitation form="OptOut" project="" private="true"><authenticationTokenValue><string field="RecruitID"/>
</authenticationTokenValue>click here</invitation></u></font><font size="180" color="000080">.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="180">If you would like to review or correct the information in your record, please </font><font size="180" color="000080"><u><invitation form="RecruitSelfEdit" project="" private="true"><authenticationTokenValue><string field="RecruitID"/>
</authenticationTokenValue>click here</invitation></u></font><font size="180" color="000080"><u>.</u></font></paragraph>
</xmlData>
</document>
<document name="OptOutThanks">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="B00000"><b><i>Thank you.  Your record has been removed from our mailing list. </i></b></font></paragraph>
</xmlData>
</document>
<document name="AdminRegNotification">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>A registration form has been received for </font><font><field name="Registration:FirstName"/></font><sp/><font><field name="Registration:LastName"/></font><font>. Here is the registration info:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="735"><row><cell width="2455"><division indent="0" align="right"><font><b>Player's Name:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:FirstName"/></font><sp/><font><field name="Registration:LastName"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Date of Birth:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:RegAgeMo"/></font><font>/</font><font><field name="Registration:RegAgeDay"/></font><font>/</font><font><field name="Registration:RegAgeYr"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Sex:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Sex"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Parent's Name:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:ParentFirstName"/></font><sp/><font><field name="Registration:ParentLastName"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Address"/></font></division></cell></row><row><cell width="2455"></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:City"/></font><font>, </font><font><field name="Registration:State"/></font><sp/><font><field name="Registration:Zip"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b> Parent's Email:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:ParentEmail"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Additional Email:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:ParentEmail2"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b><field name="Phone1Lab"/></b></font><font><b>:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Phone1"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b><field name="Phone2Lab"/></b></font><font><b>:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Phone2"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b><field name="Phone3Lab"/></b></font><font><b>:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:Phone3"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>School:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><field name="Registration:School"/></font></division></cell></row><row><cell width="2455"><division indent="0" align="right"><font><b>Grade:</b></font></division></cell><cell width="200"></cell><cell width="7410"><division indent="0" align="left"><font><display-mcq-label version="1"><field-name>Registration:Grade</field-name><display>label_only</display></display-mcq-label></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">In case of loss, here is the link to </font><font color="000000"><field name="Registration:FirstName"/></font><font color="000000">'s private </font><font color="000080"><u><invitation form="PlayerDash" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Player Dashboard</invitation></u></font><font color="000000">.</font></paragraph>
</xmlData>
</document>
<document name="OnlinePaymentInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Please pay $</font><font><field name="RegistrationFee"/></font><font> for </font><font><field name="SeasonYr"/></font><sp/><font><field name="League"/></font><font color="000000">.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">You can press the </font><font color="000000"><i>Pay </i></font><font>Now button below to pay using a major credit card or your PayPal account. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can also pay at a later time online from your Player Dashboard (a link will be sent to you by email).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="795"><row><cell width="8430"><division indent="0" align="left"><font color="FF0000">* Note: If you wish to use your credit card, you do </font><font color="FF0000"><b>not</b></font><font color="FF0000"> need to create a PayPal account or log in to PayPal; when you get to the PayPal page, just click on the </font><font color="FF0000"><u>Continue</u></font><font color="FF0000"> link above the credit card icons on the left.</font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><paypal-single-item-button version="1"><button-type>pay-logo</button-type><item><field name="OnlinePayment:PaymentDescription"/>
</item><amount><field name="OnlinePayment:AmountRequested"/>
</amount><successful-payment-return-form-name>PlayerDash</successful-payment-return-form-name><cancelled-payment-return-form-name>IndividualPaymentCanceled</cancelled-payment-return-form-name><status-field>Record:OnlinePayment:Status</status-field><amount-field>Record:OnlinePayment:AmountPaid</amount-field><style-option>paypal</style-option></paypal-single-item-button></font></paragraph>
</xmlData>
</document>
<document name="OnlinePaymentCancelledConfirmation">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It looks like you were unable to pay online at this time.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can try again later from your Player Dashboard (a link was emailed to you).</font></paragraph>
</xmlData>
</document>
<document name="PaymentAndWaiverStillNeeded">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="360" color="000000">Step 1 of your registration has been completed.</font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to complete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 2:</b></font><font>  Submit your payment of $</font><font><field name="RegistrationFee"/></font><font> and</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 3:</b></font><font>  Go to your Player Dashboard (a link will be emailed to you), and select "View/Edit Registration. Then on your registration form "sign" your waiver by clicking on the checkbox under the waiver text. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can also change any of your registration information or pay online at a later time from your Player Dashboard.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="000080"><b><u><invitation form="OnlinePayment" project="" private="true"><authenticationTokenValue><string field="Registration:RegID"/>
</authenticationTokenValue>Proceed to Step 2</invitation></u></b></font><sp/><sp/></paragraph>
</xmlData>
</document>
<document name="PaymentByCheckInstructions">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To pay by check please mail a check for $</font><font><field name="RegistrationFee"/></font><font> to:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><field name="League"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><field name="AdminAdrss"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><font><field name="AdminsZIP"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Make the check payable to </font><font><b><field name="League"/></b></font><font>.</font></paragraph>
</xmlData>
</document>
<document name="NavigationToPaymentByCheck">
<xmlData>
<paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font><u><invitation form="NavigationToPaymentByCheck" project="">Continue to payment instructions</invitation></u></font></paragraph>
</xmlData>
</document>
