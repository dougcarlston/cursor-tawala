<form name="PlayerCommunicator" startPoint="false" themePath="mvsc" process="Post-PlayerCommunicator" preProcess="Pre-PlayerCommunicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="PlayerDash" project="">Back to Player Dashboard</invitation></u></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To whom do you wish to send this message?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All players and coaches on my team</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Some of my teammates</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">My coach and/or assistant coaches</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The Administrator</font></paragraph></choice></mc>
<mc label="Q2" alternateLabel="CopySelf" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Click here to send a copy of the message to yourself</font></paragraph></choice></mc>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="PCSubject"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<and>
<doesNotEqual field="TeamViewFlag">
<string value="On"/>
</doesNotEqual>
<mcDoesNotEqual field="PlayerCommunicator:Q1" value="d"/>
</and>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="PlayerCommunicator:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="T3"/>
</trueSet>
<falseSet>
<if>
<conditions>
<mcDoesNotEqual field="PlayerCommunicator:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</falseSet>
</if>
</skipInstructions>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="PlayerDash" project="">Back to Player Dashboard</invitation></u></font></paragraph></text>
<mc label="Q6" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the player(s) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<and>
<equals field="Record:Registration:TeamId">
<string field="PlayerTeamId"/>
</equals>
<doesNotEqual field="Record:Registration:RegID">
<string field="PlayerID"/>
</doesNotEqual>
</and>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="PlayerDash" project="">Back to Player Dashboard</invitation></u></font></paragraph></text>
<mc label="Q7" alternateLabel="SendToCoach" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send message to coach </font><font face="Arial" size="200" color="000000"><field name="Coach"/></font></paragraph></choice></mc>
<mc label="Q8" alternateLabel="AssistantCoaches" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select any assistant coaches you want to receive the message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:AssistantCoachInfo:FirstName"/>
<string value=" "/>
<field name="Record:AssistantCoachInfo:LastName"/>
</display-expression><value-expression><field name="Record:AssistantCoachInfo:AsstId"/>
</value-expression><sort-expression><field name="Record:AssistantCoachInfo:FirstName"/>
<string value="#"/>
<field name="Record:AssistantCoachInfo:LastName"/>
</sort-expression><record-selector><form name="AssistantCoachInfo" /><conditions>
<equals field="Record:AssistantCoachInfo:TeamId">
<string field="Team"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<field name="PlayerIdentification"/>
</items>
</form>
<form name="PlayerCommunicatorSend" startPoint="false" themePath="mvsc" process="Post-PlayerCommunicatorSend">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="PlayerDash" project="">Back to Player Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="630"><row><cell width="10170"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><b>From: </b></font><font><field name="PlayerFirst"/></font><sp/><font><field name="PlayerLast"/></font><font> (</font><font><field name="PlayerEmail"/></font><font>)</font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><i><field name="CCSelf"/></i></font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="PlayerCommunicator:PCSubject"/></font><sp/></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="630"><row><cell width="10170"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><field name="PlayerCommunicator:Body"/></font></division></cell></row><row><cell width="10170"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10170"><division indent="0" align="left"><font><field name="PlayerCommunicator:Close"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send the email out</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Player's Dashboard</font></paragraph></choice></mc>
</items>
</form>
<form name="TeamAndCoachMenu" startPoint="false" themePath="mvsc" process="Post-TeamAndCoachMenu">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="EditCoach" startPoint="false" themePath="mvsc" process="Post-EditCoach">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="CoachId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach to edit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
<string value="#"/>
<field name="Record:Coach:FirstName"/>
</sort-expression><record-selector><form name="Coach" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="DeleteCoach" startPoint="false" themePath="mvsc" process="Post-DeleteCoach">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="CoachId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach to delete:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
<string value="#"/>
<field name="Record:Coach:FirstName"/>
</sort-expression><record-selector><form name="Coach" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="CoachToTeamAssignment" startPoint="false" themePath="mvsc" process="Post-CoachToTeamAssignment">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Assign Coach to Team</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams and Coaches</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>To assign a coach who is not already assigned to a team</b></font><font> select the team and the coach from the lists below and click the Submit button.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>To assign a coach already assigned a team to an additional team</b></font><font> select the team from the list below, check the box at the bottom of this page and click the Submit button to see all the coaches</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>To reassign a coach from one team to another team</b></font><sp/><font color="0066CC"><u><invitation form="UnassignCoachFromTeam" project="">click here to un-assign</invitation></u></font><font> that coach from the current team, then return to this page to assign the coach to the new team</font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="AE0000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<mc label="Q1" alternateLabel="TeamId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Teams without coaches:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
<string value=" "/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<isBlank field="Record:Team:CoachId" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q2" alternateLabel="CoachId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Unassigned coaches:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
<string value="#"/>
<field name="Record:Coach:FirstName"/>
</sort-expression><record-selector><form name="Coach" /><conditions>
<isBlank field="Record:Coach:Team" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q3" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check here to see all coaches</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcContains field="CoachToTeamAssignment:Q3" value="a"/>
</conditions>
<trueSet>
<if>
<conditions>
<mcIsBlank field="CoachToTeamAssignment:TeamId" />
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
</trueSet>
<falseSet>
<if>
<conditions>
<or>
<mcIsBlank field="CoachToTeamAssignment:TeamId" />
<mcIsBlank field="CoachToTeamAssignment:CoachId" />
</or>
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Assign Coach to Team</font></paragraph></heading>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="CoachToTeamAssignment" project="">Back to Unassigned Coaches</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams and Coaches</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell></row></table></text>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Select a coach to assign to team </font><font><b><field name="CoachToTeamAssignment:TeamId"/></b></font><font>, then click the Submit button.</font></paragraph></text>
<mc label="Q4" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:FullName"/>
<string value=" ("/>
<field name="Record:Coach:Team"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
</sort-expression><record-selector><form name="Coach" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="UnassignCoachFromTeam" startPoint="false" themePath="mvsc" process="Post-UnassignCoachFromTeam">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="TeamId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the team to un-assign the coach from:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
<string value=" (Coach: "/>
<field name="Record:Team:CoachFullName"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<and>
<isNotBlank field="Record:Team:CoachId" />
<doesNotEqual field="Record:Team:CoachId">
<string value=" "/>
</doesNotEqual>
</and>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="CoachRosterNotice-Setup" startPoint="false" themePath="mvsc" preProcess="Pre-CoachRosterNotice-Setup">
</form>
<form name="CoachRosterNotice" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-CoachRosterNotice" preProcess="Pre-CoachRosterNotice">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Coach's Team and Roster Notification</font></paragraph></heading>
<text label="T1" style="normal"><table indent="0"><row><cell width="3645"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: Use the Communicator best designed for your task:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>    This form is for sending an email to one or more coaches with their team assignments and Dashboard links.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><sp/><font color="0066CC"><b><u><invitation form="CommunicatorSetup" project="">Communicator</invitation></u></b></font><sp/><font><b>is for communicating with or coaches without sending out the "Coach Notification" below.</b></font></paragraph></text>
<text label="T3" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="C00000"><b><i><field name="Message"/></i></b></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Name): </i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromAdminName"/></paragraph></fib>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email): </i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject:  </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q4" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All coaches</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Only selected coaches (you will select them on the next page)</font></paragraph></choice></mc>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Dear &lt;Coach's First Name&gt;,</font></paragraph></text>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the first part of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will be the coach for &lt;TeamName&gt; in this season's </font><font><field name="League"/></font><font> League.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is a link to your personal </font><font color="0000FF"><u>Coach Dashboard</u></font><font>. </font><font><field name="DashboardLinkForCoachVerbiage"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DashboardLinkSaveVerbiage"/></font></paragraph></text>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the closing of your message, including your signoff </font><font face="Arial" size="200" color="000000"><i>(e.g. Yours,  Kerry)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<or>
<doesNotContain field="CoachRosterNotice:FromEmail">
<string value="@"/>
</doesNotContain>
<or>
<doesNotContain field="CoachRosterNotice:FromEmail">
<string value="."/>
</doesNotContain>
<contains field="CoachRosterNotice:FromEmail">
<string value=" "/>
</contains>
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Error: You must enter a valid email address in the &quot;From (Email)&quot; field."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q4" value="a"/>
</conditions>
<trueSet>
<skip to="T7"/>
</trueSet>
</if>
</skipInstructions>
<text label="T6" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q7" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach or coaches you wish to send this message to:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:FullName"/>
<string value=" ("/>
<field name="Record:Coach:Team"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
</sort-expression><record-selector><form name="Coach" /></record-selector></dynamic-mcq></data-provider></mc>
<break/>
<text label="T7" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T8" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="540"><row><cell width="10260"><division indent="0" align="left"><font><b>To: </b></font><font>&lt;Coach Name&gt;</font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><b>From: </b></font><font><field name="CoachRosterNotice:FromAdminName"/></font><font> (</font><font><field name="CoachRosterNotice:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><b>Subject:</b></font><sp/><font><field name="CoachRosterNotice:Subject"/></font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font>Dear &lt;Coach's First Name&gt;,</font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/><sp/><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><field name="CoachRosterNotice:Body"/></font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/><sp/><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font>You will be the coach for &lt;TeamName&gt; in this season's </font><font><field name="League"/></font><font> League.</font></division><division indent="0" align="left"><sp/></division><division indent="0" align="left"><font>Here is a link to your personal </font><font color="0000FF"><u>Coach Dashboard</u></font><font>. </font><font><field name="DashboardLinkForCoachVerbiage"/></font></division><division indent="0" align="left"><sp/></division><division indent="0" align="left"><font><field name="DashboardLinkSaveVerbiage"/></font></division></cell></row><row><cell width="10260"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="10260"><division indent="0" align="left"><font><field name="CoachRosterNotice:Close"/></font></division></cell></row></table></text>
<mc label="Q8" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send the email out</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon the email and return to Administrator Dashboard</font></paragraph></choice></mc>
<text label="T9" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It might take several minutes to send all the emails. Please wait for the next page to appear. Do not click "Submit" again! </font></paragraph></text>
</items>
</form>
<form name="ParentCoaches" startPoint="false" themePath="mvsc" process="Post-ParentCoaches" preProcess="Pre-ParentCoaches">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams And Coaches</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">If you see a list below, it contains parents who have volunteered to coach. Select one to add him/her as a coach.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To add a coach whose name is </font><font face="Arial" size="200" color="000000"><b><i>not</i></b></font><font face="Arial" size="200" color="000000"> on the list, just click Submit without making a selection.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:ParFulName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:ParentLastName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<mcContains field="Record:Registration:VolunteerActivities">
<string value="Coach"/>
</mcContains>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="CoachDashboard" startPoint="false" themePath="mvsc" process="Post-CoachDashboard" preProcess="RetrieveCoachSetupVariables">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="ShowCoachTeamRoster" startPoint="false" themePath="mvsc" process="Post-ShowCoachTeamRoster">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="FlashMessage" startPoint="false" themePath="mvsc" process="Post-FlashMessage" preProcess="Pre-FlashMessage">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="Count">
<string value="1"/>
</equals>
</conditions>
<trueSet>
<skip to="Q2"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">For which team is this Flash Message intended?</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<equals field="Record:Team:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter Flash Message to Display on your team's Player Dashboards: </font><blank label="a" length="62" height="3" required="false"/></paragraph></fib>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: Your message with remain on Player Dashboards until you replace it with a new message.  To remove the message, replace it with a blank message.</font></paragraph></text>
</items>
</form>
<form name="CoachCommunicatorSetup" startPoint="false" themePath="mvsc" preProcess="Pre-CoachCommunicatorSetup">
</form>
<form name="CoachCommunicator" startPoint="false" themePath="mvsc" process="Post-CoachCommunicator" preProcess="Pre-CoachCommunicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: If you wish to send a Player his personal Player Dashboard, choose the option "Some of my players" below.</font></paragraph></text>
<mc label="Q1" alternateLabel="Recipient" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To whom do you wish to send this message?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All of my players and assistant coaches</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Some of my players</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more of the other team coaches</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The administrator</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more of my assistant coaches</font></paragraph></choice></mc>
<mc label="Q2" alternateLabel="CopySelf" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Click here to send a copy of the message to yourself</font></paragraph></choice></mc>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q4" alternateLabel="Salutation" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of salutation for emails</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Include a personalized salutation (e.g., </font><font face="Arial" size="200" color="000000"><i>"Dear &lt;Player FirstName&gt; or Parents of &lt;Player FirstName&gt;")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't include personalized salutation</font></paragraph></choice></mc>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message:  </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing:  </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<mc label="Q7" alternateLabel="AttachFiles" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box if you want to "attach" files to your message</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="c"/>
</conditions>
<trueSet>
<comment>Send to one or more other head coaches</comment>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="d"/>
</conditions>
<trueSet>
<comment>Send to administrator</comment>
<if>
<conditions>
<mcContains field="CoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Attach files?</comment>
<skip to="T7"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="e"/>
</conditions>
<trueSet>
<comment>Send to one or more assistant coaches</comment>
<skip to="T6"/>
</trueSet>
</if>
<comment>Everyone else, fall through</comment>
</skipInstructions>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q8" alternateLabel="PlayerChoice" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the player(s) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
<string value=" ("/>
<field name="Record:Registration:TeamId"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
<string value=":"/>
<field name="Record:Registration:FirstName"/>
<string value=":"/>
<field name="Record:Registration:LastName"/>
</sort-expression><record-selector><form name="Registration" /><form name="Team" /><conditions>
<and>
<equals field="_InviteeID">
<string field="Record:Team:CoachId"/>
</equals>
<equals field="Record:Registration:TeamId">
<string field="Record:Team:TeamId"/>
</equals>
</and>
</conditions></record-selector></dynamic-mcq></data-provider><displayConditions>
<mcEquals field="CoachCommunicator:Recipient" value="b"/>
</displayConditions></mc>
<mc label="Q9" alternateLabel="Link" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Do you want to include a link to the Player's Dashboard with your message?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No</font></paragraph></choice></mc>
<mc label="Q10" alternateLabel="CopyAsstsWithPlayers" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><string value="Send copy of message to your assistant coaches on "/>
<field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<equals field="Record:Team:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider><displayConditions>
<mcEquals field="CoachCommunicator:Recipient" value="b"/>
</displayConditions></mc>
<skipInstructions>
<if>
<conditions>
<mcContains field="CoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Attach files?</comment>
<skip to="T7"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q11" alternateLabel="CoachChoice" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the coach(es) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:FullName"/>
<string value=" ("/>
<field name="Record:Coach:Team"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
</sort-expression><record-selector><form name="Coach" /><conditions>
<doesNotEqual field="Record:Coach:CoachId">
<string field="_InviteeID"/>
</doesNotEqual>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q12" alternateLabel="CopyAsstsWithCoaches" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><string value="Send copy of message to your assistant coaches on "/>
<field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<equals field="Record:Team:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcContains field="CoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Attach files?</comment>
<skip to="T7"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T6" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q13" alternateLabel="AsstCoachChoice" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the assistant coach(es) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:AssistantCoachInfo:FullName"/>
<string value=" ("/>
<field name="Record:AssistantCoachInfo:TeamId"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:AssistantCoachInfo:AsstId"/>
</value-expression><sort-expression><field name="Record:AssistantCoachInfo:TeamId"/>
<string value="#"/>
<field name="Record:AssistantCoachInfo:LastName"/>
<string value="#"/>
<field name="Record:AssistantCoachInfo:FirstName"/>
</sort-expression><record-selector><form name="AssistantCoachInfo" /><conditions>
<equals field="Record:AssistantCoachInfo:HeadCoachId">
<string field="_InviteeID"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<field name="CoachName"/>
<skipInstructions>
<if>
<conditions>
<mcContains field="CoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Attach files?</comment>
<skip to="T7"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T7" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<text label="T8" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You may upload up to three files to be included with your email. These files will not actually be attached to the email, but links to them will appear at the bottom of the email message. When your recipients click on the link they will be able to view the file(s).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Use the "Browse..." buttons below to select a file or files on your computer. When you click the Submit button the file(s) will be uploaded to the server so they will be accessible by your recipients.</font></paragraph></text>
<file label="F1" alternateLabel="File1" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 1:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F2" alternateLabel="File2" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 2:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F3" alternateLabel="File3" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 3:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
</items>
</form>
<form name="CoachCommunicatorSend" startPoint="false" themePath="mvsc" process="Post-CoachCommunicatorSend">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="705"><row><cell width="10095"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>From: </b></font><font><field name="Coach"/></font><font> (</font><font><field name="CoachsEmail"/></font><font>)</font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><i><field name="CCSelf"/></i></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="CoachCommunicator:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="705"><row><cell width="10095"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><field name="CoachCommunicator:Body"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><i><field name="DashboardLinkPreviewVerbiage"/></i></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><field name="CoachCommunicator:Close"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font color="0000C0"><i><u><field name="AttachedFile1"/></u></i></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><i><field name="CopyAsstCoaches"/></i></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send the email out</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Coach's Dashboard</font></paragraph></choice></mc>
</items>
</form>
<form name="ManageAssistantCoaches" startPoint="false" themePath="mvsc" process="Post-ManageAssistantCoaches" preProcess="Pre-ManageAssistantCoaches">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Assistant Coaches For </font><font face="Arial" size="360" color="000000"><field name="Team"/></font><sp/></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First"/>
</header><contents><field name="Record:AssistantCoachInfo:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:AssistantCoachInfo:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:AssistantCoachInfo:Email" /></contents></column><column><header><string value="Phone"/>
</header><contents><field name="Record:AssistantCoachInfo:Phone1" /></contents></column><conditions><form name="AssistantCoachInfo" /><conditions>
<equals field="Record:AssistantCoachInfo:TeamId">
<string field="Team"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q1" alternateLabel="Action" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">What would you like to do?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add an assistant coach</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit an existing assistant coach's information</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete an existing assistant coach</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send private Dashboard link to assistant coach(es)</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="ManageAssistantCoaches:Action" value="d"/>
</conditions>
<trueSet>
<skip to="T4"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcDoesNotEqual field="ManageAssistantCoaches:Action" value="b"/>
<mcDoesNotEqual field="ManageAssistantCoaches:Action" value="c"/>
</and>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ManageAssistantCoaches:Action" value="b"/>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="edit"/>
</set>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value="delete"/>
</set>
</falseSet>
</if>
</skipInstructions>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q2" alternateLabel="SelectedAssistant" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the assistant coach to </font><font face="Arial" size="200" color="000000"><field name="Message"/></font><font face="Arial" size="200" color="000000">.</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:AssistantCoachInfo:LastName"/>
<string value=", "/>
<field name="Record:AssistantCoachInfo:FirstName"/>
</display-expression><value-expression><field name="Record:AssistantCoachInfo:AsstId"/>
</value-expression><sort-expression><field name="Record:AssistantCoachInfo:LastName"/>
<string value="#"/>
<field name="Record:AssistantCoachInfo:FirstName"/>
</sort-expression><record-selector><form name="AssistantCoachInfo" /><conditions>
<equals field="Record:AssistantCoachInfo:TeamId">
<string field="Team"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q3" alternateLabel="SendDashboards" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the assistant coach(es) to whom you want to send their Dashboard links:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:AssistantCoachInfo:LastName"/>
<string value=", "/>
<field name="Record:AssistantCoachInfo:FirstName"/>
</display-expression><value-expression><field name="Record:AssistantCoachInfo:AsstId"/>
</value-expression><sort-expression><field name="Record:AssistantCoachInfo:LastName"/>
<string value="#"/>
<field name="Record:AssistantCoachInfo:FirstName"/>
</sort-expression><record-selector><form name="AssistantCoachInfo" /><conditions>
<equals field="Record:AssistantCoachInfo:TeamId">
<string field="Team"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="SelectTeamForAssistantCoaches" startPoint="false" themePath="mvsc" process="Post-SelectTeamForAssistantCoaches" preProcess="Pre-SelectTeamForAssistantCoaches">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Select Team for Assistant Coaches</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="SelectedTeam" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the team whose assistant coaches you wish to manage:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
</sort-expression><record-selector><form name="Team" /><conditions>
<equals field="Record:Team:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="SelectTeamForAssistantCoaches:SelectedTeam" />
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
</items>
</form>
