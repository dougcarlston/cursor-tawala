<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Manage Divisions</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Divisions:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Name"/>
</header><contents><field name="Record:Divisions:Name" /></contents></column><column><header><string value="Fee"/>
</header><contents><field name="Record:Divisions:DivFees" /></contents><display-conditions><equals field="FeeStructure">
<string value="Varies by Division"/>
</equals>
</display-conditions></column><conditions><form name="Divisions" /></conditions></itemization-table></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ChangeDivFee" project="">Change Division Fees</invitation></u></font></paragraph><displayConditions>
<equals field="FeeStructure">
<string value="Varies by Division"/>
</equals>
</displayConditions></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add a division</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit division name</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete a division </font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Setup Menu</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="ManageDivisions:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="DeleteDivision"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="ManageDivisions:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q2" alternateLabel="EditDivision" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Select a division to edit:</b></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Divisions:Name"/>
</display-expression><value-expression><field name="Record:Divisions:DivisionID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Divisions" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q3" alternateLabel="DeleteDivision" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Select a division to delete:</b></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Divisions:Name"/>
</display-expression><value-expression><field name="Record:Divisions:DivisionID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Divisions" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="ChangeDivFee" startPoint="false" themePath="mvsc" process="PostChangeDivFee">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Change Division Fees</font></paragraph></heading>
<mc label="Q1" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select one or more divisions whose fees you wish to change to the </font><font face="Arial" size="200" color="000000"><b><i>same new</i></b></font><font face="Arial" size="200" color="000000"> amount:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Divisions:Name"/>
<string value=" ($"/>
<field name="Record:Divisions:DivFees"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Divisions:DivisionID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Divisions" /></record-selector></dynamic-mcq></data-provider></mc>
<fib label="Q2" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the new registration fee for this division or these divisions: $ </font><blank label="a" length="20" required="false" alternateLabel="NewDivFee"/></paragraph></fib>
</items>
</form>
<form name="ChangeDivFeeConfirm" startPoint="false" themePath="mvsc" process="Post-DivConfirm">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Division Fee Confirmation</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Division"/>
</header><contents><field name="Record:Divisions:Name" /></contents></column><column><header><string value="Registration Fee"/>
</header><contents><field name="Record:Divisions:DivFees" /></contents></column><conditions><form name="Divisions" /></conditions></itemization-table></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All done. Return to Setup Menu</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Make more changes in fees</font></paragraph></choice></mc>
</items>
</form>
<form name="ManageGrades" startPoint="false" themePath="mvsc" process="Post-ManageGrades" preProcess="RetrieveAdminSetupVariables">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Manage Grades</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Grade levels:  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Grade"/>
</header><contents><field name="Record:Grade:Name" /></contents></column><column><header><string value="Fee"/>
</header><contents><field name="Record:Grade:Fee" /></contents><display-conditions><equals field="FeeStructure">
<string value="Varies by Grade"/>
</equals>
</display-conditions></column><conditions><form name="Grade" /></conditions></itemization-table></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ChangeGradeFee" project="">Change Grade Fees</invitation></u></font></paragraph><displayConditions>
<equals field="FeeStructure">
<string value="Varies by Grade"/>
</equals>
</displayConditions></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add another grade level</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit a grade name</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete a grade level</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Setup Menu</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="ManageGrades:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="DeleteGrade"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="ManageGrades:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q2" alternateLabel="EditGrade" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Select a grade to edit:</b></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Grade:Name"/>
</display-expression><value-expression><field name="Record:Grade:Name"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Grade" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q3" alternateLabel="DeleteGrade" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Select grade(s) to delete:</b></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Grade:Name"/>
</display-expression><value-expression><field name="Record:Grade:Name"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Grade" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="ChangeGradeFee" startPoint="false" themePath="mvsc" process="PostChangeGradeFee">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Change Grade Level Fees</font></paragraph></heading>
<mc label="Q1" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select one or more grade levels whose fees you wish to change to the </font><font face="Arial" size="200" color="000000"><b><i>same new</i></b></font><font face="Arial" size="200" color="000000"> amount:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Grade:Name"/>
<string value=" ($"/>
<field name="Record:Grade:Fee"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Grade:Name"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Grade" /></record-selector></dynamic-mcq></data-provider></mc>
<fib label="Q2" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the new registration fee for this grade (or these grades):  $</font><blank label="a" length="20" required="false" alternateLabel="NewFee"/></paragraph></fib>
</items>
</form>
<form name="ChangeGradeFeeConfirm" startPoint="false" themePath="mvsc" process="Post-GradeConfirm">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Grade Level Fee Confirmation</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Grade"/>
</header><contents><field name="Record:Grade:Name" /></contents></column><column><header><string value="Registration Fee"/>
</header><contents><field name="Record:Grade:Fee" /></contents></column><conditions><form name="Grade" /></conditions></itemization-table></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All done. Return to Setup Menu</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Make more changes in fees</font></paragraph></choice></mc>
</items>
</form>
<form name="ManageVolunteering" startPoint="false" themePath="mvsc" process="Post-ManageVolunteering" preProcess="RetrieveAdminSetupVariables">
<items>
<skipInstructions>
<set field="ManageVolunteering:RegistrationFormText" arithmeticAsText="false">
<string field="VolunteerIntroText"/>
</set>
<if>
<conditions>
<equals field="AskVolunteerOptOutFeeQuestion">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="ManageVolunteering:AskPayVolunteerFee" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
<falseSet>
<set field="ManageVolunteering:AskPayVolunteerFee" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<set field="ManageVolunteering:VolunteerOptOutFee" arithmeticAsText="false">
<string field="VolunteerOptOutFee"/>
</set>
</skipInstructions>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Use this section to add volunteer activities that you'd like people to sign up for upon registration.  Examples are: Coach, Referee,  Fundraising Activities, Field Prep.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can add as many categories as you like.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you want parents who have volunteered to coach to appear in the Set up Teams and Coaches section of Preseason Activities, make sure that there is a volunteer category entitled simply "Coach".</font></paragraph></text>
<text label="T2" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Message"/></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="240" color="000000">Text of words before list of Volunteer activity options in Registration form:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="63" height="3" required="false" alternateLabel="RegistrationFormText"/></paragraph></fib>
<mc label="Q2" alternateLabel="AskPayVolunteerFee" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Ask if the registrant would like to pay a fee in lieu of volunteering</font></paragraph></choice></mc>
<fib label="Q3" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Volunteer opt out fee $</font><blank label="a" length="20" required="false" alternateLabel="VolunteerOptOutFee"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></fib>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Volunteer Categories:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Volunteer Category"/>
</header><contents><field name="Record:Volunteers:CatName" /></contents></column><conditions><form name="Volunteers" /></conditions></itemization-table></font></paragraph></text>
<mc label="Q4" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add a volunteer activity category</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit a category name</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete a category</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Save and return to the setup menu</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<and>
<mcEquals field="ManageVolunteering:AskPayVolunteerFee">
<string value="a"/>
</mcEquals>
<isLessThan field="ManageVolunteering:VolunteerOptOutFee">
<string value=".00001"/>
</isLessThan>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please set a valid opt out fee amount."/>
</set>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ManageVolunteering:Q4" value="c"/>
</conditions>
<trueSet>
<skip to="DeleteCat"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="ManageVolunteering:Q4" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<mc label="Q5" alternateLabel="EditCat" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Select a volunteer activity category to edit:</b></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Volunteers:CatName"/>
</display-expression><value-expression><field name="Record:Volunteers:VolunteerID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Volunteers" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<mc label="Q6" alternateLabel="DeleteCat" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Select a volunteer activity category to delete:</b></font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Volunteers:CatName"/>
</display-expression><value-expression><field name="Record:Volunteers:VolunteerID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Volunteers" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="ManageUniforms" startPoint="false" themePath="mvsc" process="Post-ManageUniforms" preProcess="RetrieveAdminSetupVariables">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="UniformSelectionRequired">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="ManageUniforms:SelectionRequired" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
<falseSet>
<set field="ManageUniforms:SelectionRequired" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<set field="ManageUniforms:QuestionText" arithmeticAsText="false">
<string field="UniformQuestionText"/>
</set>
</skipInstructions>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Manage Uniform/Jersey Sizes</font></paragraph></heading>
<mc label="Q1" alternateLabel="SelectionRequired" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check here if players </font><font face="Arial" size="200" color="000000"><u>must</u></font><font face="Arial" size="200" color="000000"> select a uniform size on the registration form</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Text of the question to select the uniform size (e.g. What is  your jersey size?)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="69" required="false" alternateLabel="QuestionText"/></paragraph></fib>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Item"/>
</header><contents><field name="Record:Uniform:UniformId" /></contents></column><conditions><form name="Uniform" /></conditions></itemization-table></font></paragraph></text>
<mc label="Q3" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add a size</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit a size</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete a size(s)</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return to Setup Menu</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="ManageUniforms:Q3">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="Edit Uniform"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ManageUniforms:Q3">
<string value="c"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="Delete Uniform"/>
</trueSet>
</if>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H2" alternateLabel="Edit Uniform" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Select a Size to Edit</font></paragraph></heading>
<mc label="Q4" alternateLabel="UniformToEdit" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Uniform:UniformId"/>
</display-expression><value-expression><field name="Record:Uniform:UniformId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Uniform" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<heading label="H3" alternateLabel="Delete Uniform" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Select Size(s) to Delete</font></paragraph></heading>
<mc label="Q5" alternateLabel="UniformToDelete" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Uniform:UniformId"/>
</display-expression><value-expression><field name="Record:Uniform:UniformId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Uniform" /></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="Uniform" startPoint="false" themePath="mvsc" process="Post-Uniform">
<items>
