<form name="EditRegistration" startPoint="false" themePath="mvsc" process="Post-EditRegistration" preProcess="Pre-EditOrDeleteRegistration">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>View or Edit Player Records</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3855"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3345"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="B40000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria:  </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<comment>-- no space characters allowed; we can't handle substrings for searching on multiple fields</comment>
<if>
<conditions>
<contains field="EditRegistration:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word, or part of a word to search on. Multiple word searches are not supported."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>View or Edit Player Records</font></paragraph></heading>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3390"><division indent="0" align="left"><font color="0066CC"><u><invitation form="EditRegistration" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3810"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RegistrationId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player to view/edit, then click the SUBMIT button:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<or>
<contains field="Record:Registration:FirstName">
<string field="EditRegistration:SearchString"/>
</contains>
<or>
<contains field="Record:Registration:LastName">
<string field="EditRegistration:SearchString"/>
</contains>
<contains field="Record:Registration:ParentEmail">
<string field="EditRegistration:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="DeleteRegistration" startPoint="false" themePath="mvsc" process="Post-DeleteRegistration" preProcess="Pre-EditOrDeleteRegistration">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Player Records</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3825"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3375"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="B40000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria:  </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<comment>-- no space characters allowed; we can't handle substrings for searching on multiple fields</comment>
<if>
<conditions>
<contains field="DeleteRegistration:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word, or part of a word to search on. Multiple word searches are not supported."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Player Records</font></paragraph></heading>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="DeleteRegistration" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administration Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RegistrationIds" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the records to delete. You will get a chance to review your choice prior to deletion.</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=", paid: "/>
<field name="Record:Registration:PaymentReceived"/>
<string value=", waiver: "/>
<field name="Record:Registration:WaiverReceived"/>
<string value=") "/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<or>
<contains field="Record:Registration:FirstName">
<string field="DeleteRegistration:SearchString"/>
</contains>
<or>
<contains field="Record:Registration:LastName">
<string field="DeleteRegistration:SearchString"/>
</contains>
<contains field="Record:Registration:ParentEmail">
<string field="DeleteRegistration:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="DeleteRegistration:RegistrationIds" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H3" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Player Records</font></paragraph></heading>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The following record(s) will be deleted:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Preferred Coach"/>
</header><contents><field name="Record:Registration:PreferredCoach" /></contents></column><column><header><string value="Friends"/>
</header><contents><field name="Record:Registration:FriendsList" /></contents></column><column><header><string value="Date of birth"/>
</header><contents><field name="Record:Registration:Birthday" /></contents></column><column><header><string value="Payment Received"/>
</header><contents><field name="Record:Registration:PaymentReceived" /></contents></column><column><header><string value="Waiver Received"/>
</header><contents><field name="Record:Registration:WaiverReceived" /></contents></column><conditions><form name="Registration" /><conditions>
<mcContains field="DeleteRegistration:RegistrationIds">
<string field="Record:Registration:RegID"/>
</mcContains>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q3" alternateLabel="Confirm" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes, delete the record(s)</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, I made the wrong selection and would like to select other record(s)</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, cancel this action entirely</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="DeleteRegistration:Confirm">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
</items>
</form>
<form name="RegistrantEmail" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-RegistrantEmail" preProcess="Pre-RegistrantEmail">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Registered Player Email</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3210"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3660"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: Use the Communicator best designed for your task:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>    This form is for emailing registered players in various categories, whether or not they have been assigned to teams</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><sp/><font color="0066CC"><b><u><invitation form="CommunicatorSetup" project="">Communicator</invitation></u></b></font><sp/><font><b>is for emailing:</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Players who are already assigned to teams</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Coaches</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Volunteers</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><sp/><font color="0066CC"><b><u><invitation form="RecruitEmail-Setup" project="">Recruitment List Communicator</invitation></u></b></font><sp/><font><b>is for sending emails to people in your recruitment database</b></font></paragraph></text>
<text label="T3" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="C00000"><b><i><field name="Message"/></i></b></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All registered players, regardless whether waivers or payment have been received</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players for whom waivers have not been received</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players for whom payment has not been received</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players with fully completed forms, waivers &amp; payment</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players in certain grades only (if applicable)</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players - first time in league (if applicable)</font></paragraph></choice><choice label="g"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registered players who requested a particular division (if applicable)</font></paragraph></choice></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Name)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q5" alternateLabel="Salutation" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of Salutation:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Include a personalized salutation (e.g., </font><font face="Arial" size="200" color="000000"><i>"Dear &lt;Player's First Name&gt; or Parents of &lt;Player's First Name&gt;")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't include personalized salutation</font></paragraph></choice></mc>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>[A link to the player's </font><font color="0000FF"><u>Player Dashboard</u></font><font> will appear here.]</font></paragraph></text>
<fib label="Q7" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing:  </font><blank label="a" length="57" height="5" required="false" alternateLabel="Closing"/></paragraph></fib>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<mc label="Q8" alternateLabel="AttachFiles" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box if you want to "attach" files to your message</font></paragraph></choice></mc>
<text label="T6" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the Submit button to continue.  You will have a chance to review your letter before it is sent.</font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="RegistrantEmail:Q1" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Error: You must select the group to whom you wish to send this message!"/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<doesNotContain field="RegistrantEmail:FromEmail">
<string value="@"/>
</doesNotContain>
<or>
<doesNotContain field="RegistrantEmail:FromEmail">
<string value="."/>
</doesNotContain>
<contains field="RegistrantEmail:FromEmail">
<string value=" "/>
</contains>
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Error: You must enter a valid email address in the &quot;From (Email)&quot; field."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="RegistrantEmail:Q1" value="g"/>
</conditions>
<trueSet>
<comment>Email to players who requested a particular division</comment>
<skip to="T8"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="RegistrantEmail:Q1" value="e"/>
</conditions>
<trueSet>
<if>
<conditions>
<mcContains field="RegistrantEmail:AttachFiles" value="a"/>
</conditions>
<trueSet>
<skip to="UploadFiles"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
<comment>Players in certain grades fall through to next question</comment>
</trueSet>
</if>
</skipInstructions>
<text label="T7" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3210"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3660"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q9" alternateLabel="SelectedGrades" onlyone="false" required="false" style="multicolumn"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send message only to registrants in the following grade or grades:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Grade:Name"/>
</display-expression><value-expression><field name="Record:Grade:Name"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Grade" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcContains field="RegistrantEmail:AttachFiles" value="a"/>
</conditions>
<trueSet>
<skip to="UploadFiles"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T8" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3210"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3660"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q10" alternateLabel="SelectedDivisions" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send message only to registrants who requested to play in the following division(s):</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Divisions:Name"/>
</display-expression><value-expression><field name="Record:Divisions:DivisionID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Divisions" /></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q11" alternateLabel="NoDivision" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to registrants who did not request a division</font></paragraph></choice><displayConditions>
<doesNotEqual field="FeeStructure">
<string value="Varies by Division"/>
</doesNotEqual>
</displayConditions></mc>
<skipInstructions>
<if>
<conditions>
<mcContains field="RegistrantEmail:AttachFiles" value="a"/>
</conditions>
<trueSet>
<skip to="UploadFiles"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T9" alternateLabel="UploadFiles" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3930"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3210"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3660"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T10" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You may upload up to three files to be included with your email. These files will not actually be attached to the email, but links to them will appear at the bottom of the email message. When your recipients click on the link they will be able to view the file(s).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Use the "Browse..." buttons below to select a file or files on your computer. When you click the Submit button the file(s) will be uploaded to the server so they will be accessible by your recipients.</font></paragraph></text>
<file label="F1" alternateLabel="File1" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 1:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F2" alternateLabel="File2" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 2:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F3" alternateLabel="File3" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 3:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
</items>
</form>
<form name="RegistrantEmailSend" startPoint="false" themePath="mvsc" process="Post-RegistrantEmailSend" preProcess="RetrieveAdminSetupVariables">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3900"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3300"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="570"><row><cell width="8400"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>From</b></font><font>:  </font><font><field name="RegistrantEmail:FromName"/></font><font> (</font><font><field name="RegistrantEmail:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="8400"></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="RegistrantEmail:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="525"><row><cell width="8415"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="RegistrantEmail:Body"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font>Here is a link to your personal </font><font color="0000FF"><u>Player Dashboard</u></font><font>. </font><font><field name="DashboardLinkForPlayerVerbiage"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="DashboardLinkSaveVerbiage"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="RegistrantEmail:Closing"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font color="0000C0"><i><u><field name="AttachedFile1"/></u></i></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Registration Form Management</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="RegistrantEmailSend:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Click Submit to begin sending now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Note: It might take several minutes to send all the emails.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</i></font></paragraph></text>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3960"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
</items>
</form>
<form name="SendDashReminder" startPoint="false" themePath="mvsc" process="Post-SendDashReminder" preProcess="RetrieveAdminSetupVariables">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Send or View private Dashboard link</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility is designed to permit the Administrator to send Dashboard links out to Players and Coaches who has misplaced theirs.  If a Coach has not previously been sent his Dashboard, it is better to send it out from </font><font color="000080"><u><invitation form="Preseason" project="">Send Dashboards to Coaches</invitation></u></font><font> in the Preseason Menu.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose an action to take:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Send</b></font><font face="Arial" size="200" color="000000"> private Dashboard reminder to </font><font face="Arial" size="200" color="000000"><b>Coach(es)</b></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Send</b></font><font face="Arial" size="200" color="000000"> private Dashboard reminder to </font><font face="Arial" size="200" color="000000"><b>Player(s)</b></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>View </b></font><font face="Arial" size="200" color="000000">a </font><font face="Arial" size="200" color="000000"><b>Coach</b></font><font face="Arial" size="200" color="000000">'s private Dashboard</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>View </b></font><font face="Arial" size="200" color="000000">a </font><font face="Arial" size="200" color="000000"><b>Player</b></font><font face="Arial" size="200" color="000000">'s private Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="T4"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="SendDashReminder:Q1" value="d"/>
</conditions>
<trueSet>
<skip to="T7"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="SendDashReminder:Q1" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q2" alternateLabel="PlayerIdsForSend" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player(s) to send the dashboard link to:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ["/>
<field name="Record:Registration:ParentEmail"/>
<string value="]"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>A coach must have been assigned a team to appear on list.</i></font></paragraph></text>
<mc label="Q3" alternateLabel="CoachIdsForSend" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the coach(es) to send dashboard link to:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:LastName"/>
<string value=", "/>
<field name="Record:Coach:FirstName"/>
<string value=" "/>
<field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:LastName"/>
<string value="#"/>
<field name="Record:Coach:FirstName"/>
</sort-expression><record-selector><form name="Coach" /><form name="Team" /><conditions>
<equals field="Record:Coach:CoachId">
<string field="Record:Team:CoachId"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
