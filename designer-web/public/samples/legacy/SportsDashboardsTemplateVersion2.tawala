</header><contents><field name="Record:AssistantCoachInfo:Phone1" /></contents></column><column><header><string value="Phone 2"/>
</header><contents><field name="Record:AssistantCoachInfo:Phone2" /></contents></column><conditions><form name="AssistantCoachInfo" /><conditions>
