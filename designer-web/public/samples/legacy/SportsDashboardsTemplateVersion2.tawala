<mc label="Q23" alternateLabel="DivVolunteers" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to the following volunteers:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:ParFulName"/>
