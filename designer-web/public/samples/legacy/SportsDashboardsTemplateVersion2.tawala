<from addressField="Communicator:FromEmail" aliasField="Communicator:FromName"/>
<subject><field name="Communicator:Subject"/>  [SENT TO <field name="SendCount"/> RECIPIENTS]</subject>
<body document="LetterWithPlayerDashboardLink" reset="false" showHeader="true"/>
</send>
</trueSet>
<falseSet>
<send>
<to addressField="AdminEmail"/>
<from addressField="Communicator:FromEmail" aliasField="Communicator:FromName"/>
<subject><field name="Communicator:Subject"/>  [SENT TO <field name="SendCount"/> RECIPIENTS]</subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
</falseSet>
</if>
</foreach>
</trueSet>
</if>
<comment>Create message to display on dashboard</comment>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="f"/>
</conditions>
<trueSet>
<comment>Volunteers</comment>
<if>
<conditions>
<equals field="SendPlayerEmail2Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="true">
<string value="Emails were sent to "/>
<string field="SendPlayerEmail1Count"/>
<string value=" Volunteers"/>
</set>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="true">
<string field="SendCount"/>
<string value=" emails were sent ("/>
<string field="SendPlayerEmail1Count"/>
<string value=" Volunteers + "/>
<string field="SendPlayerEmail2Count"/>
<string value=" second addresses)"/>
</set>
</falseSet>
</if>
</trueSet>
<falseSet>
<comment>Players. coaches and/or assistant coaches</comment>
<set field="Message" arithmeticAsText="false">
<string field="SendCount"/>
<string value=" emails were sent ("/>
</set>
<if>
<conditions>
<doesNotEqual field="SendPlayerEmail1Count">
<string value="0"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="true">
<string field="Message"/>
<string field="SendPlayerEmail1Count"/>
<string value=" Players"/>
</set>
<if>
<conditions>
<doesNotEqual field="SendPlayerEmail2Count">
<string value="0"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="true">
<string field="Message"/>
<string value=" + "/>
<string field="SendPlayerEmail2Count"/>
<string value=" second addresses"/>
</set>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<doesNotEqual field="SendCoachCount">
<string value="0"/>
</doesNotEqual>
</conditions>
<trueSet>
<if>
<conditions>
<doesNotEqual field="SendPlayerEmail1Count">
<string value="0"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="true">
<string field="Message"/>
<string value=" + "/>
</set>
</trueSet>
</if>
<set field="Message" arithmeticAsText="true">
<string field="Message"/>
<string field="SendCoachCount"/>
<string value=" Coaches"/>
</set>
<if>
<conditions>
<doesNotEqual field="SendAssistantCoachCount">
<string value="0"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="true">
<string field="Message"/>
<string value=" + "/>
<string field="SendAssistantCoachCount"/>
<string value=" Asst. Coaches"/>
</set>
</trueSet>
</if>
</trueSet>
</if>
<set field="Message" arithmeticAsText="true">
<string field="Message"/>
<string value=")"/>
</set>
</falseSet>
</if>
<show document="Message" reset="false"/>
<comment>Clear the variables so that other uses of the Letter Documents don't accidentally show links</comment>
<set field="AttachedFile1" arithmeticAsText="false">
<string value="omit"/>
</set>
<set field="AttachedFile2" arithmeticAsText="false">
<string value="omit"/>
</set>
<set field="AttachedFile3" arithmeticAsText="false">
<string value="omit"/>
</set>
<show form="AdminDash"/>
</process>
<process name="Post-TeamRosters">
<set field="Count" arithmeticAsText="false">
<string value="No"/>
</set>
<get recordList="Record List 111">
<forms>
<form name="Team"/>
</forms>
</get>
<foreach record="NamedTeam" recordList="Record List 111">
<set field="Count" arithmeticAsText="false">
<string value="Yes"/>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="No"/>
</equals>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You need to set up teams before assigning players to them!"/>
</set>
<show document="Message" reset="false"/>
<show form="Preseason"/>
</trueSet>
</if>
<show document="TeamAssignment" reset="false"/>
</process>
