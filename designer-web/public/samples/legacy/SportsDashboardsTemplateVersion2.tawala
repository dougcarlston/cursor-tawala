<process name="Pre-CoachRosterNotice-Setup">
<set field="RetrieveVariablesTargetForm" arithmeticAsText="false">
<string value="CoachRosterNotice"/>
</set>
<show form="RetrieveAdminVariablesForAnotherForm"/>
</process>
<process name="Pre-CoachRosterNotice">
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="PreviousEmailData">
<forms>
<form name="CoachRosterNotice"/>
</forms>
</get>
<foreach record="Record" recordList="PreviousEmailData">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<comment>initialize fields first time in</comment>
<set field="CoachRosterNotice:FromAdminName" arithmeticAsText="false">
<string field="AdminName"/>
</set>
<set field="CoachRosterNotice:FromEmail" arithmeticAsText="false">
<string field="AdminEmail"/>
</set>
<set field="CoachRosterNotice:Q4" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
</if>
</process>
<process name="Post-CoachRosterNotice">
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q8" value="a"/>
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q4" value="a"/>
</conditions>
<trueSet>
<get recordList="TeamAndCoachList">
<forms>
<form name="Team"/>
<form name="Coach"/>
</forms>
<conditions>
<equals field="TeamAndCoachList:Team:CoachId">
<string field="TeamAndCoachList:Coach:CoachId"/>
</equals>
</conditions></get>
</trueSet>
<falseSet>
<get recordList="TeamAndCoachList">
<forms>
<form name="Team"/>
<form name="Coach"/>
</forms>
<conditions>
<and>
<equals field="TeamAndCoachList:Team:CoachId">
<string field="TeamAndCoachList:Coach:CoachId"/>
</equals>
<mcContains field="CoachRosterNotice:Q7">
<string field="TeamAndCoachList:Coach:CoachId"/>
</mcContains>
</and>
</conditions></get>
</falseSet>
</if>
<foreach record="SuchPair" recordList="TeamAndCoachList">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
<set field="Team" arithmeticAsText="false">
<string field="SuchPair:Team:TeamId"/>
</set>
<set field="CoachID" arithmeticAsText="false">
<string field="SuchPair:Coach:CoachId"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="SuchPair:Coach:FirstName"/>
<string value=","/>
</set>
<send>
<to addressField="SuchPair:Coach:Email"/>
<from addressField="CoachRosterNotice:FromEmail" aliasField="CoachRosterNotice:FromAdminName"/>
<subject><field name="CoachRosterNotice:Subject"/></subject>
<body document="CoachSetupLetter" reset="false" showHeader="true"/>
</send>
</foreach>
<set field="Message" arithmeticAsText="true">
<string field="Count"/>
<string value=" team roster / dashboard notices were sent."/>
</set>
<show document="Message" reset="false"/>
<get recordList="SetupList">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="SetupRecord" recordList="SetupList">
<if>
<conditions>
<mcContains field="SetupRecord:AdminSetup:EmailNotificationPreference" value="b"/>
</conditions>
<trueSet>
<comment>Send bulk email copy to Admin</comment>
<set field="DearSir" arithmeticAsText="false">
<string field="AdminEmailCopyText"/>
</set>
<send>
<to addressField="SetupRecord:AdminSetup:AdminsEmail"/>
<from addressField="CoachRosterNotice:FromEmail" aliasField="CoachRosterNotice:FromAdminName"/>
<subject><field name="CoachRosterNotice:Subject"/>  [SENT TO <field name="Count"/> RECIPIENTS]</subject>
<body document="CoachSetupLetter" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
</foreach>
<show form="Preseason"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachRosterNotice:Q8" value="b"/>
</conditions>
<trueSet>
<show form="CoachRosterNotice-Setup"/>
</trueSet>
</if>
<show form="AdminDash"/>
</process>
<process name="Post-ShowTeamRosters">
<if>
<conditions>
<mcEquals field="ShowTeamRosters:Q1" value="a"/>
</conditions>
<trueSet>
<set field="Initialized" arithmeticAsText="false">
<string value="false"/>
</set>
<show form="ShowAllRosters"/>
</trueSet>
<falseSet>
<show form="AdminDash"/>
</falseSet>
</if>
</process>
<process name="Post-ShowCoachTeamRoster">
<if>
<conditions>
<isBlank field="AsstCoachID" />
</conditions>
<trueSet>
<comment>-- we came from the Coach Dashboard</comment>
<show document="BackToCoachDashLink" reset="false"/>
<get recordList="Team List">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="Team List:Team:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions></get>
</trueSet>
<falseSet>
<comment>-- we came from the Assistant Coach Dashboard</comment>
<show document="BackToAssistantCoachDashLink" reset="false"/>
<get recordList="Team List">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="Team List:Team:TeamId">
<string field="Team"/>
</equals>
</conditions></get>
</falseSet>
</if>
<foreach record="SuchTeam" recordList="Team List">
<set field="CurrentTeamId" arithmeticAsText="false">
<string field="SuchTeam:Team:TeamId"/>
</set>
<set field="Team" arithmeticAsText="false">
<string field="SuchTeam:Team:TeamId"/>
</set>
<show document="CoachRosterList" reset="false"/>
</foreach>
<if>
<conditions>
<isBlank field="AsstCoachID" />
</conditions>
<trueSet>
<show document="BackToCoachDashLink" reset="false"/>
</trueSet>
<falseSet>
<show document="BackToAssistantCoachDashLink" reset="false"/>
</falseSet>
</if>
</process>
<process name="Post-OnlinePayment">
<if>
<conditions>
<isBlank field="Registration:RegID" />
</conditions>
<trueSet>
<set field="OnlinePayment:RegID" arithmeticAsText="false">
<string field="_InviteeID"/>
</set>
</trueSet>
<falseSet>
<set field="OnlinePayment:RegID" arithmeticAsText="false">
<string field="Registration:RegID"/>
</set>
</falseSet>
</if>
<set field="OnlinePayment:Status" arithmeticAsText="false">
<string value="Initiating"/>
</set>
<set field="OnlinePayment:PaymentDescription" arithmeticAsText="false">
<string field="PaymentChargeDescription"/>
</set>
<set field="OnlinePayment:AmountRequested" arithmeticAsText="false">
<string field="RegistrationFee"/>
</set>
<show document="OnlinePaymentInstructions" reset="false"/>
<if>
<conditions>
<equals field="ShowCheckPaymentInstructions">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="PaymentByCheckInstructions" reset="false"/>
</trueSet>
</if>
<show document="NavigationToPlayerDashboard" reset="false"/>
</process>
<process name="UpdatePaidStatusBasedOnInvoiceStatus">
<get recordList="Unupdated Registrants">
<forms>
<form name="Registration"/>
<form name="OnlinePayment"/>
</forms>
<conditions>
<and>
<isBlank field="Unupdated Registrants:Registration:PaymentReceived" />
<equals field="Unupdated Registrants:Registration:RegID">
<string field="Unupdated Registrants:OnlinePayment:RegID"/>
</equals>
</and>
</conditions></get>
<foreach record="Registrant" recordList="Unupdated Registrants">
<if>
<conditions>
<or>
<equals field="Registrant:OnlinePayment:Status">
<string value="Completed"/>
</equals>
<equals field="Registrant:OnlinePayment:Status">
<string value="Pending"/>
</equals>
</or>
</conditions>
<trueSet>
<set field="Registrant:Registration:PaymentReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="Registrant:Registration:PaidAmount" arithmeticAsText="false">
<string field="Registrant:OnlinePayment:AmountPaid"/>
</set>
<set field="Registrant:Registration:PaymentMethod" arithmeticAsText="false">
<string value="PayPal"/>
</set>
</trueSet>
</if>
</foreach>
</process>
<process name="Post-PaymentReceived">
<show form="PlayerDash"/>
</process>
<process name="Post-IndividualPaymentCancelled">
<show document="OnlinePaymentCancelledConfirmation" reset="false"/>
<if>
<conditions>
<equals field="ShowCheckPaymentInstructions">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="PaymentByCheckInstructions" reset="false"/>
</trueSet>
</if>
<show document="NavigationToPlayerDashboard" reset="false"/>
</process>
<process name="Post-TeamAndCoachMenu">
<delete><form name="Team"/><conditions>
<isBlank field="Record:Team:TeamId" />
</conditions></delete>
<get recordList="Record List 102">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="CoachnTeamAssgnmnt" recordList="Record List 102">
<set field="Coaches4Teams" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="CoachnTeamAssgnmnt:AdminSetup:Coach4EachTeam" arithmeticAsText="false">
<string value="Yes"/>
</set>
<get recordList="Record List 103">
<forms>
<form name="Team"/>
</forms>
<conditions>
<isBlank field="Record List 103:Team:CoachId" />
</conditions></get>
<foreach record="SuchLeaderlessTeam" recordList="Record List 103">
<set field="Coaches4Teams" arithmeticAsText="false">
<string value="No"/>
</set>
<set field="CoachnTeamAssgnmnt:AdminSetup:Coach4EachTeam" arithmeticAsText="false">
<string value="No"/>
</set>
</foreach>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<show document="TeamAndCoachMenu" reset="false"/>
</process>
<process name="Post-Team">
<if>
<conditions>
<isNotBlank field="Team:PreviousTeamId" />
</conditions>
<trueSet>
<comment>-- This is the case of editing a team</comment>
<comment>-- Other records contain team names; if the name has been changed, we need to update them</comment>
<get recordList="TeamPlayers">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="TeamPlayers:Registration:TeamId">
<string field="Team:PreviousTeamId"/>
</equals>
</conditions></get>
<foreach record="SuchPlayer" recordList="TeamPlayers">
<set field="SuchPlayer:Registration:TeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
</foreach>
<get recordList="GroupRegistrationRecords">
<forms>
<form name="GroupRegistration"/>
</forms>
<conditions>
<equals field="Team:PreviousTeamId">
<string field="GroupRegistrationRecords:GroupRegistration:TeamId"/>
</equals>
</conditions></get>
<foreach record="SuchGroup" recordList="GroupRegistrationRecords">
<set field="SuchGroup:GroupRegistration:TeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
</foreach>
<get recordList="CoachRecords">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<contains field="CoachRecords:Coach:Team">
<string field="Team:PreviousTeamId"/>
</contains>
</conditions></get>
<foreach record="SuchCoach" recordList="CoachRecords">
<comment>-- coaches can be assigned to multiple teams, so update the "team list" in the coach record</comment>
<set field="SuchCoach:Coach:Team" arithmeticAsText="false">
<string value=" "/>
</set>
<comment>-- first add team names from any other records except this current one (which hasn't been submitted yet)</comment>
<get recordList="AnyOtherTeamsForThisCoach">
<forms>
<form name="Team"/>
</forms>
<conditions>
<and>
<equals field="AnyOtherTeamsForThisCoach:Team:CoachId">
<string field="SuchCoach:Coach:CoachId"/>
</equals>
<doesNotEqual field="AnyOtherTeamsForThisCoach:Team:TeamId">
<string field="Team:PreviousTeamId"/>
</doesNotEqual>
</and>
</conditions></get>
<foreach record="OtherTeam" recordList="AnyOtherTeamsForThisCoach">
<if>
<conditions>
<isBlank field="SuchCoach:Coach:Team" />
</conditions>
<trueSet>
<set field="SuchCoach:Coach:Team" arithmeticAsText="false">
<string field="OtherTeam:Team:TeamId"/>
</set>
</trueSet>
<falseSet>
<set field="SuchCoach:Coach:Team" arithmeticAsText="false">
<string field="SuchCoach:Coach:Team"/>
<string value=", "/>
<string field="OtherTeam:Team:TeamId"/>
</set>
</falseSet>
</if>
</foreach>
<comment>-- then add this newly edited team name</comment>
<if>
<conditions>
<isBlank field="SuchCoach:Coach:Team" />
</conditions>
<trueSet>
<set field="SuchCoach:Coach:Team" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
</trueSet>
<falseSet>
<set field="SuchCoach:Coach:Team" arithmeticAsText="false">
<string field="SuchCoach:Coach:Team"/>
<string value=", "/>
<string field="Team:TeamId"/>
</set>
</falseSet>
</if>
</foreach>
<get recordList="AssistantCoachRecords">
<forms>
<form name="AssistantCoachInfo"/>
</forms>
<conditions>
<equals field="AssistantCoachRecords:AssistantCoachInfo:TeamId">
<string field="Team:PreviousTeamId"/>
</equals>
</conditions></get>
<foreach record="SuchAssistantCoach" recordList="AssistantCoachRecords">
<set field="SuchAssistantCoach:AssistantCoachInfo:TeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
</foreach>
</trueSet>
</if>
<set field="Team:PreviousTeamId" arithmeticAsText="false">
<string field="Team:TeamId"/>
</set>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-Coach">
<set field="Coach:FullName" arithmeticAsText="false">
<string field="Coach:FirstName"/>
<string value=" "/>
<string field="Coach:LastName"/>
</set>
<if>
<conditions>
<isBlank field="Coach:CoachId" />
</conditions>
<trueSet>
<comment>-- New record</comment>
<set field="Coach:CoachId" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="PreviousCoaches">
<forms>
<form name="Coach"/>
</forms>
</get>
<foreach record="Record" recordList="PreviousCoaches">
<if>
<conditions>
<isLessThanOrEqualTo field="Coach:CoachId">
<string field="Record:Coach:CoachId"/>
</isLessThanOrEqualTo>
</conditions>
<trueSet>
<set field="Coach:CoachId" arithmeticAsText="false">
<add>
<operand field="Record:Coach:CoachId"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
</trueSet>
<falseSet>
<comment>-- The record has been edited</comment>
<get recordList="AllTeamsForThisCoach">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="AllTeamsForThisCoach:Team:CoachId">
<string field="Coach:CoachId"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="AllTeamsForThisCoach">
<set field="SuchTeam:Team:CoachFullName" arithmeticAsText="false">
<string field="Coach:FullName"/>
</set>
</foreach>
</falseSet>
</if>
<if>
<conditions>
<isBlank field="_InviteeID" />
</conditions>
<trueSet>
<comment>-- This is admin adding/editing the record</comment>
<show form="TeamAndCoachMenu"/>
</trueSet>
<falseSet>
<comment>-- The coach editing his record</comment>
<show form="CoachDashboard"/>
</falseSet>
</if>
</process>
<process name="Post-CoachToTeamAssignment">
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<get recordList="CoachRecords">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<equals field="CoachRecords:Coach:CoachId">
<string field="CoachToTeamAssignment:CoachId"/>
</equals>
</conditions></get>
<foreach record="Record" recordList="CoachRecords">
<get recordList="TeamRecords">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="TeamRecords:Team:TeamId">
<string field="CoachToTeamAssignment:TeamId"/>
</equals>
</conditions></get>
<foreach record="FoundTeam" recordList="TeamRecords">
<set field="FoundTeam:Team:CoachId" arithmeticAsText="false">
<string field="Record:Coach:CoachId"/>
</set>
<set field="FoundTeam:Team:CoachFullName" arithmeticAsText="false">
<string field="Record:Coach:FullName"/>
</set>
<set field="Record:Coach:Team" arithmeticAsText="false">
<string field="FoundTeam:Team:TeamId"/>
</set>
<set field="Message" arithmeticAsText="false">
<string field="Record:Coach:FullName"/>
<string value=" has been assigned to coach "/>
<string field="FoundTeam:Team:TeamId"/>
</set>
</foreach>
</foreach>
<if>
<conditions>
<mcContains field="CoachToTeamAssignment:Q3" value="a"/>
</conditions>
<trueSet>
<get recordList="Record List 79">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<equals field="Record List 79:Coach:CoachId">
<string field="CoachToTeamAssignment:Q4"/>
</equals>
</conditions></get>
<foreach record="SuchRecord" recordList="Record List 79">
<get recordList="Record List 80">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="Record List 80:Team:TeamId">
<string field="CoachToTeamAssignment:TeamId"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="Record List 80">
<set field="SuchTeam:Team:CoachId" arithmeticAsText="false">
<string field="SuchRecord:Coach:CoachId"/>
</set>
<set field="SuchTeam:Team:CoachFullName" arithmeticAsText="false">
<string field="SuchRecord:Coach:FullName"/>
</set>
<if>
<conditions>
<isBlank field="SuchRecord:Coach:Team" />
</conditions>
<trueSet>
<set field="SuchRecord:Coach:Team" arithmeticAsText="false">
<string field="SuchTeam:Team:TeamId"/>
</set>
</trueSet>
<falseSet>
<set field="SuchRecord:Coach:Team" arithmeticAsText="false">
<string field="SuchRecord:Coach:Team"/>
<string value=", "/>
<string field="SuchTeam:Team:TeamId"/>
</set>
</falseSet>
</if>
<set field="Message" arithmeticAsText="false">
<string field="SuchRecord:Coach:FullName"/>
<string value=" has been assigned to coach "/>
<string field="SuchTeam:Team:TeamId"/>
</set>
</foreach>
</foreach>
</trueSet>
</if>
<show form="CoachToTeamAssignment"/>
</process>
<process name="Post-EditCoach">
<edit form="Coach" submit="modify">
<conditions>
<equals field="Record:Coach:CoachId">
<string field="EditCoach:CoachId"/>
</equals>
</conditions>
</edit>
<comment>-- If the coach is not selected this statement will get executed</comment>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-DeleteTeam">
<delete><form name="Team"/><conditions>
<equals field="Record:Team:TeamId">
<string field="DeleteTeam:TeamId"/>
</equals>
</conditions></delete>
<get recordList="Player List">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Player List:Registration:TeamId">
<string field="DeleteTeam:TeamId"/>
</equals>
</conditions></get>
<foreach record="Team Player Record" recordList="Player List">
<set field="Team Player Record:Registration:TeamId" arithmeticAsText="false">
<string value=" "/>
</set>
</foreach>
<get recordList="Record List 104">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<contains field="Record List 104:Coach:Team">
<string field="DeleteTeam:TeamId"/>
</contains>
</conditions></get>
<foreach record="Team CoachRecord" recordList="Record List 104">
<set field="Team CoachRecord:Coach:Team" arithmeticAsText="false">
<string value=" "/>
</set>
<get recordList="Record List 105">
<forms>
<form name="Team"/>
</forms>
<conditions>
<and>
<equals field="Team CoachRecord:Coach:CoachId">
<string field="Record List 105:Team:CoachId"/>
</equals>
<doesNotEqual field="Record List 105:Team:TeamId">
<string field="DeleteTeam:TeamId"/>
</doesNotEqual>
</and>
</conditions></get>
<foreach record="SuchCoachedTeam" recordList="Record List 105">
<comment>-- coaches can be assigned to multiple teams, so update the "team list" in the coach record</comment>
<if>
<conditions>
<isBlank field="Team CoachRecord:Coach:Team" />
</conditions>
<trueSet>
<set field="Team CoachRecord:Coach:Team" arithmeticAsText="false">
<string field="SuchCoachedTeam:Team:TeamId"/>
</set>
</trueSet>
<falseSet>
<set field="Team CoachRecord:Coach:Team" arithmeticAsText="false">
<string field="Team CoachRecord:Coach:Team"/>
<string value=", "/>
<string field="SuchCoachedTeam:Team:TeamId"/>
</set>
</falseSet>
</if>
</foreach>
</foreach>
<comment>-- assistant coaches can be assigned to only one team, so no sense keeping the record around</comment>
<delete><form name="AssistantCoachInfo"/><conditions>
<equals field="Record:AssistantCoachInfo:TeamId">
<string field="DeleteTeam:TeamId"/>
</equals>
</conditions></delete>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-DeleteCoach">
<delete><form name="Coach"/><conditions>
<equals field="Record:Coach:CoachId">
<string field="DeleteCoach:CoachId"/>
</equals>
</conditions></delete>
<get recordList="CoachesTeams">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="CoachesTeams:Team:CoachId">
<string field="DeleteCoach:CoachId"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="CoachesTeams">
<set field="SuchTeam:Team:CoachId" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SuchTeam:Team:CoachFullName" arithmeticAsText="false">
<string value=" "/>
</set>
</foreach>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-UnassignCoachFromTeam">
<get recordList="TeamList">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="TeamList:Team:TeamId">
<string field="UnassignCoachFromTeam:TeamId"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="TeamList">
<get recordList="Record List 83">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<contains field="Record List 83:Coach:Team">
<string field="SuchTeam:Team:TeamId"/>
</contains>
</conditions></get>
<foreach record="SuchCoach" recordList="Record List 83">
<set field="SuchCoach:Coach:Team" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Coach" arithmeticAsText="false">
<string field="SuchCoach:Coach:CoachId"/>
</set>
</foreach>
<set field="SuchTeam:Team:CoachId" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SuchTeam:Team:CoachFullName" arithmeticAsText="false">
<string value=" "/>
</set>
</foreach>
<get recordList="Record List 106">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<equals field="Record List 106:Coach:CoachId">
<string field="Coach"/>
</equals>
</conditions></get>
<foreach record="SuchaCoach" recordList="Record List 106">
<get recordList="Record List 107">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="Record List 107:Team:CoachId">
<string field="Coach"/>
</equals>
</conditions></get>
<foreach record="SuchaTeam" recordList="Record List 107">
<if>
<conditions>
<isBlank field="SuchaCoach:Coach:Team" />
</conditions>
<trueSet>
<set field="SuchaCoach:Coach:Team" arithmeticAsText="false">
<string field="SuchaTeam:Team:TeamId"/>
</set>
</trueSet>
<falseSet>
<set field="SuchaCoach:Coach:Team" arithmeticAsText="false">
<string field="SuchaCoach:Coach:Team"/>
<string value=", "/>
<string field="SuchaTeam:Team:TeamId"/>
</set>
</falseSet>
</if>
</foreach>
</foreach>
<show form="TeamAndCoachMenu"/>
</process>
<process name="Post-EditMyRegistrationRecord">
<edit form="Registration" submit="modify">
<conditions>
<equals field="Record:Registration:RegID">
<string field="_InviteeID"/>
</equals>
</conditions>
</edit>
<comment>-- In case the record wasn't found</comment>
<show document="NoPlayerDash" reset="false"/>
</process>
<process name="Pre-Coach">
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<isNotBlank field="_InviteeID" />
</conditions>
<trueSet>
<comment>-- This is the case of coaches editing their records</comment>
<edit form="Coach" submit="modify">
<conditions>
<equals field="Record:Coach:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions>
</edit>
</trueSet>
</if>
<if>
<conditions>
<equals field="ParentCoachSelected">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<get recordList="ParentCoachList">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="ParentCoachList:Registration:RegID">
<string field="ParentCoaches:Q1"/>
</equals>
</conditions></get>
<foreach record="SelectedParent" recordList="ParentCoachList">
<set field="Coach:FirstName" arithmeticAsText="false">
<string field="SelectedParent:Registration:ParentFirstName"/>
</set>
<set field="Coach:LastName" arithmeticAsText="false">
<string field="SelectedParent:Registration:ParentLastName"/>
</set>
<set field="Coach:Email" arithmeticAsText="false">
<string field="SelectedParent:Registration:ParentEmail"/>
</set>
<set field="Coach:Phone1" arithmeticAsText="false">
<string field="SelectedParent:Registration:Phone1"/>
</set>
<set field="Coach:Phone2" arithmeticAsText="false">
<string field="SelectedParent:Registration:Phone2"/>
</set>
<set field="Coach:Street" arithmeticAsText="false">
<string field="SelectedParent:Registration:Address"/>
</set>
<set field="Coach:City" arithmeticAsText="false">
<string field="SelectedParent:Registration:City"/>
</set>
<set field="Coach:State" arithmeticAsText="false">
<string field="SelectedParent:Registration:State"/>
</set>
<set field="Coach:ZIP" arithmeticAsText="false">
<string field="SelectedParent:Registration:Zip"/>
</set>
</foreach>
</trueSet>
</if>
</process>
<process name="Post-CoachDashboard">
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="TeamList">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="TeamList:Team:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions></get>
<foreach record="Match" recordList="TeamList">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<show document="NoCoachDash" reset="false"/>
</trueSet>
<falseSet>
<show document="CoachDashboard" reset="false"/>
</falseSet>
</if>
</process>
<process name="Pre-CoachCommunicatorSetup">
<set field="RetrieveVariablesTargetForm" arithmeticAsText="false">
<string value="CoachCommunicator"/>
</set>
<show form="RetrieveCoachVariablesForAnotherForm"/>
</process>
<process name="Pre-CoachCommunicator">
<comment>-- check to see if this coach has sent previous messages</comment>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="PreviousEmails">
<forms>
<form name="CoachCommunicator"/>
</forms>
<conditions>
<equals field="PreviousEmails:CoachCommunicator:CoachName">
<string field="Coach"/>
</equals>
</conditions></get>
<foreach record="Record" recordList="PreviousEmails">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<comment>-- if not, initialize the recipient MCQ</comment>
<set field="CoachCommunicator:Recipient" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
<falseSet>
<comment>-- fetch the last message</comment>
<edit form="CoachCommunicator" submit="modify">
<conditions>
<equals field="Record:CoachCommunicator:CoachName">
<string field="Coach"/>
</equals>
</conditions>
</edit>
</falseSet>
</if>
</process>
<process name="Post-CoachCommunicator">
<comment>-- this is set in the Coach Dashboard, and we assume that's where we came from</comment>
<comment>-- it's used to store the last message sent by each coach</comment>
<set field="CoachCommunicator:CoachName" arithmeticAsText="false">
<string field="Coach"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="DashboardLinkPreviewVerbiage" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="a"/>
</conditions>
<trueSet>
<comment>-- send to all players and assistant coaches</comment>
<set field="ToField" arithmeticAsText="false">
<string value=" "/>
</set>
<get recordList="Record List 73">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="_InviteeID">
<string field="Record List 73:Team:CoachId"/>
</equals>
</conditions></get>
<foreach record="SelectedTeam" recordList="Record List 73">
<if>
<conditions>
<isBlank field="ToField" />
</conditions>
<trueSet>
<set field="ToField" arithmeticAsText="true">
<string field="SelectedTeam:Team:TeamId"/>
</set>
</trueSet>
<falseSet>
<set field="ToField" arithmeticAsText="true">
<string field="SelectedTeam:Team:TeamId"/>
<string value=", "/>
<string field="ToField"/>
</set>
</falseSet>
</if>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="b"/>
</conditions>
<trueSet>
<comment>-- send to selected players</comment>
<set field="ToField" arithmeticAsText="false">
<string value="Selected Player(s)"/>
</set>
<comment>-- send copy to assistant coaches?</comment>
<if>
<conditions>
<mcIsBlank field="CoachCommunicator:CopyAsstsWithPlayers" />
</conditions>
<trueSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="(A copy of this message will not be sent to assistant coaches)"/>
</set>
</trueSet>
<falseSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="(A copy of this message will be sent to assistant coaches)"/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcEquals field="CoachCommunicator:Recipient" value="a"/>
<mcEquals field="CoachCommunicator:Recipient" value="b"/>
</or>
</conditions>
<trueSet>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Player FirstName"/>
<string value="&gt;"/>
<string value=" or Parents of "/>
<string value="&lt;"/>
<string value="Player FirstName"/>
<string value="&gt;"/>
<string value=","/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Link" value="a"/>
</conditions>
<trueSet>
<set field="DashboardLinkPreviewVerbiage" arithmeticAsText="false">
<string value="A link to the Player&apos;s Dashboard will be included here."/>
</set>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="c"/>
</conditions>
<trueSet>
<comment>-- send to selected coaches</comment>
<set field="ToField" arithmeticAsText="false">
<string value="Selected Coach(es)"/>
</set>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Coach&apos;s First Name"/>
<string value="&gt;"/>
<string value=","/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="CoachCommunicator:CopyAsstsWithCoaches" />
</conditions>
<trueSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="(A copy of this message will not be sent to your assistant coaches)"/>
</set>
</trueSet>
<falseSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="(A copy of this message will be sent to your assistant coaches)"/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="d"/>
</conditions>
<trueSet>
<comment>-- send to Admin</comment>
<set field="ToField" arithmeticAsText="false">
<string field="AdminName"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="e"/>
</conditions>
<trueSet>
<comment>-- one or more assistant coaches</comment>
<set field="ToField" arithmeticAsText="false">
<string value="Selected Assistant Coach(es)"/>
</set>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Assistant&apos;s First Name"/>
<string value="&gt;"/>
<string value=","/>
</set>
</trueSet>
</if>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value=" "/>
</set>
</trueSet>
</if>
<set field="CCSelf" arithmeticAsText="false">
<string value="A copy of this message will not be sent to you."/>
</set>
<if>
<conditions>
<mcContains field="CoachCommunicator:CopySelf" value="a"/>
</conditions>
<trueSet>
<set field="CCSelf" arithmeticAsText="false">
<string value="A copy of this message will be sent to you."/>
</set>
</trueSet>
</if>
<set field="AttachedFile1" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcContains field="CoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Planning to attach files?</comment>
<if>
<conditions>
<and>
<isBlank field="CoachCommunicator:File1" />
<and>
<isBlank field="CoachCommunicator:File2" />
<isBlank field="CoachCommunicator:File3" />
</and>
</and>
</conditions>
<trueSet>
<comment>But didn't actually upload any?</comment>
<set field="AttachedFile1" arithmeticAsText="false">
<string value=" No file attachments were uploaded!"/>
</set>
</trueSet>
<falseSet>
<set field="AttachedFile1" arithmeticAsText="false">
<string value="Links to included file(s) will appear here."/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<show form="CoachCommunicatorSend"/>
</process>
<process name="Post-CoachCommunicatorSend">
<if>
<conditions>
<mcEquals field="CoachCommunicatorSend:Q1" value="b"/>
</conditions>
<trueSet>
<comment>-- edit the email</comment>
<show form="CoachCommunicatorSetup"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicatorSend:Q1" value="c"/>
</conditions>
<trueSet>
<comment>-- abandon the email</comment>
<show form="CoachDashboard"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="CoachCommunicatorSend:Q1" value="a"/>
</conditions>
<trueSet>
<comment>-- no option selected</comment>
<show form="CoachCommunicatorSend"/>
</trueSet>
</if>
<set field="MessageBody" arithmeticAsText="false">
<string field="CoachCommunicator:Body"/>
</set>
<set field="MessageClose" arithmeticAsText="false">
<string field="CoachCommunicator:Close"/>
</set>
<comment>Set variables used for uploaded file URL links in Letters</comment>
<if>
<conditions>
<mcContains field="CoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<set field="AttachedFile1" arithmeticAsText="false">
<string field="CoachCommunicator:File1"/>
</set>
<set field="AttachedFile2" arithmeticAsText="false">
<string field="CoachCommunicator:File2"/>
</set>
<set field="AttachedFile3" arithmeticAsText="false">
<string field="CoachCommunicator:File3"/>
</set>
</trueSet>
<falseSet>
<set field="AttachedFile1" arithmeticAsText="false">
<string value="omit"/>
</set>
<set field="AttachedFile2" arithmeticAsText="false">
<string value="omit"/>
</set>
<set field="AttachedFile3" arithmeticAsText="false">
<string value="omit"/>
</set>
</falseSet>
</if>
<set field="DearSir" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SendCount" arithmeticAsText="false">
<string value="0"/>
</set>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="a"/>
</conditions>
<trueSet>
<comment>-- sending to all players and assistant coaches</comment>
<comment>-- first handle the assistant coaches</comment>
<get recordList="AsstCoachList">
<forms>
<form name="AssistantCoachInfo"/>
</forms>
<conditions>
<equals field="AsstCoachList:AssistantCoachInfo:HeadCoachId">
<string field="_InviteeID"/>
</equals>
</conditions></get>
<foreach record="AsstCoach" recordList="AsstCoachList">
<if>
<conditions>
<mcEquals field="CoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="AsstCoach:AssistantCoachInfo:FirstName"/>
<string value=","/>
</set>
</trueSet>
</if>
<send>
<to addressField="AsstCoach:AssistantCoachInfo:Email"/>
<from addressField="CoachsEmail" aliasField="Coach"/>
<subject><field name="CoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
</foreach>
<comment>-- now get the player list</comment>
<get recordList="Players List">
<forms>
<form name="Registration"/>
<form name="Team"/>
</forms>
<conditions>
<and>
<equals field="Players List:Team:CoachId">
<string field="_InviteeID"/>
</equals>
<equals field="Players List:Team:TeamId">
<string field="Players List:Registration:TeamId"/>
</equals>
</and>
</conditions></get>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="b"/>
</conditions>
<trueSet>
<comment>-- sending to selected players</comment>
<comment>-- copy assistant coaches? handle that first</comment>
<get recordList="AsstCoachList">
<forms>
<form name="AssistantCoachInfo"/>
</forms>
<conditions>
<mcContains field="CoachCommunicator:CopyAsstsWithPlayers">
<string field="AsstCoachList:AssistantCoachInfo:TeamId"/>
</mcContains>
</conditions></get>
<foreach record="AsstCoach" recordList="AsstCoachList">
<if>
<conditions>
<mcEquals field="CoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="AsstCoach:AssistantCoachInfo:FirstName"/>
<string value=","/>
</set>
</trueSet>
</if>
<send>
<to addressField="AsstCoach:AssistantCoachInfo:Email"/>
<from addressField="CoachsEmail" aliasField="Coach"/>
<subject><field name="CoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
</foreach>
<comment>-- now get the player list</comment>
<get recordList="Players List">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="CoachCommunicator:PlayerChoice">
<string field="Players List:Registration:RegID"/>
</mcContains>
</conditions></get>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcEquals field="CoachCommunicator:Recipient">
<string value="a"/>
</mcEquals>
<mcEquals field="CoachCommunicator:Recipient" value="b"/>
</or>
</conditions>
<trueSet>
<comment>-- sending to all or to some players</comment>
<foreach record="Individual" recordList="Players List">
<if>
<conditions>
<mcEquals field="CoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="Individual:Registration:FirstName"/>
<string value=" or Parents of "/>
<string field="Individual:Registration:FirstName"/>
<string value=","/>
</set>
</trueSet>
</if>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
<comment>-- continue from here with Setting the variables needed to send Dashboard</comment>
<set field="DashboardLinkID" arithmeticAsText="false">
<string field="Individual:Registration:RegID"/>
</set>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Link" value="a"/>
</conditions>
<trueSet>
<send>
<to addressField="Individual:Registration:ParentEmail"/>
<from addressField="CoachsEmail" aliasField="Coach"/>
<subject><field name="CoachCommunicator:Subject"/></subject>
<body document="LetterWithPlayerDashboardLink" reset="false" showHeader="true"/>
</send>
</trueSet>
<falseSet>
<send>
<to addressField="Individual:Registration:ParentEmail"/>
<from addressField="CoachsEmail" aliasField="Coach"/>
<subject><field name="CoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
</falseSet>
</if>
<if>
<conditions>
<isNotBlank field="Individual:Registration:ParentEmail2" />
</conditions>
<trueSet>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Link" value="a"/>
</conditions>
<trueSet>
<send>
<to addressField="Individual:Registration:ParentEmail2"/>
<from addressField="CoachsEmail" aliasField="Coach"/>
<subject><field name="CoachCommunicator:Subject"/></subject>
<body document="LetterWithPlayerDashboardLink" reset="false" showHeader="true"/>
</send>
</trueSet>
<falseSet>
<send>
<to addressField="Individual:Registration:ParentEmail2"/>
<from addressField="CoachsEmail" aliasField="Coach"/>
<subject><field name="CoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
</falseSet>
</if>
</trueSet>
</if>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Message sent to "/>
<string field="SendCount"/>
<string value=" user(s)"/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="CoachCommunicator:Recipient" value="c"/>
</conditions>
<trueSet>
<comment>-- sending to other coaches</comment>
<get recordList="Record List 82">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<mcContains field="CoachCommunicator:CoachChoice">
<string field="Record List 82:Coach:CoachId"/>
</mcContains>
</conditions></get>
<foreach record="IndividualCoach" recordList="Record List 82">
<if>
<conditions>
<mcEquals field="CoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="IndividualCoach:Coach:FirstName"/>
<string value=","/>
</set>
</trueSet>
</if>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
<send>
<to addressField="IndividualCoach:Coach:Email"/>
<from addressField="CoachsEmail" aliasField="Coach"/>
<subject><field name="CoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
</foreach>
