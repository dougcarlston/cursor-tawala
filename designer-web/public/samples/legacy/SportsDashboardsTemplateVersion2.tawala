<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240" color="000000"><b>Registration Records: Parents who have volunteered for a specific </b></font><font size="240"><b>Volunteer Activity: </b></font><font size="240"><b><display-mcq-label version="1"><field-name>ViewVolunteerData:Q2</field-name><display>label_only</display></display-mcq-label></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ViewVolunteerData" project="">Return to View Volunteer Data</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Return to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b><itemization-table version="2"><show-print-control>true</show-print-control><column><header><string value="Parent First"/>
</header><contents><field name="Record:Registration:ParentFirstName" /></contents></column><column><header><string value="Parent Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Player First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Player Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><field name="Phone1Lab"/>
</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header><field name="Phone2Lab"/>
</header><contents><field name="Record:Registration:Phone2" /></contents></column><column><header><field name="Phone3Lab"/>
</header><contents><field name="Record:Registration:Phone3" /></contents></column><conditions><form name="Registration" /><conditions>
<mcContains field="Record:Registration:VolunteerActivities">
<string field="ViewVolunteerData:Q2"/>
</mcContains>
</conditions></conditions></itemization-table></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ViewVolunteerData" project="">Return to View Volunteer Data</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Return to Administrator Dashboard</invitation></u></font></paragraph>
</xmlData>
