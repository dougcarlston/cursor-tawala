</set>
<set field="Temp2" arithmeticAsText="false">
<string field="CoachRecord:Coach:Team"/>
</set>
<append document="CoachEmailRecipients" appendage="EmailRecipientListItem"/>
</trueSet>
</if>
</trueSet>
<falseSet>
