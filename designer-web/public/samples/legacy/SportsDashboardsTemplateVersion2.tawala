<form name="PasswordCheck" startPoint="false" themePath="mvsc" process="Post-PasswordCheck">
<items>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Please enter your Administrator Password: </font><blank label="a" length="20" required="false" alternateLabel="PWMatch"/></paragraph></fib>
</items>
