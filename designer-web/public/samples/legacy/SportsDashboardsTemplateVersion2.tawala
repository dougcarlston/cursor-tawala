<document name="PlayerDashboardMainBody">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2430"><division indent="0" align="right"><font><b>Your Team:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="Team"/></font></division></cell><cell width="2910"><division indent="0" align="right"><font>Payment Status:</font></division></cell><cell width="255"></cell><cell width="2235"><division indent="0" align="left"><font><field name="PaymentStatusMessage"/></font><sp/></division></cell></row><row><cell width="2430"><division indent="0" align="right"><font><b>Division:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="DivName"/></font></division></cell><cell width="2910"><division indent="0" align="right"><font>Waiver Status:</font></division></cell><cell width="255"></cell><cell width="2235"><division indent="0" align="left"><font><field name="WaiverStatusMessage"/></font></division></cell></row><row><cell width="2430"><division indent="0" align="right"><font><b>League:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="League"/></font></division></cell><cell width="2910"></cell><cell width="255"></cell><cell width="2235"></cell></row><row><cell width="2430"><division indent="0" align="right"><font><b>Season:</b></font></division></cell><cell width="272"></cell><cell width="2698"><division indent="0" align="left"><font><field name="SeasonYr"/></font></division></cell><cell width="2910"></cell><cell width="255"></cell><cell width="2235"></cell></row><row><cell width="2430"></cell><cell width="272"></cell><cell width="2698"></cell><cell width="2910"></cell><cell width="255"></cell><cell width="2235"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2415"><division indent="0" align="right"><font><b>Coach:</b></font></division></cell><cell width="272"></cell><cell width="2218"><division indent="0" align="left"><font><field name="Coach"/></font></division></cell><cell width="3390"><division indent="0" align="right"><font><b><field name="League"/></b></font><font><b> Administrator:</b></font></division></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminName"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Coach's Phone:</b></font></division></cell><cell width="272"></cell><cell width="2218"><division indent="0" align="left"><font><field name="CoachsPhone"/></font></division></cell><cell width="3390"><division indent="0" align="right"><font><b><field name="League"/></b></font><font><b> Phone:</b></font></division></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminsPhone"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Alternate Phone:</b></font></division></cell><cell width="272"></cell><cell width="2218"><division indent="0" align="left"><font><field name="CoachsPhone1"/></font></division></cell><cell width="3390"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminEmail"/></font></division></cell></row><row><cell width="2415"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="2218"><division indent="0" align="left"><font><field name="CoachsEmail"/></font></division></cell><cell width="3390"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminAdrss"/></font></division></cell></row><row><cell width="2415"></cell><cell width="272"></cell><cell width="2218"></cell><cell width="3390"></cell><cell width="240"></cell><cell width="2265"><division indent="0" align="left"><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><sp/><font><field name="AdminsZIP"/></font><sp/></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b><field name="CoachFlash"/></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="840"></cell><cell width="9960"><division indent="0" align="left"><font face="Arial" size="220" color="004000"><field name="FlashMessage"/></font></division></cell></row></table>
</xmlData>
</document>
<document name="PlayerTeamRoster">
