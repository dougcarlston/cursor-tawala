<string value="Yes"/>
</set>
</falseSet>
</if>
<show form="Coach"/>
</process>
<process name="Pre-EditOrDeleteRegistration">
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</process>
<process name="Post-RegisterAnotherChild">
<if>
<conditions>
<equals field="RegViewFlag">
<string value="Closed"/>
</equals>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Sorry, the registration period is closed. Please contact the administrator."/>
</set>
<show document="Message" reset="false"/>
<show form="PlayerDash"/>
</trueSet>
</if>
<set field="PrefillRegistrationForm" arithmeticAsText="false">
<string value="Yes"/>
</set>
<get recordList="Record List">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Record List:Registration:RegID">
<string field="_InviteeID"/>
</equals>
</conditions></get>
<foreach record="CurrentPlayer" recordList="Record List">
<set field="PrefillParentFirstName" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:ParentFirstName"/>
</set>
<set field="PrefillParentLastName" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:ParentLastName"/>
</set>
<set field="PrefillAddress" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Address"/>
</set>
<set field="PrefillCity" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:City"/>
</set>
<set field="PrefillState" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:State"/>
</set>
<set field="PrefillZIP" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Zip"/>
</set>
<set field="PrefillParentEmail" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:ParentEmail"/>
</set>
<set field="PrefillParentEmail2" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:ParentEmail2"/>
</set>
<set field="PrefillPhone1" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Phone1"/>
</set>
<set field="PrefillPhone2" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Phone2"/>
</set>
<set field="PrefillPhone3" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Phone3"/>
</set>
<set field="PrefillMedPlanName" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:MedPlanName"/>
</set>
<set field="PrefillMedPlanNumber" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:MedPlanNumber"/>
</set>
<set field="PrefillDocName" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:DocName"/>
</set>
<set field="PrefillDocPhone" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:DocPhone"/>
</set>
<set field="PrefillDocAddress" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:DocAddress"/>
</set>
<set field="PrefillParent2FirstName" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Parent2FirstName"/>
</set>
<set field="PrefillParent2LastName" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Parent2LastName"/>
</set>
<set field="PrefillAddress2" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Address2"/>
</set>
<set field="PrefillCity2" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:City2"/>
</set>
<set field="PrefillState2" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:State2"/>
</set>
<set field="PrefillZip2" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Zip2"/>
</set>
<set field="PrefillParish" arithmeticAsText="false">
<string field="CurrentPlayer:Registration:Parish"/>
</set>
</foreach>
<show form="Registration"/>
</process>
<process name="Pre-ShowAllRosters">
<comment>-- The idea is to loop through all the Team records, displaying one at a time,</comment>
<comment>-- presumably so the Admin can print each one out</comment>
<comment>-- How this works:</comment>
<comment>--  1. Set "Initialized" flag to "false" in the calling Process</comment>
<comment>--  2. Clear the "printed?" flag (hidden field) in all the Team records</comment>
<comment>--  3. Set "Initialized" flag to "true" so that we only do the above step once per visit</comment>
<comment>--  4. Count the records that have not yet been displayed (printed)</comment>
<comment>--  5. If there are none, we are finished; return to the dashboard</comment>
<comment>--  6. Otherwise, show the current record; it's "printed?" flag will be set in the post-Process</comment>
<if>
<conditions>
<doesNotEqual field="Initialized">
<string value="true"/>
</doesNotEqual>
</conditions>
<trueSet>
<get recordList="AllTeams">
<forms>
<form name="Team"/>
</forms>
</get>
<foreach record="IndividualTeam" recordList="AllTeams">
<comment>"clear" the hidden field in each team; it will get set to "Yes" in the post-Process</comment>
<set field="IndividualTeam:Team:Printed?" arithmeticAsText="false">
<string value="No"/>
</set>
</foreach>
<set field="Initialized" arithmeticAsText="false">
<string value="true"/>
</set>
</trueSet>
</if>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<comment>get the list of teams that have not yet been displayed ("printed")</comment>
<get recordList="UnprintedTeamList">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="UnprintedTeamList:Team:Printed?">
<string value=" No"/>
</equals>
</conditions></get>
<foreach record="UnprintedTeam" recordList="UnprintedTeamList">
<comment>set the Team variable for use in the displayed tables</comment>
<set field="Team" arithmeticAsText="false">
<string field="UnprintedTeam:Team:TeamId"/>
</set>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<comment>no unprinted records found; return to dashboard</comment>
<show form="AdminDash"/>
</trueSet>
</if>
</process>
<process name="Post-ShowAllRosters">
<comment>get the record for the Team we just displayed</comment>
<get recordList="AllTeams">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="AllTeams:Team:TeamId">
<string field="Team"/>
</equals>
</conditions></get>
<foreach record="SuchDisplayedTeam" recordList="AllTeams">
<comment>set its flag so it won't be displayed again during this visit (see pre-Process)</comment>
<set field="SuchDisplayedTeam:Team:Printed?" arithmeticAsText="false">
<string value="Yes"/>
</set>
</foreach>
<comment>loop back to see if there is another Team to display</comment>
<show form="ShowAllRosters"/>
</process>
<process name="Post-Divisions">
<if>
<conditions>
<isBlank field="Divisions:DivisionID" />
</conditions>
<trueSet>
<set field="Divisions:DivisionID" arithmeticAsText="false">
<string value="1"/>
</set>
<get recordList="All Divisions">
<forms>
<form name="Divisions"/>
</forms>
</get>
<foreach record="Current Division" recordList="All Divisions">
<if>
<conditions>
<isLessThanOrEqualTo field="Divisions:DivisionID">
<string field="Current Division:Divisions:DivisionID"/>
</isLessThanOrEqualTo>
</conditions>
<trueSet>
<set field="Divisions:DivisionID" arithmeticAsText="false">
<add>
<operand field="Current Division:Divisions:DivisionID"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
</foreach>
</trueSet>
</if>
<show form="ManageDivisions"/>
</process>
<process name="Post-PlayerDash">
<show form="PlayerDashDisplay"/>
</process>
<process name="Post-PlayerDashDisplay">
<if>
<conditions>
<isNotBlank field="PlayerID" />
</conditions>
<trueSet>
<if>
<conditions>
<isBlank field="Team" />
</conditions>
<trueSet>
<set field="Team" arithmeticAsText="false">
<string value="Not yet assigned"/>
</set>
</trueSet>
</if>
<show document="PlayerDashboardHeader" reset="false"/>
<if>
<conditions>
<equals field="PaymentStatusMessage">
<string value="Not yet received"/>
</equals>
</conditions>
<trueSet>
<show document="PlayerDashboardPayNowLink" reset="false"/>
</trueSet>
</if>
<show document="PlayerDashboardMainBody" reset="false"/>
<if>
<conditions>
<and>
<equals field="TeamViewFlag">
<string value="On"/>
</equals>
<doesNotEqual field="Team">
<string value="Not yet assigned"/>
</doesNotEqual>
</and>
</conditions>
<trueSet>
<show document="PlayerTeamRoster" reset="false"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="EnableDonations">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<show document="NavigationToDonationPage" reset="false"/>
</trueSet>
</if>
</trueSet>
<falseSet>
<show document="NoPlayerDash" reset="false"/>
</falseSet>
</if>
</process>
<process name="Pre-PlayerCommunicatorSetup">
<comment>-- need to initialize both Admin and Player setup variables</comment>
<comment>-- so this will pass through both "RetrieveXxxVariables..." forms</comment>
<set field="RetrieveVariablesTargetForm" arithmeticAsText="false">
<string value="PlayerCommunicator"/>
</set>
<show form="RetrieveAdminVariablesForAnotherForm"/>
</process>
<process name="Pre-PlayerCommunicator">
<comment>-- check for a previous message sent by this player</comment>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="PreviousEmails">
<forms>
<form name="PlayerCommunicator"/>
</forms>
<conditions>
<equals field="PreviousEmails:PlayerCommunicator:PlayerIdentification">
<string field="PlayerID"/>
</equals>
</conditions></get>
<foreach record="Record" recordList="PreviousEmails">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<comment>-- if none, initialize the recipient MCQ</comment>
<set field="PlayerCommunicator:Q1" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
<falseSet>
<comment>-- fetch the previous message</comment>
<edit form="PlayerCommunicator" submit="modify">
<conditions>
<equals field="Record:PlayerCommunicator:PlayerIdentification">
<string field="PlayerID"/>
</equals>
</conditions>
</edit>
</falseSet>
</if>
</process>
<process name="Post-PlayerCommunicator">
<if>
<conditions>
<and>
<doesNotEqual field="TeamViewFlag">
