</add>
</set>
<if>
<conditions>
<equals field="BuildRecipientList">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<set field="Temp1" arithmeticAsText="false">
<string field="CoachRecord:Coach:FullName"/>
</set>
<set field="Temp2" arithmeticAsText="false">
<string field="CoachRecord:Coach:Team"/>
</set>
<append document="CoachEmailRecipients" appendage="EmailRecipientListItem"/>
</trueSet>
</if>
<comment>Handle assistant coaches from SELECTED Divisions here, while we have the team ID at hand</comment>
<get recordList="AsstCoachList">
<forms>
<form name="AssistantCoachInfo"/>
</forms>
<conditions>
<equals field="AsstCoachList:AssistantCoachInfo:TeamId">
<string field="SuchTeam:Team:TeamId"/>
</equals>
</conditions></get>
<foreach record="AsstCoach" recordList="AsstCoachList">
<set field="SendAssistantCoachCount" arithmeticAsText="false">
<add>
<operand field="SendAssistantCoachCount"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<equals field="BuildRecipientList">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<set field="Temp1" arithmeticAsText="false">
<string field="AsstCoach:AssistantCoachInfo:FullName"/>
</set>
<set field="Temp2" arithmeticAsText="false">
<string field="AsstCoach:AssistantCoachInfo:TeamId"/>
</set>
<append document="AssistantCoachEmailRecipients" appendage="EmailRecipientListItem"/>
</trueSet>
</if>
</foreach>
</trueSet>
</if>
</foreach>
</falseSet>
</if>
</foreach>
<if>
<conditions>
<mcDoesNotEqual field="Communicator:Q1" value="b"/>
</conditions>
<trueSet>
<comment>Handle assistant coaches from ALL Divisions here; simplest because we just send to all</comment>
<get recordList="AsstCoachList">
<forms>
<form name="AssistantCoachInfo"/>
</forms>
</get>
<foreach record="AsstCoach" recordList="AsstCoachList">
<set field="SendAssistantCoachCount" arithmeticAsText="false">
<add>
<operand field="SendAssistantCoachCount"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<equals field="BuildRecipientList">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<set field="Temp1" arithmeticAsText="false">
<string field="AsstCoach:AssistantCoachInfo:FullName"/>
</set>
<set field="Temp2" arithmeticAsText="false">
<string field="AsstCoach:AssistantCoachInfo:TeamId"/>
</set>
<append document="AssistantCoachEmailRecipients" appendage="EmailRecipientListItem"/>
</trueSet>
</if>
</foreach>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2">
<string value="c"/>
</mcEquals>
</conditions>
<trueSet>
<comment>Send to players and coaches of SELECTED TEAMS</comment>
<set field="ToField" arithmeticAsText="true">
<string field="ToField"/>
<string value=" / Selected Teams / Players, Coaches and Assistant Coaches"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Player&apos;s First Name"/>
<string value="&gt;"/>
<string value=" or Parents of "/>
<string value="&lt;"/>
<string value="Player&apos;s First Name"/>
<string value="&gt;"/>
<string value=" (or "/>
<string value="&lt;"/>
<string value="Coach&apos;s First Name"/>
<string value="&gt;"/>
<string value="),"/>
</set>
<set field="DashboardLinkPreviewLinkText" arithmeticAsText="true">
<string value="[Player/Coach] Dashboard"/>
</set>
<set field="DashboardLinkPreviewVerbiage" arithmeticAsText="false">
<string value="[Different wording will appear here for players and coaches]"/>
</set>
<if>
<conditions>
<mcDoesNotEqual field="Communicator:Q1" value="b"/>
</conditions>
<trueSet>
<comment>ALL Divisions</comment>
<get recordList="Record List 69">
<forms>
<form name="Team"/>
</forms>
<conditions>
<mcContains field="Communicator:TeamIds">
<string field="Record List 69:Team:TeamId"/>
</mcContains>
</conditions></get>
</trueSet>
<falseSet>
<comment>SELECTED Divisions</comment>
<get recordList="Record List 69">
<forms>
<form name="Team"/>
</forms>
<conditions>
<mcContains field="Communicator:DivTeamIDs">
<string field="Record List 69:Team:TeamId"/>
</mcContains>
</conditions></get>
</falseSet>
</if>
<foreach record="SuchRecord" recordList="Record List 69">
<comment>First, send to players</comment>
<get recordList="Record List 70">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="Record List 70:Registration:TeamId">
<string field="SuchRecord:Team:TeamId"/>
</equals>
</conditions></get>
<foreach record="ChosenTeamPlayer" recordList="Record List 70">
<set field="SendPlayerEmail1Count" arithmeticAsText="false">
<add>
<operand field="SendPlayerEmail1Count"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<isNotBlank field="ChosenTeamPlayer:Registration:ParentEmail2" />
</conditions>
<trueSet>
<set field="SendPlayerEmail2Count" arithmeticAsText="false">
<add>
<operand field="SendPlayerEmail2Count"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="BuildRecipientList">
<string value="true"/>
</equals>
