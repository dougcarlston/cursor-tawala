<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3840"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3360"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row><row><cell width="3840"><division indent="0" align="left"><sp/></division></cell><cell width="3360"></cell><cell width="3600"></cell></row></table></text>
