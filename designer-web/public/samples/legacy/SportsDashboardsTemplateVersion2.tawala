<form name="AssistantCoachCommunicatorSetup" startPoint="false" themePath="mvsc" preProcess="Pre-AssistantCoachCommunicatorSetup">
</form>
<form name="AssistantCoachCommunicator" startPoint="false" themePath="mvsc" process="Post-AssistantCoachCommunicator" preProcess="Pre-AssistantCoachCommunicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AssistantCoachDashboard" project="">Back to Assistant Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="Recipient" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">To whom do you wish to send this message?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All of the players and coaches on my team</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Coach </font><font face="Arial" size="200" color="000000"><field name="Coach"/></font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All coaches on my team</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Some of the players on my team</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more coaches on other teams</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The administrator, </font><font face="Arial" size="200" color="000000"><field name="AdminName"/></font></paragraph></choice></mc>
<mc label="Q2" alternateLabel="CopySelf" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Click here to send a copy of the message to yourself</font></paragraph></choice></mc>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject: </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q4" alternateLabel="Salutation" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of salutation for emails</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Include a personalized salutation (e.g., </font><font face="Arial" size="200" color="000000"><i>"Dear &lt;Player FirstName&gt; or Parents of &lt;Player FirstName&gt;")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't include personalized salutation</font></paragraph></choice></mc>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<mc label="Q7" alternateLabel="AttachFiles" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box if you want to "attach" files to your message</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="e"/>
</conditions>
<trueSet>
<skip to="Coaches"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="AssistantCoachCommunicator:Recipient" value="d"/>
</conditions>
<trueSet>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Attach files?</comment>
<skip to="UploadFiles"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</trueSet>
</if>
</skipInstructions>
<text label="T3" alternateLabel="Players" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AssistantCoachDashboard" project="">Back to Assistant Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q8" alternateLabel="PlayerChoice" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the player(s) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:FirstName"/>
<string value="#"/>
<field name="Record:Registration:LastName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<equals field="Record:Registration:TeamId">
<string field="Team"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q9" alternateLabel="CopyCoachesWithPlayers" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send copy of message to the other coaches on the team.</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Attach files?</comment>
<skip to="UploadFiles"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T4" alternateLabel="Coaches" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AssistantCoachDashboard" project="">Back to Assistant Coach Dashboard</invitation></u></font></paragraph></text>
<mc label="Q10" alternateLabel="CoachChoice" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choose the coach(es) to whom you wish to send this message:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Coach:FullName"/>
<string value=" ("/>
<field name="Record:Coach:Team"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Coach:CoachId"/>
</value-expression><sort-expression><field name="Record:Coach:Team"/>
</sort-expression><record-selector><form name="Coach" /><conditions>
<doesNotEqual field="Record:Coach:CoachId">
<string field="CoachID"/>
</doesNotEqual>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q11" alternateLabel="CopyCoachesWithCoaches" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send copy of message to the other coaches on the team.</font></paragraph></choice></mc>
<field name="AssistantCoachId"/>
<skipInstructions>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Attach files?</comment>
<skip to="UploadFiles"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T5" alternateLabel="UploadFiles" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AssistantCoachDashboard" project="">Back to Assistant Coach Dashboard</invitation></u></font></paragraph></text>
<text label="T6" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You may upload up to three files to be included with your email. These files will not actually be attached to the email, but links to them will appear at the bottom of the email message. When your recipients click on the link they will be able to view the file(s).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Use the "Browse..." buttons below to select a file or files on your computer. When you click the Submit button the file(s) will be uploaded to the server so they will be accessible by your recipients.</font></paragraph></text>
<file label="F1" alternateLabel="File1" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 1:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F2" alternateLabel="File2" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 2:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F3" alternateLabel="File3" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 3:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
</items>
</form>
<form name="AssistantCoachCommunicatorSend" startPoint="false" themePath="mvsc" process="Post-AssistantCoachCommunicatorSend">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AssistantCoachDashboard" project="">Back to Assistant Coach Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="705"><row><cell width="10095"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>From: </b></font><font><field name="AsstCoachName"/></font><font face="Arial" size="200" color="000000"> (</font><font face="Arial" size="200" color="000000"><field name="AsstCoachEmail"/></font><font face="Arial" size="200" color="000000">)</font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>Date: </b></font><font>Today</font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><i><field name="CCSelf"/></i></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="AssistantCoachCommunicator:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="705"><row><cell width="10095"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><field name="AssistantCoachCommunicator:Body"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font><field name="AssistantCoachCommunicator:Close"/></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font color="0000C0"><i><u><field name="AttachedFile1"/></u></i></font></division></cell></row><row><cell width="10095"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="10095"><division indent="0" align="left"><font color="000000"><i><field name="CopyAsstCoaches"/></i></font></division></cell></row></table></text>
<mc label="Q1" alternateLabel="Action" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send the email out</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Assistant Coach's Dashboard</font></paragraph></choice></mc>
</items>
