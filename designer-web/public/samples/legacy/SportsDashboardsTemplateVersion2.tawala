<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Item:  </font><blank label="a" length="20" required="false" alternateLabel="UniformId"/></paragraph></fib>
</items>
