</equals>
</conditions></get>
<foreach record="Such Player" recordList="Current Player">
<if>
<conditions>
<equals field="Such Player:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="PaymentStatus" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
<falseSet>
<comment>-- This code is duplicated in Post-PlayerDash. Make sure to keep them in synch.</comment>
<set field="PaymentStatus" arithmeticAsText="false">
<string value="No"/>
</set>
<get recordList="OnlinePaymentRecords">
<forms>
<form name="OnlinePayment"/>
</forms>
<conditions>
<equals field="OnlinePaymentRecords:OnlinePayment:RegID">
<string field="_InviteeID"/>
</equals>
</conditions></get>
<foreach record="SuchRecord" recordList="OnlinePaymentRecords">
<if>
<conditions>
<or>
<equals field="SuchRecord:OnlinePayment:Status">
<string value="Completed"/>
</equals>
<equals field="SuchRecord:OnlinePayment:Status">
<string value="Pending"/>
</equals>
</or>
</conditions>
<trueSet>
<set field="PaymentStatus" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="SuchPlayer:Registration:PaymentReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="SuchPlayer:Registration:PaidAmount" arithmeticAsText="false">
<string field="SuchRecord:OnlinePayment:AmountPaid"/>
</set>
<set field="SuchPlayer:Registration:PaymentMethod" arithmeticAsText="false">
<string value="PayPal"/>
</set>
</trueSet>
</if>
</foreach>
</falseSet>
</if>
</foreach>
