<form name="TeamViewToggle" startPoint="false" themePath="mvsc" process="Post-TeamViewToggle" preProcess="RetrieveAdminSetupVariables">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="TeamViewFlag">
<string value="On"/>
</equals>
</conditions>
<trueSet>
<set field="TeamViewToggle:ShowTeams" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
<falseSet>
<set field="TeamViewToggle:ShowTeams" arithmeticAsText="false">
<string value="b"/>
</set>
</falseSet>
</if>
</skipInstructions>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Toggle Team View on Player Dashboards</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="ShowTeams" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Show team and coach information on Player Dashboards</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't show team and coach information on Player Dashboards yet</font></paragraph></choice></mc>
</items>
</form>
