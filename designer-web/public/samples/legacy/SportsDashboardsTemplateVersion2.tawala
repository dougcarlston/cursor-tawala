<trueSet>
<set field="Temp1" arithmeticAsText="false">
<string field="ChosenTeamPlayer:Registration:FirstName"/>
<string value=" "/>
<string field="ChosenTeamPlayer:Registration:LastName"/>
</set>
<set field="Temp2" arithmeticAsText="false">
<string field="ChosenTeamPlayer:Registration:TeamId"/>
</set>
<append document="PlayerEmailRecipients" appendage="EmailRecipientListItem"/>
</trueSet>
</if>
</foreach>
<comment>Next, send to coaches</comment>
<set field="CoachID" arithmeticAsText="false">
<string field="SuchRecord:Team:CoachId"/>
</set>
<get recordList="Coach List">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<equals field="Coach List:Coach:CoachId">
<string field="CoachID"/>
</equals>
</conditions></get>
<foreach record="ChosenCoach" recordList="Coach List">
<set field="SendCoachCount" arithmeticAsText="false">
<add>
<operand field="SendCoachCount"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<equals field="BuildRecipientList">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<set field="Temp1" arithmeticAsText="false">
<string field="ChosenCoach:Coach:FullName"/>
</set>
<set field="Temp2" arithmeticAsText="false">
<string field="ChosenCoach:Coach:Team"/>
</set>
<append document="CoachEmailRecipients" appendage="EmailRecipientListItem"/>
</trueSet>
</if>
</foreach>
<comment>Finally, send to assistant coaches</comment>
<get recordList="AsstCoachList">
<forms>
<form name="AssistantCoachInfo"/>
</forms>
<conditions>
<equals field="AsstCoachList:AssistantCoachInfo:TeamId">
<string field="SuchRecord:Team:TeamId"/>
</equals>
</conditions></get>
<foreach record="AsstCoach" recordList="AsstCoachList">
<set field="SendAssistantCoachCount" arithmeticAsText="false">
<add>
<operand field="SendAssistantCoachCount"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<equals field="BuildRecipientList">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<set field="Temp1" arithmeticAsText="false">
<string field="AsstCoach:AssistantCoachInfo:FullName"/>
</set>
<set field="Temp2" arithmeticAsText="false">
<string field="AsstCoach:AssistantCoachInfo:TeamId"/>
</set>
<append document="AssistantCoachEmailRecipients" appendage="EmailRecipientListItem"/>
</trueSet>
</if>
</foreach>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="d"/>
</conditions>
<trueSet>
<comment>Send to selected coach or coaches</comment>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="false"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Coach&apos;s First Name"/>
<string value="&gt;"/>
<string value=","/>
</set>
<set field="DashboardLinkPreviewLinkText" arithmeticAsText="true">
<string value="Coach Dashboard"/>
</set>
<set field="DashboardLinkPreviewVerbiage" arithmeticAsText="false">
<string field="DashboardLinkForCoachVerbiage"/>
</set>
<if>
<conditions>
<or>
<mcEquals field="Communicator:Q1" value="a"/>
<mcIsBlank field="Communicator:Q1" />
