<form name="Grade" startPoint="false" themePath="mvsc" process="Post-Grade">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="PrepopulateGrades">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add/Edit Grade</font></paragraph></heading>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Grade:  </font><blank label="a" length="20" required="true" alternateLabel="Name"/></paragraph></fib>
<field name="Fee"/>
</items>
</form>
<form name="Coach" startPoint="false" themePath="mvsc" process="Post-Coach" preProcess="Pre-Coach">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Coach Contact Information</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams and Coaches</invitation></u></font></paragraph><displayConditions>
<isBlank field="_InviteeID" />
</displayConditions></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph><displayConditions>
<isNotBlank field="_InviteeID" />
</displayConditions></text>
<text label="T3" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="A00000"><b><i><field name="Message"/></i></b></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">First Name:  </font><blank label="a" length="20" required="false" alternateLabel="FirstName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Last Name:  </font><blank label="b" length="20" required="false" alternateLabel="LastName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="c" length="22" required="false" alternateLabel="Email"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone: </font><blank label="d" length="20" required="false" alternateLabel="Phone1"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Alternate Phone: </font><blank label="e" length="19" required="false" alternateLabel="Phone2"/></paragraph></fib>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Street:  </font><blank label="a" length="20" required="false" alternateLabel="Street"/></paragraph></fib>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City: </font><blank label="a" length="20" required="false" alternateLabel="City"/></paragraph></fib>
<fib label="Q4" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">State: </font><blank label="a" length="6" required="false" alternateLabel="State"/></paragraph></fib>
<fib label="Q5" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Zip: </font><blank label="a" length="6" required="false" alternateLabel="ZIP"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<or>
<isBlank field="Coach:FirstName" />
<or>
<isBlank field="Coach:LastName" />
<isBlank field="Coach:Email" />
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You must enter at least First Name, Last Name and Email"/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<doesNotContain field="Coach:Email">
<string value="@"/>
</doesNotContain>
<or>
<contains field="Coach:Email">
<string value=" "/>
</contains>
<or>
<contains field="Coach:Email">
<string value=","/>
</contains>
<doesNotContain field="Coach:Email">
<string value="."/>
</doesNotContain>
</or>
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Email address appears invalid. Please correct it."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<field name="CoachId"/>
<field name="FullName"/>
<field name="Team"/>
</items>
</form>
<form name="AssistantCoachInfo" startPoint="false" themePath="mvsc" process="Post-AssistantCoachInfo" preProcess="Pre-AssistantCoachInfo">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Assistant Coach Information</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="CoachDashboard" project="">Back to Coach Dashboard</invitation></u></font></paragraph><displayConditions>
<isBlank field="AsstCoachID" />
</displayConditions></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AssistantCoachDashboard" project="">Back to Assistant Coach Dashboard</invitation></u></font></paragraph><displayConditions>
<isNotBlank field="AsstCoachID" />
</displayConditions></text>
<text label="T3" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="A00000"><b><i><field name="Message"/></i></b></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">First Name:  </font><blank label="a" length="20" required="false" alternateLabel="FirstName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Last Name:  </font><blank label="b" length="20" required="false" alternateLabel="LastName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="c" length="22" required="false" alternateLabel="Email"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone: </font><blank label="d" length="20" required="false" alternateLabel="Phone1"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Alternate Phone: </font><blank label="e" length="19" required="false" alternateLabel="Phone2"/></paragraph></fib>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Street:  </font><blank label="a" length="20" required="false" alternateLabel="Street"/></paragraph></fib>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City: </font><blank label="a" length="20" required="false" alternateLabel="City"/></paragraph></fib>
<fib label="Q4" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">State: </font><blank label="a" length="6" required="false" alternateLabel="State"/></paragraph></fib>
<fib label="Q5" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Zip: </font><blank label="a" length="6" required="false" alternateLabel="ZIP"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<or>
<isBlank field="AssistantCoachInfo:FirstName" />
<or>
<isBlank field="AssistantCoachInfo:LastName" />
<isBlank field="AssistantCoachInfo:Email" />
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You must enter at least First Name, Last Name and Email"/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<doesNotContain field="AssistantCoachInfo:Email">
<string value="@"/>
</doesNotContain>
<or>
<contains field="AssistantCoachInfo:Email">
<string value=" "/>
</contains>
<or>
<contains field="AssistantCoachInfo:Email">
<string value=","/>
</contains>
<doesNotContain field="AssistantCoachInfo:Email">
<string value="."/>
</doesNotContain>
</or>
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Email address appears invalid. Please correct it."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<field name="AsstId"/>
<field name="FullName"/>
<field name="TeamId"/>
<field name="HeadCoachId"/>
</items>
</form>
<form name="Team" startPoint="false" themePath="mvsc" process="Post-Team">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams and Coaches</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Teams"/>
</header><contents><field name="Record:Team:TeamId" /></contents></column><conditions><form name="Team" /></conditions></itemization-table></font></paragraph></text>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Team Name:  </font><blank label="a" length="20" required="false" alternateLabel="TeamId"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<isBlank field="Team:TeamId" />
</conditions>
<trueSet>
<skip to="T1"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="Divs">
<string value="No"/>
</equals>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="TeamAndCoachMenu" project="">Back to Teams and Coaches</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Teams"/>
</header><contents><field name="Record:Team:TeamId" /></contents></column><column><header><string value="Division"/>
</header><contents><field name="Record:Team:Division" /></contents></column><conditions><form name="Team" /></conditions></itemization-table></font></paragraph></text>
<mc label="Q2" alternateLabel="Division" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Assign </font><font face="Arial" size="200" color="000000"><field name="Team:TeamId"/></font><font face="Arial" size="200" color="000000"> to the following division:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Divisions:Name"/>
</display-expression><value-expression><field name="Record:Divisions:DivisionID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Divisions" /></record-selector></dynamic-mcq></data-provider></mc>
<field name="CoachId"/>
<field name="CoachFullName"/>
<field name="PreviousTeamId"/>
<field name="Printed?"/>
<field name="FlashMessage"/>
</items>
</form>
<form name="Volunteers" startPoint="false" themePath="mvsc" process="Post-Volunteers">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add/Edit Volunteer Activity Category</font></paragraph></heading>
<fib label="Q1" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Category Name: </font><blank label="a" length="20" required="false" alternateLabel="CatName"/></paragraph></fib>
<field name="VolunteerID"/>
</items>
</form>
<form name="PrepareForRelease" startPoint="true" themePath="mvsc" process="Post-PrepareForRelease" preProcess="RetrieveAdminSetupVariables">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Prepare Project for Release</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If you tested the project for </font><font><field name="League"/></font><font> and feel that everything is ready you can purge the recruitment and registration data that you used as test data and be ready to start the real registration process.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>This step will clear your recruitment and registration records and is not reversible. If there is any chance you have the data that you want to keep make sure that you export the data first.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can optionally purge coaches, teams and divisions if they were set up for testing purposes only.</font></paragraph></text>
<mc label="Q1" alternateLabel="PurgeCoaches" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Purge coaches data</font></paragraph></choice></mc>
<mc label="Q2" alternateLabel="PurgeAssistantCoaches" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Purge assistant coaches data</font></paragraph></choice></mc>
<mc label="Q3" alternateLabel="PurgeTeams" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Purge teams data</font></paragraph></choice></mc>
<mc label="Q4" alternateLabel="PurgeDivisions" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Purge divisions data</font></paragraph></choice></mc>
<text label="T3" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Message"/></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q5" alternateLabel="Confirm" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes, purge all current recruitment and registration data and the data checked off in the previous four check boxes.</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotContain field="PrepareForRelease:Confirm">
<string value="a"/>
</mcDoesNotContain>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please confirm that you would like to proceed with purging the data"/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
</items>
</form>
<form name="CommunicatorSetup" startPoint="false" themePath="mvsc" preProcess="Pre-CommunicatorSetup">
</form>
<form name="Communicator" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="GetAdminCommunicatorRecipientInfo" preProcess="Pre-Communicator">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Communicator</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: Use the Communicator best designed for your task:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>    This form is to create emails for:</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Players who are already assigned to teams</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Coaches</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Volunteers</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><sp/><font color="000080"><b><u><invitation form="RegistrantEmail" project="">Preseason Registrant Communicator</invitation></u></b></font><font><b> is for emailing registered players before team assignments have been made</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><sp/><font color="0066CC"><b><u><invitation form="RecruitEmail-Setup" project="">Recruitment List Communicator</invitation></u></b></font><sp/><font><b>is for sending emails to people in your recruitment database</b></font></paragraph></text>
<text label="T3" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><font size="280" color="C00000"><b><i><field name="Message"/></i></b></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">This message is to be sent to:</font><sp/><font face="Arial" size="200" color="000000"><i>(You may ignore this question if you don't use divisions.)</i></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All divisions </font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Only selected division(s) </font><font face="Arial" size="200" color="000000"><i>(You will choose the divisions on the next page.)</i></font></paragraph></choice></mc>
<mc label="Q2" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All players assigned to teams and their coaches (includes assistant coaches)</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">All coaches (includes assistant coaches)</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Players and coaches from selected teams (includes assistant coaches)</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more individual coaches</font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">One or more individual registered players</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Parents who have volunteered for a specific activity</font></paragraph></choice></mc>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Name):</i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromName"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email):</i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q5" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject</font><font face="Arial" size="200" color="000000"><i>:</i></font><sp/><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q6" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of salutation for emails</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Include a personalized salutation (e.g., </font><font face="Arial" size="200" color="000000"><i>"Dear &lt;Player FirstName&gt; or Parents of &lt;Player FirstName&gt;")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't include personalized salutation</font></paragraph></choice></mc>
<fib label="Q7" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message:  </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<mc label="Q8" alternateLabel="Link" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box to include a link to the player's or coach's </font><font face="Arial" size="200" color="000000"><u>Personal Dashboard</u></font><font face="Arial" size="200" color="000000"> in your message</font></paragraph></choice></mc>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>[A link to the player's or coach's </font><font color="0000FF"><u>Dashboard</u></font><font> may appear here.]</font></paragraph></text>
<fib label="Q9" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing:  </font><blank label="a" length="57" height="5" required="false" alternateLabel="Close"/></paragraph></fib>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<mc label="Q10" alternateLabel="AttachFiles" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box if you want to "attach" files to your message</font></paragraph></choice></mc>
<text label="T6" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="Communicator:Q2" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Error: You must select a group or individual to send this message to."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<doesNotContain field="Communicator:FromEmail">
<string value="@"/>
</doesNotContain>
<or>
<doesNotContain field="Communicator:FromEmail">
<string value="."/>
</doesNotContain>
<contains field="Communicator:FromEmail">
<string value=" "/>
</contains>
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Error: You must enter a valid email address in the &quot;From (Email)&quot; field."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q1" value="b"/>
</conditions>
<trueSet>
<comment>select division(s) first</comment>
<skip to="T7"/>
</trueSet>
<falseSet>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="c"/>
</conditions>
<trueSet>
<comment>send to players and coaches from selected teams</comment>
<skip to="T8"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="d"/>
</conditions>
<trueSet>
<comment>send to one or more selected coaches</comment>
<skip to="T9"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="e"/>
</conditions>
<trueSet>
<comment>send to one or more selected players</comment>
<skip to="T10"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="f"/>
</conditions>
<trueSet>
<comment>send to parent volunteers</comment>
<set field="Communicator:Q21" arithmeticAsText="false">
<string value="a"/>
</set>
<skip to="T14"/>
</trueSet>
</if>
</falseSet>
</if>
<comment>everyone else</comment>
<if>
<conditions>
<mcContains field="Communicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>attaching files?</comment>
<skip to="T18"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T7" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q11" alternateLabel="Divisions" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to recipients in the following division(s) only:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Divisions:Name"/>
</display-expression><value-expression><field name="Record:Divisions:DivisionID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Divisions" /></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="c"/>
</conditions>
<trueSet>
<comment>send to players and coaches on selected teams</comment>
<skip to="T13"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="d"/>
</conditions>
<trueSet>
<comment>send to one or more selected coaches</comment>
<skip to="T12"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="e"/>
</conditions>
<trueSet>
<comment>send to one or more selected players</comment>
<skip to="T11"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="f"/>
</conditions>
<trueSet>
<comment>send to one or more parent volunteers</comment>
<skip to="T14"/>
</trueSet>
</if>
<comment>everyone else</comment>
<if>
<conditions>
<mcContains field="Communicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>attaching files?</comment>
<skip to="T18"/>
</trueSet>
<falseSet>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
<text label="T8" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<mc label="Q12" alternateLabel="TeamIds" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send to players and coaches (includes assistant coaches) on the following team(s):</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression><field name="Record:Team:TeamId"/>
