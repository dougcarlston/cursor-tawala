<text label="T18" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T19" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You may upload up to three files to be included with your email. These files will not actually be attached to the email, but links to them will appear at the bottom of the email message. When your recipients click on the links they will be able to view the files.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Use the "Browse..." buttons below to select a file or files on your computer. When you click the Submit button the file(s) will be uploaded to the server so they will be accessible by your recipients.</font></paragraph></text>
<file label="F1" alternateLabel="File1" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 1:  </font><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F2" alternateLabel="File2" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 2:  </font><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F3" alternateLabel="File3" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 3:  </font><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
</items>
</form>
<form name="CommunicatorSend" startPoint="false" themePath="mvsc" process="Post-CommunicatorSend" preProcess="RetrieveAdminSetupVariables">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="720"><row><cell width="8460"><division indent="0" align="left"><font size="240"><b>To: </b></font><font size="240"><b><field name="ToField"/></b></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><b>From: </b></font><font><field name="Communicator:FromName"/></font><font> (</font><font><field name="Communicator:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="Communicator:Subject"/></font></division></cell></row></table><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><table indent="750"><row><cell width="8415"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="Communicator:Body"/></font></division></cell></row></table></text>
<text label="T3" style="normal"><table indent="705"><row><cell width="8460"><division indent="0" align="left"><font>Here is a link to your personal </font><font color="0000FF"><u><field name="DashboardLinkPreviewLinkText"/></u></font><font>. </font><font><field name="DashboardLinkPreviewVerbiage"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font><field name="DashboardLinkSaveVerbiage"/></font></division></cell></row></table><displayConditions>
<mcContains field="Communicator:Link" value="a"/>
</displayConditions></text>
<text label="T4" style="normal"><table indent="705"><row><cell width="8460"><division indent="0" align="left"><font><field name="Communicator:Close"/></font></division></cell></row><row><cell width="8460"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8460"><division indent="0" align="left"><font color="0000C0"><i><u><field name="AttachedFile1"/></u></i></font></division></cell></row></table><paragraph indent="0" align="left"></paragraph><paragraph indent="0" align="left"><font size="280" color="C00000"><i><field name="SendCountMessage"/></i></font></paragraph><paragraph indent="0" align="left"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font size="240" color="C00000"><i>For details, select "View complete list of recipients" below and click Submit</i></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">View complete list of recipients</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the email</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="CommunicatorSend:Q1" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Send Email Now</font></paragraph></heading>
<text label="T5" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="240"><b>Click Submit to begin sending now.</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Note: It might take several minutes to send all the emails.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Do not click Submit a second time! Wait for the Administrator Dashboard page to reappear.</font></paragraph></text>
<text label="T6" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
</items>
</form>
