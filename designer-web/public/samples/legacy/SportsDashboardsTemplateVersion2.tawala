<process name="Post-Registration">
<set field="Registration:ParFulName" arithmeticAsText="false">
<string field="Registration:ParentFirstName"/>
<string value=" "/>
<string field="Registration:ParentLastName"/>
</set>
<if>
<conditions>
<and>
<doesNotEqual field="Operation">
<string value="AdminRegisteringPlayer"/>
</doesNotEqual>
<and>
<equals field="RegViewFlag">
<string value="Closed"/>
</equals>
<isBlank field="_InviteeID" />
</and>
</and>
</conditions>
<trueSet>
<comment>If Registrations closed, shunt off to closed reg message, unless it's an Admin registration or a registered player edit.</comment>
<set field="Registration:RegID" arithmeticAsText="false">
<string value="to be deleted"/>
</set>
<show form="RegClosed"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<isBlank field="Registration:ParentEmail" />
<doesNotEqual field="From">
<string value="AddPlayerToGroupRegistration"/>
</doesNotEqual>
</and>
</conditions>
<trueSet>
<comment>-- If the session expires we need to delete the record and start again.</comment>
<set field="SessionExpired" arithmeticAsText="false">
<string value="Yes"/>
</set>
<show form="DeleteEmptyRegistrationRecordsAndRedisplayForm"/>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="SeasonYr" />
</conditions>
<trueSet>
<set field="SeasonYr" arithmeticAsText="false">
<string value="2008"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Registration:RegAgeYr" />
</conditions>
<trueSet>
<if>
<conditions>
<isGreaterThanOrEqualTo field="Registration:RegAgeMo">
<string field="AgeDeterminationMonth"/>
</isGreaterThanOrEqualTo>
</conditions>
<trueSet>
<set field="Registration:PlayerAge" arithmeticAsText="false">
<sub>
<sub>
<operand field="SeasonYr"/>
<operand field="Registration:RegAgeYr"/>
</sub>
<operand value="1"/>
</sub>
</set>
</trueSet>
<falseSet>
<set field="Registration:PlayerAge" arithmeticAsText="false">
<sub>
<operand field="SeasonYr"/>
<operand field="Registration:RegAgeYr"/>
</sub>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SexMCQ" value="a"/>
</conditions>
<trueSet>
<set field="Registration:Sex" arithmeticAsText="false">
<string value="Boy"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="Registration:SexMCQ" value="b"/>
</conditions>
<trueSet>
<set field="Registration:Sex" arithmeticAsText="false">
<string value="Girl"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="Registration:RegID" />
</conditions>
<trueSet>
<get recordList="Record List 18">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="RegNo" recordList="Record List 18">
<set field="RegNo:AdminSetup:PlayerIDGenerator" arithmeticAsText="false">
<add>
<operand field="RegNo:AdminSetup:PlayerIDGenerator"/>
<operand value="1"/>
</add>
</set>
<set field="PlayerID" arithmeticAsText="false">
<string value="player"/>
<string field="RegNo:AdminSetup:PlayerIDGenerator"/>
<string field="Registration:ParentEmail"/>
</set>
<set field="Registration:RegID" arithmeticAsText="false">
<string field="PlayerID"/>
</set>
</foreach>
</trueSet>
</if>
<set field="Registration:Birthday" arithmeticAsText="true">
<string field="Registration:RegAgeMo"/>
<string value="/"/>
<string field="Registration:RegAgeDay"/>
<string value="/"/>
<string field="Registration:RegAgeYr"/>
</set>
<set field="Registration:FriendsList" arithmeticAsText="false">
<string field="Registration:Friend:a"/>
<string value="   "/>
<string field="Registration:Friend:b"/>
<string value="   "/>
<string field="Registration:Friend:c"/>
</set>
<if>
<conditions>
<and>
<equals field="WaiverType">
<string value="OnRegForm"/>
</equals>
<mcEquals field="Registration:WaiverSignedMCQ" value="a"/>
</and>
</conditions>
<trueSet>
<comment>-- set WaiverReceived flag only if waiver is in the Reg Form and it is "checked off"</comment>
<comment>-- otherwise, leave it empty; its meaning may then be implied elsewhere by WaiverType setting</comment>
<set field="Registration:WaiverReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
</if>
<set field="PlayerFirst" arithmeticAsText="false">
<string field="Registration:FirstName"/>
</set>
<set field="PlayerLast" arithmeticAsText="false">
<string field="Registration:LastName"/>
</set>
<if>
<conditions>
<equals field="From">
<string value="AdminRegMgmt"/>
</equals>
</conditions>
<trueSet>
<show form="RegFormMgmt"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="RegistrationAudit"/>
</equals>
</conditions>
<trueSet>
<set field="Registration:BadEmail?" arithmeticAsText="false">
<string value=" "/>
</set>
<show form="AuditFormLoop"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="AddPlayerToGroupRegistration"/>
</equals>
</conditions>
<trueSet>
<set field="Registration:GroupRegistrationId" arithmeticAsText="false">
<string field="GroupRegistationId"/>
</set>
<set field="Registration:TeamId" arithmeticAsText="false">
<string field="Team"/>
</set>
<set field="Registration:PaymentReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
<set field="Registration:PaidAmount" arithmeticAsText="false">
<string value="0"/>
</set>
<set field="Registration:PaymentMethod" arithmeticAsText="false">
<string value="Group"/>
</set>
<set field="Registration:FirstName" arithmeticAsText="false">
<string field="AddPlayerToGroupRegistration:FirstName"/>
</set>
<set field="Registration:LastName" arithmeticAsText="false">
<string field="AddPlayerToGroupRegistration:LastName"/>
</set>
<set field="Registration:ParentEmail" arithmeticAsText="false">
<string field="AddPlayerToGroupRegistration:Parents&apos; Email"/>
</set>
<send>
<to addressField="AddPlayerToGroupRegistration:Parents&apos; Email"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject><field name="League"/> Registration</subject>
<body document="InvitationToCompleteRegistration" reset="false" showHeader="true"/>
</send>
<show form="AddPlayerToGroupRegistration"/>
</trueSet>
</if>
<show form="RegStep2"/>
</process>
<process name="Post-RegStep2">
<comment>-- Calculate payment information based on fee structure</comment>
<if>
<conditions>
<doesNotEqual field="Registration:PaymentReceived">
<string value="Yes"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="RegistrationFee" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<equals field="FeeStructure">
<string value="Flat Fee"/>
</equals>
</conditions>
<trueSet>
<set field="RegistrationFee" arithmeticAsText="false">
<string field="SignupFeeForIndividual"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="FeeStructure">
<string value="Varies by Division"/>
</equals>
</conditions>
<trueSet>
<get recordList="Selected Division">
<forms>
<form name="Divisions"/>
</forms>
<conditions>
<equals field="Selected Division:Divisions:DivisionID">
<string field="Registration:DivisionId"/>
</equals>
</conditions></get>
<foreach record="Such Division" recordList="Selected Division">
<set field="RegistrationFee" arithmeticAsText="false">
<string field="Such Division:Divisions:DivFees"/>
</set>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<equals field="FeeStructure">
<string value="Varies by Grade"/>
</equals>
</conditions>
<trueSet>
<get recordList="Selected Grade">
<forms>
<form name="Grade"/>
</forms>
<conditions>
<equals field="Selected Grade:Grade:Name">
<string field="Registration:Grade"/>
</equals>
</conditions></get>
<foreach record="Such Grade" recordList="Selected Grade">
<set field="RegistrationFee" arithmeticAsText="false">
<string field="Such Grade:Grade:Fee"/>
</set>
</foreach>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="RegistrationFee" />
</conditions>
<trueSet>
<show document="Error Calculating Payment" reset="false"/>
</trueSet>
</if>
<set field="RegistrationFee" arithmeticAsText="false">
<add>
<operand field="RegistrationFee"/>
<operand field="Registration:DonationAmount"/>
</add>
</set>
<if>
<conditions>
<equals field="Registration:OptedOutFromVolunteering">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="RegistrationFee" arithmeticAsText="false">
<add>
<operand field="RegistrationFee"/>
<operand field="VolunteerOptOutFee"/>
</add>
</set>
</trueSet>
</if>
</trueSet>
</if>
<comment>-- Send the welcome letter with the link to the dashboard</comment>
<if>
<conditions>
<isBlank field="Registration:LinkToPlayerDashboardSent" />
</conditions>
<trueSet>
<comment>-- Means that this is not the user editing his/her record from the player dashboard,</comment>
<comment>-- but either the first time registrant or the admin creating the record.</comment>
<if>
<conditions>
<equals field="Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<send>
<to addressField="Registration:ParentEmail"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Registration</subject>
<body document="PostRegistrationLetterWithoutPaymentInstructions" reset="false" showHeader="true"/>
</send>
<if>
<conditions>
<isNotBlank field="Registration:ParentEmail2" />
</conditions>
<trueSet>
<send>
<to addressField="Registration:ParentEmail2"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Registration</subject>
<body document="PostRegistrationLetterWithoutPaymentInstructions" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
</trueSet>
<falseSet>
<send>
<to addressField="Registration:ParentEmail"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Registration</subject>
<body document="PostRegistrationLetterWithPaymentInstructions" reset="false" showHeader="true"/>
</send>
<if>
<conditions>
<isNotBlank field="Registration:ParentEmail2" />
</conditions>
<trueSet>
<send>
<to addressField="Registration:ParentEmail2"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
