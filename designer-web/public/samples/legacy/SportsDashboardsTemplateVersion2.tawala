</equals>
</conditions></get>
<foreach record="SuchRecord" recordList="Registration List">
<if>
<conditions>
<equals field="SuchRecord:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="FinishPaymentAndWaiverReceipts:Payment Received" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
<falseSet>
<set field="FinishPaymentAndWaiverReceipts:Payment Received" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<equals field="SuchRecord:Registration:WaiverReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="FinishPaymentAndWaiverReceipts:Waiver Received" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
<falseSet>
<set field="FinishPaymentAndWaiverReceipts:Waiver Received" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
</foreach>
</process>
<process name="Post-FinishPaymentAndWaiverReceipt">
<get recordList="RegistrationList">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="RegistrationList:Registration:RegID">
<string field="ConfirmPaymentAndWaiverReceipts:UnmarkReceipts"/>
</equals>
</conditions></get>
<foreach record="SuchRecord" recordList="RegistrationList">
<if>
<conditions>
<mcEquals field="FinishPaymentAndWaiverReceipts:Waiver Received">
<string value="a"/>
</mcEquals>
</conditions>
<trueSet>
<set field="SuchRecord:Registration:WaiverReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
<falseSet>
<set field="SuchRecord:Registration:WaiverReceived" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<mcEquals field="FinishPaymentAndWaiverReceipts:Payment Received">
<string value="a"/>
</mcEquals>
</conditions>
<trueSet>
<set field="SuchRecord:Registration:PaymentReceived" arithmeticAsText="false">
<string value="Yes"/>
</set>
</trueSet>
<falseSet>
<set field="SuchRecord:Registration:PaymentReceived" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SuchRecord:Registration:PaidAmount" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="SuchRecord:Registration:PaymentMethod" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
</foreach>
<show form="ConfirmPaymentAndWaiverReceipts"/>
</process>
