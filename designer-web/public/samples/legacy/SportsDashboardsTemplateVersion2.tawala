<form name="RetrieveAdminVariablesForAnotherForm" startPoint="false" themePath="mvsc" process="Post-RetrieveAdminVariablesForAnotherForm" preProcess="RetrieveAdminSetupVariables">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF"><b>Tawala kludge: </b></font><font color="0000FF">This Form is invoked for the purpose of initializing the global </font><font color="0000FF"><i>AdminSetup</i></font><font color="0000FF"> variables for another Form that has its own pre-process.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF"><b>Example:</b></font><font color="0000FF"> Suppose you have a Form called </font><font color="0000FF"><b><i>EmailSender</i></b></font><font color="0000FF">  that needs to be sure that the </font><font color="0000FF"><i>AdminSetup</i></font><font color="0000FF"> variables are in place, but it also has to do some pre-processing of its own. Here's the strategy:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF">1. Create a non-displaying "setup" Form for the desired target Form (e.g., </font><font color="0000FF"><b><i>EmailSender-Setup</i></b></font><font color="0000FF">)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF">2. Attach a pre-process to </font><font color="0000FF"><b><i>EmailSender-Setup  </i></b></font><font color="0000FF">that sets the variable </font><font color="0000FF"><b><i>RetrieveVariablesTargetForm</i></b></font><font color="0000FF">  to a unique value (using the target form name is a good idea), then invokes this form. E.g.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Courier New">      SET RetrieveVariablesTargetForm to "EmailSender"</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Courier New">      SHOW Form RetrieveVariablesForAnotherForm</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF">3. Add the following to this Form's post-process:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Courier New">      IF RetrieveVariablesTargetForm equals "EmailSender"</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Courier New">      SHOW Form EmailSender</font></paragraph></text>
</items>
</form>
<form name="RetrievePlayerVariablesForAnotherForm" startPoint="false" themePath="mvsc" process="Post-RetrievePlayerVariablesForAnotherForm" preProcess="RetrievePlayerSetupVariables">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF"><b>Tawala kludge: </b></font><font color="0000FF">This Form is invoked for the purpose of initializing the global </font><font color="0000FF"><i>Player</i></font><font color="0000FF"> variables for another Form that has its own pre-process.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF">(See the </font><font color="0000FF"><i>RetrieveAdminVariablesForAnotherForm  </i></font><font color="0000FF">Form for further information.</font></paragraph></text>
</items>
</form>
<form name="RetrieveCoachVariablesForAnotherForm" startPoint="false" themePath="mvsc" process="Post-RetrieveCoachVariablesForAnotherForm" preProcess="RetrieveCoachSetupVariables">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF"><b>Tawala kludge: </b></font><font color="0000FF">This Form is invoked for the purpose of initializing the global </font><font color="0000FF"><i>Coach</i></font><font color="0000FF"> variables for another Form that has its own pre-process.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF">(See the </font><font color="0000FF"><i>RetrieveAdminVariablesForAnotherForm  </i></font><font color="0000FF">Form for further information.</font></paragraph></text>
</items>
</form>
<form name="RetrieveAsstCoachVariablesForAnotherForm" startPoint="false" themePath="mvsc" process="Post-RetrieveAsstCoachVariablesForAnotherForm" preProcess="RetrieveAsstCoachSetupVariables">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF"><b>Tawala kludge: </b></font><font color="0000FF">This Form is invoked for the purpose of initializing the global </font><font color="0000FF"><i>Assistant Coach</i></font><font color="0000FF"> variables for another Form that has its own pre-process.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0000FF">(See the </font><font color="0000FF"><i>RetrieveAdminVariablesForAnotherForm  </i></font><font color="0000FF">Form for further information.</font></paragraph></text>
</items>
</form>
</forms>
<processes>
<process name="RetrieveAdminSetupVariables">
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<get recordList="SetupRecords">
<forms>
<form name="AdminSetup"/>
</forms>
</get>
<foreach record="Admin" recordList="SetupRecords">
<set field="PW" arithmeticAsText="false">
<string field="Admin:AdminSetup:Password"/>
</set>
<set field="AgeDeterminationMonth" arithmeticAsText="false">
<string field="Admin:AdminSetup:AgeFormula"/>
</set>
<set field="AdminName" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminsName"/>
</set>
<set field="AdminEmail" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminsEmail"/>
</set>
<set field="AdminsPhone" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminPhone"/>
</set>
<set field="AdminAdrss" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminAddress"/>
</set>
<set field="AdminsCity" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminCity"/>
</set>
<set field="AdminState" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminST"/>
</set>
<set field="AdminsZIP" arithmeticAsText="false">
<string field="Admin:AdminSetup:AdminZIP"/>
</set>
<set field="League" arithmeticAsText="false">
<string field="Admin:AdminSetup:LeagueName"/>
</set>
<set field="SeasonYr" arithmeticAsText="false">
<string field="Admin:AdminSetup:Season"/>
</set>
<set field="HomeURL" arithmeticAsText="false">
<string field="Admin:AdminSetup:LeagueWebSite"/>
</set>
<set field="ScheduleURL" arithmeticAsText="false">
<string field="Admin:AdminSetup:ScheduleURL"/>
</set>
<set field="RulesURL" arithmeticAsText="false">
<string field="Admin:AdminSetup:LeagueRules"/>
</set>
<set field="RegFormHeaderText" arithmeticAsText="false">
<string field="Admin:AdminSetup:RegFormHeader"/>
</set>
<set field="RegFormSubHeaderText" arithmeticAsText="false">
