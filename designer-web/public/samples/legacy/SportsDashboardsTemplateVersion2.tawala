<form name="AuditRecruitList" startPoint="false" themePath="mvsc" process="Post-AuditRecruitList" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Recruiting List</font></paragraph></heading>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility will check the recruiting list for valid emails.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds a record with more than one valid email or none, it will pull up the record and give you a chance to edit it so that it will work with the Tawala utilities.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It is not possible to keep two email addresses in one contact field.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit or delete each record that fails the audit test.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return </font></paragraph></choice></mc>
</items>
</form>
<form name="AuditRecruitLoop" startPoint="false" themePath="mvsc" process="Post-AuditRecruitLoop" preProcess="Pre-AuditRecruitLoop">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Clean Recruitment Records</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<mc label="Q1" alternateLabel="RecruitmentId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the recruitment record:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:FirstName"/>
<string value=" "/>
<field name="Record:RecruitmentDB:LastName"/>
<string value=" (parent: "/>
<field name="Record:RecruitmentDB:ParentFirst"/>
<string value=", email: "/>
<field name="Record:RecruitmentDB:Email"/>
<string value=", phone: "/>
<field name="Record:RecruitmentDB:Email2"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<equals field="Record:RecruitmentDB:BadRecord?">
<string value="Yes"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<mc label="Q2" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the action to perform:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit this record</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete this record</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark as "good" (it will remove this record from this list)</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Break off audit for now (you can always return)</font></paragraph></choice></mc>
</items>
</form>
<form name="DuplicateRecruitCheck" startPoint="false" themePath="mvsc" process="Post-DuplicateRecruitCheck" preProcess="Pre-DuplicateRecruitCheck">
<items>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Compare the data from the two files:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="center"><font><b>Record #1</b></font></division></cell><cell width="5400"><division indent="0" align="center"><font><b>Record #2</b></font></division></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="1800"><division indent="0" align="right"><font><b>First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPFirst"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SFirst"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Last:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPLast"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Last:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SLast"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Parent First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitParentFirst"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Parent First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SParentFirst"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitEmail"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SEmail"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email1:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitEmail2"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Email1:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SEmail2"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPhone"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SPhone"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Record ID:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitID"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Record ID:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="SRecruitID"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Record 2 is not a duplicate of Record 1.  Leave both in.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete Record #1</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete Record #2</font></paragraph></choice></mc>
</items>
</form>
<form name="RecruitDBDupe" startPoint="false" themePath="mvsc" process="Post-RecruitDBDupe">
<items>
<text label="T1" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This person appears to be in the recruitment files already.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header><string value="Parent"/>
</header><contents><field name="Record:RecruitmentDB:ParentFirst" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header><string value="Additional Email"/>
</header><contents><field name="Record:RecruitmentDB:Email2" /></contents></column><column><header><string value="Phone"/>
</header><contents><field name="Record:RecruitmentDB:Phone" /></contents></column><conditions><form name="RecruitmentDB" /><conditions>
<and>
<equals field="Record:RecruitmentDB:FirstName">
<string field="RecruitmentDB:FirstName"/>
</equals>
<and>
<equals field="Record:RecruitmentDB:LastName">
<string field="RecruitmentDB:LastName"/>
</equals>
<equals field="Record:RecruitmentDB:Email">
<string field="RecruitmentDB:Email"/>
</equals>
</and>
</and>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add anyhow?</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No</font></paragraph></choice></mc>
</items>
</form>
<form name="AddRecruitRecord" startPoint="false" themePath="mvsc" process="PostAddRecruitRecord">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AddRecruitFromReg" startPoint="false" themePath="mvsc" process="Post-AddRecruitFromReg" preProcess="Pre-AddRecruitFromReg">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add to Recruiting list from Registrations</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Recruitment" project="">Back to Recruitment List Management</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Registered players may be added to the Recruitment list for next year using this utility.  The process cannot be completly automatic, as Players and their families change email addresses, phone numbers, even first names with some regularity.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Instead, this utility offers a series of tools to permit you to review potential additions to your list before making a final decision.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Registration data is not changed here.  Rather this tool is used to prepare the recruitment list for use in future years.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Which approach do you want to use? (you can use more than one)</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add all registered players that don't appear to be in recruitment list already.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add all registered players to recruitment list if they were born after a specified date and don't appear to be in list already</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Add all registration data, automatically replacing recruitment list data with registration data for apparent matches</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Manually compare recruitment and registration data of apparent matches before changing recruitment list data</font></paragraph></choice></mc>
<skipInstructions>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcDoesNotEqual field="AddRecruitFromReg:Q1" value="b"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i><field name="Message"/></i></font></paragraph></text>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the  cut-off year using 4 digits, e.g. 1999  (Players born before this year will not be added to recruitment list).  </font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="9" required="false" alternateLabel="Year"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<isLessThan field="AddRecruitFromReg:Year">
<string value="1940"/>
</isLessThan>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Enter year as a four digit number, e.g. &quot;2001&quot;"/>
</set>
<skip to="T3"/>
</trueSet>
</if>
</skipInstructions>
</items>
</form>
<form name="CompareNMark" startPoint="false" themePath="mvsc" process="Post-CompareNMark" preProcess="Pre-CompareNMark">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Recruitment" project="">Back to Recruitment List Management</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Compare the data from the two files:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="center"><font><b>From Recruitment Records:</b></font></division></cell><cell width="5400"><division indent="0" align="center"><font><b>From Registration Records:</b></font></division></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="1800"><division indent="0" align="right"><font><b>First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPFirst"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="PlayerFirst"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Last:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPLast"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Last:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="PlayerLast"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Parent First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitParentFirst"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Parent First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RegParentFirstName"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitEmail"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RegParentEmail"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email1:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitEmail2"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Email1:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RegParentEmail2"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPhone"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RegPhone1"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Leave both records as they are</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Overwrite the record in the recruitment file with the newer data in the registration</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">These records are not for the same person.  Add the registration data as a new recruitment record.</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit the recruitment record manually, using data from both records.</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="CompareNMark:Q1" value="d"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="center"><font><b>From Recruitment Records:</b></font></division></cell><cell width="5400"><division indent="0" align="center"><font><b>From Registration Records:</b></font></division></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="1800"><division indent="0" align="right"><font><b>First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPFirst"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="PlayerFirst"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Last:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPLast"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Last:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="PlayerLast"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Parent First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitParentFirst"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Parent First:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RegParentFirstName"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitEmail"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RegParentEmail"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email1:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitEmail2"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Email1:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RegParentEmail2"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RecruitPhone"/></font></division></cell><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="272"></cell><cell width="3328"><division indent="0" align="left"><font><field name="RegPhone1"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Make desired changes to recruitment list data below:</font></paragraph></text>
<fib label="Q2" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">First: </font><blank label="a" length="20" required="false" alternateLabel="RFirst"/></paragraph></fib>
<fib label="Q3" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Last: </font><blank label="a" length="20" required="false" alternateLabel="RLast"/></paragraph></fib>
<fib label="Q4" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">ParentFirst: </font><blank label="a" length="20" required="false" alternateLabel="RParFirst"/></paragraph></fib>
<fib label="Q5" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="a" length="20" required="false" alternateLabel="REmail"/></paragraph></fib>
<fib label="Q6" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email1: </font><blank label="a" length="20" required="false" alternateLabel="REmail1"/></paragraph></fib>
<fib label="Q7" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone: </font><blank label="a" length="20" required="false" alternateLabel="RPhone"/></paragraph></fib>
</items>
</form>
<form name="EditRecruitment" startPoint="false" themePath="mvsc" process="Post-EditRecruitment" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Edit Recruitment Records</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="B40000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria:  </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<comment>-- no space characters allowed; we can't handle substrings for searching on multiple fields</comment>
<if>
<conditions>
<contains field="EditRecruitment:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word, or part of a word to search on. Multiple word searches are not supported."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Edit Recruitment Records</font></paragraph></heading>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3360"><division indent="0" align="left"><font color="0066CC"><u><invitation form="EditRecruitment" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3840"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RecruitmentId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the record to edit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:LastName"/>
<string value=", "/>
<field name="Record:RecruitmentDB:FirstName"/>
<string value=" ("/>
<field name="Record:RecruitmentDB:Email"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentId"/>
</value-expression><sort-expression><field name="Record:RecruitmentDB:LastName"/>
<string value="#"/>
<field name="Record:RecruitmentDB:FirstName"/>
</sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<or>
<contains field="Record:RecruitmentDB:FirstName">
<string field="EditRecruitment:SearchString"/>
</contains>
<or>
<contains field="Record:RecruitmentDB:LastName">
<string field="EditRecruitment:SearchString"/>
</contains>
<contains field="Record:RecruitmentDB:Email">
<string field="EditRecruitment:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="RecruitSelfEdit" startPoint="false" themePath="mvsc" process="Post-RecruitSelfEdit" preProcess="Pre-RecruitSelfEdit">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Here is the information in your file.  Please make any corrections right to the form and then press Submit.  If the information is correct, you need do nothing.</font></paragraph></text>
<fib label="Q1" style="rightAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name: </font><blank label="a" length="20" required="false" alternateLabel="SEFirst"/><sp/><font face="Arial" size="200" color="000000"><i>(first) </i></font><blank label="b" length="20" required="false" alternateLabel="SELast"/><sp/><font face="Arial" size="200" color="000000"><i>(last)</i></font></paragraph></fib>
<fib label="Q2" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Parent's first name:  </font><blank label="a" length="20" required="false" alternateLabel="SEParFirst"/></paragraph></fib>
<fib label="Q3" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email: </font><blank label="a" length="20" required="false" alternateLabel="SEEmail"/></paragraph></fib>
<fib label="Q4" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Alternate Email: </font><blank label="a" length="20" required="false" alternateLabel="SEEmail1"/></paragraph></fib>
<fib label="Q5" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone: </font><blank label="a" length="20" required="false" alternateLabel="SEPhone"/></paragraph></fib>
</items>
</form>
<form name="DeleteRecruitment" startPoint="false" themePath="mvsc" process="Post-DeleteRecruitment" preProcess="AssignRecruitmentIds">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To search for a record:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Enter all or part of a</font><sp/><font><b><i>last name OR first name OR email address </i></b></font><font>in the box below.</font><sp/><font>(Multiple word searches not supported.)</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Leave the box blank to see all player records.</font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="B40000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Search criteria:  </font><blank label="a" length="20" required="false" alternateLabel="SearchString"/></paragraph></fib>
<skipInstructions>
<comment>-- no space characters allowed; we can't handle substrings for searching on multiple fields</comment>
<if>
<conditions>
<contains field="DeleteRecruitment:SearchString">
<string value=" "/>
</contains>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter only a single word, or part of a word to search on. Multiple word searches are not supported."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3255"><division indent="0" align="left"><font color="0066CC"><u><invitation form="DeleteRecruitment" project="">Revise your search criteria</invitation></u></font></division></cell><cell width="3945"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="5720"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q2" alternateLabel="RecruitmentIds" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the record(s) to delete</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:RecruitmentDB:LastName"/>
<string value=", "/>
<field name="Record:RecruitmentDB:FirstName"/>
<string value=" ("/>
<field name="Record:RecruitmentDB:Email"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:RecruitmentDB:RecruitmentId"/>
</value-expression><sort-expression><field name="Record:RecruitmentDB:LastName"/>
<string value="#"/>
<field name="Record:RecruitmentDB:FirstName"/>
</sort-expression><record-selector><form name="RecruitmentDB" /><conditions>
<or>
<contains field="Record:RecruitmentDB:FirstName">
<string field="DeleteRecruitment:SearchString"/>
</contains>
<or>
<contains field="Record:RecruitmentDB:LastName">
<string field="DeleteRecruitment:SearchString"/>
</contains>
<contains field="Record:RecruitmentDB:Email">
<string field="DeleteRecruitment:SearchString"/>
</contains>
</or>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="DeleteRecruitment:RecruitmentIds" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H3" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Delete Recruitment Records</font></paragraph></heading>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The following recruitment record(s) will be deleted:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header><string value="Email 2"/>
</header><contents><field name="Record:RecruitmentDB:Email2" /></contents></column><conditions><form name="RecruitmentDB" /><conditions>
<mcContains field="DeleteRecruitment:RecruitmentIds">
<string field="Record:RecruitmentDB:RecruitmentId"/>
</mcContains>
</conditions></conditions></itemization-table></font></paragraph></text>
<mc label="Q3" alternateLabel="Confirm" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Yes, delete this record(s)</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">No, do not delete</font></paragraph></choice></mc>
</items>
</form>
<form name="RecruitEmail-Setup" startPoint="false" themePath="mvsc" preProcess="Pre-RecruitEmail-Setup">
</form>
<form name="RecruitEmail" startPoint="false" themePath="mvsc" dataEntryOnly="true" process="Post-RecruitEmail" preProcess="Pre-RecruitEmail">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Recruitment Email</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3915"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3645"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Note: Use the Communicator best designed for your task:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>    This form is for emailing people in your recruitment contact list</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><sp/><font color="0066CC"><b><u><invitation form="RegistrantEmail" project="">Preseason Registrant Communicator</invitation></u></b></font><font><b> is for emailing registered players before team assignments have been made</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><sp/><sp/><sp/><font color="0066CC"><b><u><invitation form="CommunicatorSetup" project="">Communicator</invitation></u></b></font><sp/><font><b>is for emailing:</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Players who are already assigned to teams</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Coaches</b></font></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><b>o   Volunteers</b></font></paragraph></text>
<text label="T3" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="C00000"><b><i><field name="Message"/></i></b></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q1" alternateLabel="To" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send this email to:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Everyone in the Recruitment Database</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">People who have been contacted fewer than "x" times already</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Everyone in the Recruitment Database who has not yet submitted a registration form *</font></paragraph></choice></mc>
<text label="T4" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>* Note: Player name and email addresses are used to match registration records with recruitment records. If names are not present in the Recruitment Database, or if they are not entered the same in both places, or if different email addresses are used, those records will not be filtered out of this mailing.</font></paragraph></text>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Name): </i></font><sp/><blank label="a" length="57" required="false" alternateLabel="FromAdminName"/></paragraph></fib>
<fib label="Q3" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">From </font><font face="Arial" size="200" color="000000"><i>(Email): </i></font><font face="Arial" size="200" color="000000"> </font><blank label="a" length="57" required="false" alternateLabel="FromEmail"/></paragraph></fib>
<fib label="Q4" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Subject:  </font><blank label="a" length="57" required="false" alternateLabel="Subject"/></paragraph></fib>
<mc label="Q5" alternateLabel="Salutation" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Choice of Salutation:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Include a personalized salutation (</font><font face="Arial" size="200" color="000000"><i>"Dear &lt;Player's First Name&gt; or Parents of &lt;Player's First Name&gt;")</i></font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Don't include personalized salutation</font></paragraph></choice></mc>
<fib label="Q6" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter the body of your message: </font><blank label="a" length="57" height="10" required="false" alternateLabel="Body"/></paragraph></fib>
<mc label="Q7" alternateLabel="Link" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box  to include a link to your Registration page in this message</font></paragraph></choice></mc>
<fib label="Q8" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enter your closing: </font><blank label="a" length="57" height="5" required="false" alternateLabel="Closing"/></paragraph></fib>
<text label="T5" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></text>
<mc label="Q9" alternateLabel="AttachFiles" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check this box if you want to "attach" files to your message</font></paragraph></choice></mc>
<text label="T6" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Press the Submit button to continue.  You will have a chance to review your letter before it is sent.</font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<or>
<doesNotContain field="RecruitEmail:FromEmail">
<string value="@"/>
</doesNotContain>
<or>
<doesNotContain field="RecruitEmail:FromEmail">
<string value="."/>
</doesNotContain>
<contains field="RecruitEmail:FromEmail">
<string value=" "/>
</contains>
</or>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Error: You must enter a valid email address in the &quot;From (Email)&quot; field."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotContain field="RecruitEmail:AttachFiles" value="a"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T7" alternateLabel="UploadFiles" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3915"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3645"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T8" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You may upload up to three files to be included with your email. These files will not actually be attached to the email, but links to them will appear at the bottom of the email message. When your recipients click on the link they will be able to view the file(s).</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Use the "Browse..." buttons below to select a file or files on your computer. When you click the Submit button the file(s) will be uploaded to the server so they will be accessible by your recipients.</font></paragraph></text>
<file label="F1" alternateLabel="File1" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 1:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F2" alternateLabel="File2" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 2:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
<file label="F3" alternateLabel="File3" required="false" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000">File 3:</font><sp/><sp/><font face="Arial" color="000000"><i><field name="MaxUploadFileSizeText"/></i></font><fileNameInput/></paragraph></file>
</items>
</form>
<form name="RecruitEmailSend" startPoint="false" themePath="mvsc" process="Post-RecruitEmailSend" preProcess="RetrieveAdminSetupVariables">
<items>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3915"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3645"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Here is what your email will look like:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="570"><row><cell width="8400"><division indent="0" align="left"><font><b>To: </b></font><font><field name="ToField"/></font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>From</b></font><font>: </font><font><field name="RecruitEmail:FromAdminName"/></font><font> (</font><font><field name="RecruitEmail:FromEmail"/></font><font>)</font></division></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Date:</b></font><font> Today</font></division></cell></row><row><cell width="8400"></cell></row><row><cell width="8400"><division indent="0" align="left"><font><b>Subject: </b></font><font><field name="RecruitEmail:Subject"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="525"><row><cell width="8415"><division indent="0" align="left"><font><field name="DearSir"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="RecruitEmail:Body"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><i>(If you opted to include a registration link:)</i></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font>To register for the </font><font><field name="SeasonYr"/></font><sp/><font><field name="League"/></font><font>, just </font><font color="000080"><u>click here</u></font><font>.</font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font><field name="RecruitEmail:Closing"/></font></division></cell></row><row><cell width="8415"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="8415"><division indent="0" align="left"><font color="0000C0"><i><u><field name="AttachedFile1"/></u></i></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed to send emails</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit email</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Recruitment List Management</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="RecruitEmailSend:Q1">
<string value="a"/>
</mcDoesNotEqual>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3915"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3645"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T4" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Click Submit to begin sending now.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Note: It might take several minutes to send all the emails.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><i>Do not click Submit a second time! Wait for the Preseason Setup page to reappear.</i></font></paragraph></text>
</items>
</form>
<form name="ChooseX" startPoint="false" themePath="mvsc" process="Post-ChooseX">
<items>
<text label="T1" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You chose to send this letter only to those who have been contacted fewer than "x" times.  Right now, "x" equals </font><font><field name="X"/></font><font>.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">See Recruitment List with number of times each has been contacted</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">See Recruitment List of those contacted fewer than </font><font face="Arial" size="200" color="000000"><field name="X"/></font><font face="Arial" size="200" color="000000"> times</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Change "x" from its current value of </font><font face="Arial" size="200" color="000000"><field name="X"/></font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Review Email and send to those contacted fewer than </b></font><font face="Arial" size="200" color="000000"><b><field name="X"/></b></font><font face="Arial" size="200" color="000000"><b> times</b></font></paragraph></choice><choice label="e"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit Email and options further</font></paragraph></choice><choice label="f"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon Email and return to Recruitment Options</font></paragraph></choice><choice label="g"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Abandon Email and return to Administrator Dashboard</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcDoesNotEqual field="ChooseX:Q1" value="c"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<fib label="Q2" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Change "x" from </font><font face="Arial" size="200" color="000000"><field name="X"/></font><font face="Arial" size="200" color="000000"> to:  </font><blank label="a" length="5" required="false"/></paragraph></fib>
</items>
</form>
