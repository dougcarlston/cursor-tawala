<form name="GroupRegistration" startPoint="false" themePath="mvsc" process="Post-GroupRegistration">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Group Registrations</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Existing Group Registrations:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Team"/>
</header><contents><field name="Record:GroupRegistration:TeamId" /></contents></column><column><header><string value="Fee ($)"/>
</header><contents><field name="Record:GroupRegistration:RegistrationFee" /></contents></column><conditions><form name="GroupRegistration" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AddPlayerToExistingGroupRegistration" project="">Add a player to an existing group registration</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>To create a new group registration fill out the form below. (</font><font color="000080"><u><invitation form="Team" project="">Add a team</invitation></u></font><font color="000000"> and assign a coach to it first if you don't see the team on the list and then come back to this screen.)</font></paragraph></text>
<mc label="Q1" alternateLabel="TeamId" onlyone="true" required="true" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the team (only teams with assigned coaches are shown):</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Team:TeamId"/>
</display-expression><value-expression><field name="Record:Team:TeamId"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Team" /><conditions>
<isNotBlank field="Record:Team:CoachId" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<fib label="Q2" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Team registration fee </font><font face="Arial" size="200" color="000000"><i>(this fee covers all players assigned to this team)</i></font><font face="Arial" size="200" color="000000">: $</font><blank label="a" length="20" required="true" alternateLabel="RegistrationFee"/></paragraph></fib>
<field name="GroupRegistrationId"/>
</items>
</form>
<form name="AddPlayerToGroupRegistration" startPoint="false" themePath="mvsc" process="Post-AddGroupRegistrationPlayer">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Add player to group registration</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font></paragraph></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>List of players added to the group registration for </font><font><field name="Team"/></font><font>:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:GroupRegistrationId">
<string field="GroupRegistationId"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph></text>
<fib label="Q1" style="rightAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">First Name: </font><blank label="a" length="20" required="true" alternateLabel="FirstName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Last Name: </font><blank label="b" length="20" required="true" alternateLabel="LastName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Parents' Email: </font><blank label="c" length="20" required="true" alternateLabel="Parents&apos; Email"/></paragraph></fib>
</items>
