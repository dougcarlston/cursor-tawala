</conditions></get>
<foreach record="NewRecruitmentRecord" recordList="RecruitmentRecords">
<set field="NewRecruitmentRecord:RecruitmentDB:RecruitmentId" arithmeticAsText="false">
<add>
<operand field="SetupRecord:AdminSetup:RecruitmentIdGenerator"/>
<operand value="1"/>
</add>
</set>
<set field="SetupRecord:AdminSetup:RecruitmentIdGenerator" arithmeticAsText="false">
<string field="NewRecruitmentRecord:RecruitmentDB:RecruitmentId"/>
</set>
</foreach>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</process>
