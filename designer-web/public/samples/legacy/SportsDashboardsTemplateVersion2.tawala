<equals field="SetupNavigation">
<string value="Registration"/>
</equals>
</conditions>
<trueSet>
<skip to="Registration Form Header"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="SetupNavigation">
<string value="Custom Question"/>
</equals>
</conditions>
<trueSet>
<skip to="Custom Question Header"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="SetupNavigation">
<string value="Waiver"/>
</equals>
</conditions>
<trueSet>
<skip to="Medical Waiver Header"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="SetupNavigation">
<string value="Financial"/>
</equals>
</conditions>
<trueSet>
<skip to="Financial Setup Header"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="SetupNavigation">
<string value="Donation"/>
</equals>
</conditions>
<trueSet>
<skip to="Donation Header"/>
</trueSet>
</if>
<if>
<conditions>
