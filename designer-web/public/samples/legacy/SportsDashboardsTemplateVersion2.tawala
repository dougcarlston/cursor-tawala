</trueSet>
</if>
</skipInstructions>
<heading label="H1" alternateLabel="Basic Info Header" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Basic Information Setup</font></paragraph></heading>
<text label="T1" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Message"/></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Administrator:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name:  </font><blank label="a" length="35" required="false" alternateLabel="AdminsName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email Address:  </font><blank label="b" length="35" required="false" alternateLabel="AdminsEmail"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone Number: </font><blank label="c" length="35" required="false" alternateLabel="AdminPhone"/></paragraph></fib>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Mailing Address:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Street: </font><blank label="a" length="52" required="false" alternateLabel="AdminAddress"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">City:     </font><blank label="b" length="52" required="false" alternateLabel="AdminCity"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">State:   </font><blank label="c" length="52" required="false" alternateLabel="AdminST"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Zip: </font><blank label="d" length="52" required="false" alternateLabel="AdminZIP"/></paragraph></fib>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><i>Note: The above address is where waivers and checks will be sent.</i></font></paragraph></text>
<text label="T3" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Administrator Password:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>For additional security, you may add an optional Administrator password.  Most Administrators may prefer to leave this blank.  If you forget your password, it can be retrieved from your MyTawala site in the AdminSetup Form.  Look under the column entitled "Password."</i></font></paragraph></text>
<fib label="Q3" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Password: </font><blank label="a" length="20" required="false" alternateLabel="Password"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Please enter again: </font><blank label="b" length="20" required="false" alternateLabel="Passcheck"/></paragraph></fib>
<fib label="Q4" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>League Information:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">League Name </font><font face="Arial" size="200" color="000000"><i>(e.g. Mill Valley Dirt Bowl)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="a" length="20" required="false" alternateLabel="LeagueName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Season </font><font face="Arial" size="200" color="000000"><i>(e.g 2008)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="b" length="20" required="false" alternateLabel="Season"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">URL of the league schedule: </font><blank label="c" length="19" required="false" alternateLabel="ScheduleURL"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">URL of the league Web site: </font><blank label="d" length="19" required="false" alternateLabel="LeagueWebSite"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">URL of the league rules: </font><blank label="e" length="19" required="false" alternateLabel="LeagueRules"/></paragraph></fib>
<text label="T4" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><i>Notes:</i></font><sp/><sp/><sp/><font><i>The Season field above is used to calculate player age, so please enter only a whole number such as "2009"</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="720" align="left"><tabPositions><tabStop position="720"/><tabStop position="2880"/></tabPositions><font><i>Make sure the URLs above start with  </i></font><font>http:// or  https:// </font></paragraph></text>
<fib label="Q5" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Registration Form Text:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registration deadline date: </font><blank label="a" length="17" required="false" alternateLabel="RegFormDeadline"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Header text: </font><blank label="b" length="20" required="false" alternateLabel="RegFormHeader"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Sub-header text </font><font face="Arial" size="200" color="000000"><i>(optional)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="c" length="20" required="false" alternateLabel="RegFormSubHeader"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Additional descriptive text </font><font face="Arial" size="200" color="000000"><i>(optional)</i></font><font face="Arial" size="200" color="000000">: </font><blank label="d" length="19" required="false" alternateLabel="RegFormDescription"/></paragraph></fib>
<text label="T5" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Note: The above Header, Sub-header and descriptive text appear at the top of the Registration Form, and can contain any information you would like to have appear there.</i></font></paragraph></text>
<fib label="Q6" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Age Determination:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Some leagues determine a player's age ("league age") based on their actual age at the beginning of a particular month. For example, if your league uses an April 30 cutoff (such as Little League) you would enter 5 below, indicating that league age is based on a player's physical age as of May 1.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">If your program uses such a system for determining a player's league age, please enter the number of the month here:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><i>(1 = Jan, 2 = Feb, etc.):</i></font><sp/><blank label="a" length="5" required="false" alternateLabel="AgeFormula"/></paragraph></fib>
<text label="T6" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Note: If your league uses a more complex formula for determining league age, you will have to enter the age field manually in the Registration Form from your MyTawala Project Details page.</i></font></paragraph></text>
<mc label="Q7" alternateLabel="EmailNotificationPreference" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Administrator Email Options:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send me an email notification of each new registration</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Send me a single copy of each bulk mailing</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<and>
<isNotBlank field="AdminSetup:Password" />
<doesNotEqual field="AdminSetup:Password">
<string field="AdminSetup:Passcheck"/>
</doesNotEqual>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="The two copies of your password don&apos;t match."/>
</set>
<skip to="Basic Info Header"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<isLessThan field="AdminSetup:Season">
<string value="2008"/>
</isLessThan>
<isGreaterThan field="AdminSetup:Season">
<string value="2060"/>
</isGreaterThan>
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Season must be a year between 2008 and 2060."/>
</set>
<skip to="Basic Info Header"/>
</trueSet>
</if>
<if>
<conditions>
<isBlank field="AdminSetup:LeagueName" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please provide League name"/>
</set>
<skip to="Basic Info Header"/>
</trueSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<isNotBlank field="SetupNavigation" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H2" alternateLabel="Registration Form Header" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Registration Form Setup</font></paragraph></heading>
<text label="T7" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Place a check next to question items you want to include in your Registration Form:</b></font></paragraph></text>
<mc label="Q8" alternateLabel="AskSecondParentName" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Second parent name</font></paragraph></choice></mc>
<mc label="Q9" alternateLabel="AskSecondParentAddress" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Second parent address</font></paragraph></choice></mc>
<mc label="Q10" alternateLabel="AskSecondParentEmail" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Additional email address</font></paragraph></choice></mc>
<mc label="Q11" alternateLabel="AskIfFirstTimePlaying" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Is this the first year the player will be playing in the league?</font></paragraph></choice></mc>
<mc label="Q12" alternateLabel="AskParish" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Parish information </font><font face="Arial" size="200" color="000000"><i>(for Catholic Youth Organization leagues)</i></font></paragraph></choice></mc>
<mc label="Q13" alternateLabel="AskSchoolName" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">School name</font></paragraph></choice></mc>
<mc label="Q14" alternateLabel="AskGrade" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">School grade. </font><font face="Arial" size="200" color="000000"><i>(You will set up grades later.)</i></font></paragraph></choice></mc>
<mc label="Q15" alternateLabel="AskDesiredDivision" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Division player would prefer to play in. </font><font face="Arial" size="200" color="000000"><i>(You will set up divisions later.)</i></font></paragraph></choice></mc>
<mc label="Q16" alternateLabel="AskPreviousDivision" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Division player played in previously. </font><font face="Arial" size="200" color="000000"><i>(You will set up divisions later.)</i></font></paragraph></choice></mc>
<mc label="Q17" alternateLabel="AskCoachPreference" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Name of player's preference(s) for his/her coach</font></paragraph></choice></mc>
<mc label="Q18" alternateLabel="AskFriendNames" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Names of friends that player would like to have on player's team</font></paragraph></choice></mc>
<mc label="Q19" alternateLabel="AskUniform" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Uniform/jersey size. </font><font face="Arial" size="200" color="000000"><i>(You will set up  sizes later.)</i></font></paragraph></choice></mc>
<mc label="Q20" alternateLabel="AskMedicalInfo" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Player medical information </font><font face="Arial" size="200" color="000000"><i>(doctor's address and phone numbers, insurance information)</i></font></paragraph></choice></mc>
<mc label="Q21" alternateLabel="AskVolunteerQuestions" onlyone="false" required="false" style="vertical" paddingBottom="false"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Present volunteer activity options. </font><font face="Arial" size="200" color="000000"><i>(You will set activities up later.)</i></font></paragraph></choice></mc>
<text label="T8" alternateLabel="Phone Descriptions" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000"><b>Phone Descriptions: </b></font><font color="000000"><i>(Enter name you would like each phone field described as, e.g. Dad's Mobile, Home phone, etc.)</i></font></paragraph></text>
<fib label="Q22" style="leftAlignLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">    Phone 1: </font><blank label="a" length="20" required="false" alternateLabel="Phone1Label"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">    Phone 2: </font><blank label="b" length="20" required="false" alternateLabel="Phone2Label"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">    Phone 3: </font><blank label="c" length="20" required="false" alternateLabel="Phone3Label"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<isNotBlank field="SetupNavigation" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H3" alternateLabel="Custom Question Header" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Custom Question Setup</font></paragraph></heading>
<text label="T9" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You can ask up to three additional questions. Please leave the unneeded questions blank.</font></paragraph></text>
<fib label="Q23" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Custom Question 1:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="64" required="false" alternateLabel="CustomQuestion1"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Custom Question 2:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="b" length="64" required="false" alternateLabel="CustomQuestion2"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Custom Question 3:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="c" length="64" required="false" alternateLabel="CustomQuestion3"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<isNotBlank field="SetupNavigation" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H4" alternateLabel="Medical Waiver Header" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Waiver Setup</font></paragraph></heading>
<text label="T10" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Message"/></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q24" alternateLabel="AskMedicalWaiver" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Include waiver on registration form</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">We will provide our own waivers separately, but still want to track when they are received</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">We do not use waivers, or we will track them independently of SportsDashboards</font></paragraph></choice></mc>
<text label="T11" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Complete the following if you selected the first option above (Include waiver on registration form)</font></paragraph></text>
<mc label="Q25" alternateLabel="WaiverMustBeAgreedTo" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Registrant must agree to the waiver on the registration form before proceeding</font></paragraph></choice></mc>
<fib label="Q26" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Waiver text:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="119" height="40" required="false" alternateLabel="WaiverText"/></paragraph></fib>
<skipInstructions>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<and>
<mcEquals field="AdminSetup:AskMedicalWaiver" value="a"/>
<isBlank field="AdminSetup:WaiverText" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Waiver text is required."/>
</set>
<skip to="Medical Waiver Header"/>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="SetupNavigation" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H5" alternateLabel="Financial Setup Header" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Financial Setup</font></paragraph></heading>
<text label="T12" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Message"/></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q27" alternateLabel="FeeStructureChoice" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000"><b>Fee structure:</b></font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Flat fee</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Fees vary by division ("Desired division" question will be shown on Registration form)</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Fees vary by grade ("Grade" question will be shown on Registration form)</font></paragraph></choice></mc>
<fib label="Q28" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Flat fee amount (if you selected the first option) $ </font><blank label="a" length="20" required="false" alternateLabel="IndividualSignupFee"/></paragraph></fib>
<mc label="Q29" alternateLabel="PaymentMethods" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" color="000000"><b>Payment methods: </b></font><font face="Arial" color="000000">(select at least one)</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enable PayPal online payments</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Show instructions on how to pay by check</font></paragraph></choice></mc>
<text label="T13" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Description of charges (will appear on PayPal check out screen):</font></paragraph></text>
<fib label="Q30" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="41" required="false" alternateLabel="ChargeDescription"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<and>
<mcEquals field="AdminSetup:FeeStructureChoice" value="a"/>
<isLessThan field="AdminSetup:IndividualSignupFee">
<string value="0.0001"/>
</isLessThan>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Flat fee must be a valid amount."/>
</set>
<skip to="Financial Setup Header"/>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="AdminSetup:FeeStructureChoice" value="b"/>
<mcIsBlank field="AdminSetup:AskDesiredDivision" />
</and>
</conditions>
<trueSet>
<set field="AdminSetup:AskDesiredDivision" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="AdminSetup:FeeStructureChoice" value="c"/>
<mcIsBlank field="AdminSetup:AskGrade" />
</and>
</conditions>
<trueSet>
<set field="AdminSetup:AskGrade" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="AdminSetup:PaymentMethods" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="At least one of payment methods must be selected"/>
</set>
<skip to="Financial Setup Header"/>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<and>
<mcContains field="AdminSetup:PaymentMethods" value="a"/>
<isBlank field="AdminSetup:ChargeDescription" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please put the description of charges. It is needed for PayPal payments."/>
</set>
<skip to="Financial Setup Header"/>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="SetupNavigation" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H6" alternateLabel="Donation Header" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Donation Setup</font></paragraph></heading>
<text label="T14" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Message"/></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q31" alternateLabel="EnableDonations" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enable online donations on players' dashboards</font></paragraph></choice></mc>
<fib label="Q32" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Text to be displayed on the players's dashboard and donation page:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="54" height="5" required="false" alternateLabel="DonationPageMessage"/></paragraph></fib>
<mc label="Q33" alternateLabel="AskForDonationDuringRegistration" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Enable online donations during the registration process</font></paragraph></choice></mc>
<fib label="Q34" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Text to be displayed on the registration form:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><blank label="a" length="54" height="5" required="false" alternateLabel="DonationTextOnRegistration"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<and>
<mcEquals field="AdminSetup:EnableDonations" value="a"/>
<isBlank field="AdminSetup:DonationPageMessage" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please provide the text to be displayed on players&apos; dashboards."/>
</set>
<skip to="Donation Header"/>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<and>
<mcEquals field="AdminSetup:AskForDonationDuringRegistration" value="a"/>
<isBlank field="AdminSetup:DonationTextOnRegistration" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please provide the text to be displayed on the registration form."/>
</set>
<skip to="Donation Header"/>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<isNotBlank field="SetupNavigation" />
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<heading label="H7" alternateLabel="Code of Conduct Header" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Code of Conduct Setup</font></paragraph></heading>
<text label="T15" style="error"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="Message"/></font></paragraph><displayConditions>
<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q35" alternateLabel="AskToSignCodeOfConduct" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Have player's parent sign code of conduct.</font></paragraph></choice></mc>
<fib label="Q36" style="topLabels"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Code of conduct text:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/><blank label="a" length="100" height="25" required="false" alternateLabel="CodeOfConductText"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<and>
<mcEquals field="AdminSetup:AskToSignCodeOfConduct" value="a"/>
<isBlank field="AdminSetup:CodeOfConductText" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter the code of conduct below."/>
</set>
<skip to="Code of Conduct Header"/>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<skip to="__EndOfForm__"/>
</falseSet>
</if>
</skipInstructions>
