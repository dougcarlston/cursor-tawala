<document name="NavigationToDonationPage">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="375"><row><cell width="10425"><division indent="0" align="left"><font><field name="DonationMessage"/></font></division></cell></row><row><cell width="10425"><division indent="0" align="left"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></division></cell></row><row><cell width="10425"><division indent="0" align="left"><font color="000080"><u><invitation form="OnlineDonation" project="">Make a donation</invitation></u></font></division></cell></row><row><cell width="10425"><division indent="0" align="left"><sp/></division></cell></row></table>
</xmlData>
</document>
<document name="Donation">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><field name="DonationMessage"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><paypal-single-item-button version="1"><button-type>donate-logo</button-type><item><field name="OnlineDonation:DonationDescription"/>
</item><amount><field name="OnlineDonation:DonationAmount"/>
