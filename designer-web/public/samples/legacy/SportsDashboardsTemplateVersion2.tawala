<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000"><field name="Action"/></font><font face="Arial" size="360" color="000000"> Recruitment Database</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Recruitment" project="">Back to Recruitment Management</invitation></u></font></division></cell><cell width="5400"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="C00000"><b><i><field name="Message"/></i></b></font></paragraph></text>
<fib label="Q1" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">First Name: </font><blank label="a" length="20" required="false" alternateLabel="FirstName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Last Name: </font><blank label="b" length="20" required="false" alternateLabel="LastName"/></paragraph></fib>
<fib label="Q2" style="leftAlignLabelsJustified"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><sp/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Parent's First Name:  </font><blank label="a" length="20" required="false" alternateLabel="ParentFirst"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Email Address: </font><blank label="b" length="20" required="false" alternateLabel="Email"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Additional Email Address: </font><blank label="c" length="17" required="false" alternateLabel="Email2"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Phone Number: </font><blank label="d" length="20" required="false" alternateLabel="Phone"/></paragraph></fib>
<skipInstructions>
<if>
<conditions>
<isBlank field="RecruitmentDB:Email" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter an email address."/>
</set>
<skip to="H1"/>
</trueSet>
</if>
</skipInstructions>
<field name="RecruitmentId"/>
<field name="BadRecord?"/>
<field name="ContactsNo"/>
</items>
</form>
