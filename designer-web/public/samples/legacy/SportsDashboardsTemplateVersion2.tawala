<string value=".0001"/>
</isLessThan>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Enter correct donation amount. Please make sure you omit the dollar sign and commas."/>
</set>
<skip to="T5"/>
</trueSet>
</if>
