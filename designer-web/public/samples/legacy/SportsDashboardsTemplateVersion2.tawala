<text label="T4" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2160"><division indent="0" align="left"><font color="000000"><b>Registration:</b></font></division></cell><cell width="1785"></cell><cell width="3330"><division indent="0" align="left"><font color="C10000"><b><field name="League"/></b></font></division></cell><cell width="3795"><division indent="0" align="left"><font color="C10000">Due date:</font><sp/><font color="C10000"><b><field name="RegistrationDeadline"/></b></font></division></cell></row><row><cell width="2160"></cell><cell width="1785"></cell><cell width="3330"><division indent="0" align="left"><font><field name="AdminAdrss"/></font></division></cell><cell width="3795"></cell></row><row><cell width="2160"></cell><cell width="1785"></cell><cell width="3330"><division indent="0" align="left"><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><sp/><font><field name="AdminsZIP"/></font></division></cell><cell width="3795"></cell></row><row><cell width="2160"></cell><cell width="1785"></cell><cell width="3330"></cell><cell width="3795"><division indent="0" align="left"><font color="C10000">Cost per player:</font><font color="C10000"><b><field name="FeeStructureDescription"/></b></font><sp/><sp/></division></cell></row><row><cell width="2160"></cell><cell width="1785"></cell><cell width="3330"><division indent="0" align="left"><font size="320" color="B30000"><field name="PaymentStatus"/></font></division></cell><cell width="3795"></cell></row></table></text>
