</skipInstructions>
</items>
</form>
<form name="RegFormMgmt" startPoint="false" themePath="mvsc" process="Post-RegistrantMgmt">
<items>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
</items>
</form>
<form name="AuditRegForms" startPoint="false" themePath="mvsc" process="Post-AuditRegForms">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Registration Forms</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3975"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3225"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This utility will check all the submitted Registration Forms for valid emails.  </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>If it finds one with more than one valid email or none, it will pull up the record and give you a chance to edit it so that it will work with the Tawala utilities.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>It is not possible to keep two email addresses in one contact field.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will have the opportunity to edit or delete each record that fails the audit test.</font></paragraph></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select:</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Proceed</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Return</font></paragraph></choice></mc>
</items>
</form>
<form name="AuditFormLoop" startPoint="false" themePath="mvsc" process="Post-AuditFormLoop" preProcess="Pre-AuditFormLoop">
<items>
<heading label="H1" type="Main"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Audit Players with Invalid Emails</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000080"><u><invitation form="RegFormMgmt" project="">Back to Player Registration Management</invitation></u></font></paragraph></text>
<mc label="Q1" alternateLabel="RegistrationId" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player to audit:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:FirstName"/>
<string value=" "/>
<field name="Record:Registration:LastName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression></sort-expression><record-selector><form name="Registration" /><conditions>
<equals field="Record:Registration:BadEmail?">
<string value="Yes"/>
</equals>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="RegistrantDeduping" startPoint="false" themePath="mvsc" process="Post-RegistrantDeduping" preProcess="Pre-RegistrantDeduping">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Registration Deduping Routine</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3855"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3345"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row><row><cell width="3855"><division indent="0" align="left"><sp/></division></cell><cell width="3345"></cell><cell width="3600"></cell></row></table></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><i>Compare the data from the following two files:</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="center"><font><b>Record #1</b></font></division></cell><cell width="5400"><division indent="0" align="center"><font><b>Record #2</b></font></division></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="1800"><division indent="0" align="right"><font><b>Player Name:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegName"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Player Name:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegName"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Birthday:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegBD"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Birthday:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegBD"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Sex:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegSex"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Sex:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegSex"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Parent:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPName"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Parent:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPName"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegAddress"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegAddress"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegAddress1"/></font></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegAddress1"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegEmail"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Email:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegEmail"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegEmail1"/></font></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegEmail1"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Phone #s:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPhone1"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Phone #s:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPhone1"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPhone2"/></font></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPhone2"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPhone3"/></font></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPhone3"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>School:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegSchool"/></font><sp/><font><field name="RegParish"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>School:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegSchool"/></font><sp/><font><field name="SRegParish"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Grade:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegGrade"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Grade:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegGrade"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Friends:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegFriends"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Friends:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegFriends"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Jersey:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegUniform"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Jersey:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegUniform"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><sp/></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Medical Plan:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegMedPlan"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Medical Plan:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegMedPlan"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Doctor:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegDoctor"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Doctor:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegDoctor"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegDocPhone"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Phone:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegDocPhone"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegDocAddress"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Address:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegDocAddress"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><sp/><sp/><sp/></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><sp/><sp/></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Team:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegTeam"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Team:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegTeam"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Payment:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPayment"/></font><font> ($</font><font><field name="RegPaidAmount"/></font><font>)</font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Payment:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPayment"/></font><font> ($</font><font><field name="SRegPaidAmt"/></font><font>)</font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Method:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegPaymentMethod"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Method:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegPaymentMethod"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Waiver:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegWaiver"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Waiver:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegWaiver"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Exception:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegWaiverException"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Exception:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegWaiverException"/></font></division></cell></row><row><cell width="1800"></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><sp/></division></cell><cell width="1875"></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><sp/></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Registration ID:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegID"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Registration ID:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegID"/></font></division></cell></row><row><cell width="1800"><division indent="0" align="right"><font><b>Group ID:</b></font></division></cell><cell width="200"></cell><cell width="3400"><division indent="0" align="left"><font><field name="RegGroupID"/></font></division></cell><cell width="1875"><division indent="0" align="right"><font><b>Group ID:</b></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="left"><font><field name="SRegGroupdID"/></font></division></cell></row></table></text>
<mc label="Q1" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Record 2 is not a duplicate of Record 1.  Leave both in.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete Record #1</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Delete Record #2</font></paragraph></choice></mc>
</items>
</form>
