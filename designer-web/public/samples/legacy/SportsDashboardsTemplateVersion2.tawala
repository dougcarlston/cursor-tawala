</trueSet>
</if>
<if>
<conditions>
<or>
<isLessThan field="Registration:RegAgeYr">
<string value="1900"/>
</isLessThan>
<isBlank field="Registration:RegAgeYr" />
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter year of birth as a four digit number (e.g. &quot;1998&quot;)"/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<or>
<doesNotEqual field="Registration:ParentEmail">
<string field="Registration:ParentEmailConfirm"/>
</doesNotEqual>
<isBlank field="Registration:ParentEmail" />
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Email address is blank or copies of email fail to match."/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<isNotBlank field="Registration:ParentEmail2" />
</conditions>
<trueSet>
<if>
<conditions>
<doesNotEqual field="Registration:ParentEmail2">
<string field="Registration:ParentEmail2Confirm"/>
</doesNotEqual>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Two copies of additional email fail to match."/>
</set>
<skip to="T5"/>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<or>
<isBlank field="Registration:FirstName" />
<isBlank field="Registration:LastName" />
</or>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please enter Player&apos;s First and Last names in the spaces provided."/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<mcIsBlank field="Registration:SexMCQ" />
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please indicate Player&apos;s sex."/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<mcIsBlank field="Registration:Grade" />
<equals field="FeeStructure">
<string value="Varies by Grade"/>
</equals>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please mark the Player&apos;s grade level."/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<equals field="FeeStructure">
<string value="Varies by Division"/>
</equals>
<mcIsBlank field="Registration:DivisionId" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please mark the Player&apos;s preferred Division."/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<equals field="UniformSelectionRequired">
<string value="Yes"/>
</equals>
<and>
<mcIsBlank field="Registration:UniformSize" />
<equals field="AskUniform">
<string value="Yes"/>
</equals>
</and>
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Please answer the question: &apos;"/>
<string field="UniformQuestionText"/>
<string value=".&apos;"/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<equals field="WaiverRequired">
<string value="Yes"/>
</equals>
<mcIsBlank field="Registration:WaiverSignedMCQ" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You need to accept the waiver in order to register"/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<equals field="AskToSignCodeOfConduct">
<string value="Yes"/>
</equals>
<mcIsBlank field="Registration:CodeOfConductAgreedTo" />
</and>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="You need to agree to the Code of Conduct in order to register"/>
</set>
<skip to="T5"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<isNotBlank field="Registration:DonationAmount" />
