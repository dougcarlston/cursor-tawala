<if>
<conditions>
<or>
<mcEquals field="Communicator:Q2">
<string value="a"/>
</mcEquals>
<mcEquals field="Communicator:Q2" value="b"/>
</or>
</conditions>
<trueSet>
<comment>Send a) to all players and coaches, or b) just to all coaches</comment>
<comment>(assistant coaches are included in both cases)</comment>
<set field="ToField" arithmeticAsText="true">
