<isNotBlank field="Message" />
</displayConditions></text>
<mc label="Q29" alternateLabel="InfoCorrect" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select an option and click Submit.</font></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Edit or change the above information.</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">The above information is correct. Continue to the next step.</font></paragraph></choice></mc>
<text label="T33" style="instructional"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You will always be able to change this information later from your Player Dashboard.</font></paragraph></text>
<skipInstructions>
<if>
<conditions>
<equals field="RegistrationPreview">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<skip to="T12"/>
</trueSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcEquals field="Registration:InfoCorrect" value="a"/>
</conditions>
<trueSet>
<skip to="T2"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="Registration:InfoCorrect" value="b"/>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Select an option below and click Submit."/>
</set>
<set field="Registration:InfoCorrect" arithmeticAsText="false">
<string value=" "/>
</set>
<skip to="T13"/>
</trueSet>
</if>
</skipInstructions>
