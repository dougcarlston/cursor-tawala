<document name="PaymentReport">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280"><b>Payment Report</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3855"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3345"><division indent="0" align="left"><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Individual Registrations</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>true</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Paid Amount"/>
</header><contents><field name="Record:Registration:PaidAmount" /></contents></column><column><header><string value="Payment Method"/>
</header><contents><field name="Record:Registration:PaymentMethod" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Total amount: $</font><font><sum version="1"><field>Record:Registration:PaidAmount</field><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions></conditions></sum></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Group Registrations</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>true</show-print-control><column><header><string value="Team"/>
</header><contents><field name="Record:GroupRegistration:TeamId" /></contents></column><column><header><string value="Group Registration Fee"/>
</header><contents><field name="Record:GroupRegistration:RegistrationFee" /></contents></column><conditions><form name="GroupRegistration" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Total group registrations: $</font><font><sum version="1"><field>Record:GroupRegistration:RegistrationFee</field><conditions><form name="GroupRegistration" /></conditions></sum></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Online Donations</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>true</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Amount"/>
</header><contents><field name="Record:OnlineDonation:DonationAmount" /></contents></column><column><header><string value="User Notes"/>
</header><contents><field name="Record:OnlineDonation:UserMemo" /></contents></column><conditions><form name="Registration" /><form name="OnlineDonation" /><conditions>
<and>
<equals field="Record:Registration:RegID">
<string field="Record:OnlineDonation:RegID"/>
</equals>
<equals field="Record:OnlineDonation:Status">
<string value="Completed"/>
</equals>
</and>
</conditions></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Total donated: $</font><font><sum version="1"><field>Record:OnlineDonation:DonationAmount</field><conditions><form name="OnlineDonation" /><conditions>
<equals field="Record:OnlineDonation:Status">
<string value="Completed"/>
</equals>
</conditions></conditions></sum></font></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><sp/></division></cell><cell width="5400"></cell></row></table>
</xmlData>
</document>
