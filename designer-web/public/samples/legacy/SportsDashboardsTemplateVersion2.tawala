</equals>
</conditions></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Assistant Coaches:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First"/>
</header><contents><field name="Record:AssistantCoachInfo:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:AssistantCoachInfo:LastName" /></contents></column><column><header><string value="Phone 1"/>
</header><contents><field name="Record:AssistantCoachInfo:Phone1" /></contents></column><column><header><string value="Phone 2"/>
</header><contents><field name="Record:AssistantCoachInfo:Phone2" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:AssistantCoachInfo:Email" /></contents></column><conditions><form name="AssistantCoachInfo" /><conditions>
