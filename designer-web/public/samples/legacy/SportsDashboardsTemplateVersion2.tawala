</conditions>
<trueSet>
<show form="RegFormMgmt"/>
</trueSet>
</if>
<delete><form name="Registration"/><conditions>
<mcContains field="DeleteRegistration:RegistrationIds">
<string field="Record:Registration:RegID"/>
</mcContains>
</conditions></delete>
<set field="Message" arithmeticAsText="false">
<string value="Registration deleted."/>
</set>
<show document="Message" reset="false"/>
<show form="RegFormMgmt"/>
</process>
