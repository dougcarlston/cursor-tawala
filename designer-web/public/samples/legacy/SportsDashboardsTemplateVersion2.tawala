<to addressField="Registrant:Registration:ParentEmail2"/>
<from addressField="AdminEmail" aliasField="AdminName"/>
<subject>Your <field name="League"/> Player Dashboard link</subject>
<body document="PlayerDashboardReminder" reset="false" showHeader="true"/>
</send>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
</trueSet>
