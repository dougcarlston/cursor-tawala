<document name="WaiverNeededAndPaymentByCheckOnly">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="360" color="000000">Step 1 of your registration has been completed.</font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to complete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 2:</b></font><font> Submit your payment of $</font><font><field name="RegistrationFee"/></font><font> and</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Step 3:</b></font><font> Click the link to your personal </font><font><field name="League"/></font><font> Dashboard, and from there select "View/Edit Registration. Then on your registration form "sign" your waiver by clicking on the checkbox under the waiver text.</font></paragraph>
</xmlData>
</document>
<document name="OnlyWaiverIsNeeded">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="A00000"><b><i>Note: DO NOT USE THE BACK BUTTON on your browser.</i></b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>You still need to complete:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>A signed waiver</b></font><font>.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>On your Player Dashboard select "View/Edit Registration. Then on your registration form "sign" your waiver by clicking on the checkbox under the waiver text.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="240" color="000000"><b>*NOTE: No player will be allowed to participate without a signed waiver.</b></font></paragraph>
</xmlData>
</document>
