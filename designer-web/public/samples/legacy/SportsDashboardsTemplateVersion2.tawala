<form name="ConfirmPaymentAndWaiverReceipts" startPoint="false" themePath="mvsc" process="Post-ConfirmPaymentAndWaiverReceipts" preProcess="UpdatePaidStatusBasedOnInvoiceStatus">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Mark Waiver &amp; Payment Receipts</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3840"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3360"><division indent="0" align="left"><font color="0066CC"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font></division></cell><cell width="3600"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administration Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q1" alternateLabel="PaymentOrWaiver" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark waiver receipts</font></paragraph></choice><choice label="b"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Mark payment receipts</font></paragraph></choice><choice label="c"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Review all records</font></paragraph></choice><choice label="d"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Unmark incorrectly marked record</font></paragraph></choice></mc>
<skipInstructions>
<if>
<conditions>
<mcIsBlank field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" />
</conditions>
<trueSet>
<skip to="H1"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver">
<string value="b"/>
</mcEquals>
</conditions>
<trueSet>
<set field="ConfirmPaymentAndWaiverReceipts:PaidAmount" arithmeticAsText="false">
<string field="SignupFeeForIndividual"/>
</set>
<skip to="Payment Receipt Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="c"/>
</conditions>
<trueSet>
<skip to="ReviewRcrds Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="d"/>
</conditions>
<trueSet>
<skip to="Unmark Text"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ConfirmPaymentAndWaiverReceipts:PaymentOrWaiver" value="e"/>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
</skipInstructions>
<text label="T2" alternateLabel="WaiverReceiptText" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This is a list of players who have not sent or submitted the waivers.</font></paragraph></text>
<mc label="Q2" alternateLabel="WaiverRegIds" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check players whose waivers you wish to mark as received:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<isBlank field="Record:Registration:WaiverReceived" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T3" alternateLabel="Payment Receipt Text" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>This is a list of players who have not paid.</font></paragraph></text>
<mc label="Q3" alternateLabel="PaymentRegIds" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Check players whom you wish to mark as paid:</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<isBlank field="Record:Registration:PaymentReceived" />
</conditions></record-selector></dynamic-mcq></data-provider></mc>
<fib label="Q4" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Payment amount:  $</font><blank label="a" length="9" required="false" alternateLabel="PaidAmount"/></paragraph></fib>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T4" alternateLabel="ReviewRcrds Text" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4125"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3405"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3270"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Waiver"/>
</header><contents><field name="Record:Registration:WaiverReceived" /></contents></column><column><header><string value="Payment"/>
</header><contents><field name="Record:Registration:PaymentReceived" /></contents></column><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Parent"/>
</header><contents><field name="Record:Registration:ParentFirstName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Email 2"/>
</header><contents><field name="Record:Registration:ParentEmail2" /></contents></column><column><header><field name="Phone1Lab"/>
</header><contents><field name="Record:Registration:Phone1" /></contents></column><column><header><field name="Phone2Lab"/>
</header><contents><field name="Record:Registration:Phone2" /></contents></column><column><header><field name="Phone3Lab"/>
</header><contents><field name="Record:Registration:Phone3" /></contents></column><column><header><string value="Desired Division"/>
</header><contents><field name="Record:Registration:DivisionId" /></contents></column><conditions><form name="Registration" /></conditions></itemization-table></font></paragraph></text>
<skipInstructions>
<skip to="__EndOfForm__"/>
</skipInstructions>
<text label="T5" alternateLabel="Unmark Text" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4095"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver &amp; Payment Management</invitation></u></font></division></cell><cell width="3480"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3225"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<mc label="Q5" alternateLabel="UnmarkReceipts" onlyone="true" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Select the player to unmark either payment receipt or waiver receipt</font></paragraph></question><data-provider><dynamic-mcq version="1"><display-expression><field name="Record:Registration:LastName"/>
<string value=", "/>
<field name="Record:Registration:FirstName"/>
<string value=" ("/>
<field name="Record:Registration:ParentEmail"/>
<string value=")"/>
</display-expression><value-expression><field name="Record:Registration:RegID"/>
</value-expression><sort-expression><field name="Record:Registration:LastName"/>
<string value="#"/>
<field name="Record:Registration:FirstName"/>
</sort-expression><record-selector><form name="Registration" /><conditions>
<or>
<equals field="Record:Registration:PaymentReceived">
<string value="Yes"/>
</equals>
<equals field="Record:Registration:WaiverReceived">
<string value="Yes"/>
</equals>
</or>
</conditions></record-selector></dynamic-mcq></data-provider></mc>
</items>
</form>
<form name="FinishPaymentAndWaiverReceipts" startPoint="false" themePath="mvsc" process="Post-FinishPaymentAndWaiverReceipt" preProcess="Pre-FinishPaymentAndWaiverReceipt">
<items>
<heading label="H1" type="Sub"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="360" color="000000">Unmark Waiver or Payment Receipts</font></paragraph></heading>
<text label="T1" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4140"><division indent="0" align="left"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Back to Waiver and Payment Management</invitation></u></font></division></cell><cell width="3420"><division indent="0" align="left"><font color="0066CC"><u><invitation form="RegFormMgmt" project="">Back to Registration Management</invitation></u></font></division></cell><cell width="3240"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table></text>
<text label="T2" style="normal"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Current Status:</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Registration:ParentEmail" /></contents></column><column><header><string value="Payment Received"/>
</header><contents><field name="Record:Registration:PaymentReceived" /></contents></column><column><header><string value="Waiver Received"/>
</header><contents><field name="Record:Registration:WaiverReceived" /></contents></column><conditions><form name="Registration" /><conditions>
<equals field="Record:Registration:RegID">
<string field="ConfirmPaymentAndWaiverReceipts:UnmarkReceipts"/>
</equals>
</conditions></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>Uncheck  to unmark or check to mark:</font></paragraph></text>
<mc label="Q1" alternateLabel="Waiver Received" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Waiver received</font></paragraph></choice></mc>
<mc label="Q2" alternateLabel="Payment Received" onlyone="false" required="false" style="vertical"><question><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph></question><choice label="a"><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font face="Arial" size="200" color="000000">Payment received</font></paragraph></choice></mc>
</items>
