<?xml version="1.0" encoding="utf-8" ?>
<project name="SportsDashboardsTemplateVersion2" themePath="mvsc" format="1.13" designerBuild="235">
<pageHeader></pageHeader><forms>
<form name="Registration" startPoint="true" themePath="mvsc" process="Post-Registration" preProcess="RetrieveAdminSetupVariables">
<items>
<skipInstructions>
<if>
<conditions>
<equals field="Registration:PaymentReceived">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="PaymentStatus" arithmeticAsText="false">
<string value="PAID"/>
</set>
</trueSet>
<falseSet>
<set field="PaymentStatus" arithmeticAsText="false">
<string value=" "/>
</set>
</falseSet>
</if>
<if>
<conditions>
<equals field="From">
<string value="AddPlayerToGroupRegistration"/>
</equals>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="NavigateToPaymentInstructions">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="NavigateToPaymentInstructions" arithmeticAsText="false">
<string value=" "/>
</set>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<and>
<doesNotEqual field="Operation">
<string value="AdminRegisteringPlayer"/>
</doesNotEqual>
<and>
<equals field="RegViewFlag">
<string value="Closed"/>
</equals>
<isBlank field="_InviteeID" />
</and>
</and>
</conditions>
<trueSet>
<skip to="__EndOfForm__"/>
</trueSet>
</if>
<if>
<conditions>
<equals field="PrefillRegistrationForm">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="PrefillRegistrationForm" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Registration:ParentFirstName" arithmeticAsText="false">
<string field="PrefillParentFirstName"/>
</set>
<set field="Registration:ParentLastName" arithmeticAsText="false">
<string field="PrefillParentLastName"/>
</set>
<set field="Registration:Address" arithmeticAsText="false">
<string field="PrefillAddress"/>
</set>
<set field="Registration:City" arithmeticAsText="false">
<string field="PrefillCity"/>
</set>
<set field="Registration:State" arithmeticAsText="false">
<string field="PrefillState"/>
</set>
<set field="Registration:Zip" arithmeticAsText="false">
<string field="PrefillZIP"/>
</set>
<set field="Registration:ParentEmail" arithmeticAsText="false">
<string field="PrefillParentEmail"/>
</set>
<set field="Registration:ParentEmailConfirm" arithmeticAsText="false">
<string field="PrefillParentEmail"/>
</set>
<set field="Registration:ParentEmail2" arithmeticAsText="false">
<string field="PrefillParentEmail2"/>
</set>
<set field="Registration:ParentEmail2Confirm" arithmeticAsText="false">
<string field="PrefillParentEmail2"/>
</set>
<set field="Registration:Phone1" arithmeticAsText="false">
<string field="PrefillPhone1"/>
</set>
<set field="Registration:Phone2" arithmeticAsText="false">
<string field="PrefillPhone2"/>
</set>
<set field="Registration:Phone3" arithmeticAsText="false">
<string field="PrefillPhone3"/>
</set>
<set field="Registration:MedPlanName" arithmeticAsText="false">
<string field="PrefillMedPlanName"/>
</set>
<set field="Registration:MedPlanNumber" arithmeticAsText="false">
<string field="PrefillMedPlanNumber"/>
</set>
<set field="Registration:DocName" arithmeticAsText="false">
<string field="PrefillDocName"/>
</set>
<set field="Registration:DocPhone" arithmeticAsText="false">
<string field="PrefillDocPhone"/>
</set>
<set field="Registration:DocAddress" arithmeticAsText="false">
<string field="PrefillDocAddress"/>
</set>
<set field="Registration:Parent2FirstName" arithmeticAsText="false">
<string field="PrefillParent2FirstName"/>
</set>
<set field="Registration:Parent2LastName" arithmeticAsText="false">
<string field="PrefillParent2LastName"/>
</set>
<set field="Registration:Address2" arithmeticAsText="false">
<string field="PrefillAddress2"/>
</set>
<set field="Registration:City2" arithmeticAsText="false">
<string field="PrefillCity2"/>
</set>
<set field="Registration:State2" arithmeticAsText="false">
<string field="PrefillState2"/>
</set>
<set field="Registration:Zip2" arithmeticAsText="false">
<string field="PrefillZip2"/>
</set>
<set field="Registration:Parish" arithmeticAsText="false">
<string field="PrefillParish"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="SessionExpired">
<string value="Yes"/>
</equals>
</conditions>
<trueSet>
<set field="Message" arithmeticAsText="false">
<string value="Your session has expired due to more than 30 minutes of inactivity. Please register again."/>
</set>
<set field="SessionExpired" arithmeticAsText="false">
<string value="No"/>
</set>
</trueSet>
</if>
</skipInstructions>
<text label="T1" style="instructional"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Registration Preview.</font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font>The data entered on this form is not validated and will not be saved. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="SetupMenu" project="">Return to Setup Menu</invitation></u></font><font>.</font></paragraph><displayConditions>
<equals field="RegistrationPreview">
<string value="Yes"/>
</equals>
</displayConditions></text>
