<text label="T12" style="instructional"><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font size="280">Registration Preview.</font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions><font>The data entered on this form is not validated and will not be saved. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="SetupMenu" project="">Return to Setup Menu</invitation></u></font><font>.</font></paragraph><displayConditions>
