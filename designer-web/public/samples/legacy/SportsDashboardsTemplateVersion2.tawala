<comment>-- add new assistant coach</comment>
<set field="CoachID" arithmeticAsText="false">
<string field="_InviteeID"/>
</set>
<show form="AssistantCoachInfo"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ManageAssistantCoaches:Action" value="b"/>
</conditions>
<trueSet>
<comment>-- edit existing record</comment>
<edit form="AssistantCoachInfo" submit="modify">
<conditions>
<equals field="Record:AssistantCoachInfo:AsstId">
<string field="ManageAssistantCoaches:SelectedAssistant"/>
</equals>
</conditions>
</edit>
</trueSet>
</if>
