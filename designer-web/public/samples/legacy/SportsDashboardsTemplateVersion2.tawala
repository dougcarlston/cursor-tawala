</header><contents><field name="Record:Coach:Email" /></contents></column><column><header><string value="Phone 1"/>
</header><contents><field name="Record:Coach:Phone1" /></contents></column><column><header><string value="Phone 2"/>
</header><contents><field name="Record:Coach:Phone2" /></contents></column><conditions><form name="Coach" /><conditions>
