<mcIsNotBlank field="Record:Registration:VolunteerActivities" />
</conditions></conditions></question-correlation-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="ViewVolunteerData" project="">Return to View Volunteer Data</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Return to Administrator Dashboard</invitation></u></font></paragraph>
