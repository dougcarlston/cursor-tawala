</set>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Coach&apos;s First Name"/>
<string value="&gt;"/>
<string value=","/>
</set>
<set field="DashboardLinkPreviewLinkText" arithmeticAsText="false">
<string value="Coach Dashboard"/>
</set>
<set field="DashboardLinkPreviewVerbiage" arithmeticAsText="false">
<string field="DashboardLinkForCoachVerbiage"/>
</set>
<if>
<conditions>
<mcEquals field="Communicator:Q2" value="a"/>
</conditions>
<trueSet>
<comment>Send to all players and coaches</comment>
<set field="ToField" arithmeticAsText="true">
<string field="ToField"/>
<string value=" / Players, Coaches and Assistant Coaches"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Player&apos;s First Name"/>
<string value="&gt;"/>
<string value=" or Parents of "/>
<string value="&lt;"/>
<string value="Player&apos;s First Name"/>
<string value="&gt;"/>
<string value=" (or "/>
<string value="&lt;"/>
<string value="Coach&apos;s First Name"/>
<string value="&gt;"/>
<string value="),"/>
</set>
<set field="DashboardLinkPreviewLinkText" arithmeticAsText="true">
<string value="[Player/Coach] Dashboard"/>
</set>
<set field="DashboardLinkPreviewVerbiage" arithmeticAsText="false">
<string value="[Different wording will appear here for players and coaches]"/>
</set>
<comment>First, the players</comment>
<if>
<conditions>
<mcDoesNotEqual field="Communicator:Q1" value="b"/>
</conditions>
<trueSet>
<comment>In all Divisions</comment>
<get recordList="Record List 53">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<isNotBlank field="Record List 53:Registration:TeamId" />
</conditions></get>
</trueSet>
<falseSet>
<comment>In selected Divisions</comment>
<get recordList="Record List 53">
<forms>
<form name="Registration"/>
<form name="Team"/>
</forms>
<conditions>
<and>
<mcContains field="Communicator:Divisions">
<string field="Record List 53:Team:Division"/>
</mcContains>
<equals field="Record List 53:Registration:TeamId">
<string field="Record List 53:Team:TeamId"/>
</equals>
</and>
</conditions></get>
</falseSet>
</if>
<foreach record="TeamPlayer" recordList="Record List 53">
<set field="SendPlayerEmail1Count" arithmeticAsText="false">
<add>
<operand field="SendPlayerEmail1Count"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<isNotBlank field="TeamPlayer:Registration:ParentEmail2" />
</conditions>
<trueSet>
<set field="SendPlayerEmail2Count" arithmeticAsText="false">
<add>
<operand field="SendPlayerEmail2Count"/>
<operand value="1"/>
</add>
</set>
</trueSet>
</if>
<if>
<conditions>
<equals field="BuildRecipientList">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<set field="Temp1" arithmeticAsText="false">
<string field="TeamPlayer:Registration:FirstName"/>
<string value=" "/>
<string field="TeamPlayer:Registration:LastName"/>
</set>
<set field="Temp2" arithmeticAsText="false">
<string field="TeamPlayer:Registration:TeamId"/>
</set>
<append document="PlayerEmailRecipients" appendage="EmailRecipientListItem"/>
</trueSet>
</if>
</foreach>
</trueSet>
<falseSet>
<set field="ToField" arithmeticAsText="true">
<string field="ToField"/>
<string value=" / Coaches and Assistant Coaches"/>
</set>
</falseSet>
</if>
<comment>Send to coaches</comment>
<get recordList="Coach List">
<forms>
<form name="Coach"/>
</forms>
</get>
<foreach record="CoachRecord" recordList="Coach List">
<if>
<conditions>
<mcDoesNotEqual field="Communicator:Q1" value="b"/>
</conditions>
<trueSet>
<comment>Send to coaches from all Divisions</comment>
<set field="SendCoachCount" arithmeticAsText="false">
<add>
<operand field="SendCoachCount"/>
<operand value="1"/>
</add>
</set>
<if>
<conditions>
<equals field="BuildRecipientList">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<set field="Temp1" arithmeticAsText="false">
