<isNotBlank field="Message" />
</displayConditions></text>
<fib label="Q1" style="freeform"><paragraph indent="0" align="left"><tabPositions><tabStop position="4896"/><tabStop position="8496"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4896"/><tabStop position="8496"/></tabPositions><tab/><font face="Arial" size="200" color="000000"><i>[First]</i></font><tab/><font face="Arial" size="200" color="000000"><i>[Last]</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000"><b>Player Name: </b></font><tab/><blank label="a" length="18" required="false" alternateLabel="FirstName"/><tab/><blank label="b" length="18" required="false" alternateLabel="LastName"/></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="4031"/><tabStop position="6192"/></tabPositions><font face="Arial" size="200" color="000000"><b>Date of Birth: </b></font><font face="Arial" size="200" color="000000"><i>(mm/dd/yyyy)</i></font><tab/><blank label="c" length="5" required="false" alternateLabel="RegAgeMo"/><font face="Arial" size="200" color="000000">/</font><blank label="d" length="5" required="false" alternateLabel="RegAgeDay"/><font face="Arial" size="200" color="000000">/</font><blank label="e" length="8" required="false" alternateLabel="RegAgeYr"/></paragraph></fib>
