<equals field="Record:AssistantCoachInfo:AsstId">
<string field="ManageAssistantCoaches:SelectedAssistant"/>
</equals>
</conditions></delete>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="ManageAssistantCoaches:Action" value="d"/>
</conditions>
<trueSet>
<comment>-- send Dashboards</comment>
<if>
<conditions>
<mcIsNotBlank field="ManageAssistantCoaches:SendDashboards" />
</conditions>
<trueSet>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="AssistantCoachList">
<forms>
<form name="AssistantCoachInfo"/>
</forms>
<conditions>
<mcContains field="ManageAssistantCoaches:SendDashboards">
<string field="AssistantCoachList:AssistantCoachInfo:AsstId"/>
</mcContains>
</conditions></get>
<foreach record="AssistantCoach" recordList="AssistantCoachList">
<set field="Team" arithmeticAsText="false">
<string field="AssistantCoach:AssistantCoachInfo:TeamId"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string field="AssistantCoach:AssistantCoachInfo:FirstName"/>
</set>
<set field="DashboardLinkID" arithmeticAsText="false">
<string field="AssistantCoach:AssistantCoachInfo:AsstId"/>
</set>
<send>
<to addressField="AssistantCoach:AssistantCoachInfo:Email"/>
<from addressField="Coach" aliasField="CoachsEmail"/>
<subject>Your Assistant Coach Dashboard for <field name="Team"/></subject>
<body document="AssistantCoachDashReminder" reset="false" showHeader="true"/>
</send>
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Dashboard links sent to "/>
<string field="Count"/>
<string value=" assistant coaches"/>
</set>
<show document="Message" reset="false"/>
</trueSet>
</if>
</trueSet>
</if>
<comment>-- redisplay form</comment>
<show form="ManageAssistantCoaches"/>
</process>
<process name="Pre-SelectTeamForAssistantCoaches">
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="Team List">
<forms>
<form name="Team"/>
</forms>
<conditions>
<equals field="Team List:Team:CoachId">
<string field="_InviteeID"/>
</equals>
</conditions></get>
<foreach record="SuchTeam" recordList="Team List">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
<set field="Team" arithmeticAsText="false">
<string field="SuchTeam:Team:TeamId"/>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<comment>-- JDF TODO: Error - shouldn't happen - should we handle it?</comment>
</trueSet>
</if>
<if>
<conditions>
<equals field="Count">
<string value="1"/>
</equals>
</conditions>
<trueSet>
<comment>-- coach has only one team; jump to Asst. Coach Mgmt. form</comment>
<show form="ManageAssistantCoaches"/>
</trueSet>
</if>
<comment>-- coach has more than one team; must pick one, so proceed</comment>
</process>
<process name="Post-SelectTeamForAssistantCoaches">
<set field="Team" arithmeticAsText="false">
<string field="SelectTeamForAssistantCoaches:SelectedTeam"/>
</set>
<show form="ManageAssistantCoaches"/>
</process>
<process name="Post-AssistantCoachDashboard">
<if>
<conditions>
<isBlank field="CoachID" />
</conditions>
<trueSet>
<show document="NoAssistantCoachDash" reset="false"/>
</trueSet>
<falseSet>
<show document="AssistantCoachDashboard" reset="false"/>
</falseSet>
</if>
</process>
<process name="Pre-AssistantCoachCommunicatorSetup">
<set field="RetrieveVariablesTargetForm" arithmeticAsText="false">
<string value="AssistantCoachCommunicator"/>
</set>
<show form="RetrieveAsstCoachVariablesForAnotherForm"/>
</process>
<process name="Pre-AssistantCoachCommunicator">
<comment>-- check for a previous message sent by this asst. coach</comment>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="PreviousEmails">
<forms>
<form name="AssistantCoachCommunicator"/>
</forms>
<conditions>
<equals field="PreviousEmails:AssistantCoachCommunicator:AssistantCoachId">
<string field="AsstCoachID"/>
</equals>
</conditions></get>
<foreach record="Record" recordList="PreviousEmails">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<comment>-- if none, initialize the recipient MCQ</comment>
<set field="AssistantCoachCommunicator:Recipient" arithmeticAsText="false">
<string value="a"/>
</set>
</trueSet>
<falseSet>
<comment>-- fetch the previous message</comment>
<edit form="AssistantCoachCommunicator" submit="modify">
<conditions>
<equals field="Record:AssistantCoachCommunicator:AssistantCoachId">
<string field="AsstCoachID"/>
</equals>
</conditions>
</edit>
</falseSet>
</if>
</process>
<process name="Post-AssistantCoachCommunicator">
<comment>-- ID used to retrieve asst. coach-specific messages in the pre-process</comment>
<set field="AssistantCoachCommunicator:AssistantCoachId" arithmeticAsText="false">
<string field="AsstCoachID"/>
</set>
<set field="DearSir" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="a"/>
</conditions>
<trueSet>
<comment>-- sending to all players and coaches on this team</comment>
<set field="ToField" arithmeticAsText="false">
<string value="All players and coaches on my team"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="d"/>
</conditions>
<trueSet>
<comment>-- sending to some players</comment>
<set field="ToField" arithmeticAsText="false">
<string value="Selected Players"/>
</set>
<comment>-- send copy to other assistants?</comment>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:CopyCoachesWithPlayers" value="a"/>
</conditions>
<trueSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value=" (A copy of this message will be sent to the other coaches on your team)"/>
</set>
</trueSet>
<falseSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value=" (A copy of this message will not be sent to the other coaches on your team)"/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="a"/>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="d"/>
</or>
</conditions>
<trueSet>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Player FirstName"/>
<string value="&gt;"/>
<string value=" or Parents of "/>
<string value="&lt;"/>
<string value="Player FirstName"/>
<string value="&gt;"/>
<string value=","/>
</set>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="b"/>
</conditions>
<trueSet>
<comment>-- sending to head coach only</comment>
<set field="ToField" arithmeticAsText="false">
<string field="Coach"/>
</set>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear coach"/>
</set>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="c"/>
</conditions>
<trueSet>
<comment>-- sending to all coaches on this team</comment>
<set field="ToField" arithmeticAsText="false">
<string value="All coaches on my team"/>
</set>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear coach"/>
</set>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="e"/>
</conditions>
<trueSet>
<comment>-- sending to one or more other team coaches</comment>
<set field="ToField" arithmeticAsText="false">
<string value="Selected Team Coach(es)"/>
</set>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string value="&lt;"/>
<string value="Coach&apos;s First Name"/>
<string value="&gt;"/>
</set>
</trueSet>
</if>
<comment>-- send copy to other assistants?</comment>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:CopyCoachesWithCoaches" value="a"/>
</conditions>
<trueSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value=" (A copy of this message will be sent to the other coaches on your team)"/>
</set>
</trueSet>
<falseSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value=" (A copy of this message will not be sent to the other coaches on your team)"/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="f"/>
</conditions>
<trueSet>
<comment>-- sending to Administrator</comment>
<set field="ToField" arithmeticAsText="false">
<string field="AdminName"/>
</set>
</trueSet>
</if>
<set field="CCSelf" arithmeticAsText="false">
<string value="A copy of this message will not be sent to you."/>
</set>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:CopySelf" value="a"/>
</conditions>
<trueSet>
<set field="CCSelf" arithmeticAsText="false">
<string value="A copy of this message will be sent to you."/>
</set>
</trueSet>
</if>
<set field="AttachedFile1" arithmeticAsText="false">
<string value=" "/>
</set>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<comment>Planning to attach files?</comment>
<if>
<conditions>
<and>
<isBlank field="AssistantCoachCommunicator:File1" />
<and>
<isBlank field="AssistantCoachCommunicator:File2" />
<isBlank field="AssistantCoachCommunicator:File3" />
</and>
</and>
</conditions>
<trueSet>
<comment>But didn't actually upload any?</comment>
<set field="AttachedFile1" arithmeticAsText="false">
<string value=" No file attachments were uploaded!"/>
</set>
</trueSet>
<falseSet>
<set field="AttachedFile1" arithmeticAsText="false">
<string value="Links to included file(s) will appear here."/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<show form="AssistantCoachCommunicatorSend"/>
</process>
<process name="Post-AssistantCoachCommunicatorSend">
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicatorSend:Action" value="b"/>
</conditions>
<trueSet>
<comment>-- edit the email</comment>
<show form="AssistantCoachCommunicatorSetup"/>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicatorSend:Action" value="c"/>
</conditions>
<trueSet>
<comment>-- abandon the email</comment>
<show form="AssistantCoachDashboard"/>
</trueSet>
</if>
<if>
<conditions>
<mcDoesNotEqual field="AssistantCoachCommunicatorSend:Action" value="a"/>
</conditions>
<trueSet>
<comment>-- no option selected</comment>
<show form="AssistantCoachCommunicatorSend"/>
</trueSet>
</if>
<set field="MessageBody" arithmeticAsText="false">
<string field="AssistantCoachCommunicator:Body"/>
</set>
<set field="MessageClose" arithmeticAsText="false">
<string field="AssistantCoachCommunicator:Close"/>
</set>
<comment>Set variables used for uploaded file URL links in Letters</comment>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:AttachFiles" value="a"/>
</conditions>
<trueSet>
<set field="AttachedFile1" arithmeticAsText="false">
<string field="AssistantCoachCommunicator:File1"/>
</set>
<set field="AttachedFile2" arithmeticAsText="false">
<string field="AssistantCoachCommunicator:File2"/>
</set>
<set field="AttachedFile3" arithmeticAsText="false">
<string field="AssistantCoachCommunicator:File3"/>
</set>
</trueSet>
<falseSet>
<set field="AttachedFile1" arithmeticAsText="false">
<string value="omit"/>
</set>
<set field="AttachedFile2" arithmeticAsText="false">
<string value="omit"/>
</set>
<set field="AttachedFile3" arithmeticAsText="false">
<string value="omit"/>
</set>
</falseSet>
</if>
<set field="DearSir" arithmeticAsText="false">
<string value=" "/>
</set>
<comment>-- (Note: overloading the CopyAsstCoaches variable in this Process: could mean either all coaches or assistant coaches)</comment>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="false"/>
</set>
<set field="SendCount" arithmeticAsText="false">
<string value="0"/>
</set>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="a"/>
</conditions>
<trueSet>
<comment>-- send to all players and coaches on this team</comment>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="true"/>
</set>
<get recordList="PlayerList">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<equals field="PlayerList:Registration:TeamId">
<string field="Team"/>
</equals>
</conditions></get>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="d"/>
</conditions>
<trueSet>
<comment>-- send to some players</comment>
<get recordList="PlayerList">
<forms>
<form name="Registration"/>
</forms>
<conditions>
<mcContains field="AssistantCoachCommunicator:PlayerChoice">
<string field="PlayerList:Registration:RegID"/>
</mcContains>
</conditions></get>
<comment>-- copy coaches on this team?</comment>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:CopyCoachesWithPlayers" value="a"/>
</conditions>
<trueSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="true"/>
</set>
</trueSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="a"/>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="d"/>
</or>
</conditions>
<trueSet>
<foreach record="Player" recordList="PlayerList">
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="Player:Registration:FirstName"/>
<string value=" or Parents of "/>
<string field="Player:Registration:FirstName"/>
<string value=","/>
</set>
</trueSet>
</if>
<send>
<to addressField="Player:Registration:ParentEmail"/>
<from addressField="AsstCoachEmail" aliasField="AsstCoachName"/>
<subject><field name="AssistantCoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<if>
<conditions>
<isNotBlank field="Player:Registration:ParentEmail2" />
</conditions>
<trueSet>
<send>
<to addressField="Player:Registration:ParentEmail2"/>
<from addressField="AsstCoachEmail" aliasField="AsstCoachName"/>
<subject><field name="AssistantCoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Message sent to "/>
<string field="SendCount"/>
<string value=" user(s)"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="c"/>
</conditions>
<trueSet>
<comment>-- send to all coaches on this team</comment>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="true"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="e"/>
</conditions>
<trueSet>
<comment>-- send to one or more coaches on other teams</comment>
<get recordList="CoachList">
<forms>
<form name="Coach"/>
</forms>
<conditions>
<mcContains field="AssistantCoachCommunicator:CoachChoice">
<string field="CoachList:Coach:CoachId"/>
</mcContains>
</conditions></get>
<foreach record="IndividualCoach" recordList="CoachList">
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="IndividualCoach:Coach:FirstName"/>
<string value=","/>
</set>
</trueSet>
</if>
<send>
<to addressField="IndividualCoach:Coach:Email"/>
<from addressField="AsstCoachEmail" aliasField="AsstCoachName"/>
<subject><field name="AssistantCoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
</foreach>
<comment>-- copy coaches on this team?</comment>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:CopyCoachesWithCoaches" value="a"/>
</conditions>
<trueSet>
<set field="CopyAsstCoaches" arithmeticAsText="false">
<string value="true"/>
</set>
</trueSet>
</if>
<set field="Message" arithmeticAsText="false">
<string value="Message sent to "/>
<string field="SendCount"/>
<string value=" user(s)"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<or>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="b"/>
<equals field="CopyAsstCoaches">
<string value="true"/>
</equals>
</or>
</conditions>
<trueSet>
<comment>-- send to head coach only OR to all coaches on this team</comment>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear coach,"/>
</set>
</trueSet>
</if>
<send>
<to addressField="CoachsEmail"/>
<from addressField="AsstCoachEmail" aliasField="AsstCoachName"/>
<subject><field name="AssistantCoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<if>
<conditions>
<equals field="CopyAsstCoaches">
<string value="true"/>
</equals>
</conditions>
<trueSet>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
<get recordList="AsstCoachList">
<forms>
<form name="AssistantCoachInfo"/>
</forms>
<conditions>
<and>
<equals field="AsstCoachList:AssistantCoachInfo:TeamId">
<string field="Team"/>
</equals>
<doesNotEqual field="AsstCoachList:AssistantCoachInfo:AsstId">
<string field="AsstCoachID"/>
</doesNotEqual>
</and>
</conditions></get>
<foreach record="AsstCoach" recordList="AsstCoachList">
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Salutation" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="Dear "/>
<string field="AsstCoach:AssistantCoachInfo:FirstName"/>
<string value=","/>
</set>
</trueSet>
</if>
<send>
<to addressField="AsstCoach:AssistantCoachInfo:Email"/>
<from addressField="AsstCoachEmail" aliasField="AsstCoachName"/>
<subject><field name="AssistantCoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="SendCount" arithmeticAsText="false">
<add>
<operand field="SendCount"/>
<operand value="1"/>
</add>
</set>
</foreach>
<set field="Message" arithmeticAsText="false">
<string value="Message sent to "/>
<string field="SendCount"/>
<string value=" user(s)"/>
</set>
</trueSet>
<falseSet>
<set field="Message" arithmeticAsText="false">
<string value="Email sent to coach"/>
</set>
</falseSet>
</if>
</trueSet>
</if>
<if>
<conditions>
<mcEquals field="AssistantCoachCommunicator:Recipient" value="f"/>
</conditions>
<trueSet>
<comment>-- send to Administrator</comment>
<send>
<to addressField="AdminEmail"/>
<from addressField="AsstCoachEmail" aliasField="AsstCoachName"/>
<subject><field name="AssistantCoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
<set field="Message" arithmeticAsText="false">
<string value="Email sent to Administrator"/>
</set>
</trueSet>
</if>
<if>
<conditions>
<mcContains field="AssistantCoachCommunicator:CopySelf" value="a"/>
</conditions>
<trueSet>
<set field="DearSir" arithmeticAsText="false">
<string value="(Copy of message sent from my Assistant Coach Dashboard)"/>
</set>
<send>
<to addressField="AsstCoachEmail"/>
<from addressField="AsstCoachEmail" aliasField="AsstCoachName"/>
<subject><field name="AssistantCoachCommunicator:Subject"/></subject>
<body document="Letter" reset="false" showHeader="true"/>
</send>
</trueSet>
</if>
<comment>Clear the variables so that other uses of the Letter Documents don't accidentally show links</comment>
<set field="AttachedFile1" arithmeticAsText="false">
<string value="omit"/>
</set>
<set field="AttachedFile2" arithmeticAsText="false">
<string value="omit"/>
</set>
<set field="AttachedFile3" arithmeticAsText="false">
<string value="omit"/>
</set>
<show document="Message" reset="false"/>
<show form="AssistantCoachDashboard"/>
</process>
<process name="Pre-RegistrantEmail">
<set field="Message" arithmeticAsText="false">
<string value=" "/>
</set>
<set field="Count" arithmeticAsText="false">
<string value="0"/>
</set>
<get recordList="PreviousEmailData">
<forms>
<form name="RegistrantEmail"/>
</forms>
</get>
<foreach record="Record" recordList="PreviousEmailData">
<set field="Count" arithmeticAsText="false">
<add>
<operand field="Count"/>
<operand value="1"/>
</add>
</set>
</foreach>
<if>
<conditions>
<equals field="Count">
<string value="0"/>
</equals>
</conditions>
<trueSet>
<comment>initialize fields first time in</comment>
<set field="RegistrantEmail:Q1" arithmeticAsText="false">
<string value="a"/>
</set>
<set field="RegistrantEmail:FromEmail" arithmeticAsText="false">
<string field="AdminEmail"/>
</set>
<set field="RegistrantEmail:FromName" arithmeticAsText="false">
<string field="AdminName"/>
</set>
</trueSet>
</if>
</process>
<process name="Pre-AdminCommunicatorRecipientList">
<set field="BuildRecipientList" arithmeticAsText="false">
<string value="true"/>
</set>
</process>
</processes>
<documents>
<document name="AdminDashboard">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="10185"><division indent="0" align="center"><font size="320"><b>Administrator Dashboard for </b></font><font size="320"><b><field name="League"/></b></font></division></cell></row><row><cell width="10185"><division indent="0" align="center"><font size="280">Administrator: </font><font size="280"><field name="AdminName"/></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="210"></cell><cell width="3660"><division indent="0" align="center"><font><u><invitation form="Preseason" project="">Preseason Activities</invitation></u></font></division></cell><cell width="2625"><division indent="0" align="center"><font><u><invitation form="ShowTeamRosters" project="">View Team Rosters</invitation></u></font></division></cell><cell width="3705"><division indent="0" align="center"><font color="0066CC"><u><invitation form="CommunicatorSetup" project="">Communicator</invitation></u></font></division></cell></row><row><cell width="210"></cell><cell width="3660"><division indent="0" align="center"><font color="000080"><u><invitation form="SetupMenu" project="">View/Edit Administrator Setup</invitation></u></font></division></cell><cell width="2625"><division indent="0" align="center"><font><u><invitation form="ShowContactFields" project="">View Player Data</invitation></u></font></division></cell><cell width="3705"><division indent="0" align="center"><font><link-to-project-details version="1"><description><string value="Jump to MyTawala"/>
</description><open-preference>current-window</open-preference></link-to-project-details></font></division></cell></row><row><cell width="210"></cell><cell width="3660"><division indent="0" align="center"><font color="000080"><u><invitation form="TeamViewToggle" project="">Toggle Team View on Player Dashes</invitation></u></font></division></cell><cell width="2625"><division indent="0" align="center"><font color="000080"><u><invitation form="ViewVolunteerData" project="">View Volunteer Data</invitation></u></font></division></cell><cell width="3705"><division indent="0" align="center"><font><u><invitation form="SendDashReminder" project="">Send/View Coach/Player Dashboard</invitation></u></font></division></cell></row><row><cell width="210"></cell><cell width="3660"><division indent="0" align="center"><font color="000080"><u><invitation form="CloseRegistration" project="">Close/Reopen Registration Period</invitation></u></font></division></cell><cell width="2625"><division indent="0" align="center"><font><u><invitation form="AdminSiteMap" project="">Site Map</invitation></u></font></division></cell><cell width="3705"></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Links:</b></font></paragraph><table indent="0"><row><cell width="272"></cell><cell width="3628"><division indent="0" align="center"><font color="000080"><u><link>
<new-window/>
<description>
<string value="League Home Page"/>
</description>
<url>
<field name="HomeURL"/>
</url>
</link>
</u></font></division></cell><cell width="2610"><division indent="0" align="center"><font color="000080"><u><link>
<new-window/>
<description>
<string value="Schedule"/>
</description>
<url>
<field name="ScheduleURL"/>
</url>
</link>
</u></font></division></cell><cell width="3705"><division indent="0" align="center"><font color="000080"><u><link>
<new-window/>
<description>
<string value="League Rules"/>
</description>
<url>
<field name="RulesURL"/>
</url>
</link>
</u></font></division></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font color="FF0000"><field name="Message"/></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="2340"><division indent="0" align="left"><font><b>Basic Info:</b></font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font face="Arial" size="200" color="0000A0"><u><invitation form="AdminSetup" project="">edit</invitation></u></font></division></cell><cell width="4380"><division indent="0" align="center"><font><b>Status Check:     </b></font></division></cell><cell width="930"></cell></row><row><cell width="2340"><division indent="0" align="right"><font>League:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="League"/></font></division></cell><cell width="4380"><division indent="0" align="right"><font>Uniforms/Jerseys ordered:</font></division></cell><cell width="930"><division indent="0" align="right"><font face="Arial" size="200"><field name="UniFlag"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Season:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="SeasonYr"/></font></division></cell><cell width="4380"><division indent="0" align="right"><font>All Teams assigned coaches:</font></division></cell><cell width="930"><division indent="0" align="right"><font face="Arial" size="200"><field name="Coaches4Teams"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminName"/></font></division></cell><cell width="4380"><division indent="0" align="right"><font>All Players assigned:</font></division></cell><cell width="930"><division indent="0" align="right"><font face="Arial" size="200"><field name="AllPlayersAssignedChecked"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Email:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminEmail"/></font></division></cell><cell width="4380"><division indent="0" align="right"><font>Team View on Player Dashboards:</font></division></cell><cell width="930"><division indent="0" align="right"><font face="Arial" size="200"><field name="TeamViewFlag"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Phone:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminsPhone"/></font></division></cell><cell width="4380"><division indent="0" align="right"><font>  Registration Period: </font></division></cell><cell width="930"><division indent="0" align="right"><font face="Arial" size="200"><field name="RegViewFlag"/></font></division></cell></row><row><cell width="2340"><division indent="0" align="right"><font>Administrator Address:</font></division></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminAdrss"/></font></division></cell><cell width="4380"></cell><cell width="930"></cell></row><row><cell width="2340"></cell><cell width="240"></cell><cell width="2340"><division indent="0" align="left"><font><field name="AdminsCity"/></font><font>, </font><font><field name="AdminState"/></font><sp/><font><field name="AdminsZIP"/></font></division></cell><cell width="4380"><division indent="0" align="right"><font>Fee structure: </font><font><field name="FeeStructureDescription"/></font><sp/></division></cell><cell width="930"></cell></row></table><paragraph indent="0" align="right"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="3735"><division indent="0" align="left"><font><b>Options:</b></font></division></cell><cell width="285"></cell><cell width="790"><division indent="0" align="right"><font face="Arial" size="180" color="0000A0"><u><invitation form="AdminSetup" project="">edit</invitation></u></font></division></cell><cell width="200"></cell><cell width="4305"><division indent="0" align="center"><font><b>Statistics:</b></font></division></cell><cell width="915"><division indent="0" align="right"><font face="Arial" size="200" color="000080"><u><invitation form="RefreshAdminDash" project="">refresh</invitation></u></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font>Email Notification Options       </font></division></cell><cell width="285"></cell><cell width="790"><division indent="0" align="right"><sp/></division></cell><cell width="200"></cell><cell width="4305"><division indent="0" align="right"><font>Recruiting List:</font></division></cell><cell width="915"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>RecruitmentDB</form-name><conditions><form name="RecruitmentDB" /><conditions>
<isNotBlank field="Record:RecruitmentDB:Email" />
</conditions></conditions></record-count></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font><i>Upon each new registration:</i></font></division></cell><cell width="285"></cell><cell width="790"><division indent="0" align="left"><font face="Arial" size="200"><field name="EmailAdminUponNewRegistration"/></font></division></cell><cell width="200"></cell><cell width="4305"><division indent="0" align="right"><font>Registrations:</font></division></cell><cell width="915"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /></conditions></record-count></font></division></cell></row><row><cell width="3735"><division indent="0" align="right"><font><i>Upon each bulk mailing:</i></font></division></cell><cell width="285"></cell><cell width="790"><division indent="0" align="left"><font face="Arial" size="200"><field name="EmailAdminUponBulkMailing"/></font></division></cell><cell width="200"></cell><cell width="4305"><division indent="0" align="right"><font>Waivers turned in:</font></division></cell><cell width="915"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /><conditions>
<isNotBlank field="Record:Registration:WaiverReceived" />
</conditions></conditions></record-count></font></division></cell></row><row><cell width="3735"></cell><cell width="285"></cell><cell width="790"></cell><cell width="200"></cell><cell width="4305"><division indent="0" align="right"><font>Payment received:</font></division></cell><cell width="915"><division indent="0" align="right"><font face="Arial" size="200"><record-count version="3"><form-name>Registration</form-name><conditions><form name="Registration" /><conditions>
<isNotBlank field="Record:Registration:PaymentReceived" />
</conditions></conditions></record-count></font></division></cell></row></table><paragraph indent="0" align="right"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The </font><font><b>Toggle Team View on Dashes</b></font><font> link at the top of this Dashboard permits you to hide coach and team</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>information from players until you have had a chance to review different rosters with others.  When this toggle</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>is set to </font><font><b>Off</b></font><font>, the players cannot see any coach, team or teammate information on their Dashboards, even though</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>you may have already assigned them to a team.  Once the assignments are fairly final, you should click this link</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>to </font><font><b>On</b></font><font>, which will populate all of the Player Dashboards with information on their team, division, coach and</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>teammates.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>The </font><font><b>Close/Re-Open Registration Period </b></font><font>link on this Dashboard permits you to redirect the Registration link on</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>your Web page to a message stating that registrations for this season have been closed and giving the contact</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>information for the Administrator in case a player wants to apply for late registration.  </font><font><b>Note: </b></font><font>The Administrator</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>can still register a player directly from this Dashboard, which will send a link then to the Player, permitting him or</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font>her to pay, sign the waiver and complete and missing information from the registration.</font></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row></table>
</xmlData>
</document>
<document name="Pre-Season">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280"><b>Preseason Activities</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="272"></cell><cell width="3608"><division indent="0" align="center"><font color="000080"><u><invitation form="Recruitment" project="">Recruitment List Tools</invitation></u></font></division></cell><cell width="200"></cell><cell width="3810"><division indent="0" align="center"><font color="000080"><u><invitation form="Team Rosters" project="">Assign Players to Teams</invitation></u></font></division></cell><cell width="210"></cell></row><row><cell width="272"></cell><cell width="3608"><division indent="0" align="center"><font color="000080"><u><invitation form="RegFormMgmt" project="">Player Registration Tools</invitation></u></font></division></cell><cell width="200"></cell><cell width="3810"><division indent="0" align="center"><font color="000080"><u><invitation form="Uniforms" project="">Order Jerseys/Uniforms</invitation></u></font></division></cell><cell width="210"></cell></row><row><cell width="272"></cell><cell width="3608"><division indent="0" align="center"><font color="000080"><u><invitation form="TeamAndCoachMenu" project="">Set up Teams and Coaches</invitation></u></font></division></cell><cell width="200"></cell><cell width="3810"><division indent="0" align="center"><font color="0066CC"><u><invitation form="CoachRosterNotice-Setup" project="">Send Dashboards to Coaches </invitation></u></font></division></cell><cell width="210"></cell></row><row><cell width="272"></cell><cell width="3608"></cell><cell width="200"></cell><cell width="3810"></cell><cell width="210"></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The</font><font color="004000"><b> Recruitment List Tools</b></font><font color="004000"> allow you to maintain an email list of potential prospects for your</font><sp/><font color="004000">League.   You can add, edit and delete names from the list, audit the email addresses for validity and send bulk mailings out to this list inviting them to register for your league.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The </font><font color="004000"><b>Player Registration Tools</b></font><font color="004000"> allow you to register a player or a group for your league, edit </font><sp/><font color="004000">or delete player registrations, mark receipt of waivers and payments, audit email addresses</font><sp/><font color="004000">and send bulk messages out to the players and their families.  You can use this tool to send</font><sp/><font color="004000">reminders to those with incomplete registrations as well as to send personal Player dashboards</font><sp/><font color="004000">to those who have lost theirs.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The </font><font color="004000"><b>Set up Teams and Coaches</b></font><font color="004000"> link lets you add, edit or delete team names, gather contact</font><sp/><font color="004000">information on your coaches, and assign coaches to individual teams.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">You may use the </font><font color="004000"><b>Assign Players to Teams</b></font><font color="004000"> link to move players onto teams using a drag-and-drop tool that lets you see basic player information, such as sex, age and friends.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The </font><font color="004000"><b>Order Uniforms</b></font><font color="004000"> link will give you size breakouts for uniforms for all of your registered players.</font><sp/><sp/><font color="004000">If you use divisions, it will break them out by division.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">The final link, </font><font color="004000"><b>Send Dashboards to Coaches</b></font><font color="004000">, permits you to send out a bulk mailing to all of</font><sp/><font color="004000">your coaches, giving them their team assignments and providing each with a personal Coach's</font><sp/><font color="004000">Dashboard with a set of tools to help them manage their team.</font></paragraph><table indent="0"><row><cell width="5400"><division indent="0" align="left"><sp/></division></cell><cell width="5400"></cell></row></table>
</xmlData>
</document>
<document name="RecruitmentMgmt">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280"><b>Manage the Recruitment List</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="105"><row><cell width="3570"><division indent="0" align="center"><font color="0066CC"><u><invitation form="Show RecruitDB" project="">View Recruitment List</invitation></u></font></division></cell><cell width="200"></cell><cell width="3475"><division indent="0" align="center"><font color="0066CC"><u><invitation form="AddRecruitRecord" project="">Add a Recruitment Record</invitation></u></font></division></cell><cell width="3449"><division indent="0" align="center"><font color="0066CC"><u><invitation form="RecruitEmail" project="">Send Email to Recruitment List</invitation></u></font></division></cell></row><row><cell width="3570"><division indent="0" align="center"><font color="0066CC"><u><invitation form="AuditRecruitList" project="">Audit Recruitment Email Addresses</invitation></u></font></division></cell><cell width="200"></cell><cell width="3475"><division indent="0" align="center"><font color="0066CC"><u><invitation form="EditRecruitment" project="">Edit a Recruitment Record</invitation></u></font></division></cell><cell width="3449"></cell></row><row><cell width="3570"><division indent="0" align="center"><font color="0066CC"><u><invitation form="DuplicateRecruitCheck" project="">Check for Duplicate Records</invitation></u></font></division></cell><cell width="200"></cell><cell width="3475"><division indent="0" align="center"><font color="0066CC"><u><invitation form="DeleteRecruitment" project="">Delete a Recruitment Record</invitation></u></font></division></cell><cell width="3449"></cell></row><row><cell width="3570"></cell><cell width="200"></cell><cell width="3475"><division indent="0" align="center"><font color="0066CC"><u><invitation form="AddRecruitFromReg" project="">Add Records from Registration List</invitation></u></font></division></cell><cell width="3449"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">With </font><font color="004000"><b>View Recruitment List</b></font><font color="004000"> you can see a tabular view of all your recruitment records. You may sort the list on any column by clicking on the heading for that column.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Audit Recruitment Email Addresses</b></font><font color="004000"> checks all email addresses in the list for validity. It can catch common typos and misspellings, although it doesn't catch everything.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Check for Duplicate Records</b></font><font color="004000"> is useful to locate records that may have inadvertently been entered more than once.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Add a Recruitment Record </b></font><font color="004000">is the way to add a new record to the recruitment database. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">Use </font><font color="004000"><b>Edit a Recruitment Record</b></font><font color="004000"> to change or correct information for an individual record from the recruitment database. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Delete a Recruitment Record </b></font><font color="004000">is used to remove a record from the recruitment database. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Add Records from Registration List</b></font><font color="004000"> is a handy way to copy information from your database of registered players into the recruitment database. This is useful for updating your recruitment list for the next season to include registrants from the current or past season.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">With </font><font color="004000"><b>Send Email to Recruitment List</b></font><font color="004000"> you are able to send bulk mailings to everyone in your recruitment list, to those whom you have not previously contacted or to those who have not yet registered.</font></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row></table>
</xmlData>
</document>
<document name="RecruitDB">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Recruitment" project="">Back to Recruitment</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000000">Number of records: </font><font color="000000"><record-count version="3"><form-name>RecruitmentDB</form-name><conditions><form name="RecruitmentDB" /></conditions></record-count></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header><string value="Parent"/>
</header><contents><field name="Record:RecruitmentDB:ParentFirst" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header><string value="Email 2"/>
</header><contents><field name="Record:RecruitmentDB:Email2" /></contents></column><column><header><string value="Phone"/>
</header><contents><field name="Record:RecruitmentDB:Phone" /></contents></column><conditions><form name="RecruitmentDB" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Recruitment" project="">Back to Recruitment</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="RecruitDBContacts">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:RecruitmentDB:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:RecruitmentDB:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:RecruitmentDB:Email" /></contents></column><column><header><string value="Email 2"/>
</header><contents><field name="Record:RecruitmentDB:Email2" /></contents></column><column><header><string value="# Emails Sent"/>
</header><contents><field name="Record:RecruitmentDB:ContactsNo" /></contents></column><conditions><form name="RecruitmentDB" /><conditions>
<isLessThan field="Record:RecruitmentDB:ContactsNo">
<string field="Count"/>
</isLessThan>
</conditions></conditions></itemization-table></font></paragraph>
</xmlData>
</document>
<document name="PlayerRegMgmt">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280"><b>Player Registration Management</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Setup</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="105"><row><cell width="3225"><division indent="0" align="center"><font color="0066CC"><u><invitation form="AdminPlayerRegistration" project="">Register a Player or Group</invitation></u></font></division></cell><cell width="3465"><division indent="0" align="center"><font color="0066CC"><u><invitation form="ShowContactFields" project="">View All Registrations</invitation></u></font></division></cell><cell width="4005"><division indent="0" align="center"><font color="0066CC"><u><invitation form="AuditRegForms" project="">Audit Registration Email Addresses</invitation></u></font></division></cell></row><row><cell width="3225"><division indent="0" align="center"><font color="0066CC"><u><invitation form="ConfirmPaymentAndWaiverReceipts" project="">Mark Waivers and Payments</invitation></u></font></division></cell><cell width="3465"><division indent="0" align="center"><font color="0066CC"><u><invitation form="ViewEditRecord" project="">View/Edit a Specific Registration</invitation></u></font></division></cell><cell width="4005"><division indent="0" align="center"><font color="0066CC"><u><invitation form="RegistrantEmail" project="">Send Email to Registered Players</invitation></u></font></division></cell></row><row><cell width="3225"><division indent="0" align="center"><font color="0066CC"><u><invitation form="RegistrantDeduping" project="">Check for Duplicates</invitation></u></font></division></cell><cell width="3465"><division indent="0" align="center"><font color="0066CC"><u><invitation form="DeleteRegistration" project="">Delete a Registration</invitation></u></font></division></cell><cell width="4005"><division indent="0" align="center"><font color="0066CC"><u><invitation form="PaymentReport" project="">View Payment Report</invitation></u></font></division></cell></row><row><cell width="3225"></cell><cell width="3465"></cell><cell width="4005"></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">In </font><font color="004000"><b>Register a Player or Group</b></font><font color="004000"> you may enter registration information directly, send someone a direct link to the registration form for them to fill out, or do a group registration.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">You may use </font><font color="004000"><b>Mark Waivers and Payments</b></font><font color="004000"> to record the receipt of registration fees and waivers. You may also unmark any items that were previously marked in error.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Check for Duplicates</b></font><font color="004000"> is useful to locate records of registrants who may have inadvertently registered more than once.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">You may use </font><font color="004000"><b>View All Registrations</b></font><font color="004000"> to access several summary view of all the registrations forms. You may sort any view by the responses in any column just by clicking on the heading for that column.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>View/Edit a Specific Registration</b></font><font color="004000"> permits you to access any player's registration form in order to view it or correct information.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Delete a Registration </b></font><font color="004000">is useful to remove a record entirely. This is especially valuable when registrants inadvertently end up with duplicate records in the database. </font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000"><b>Audit Registration Email Addresses</b></font><font color="004000"> checks the addresses in all the registrations for validity. It can catch common typos and misspellings, although it doesn't catch everything.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">With </font><font color="004000"><b>Send Email to Registered Players</b></font><font color="004000"> you are able to send bulk mailings to all players, to those missing waivers, to those who have not yet paid and to those whose registrations are complete in all respects.</font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="004000">With </font><font color="004000"><b>View Payment Report</b></font><font color="004000"> you can see the list of players whose registrations are paid, including the payment amounts and payment methods.</font></paragraph><table indent="0"><row><cell width="10800"><division indent="0" align="left"><sp/></division></cell></row></table>
</xmlData>
</document>
<document name="TeamAndCoachMenu">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="000000"><b>Teams and Coaches</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="200"></cell><cell width="1855"><division indent="0" align="center"><font color="0066CC"><u><invitation form="Team" project="">Add a Team</invitation></u></font></division></cell><cell width="285"></cell><cell width="1935"><division indent="0" align="center"><font color="0066CC"><u><invitation form="ParentCoaches" project="">Add a Coach</invitation></u></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="center"><font color="0066CC"><u><invitation form="CoachToTeamAssignment" project="">Assign Coach to Team</invitation></u></font></division></cell><cell width="200"></cell><cell width="2752"><division indent="0" align="center"><font color="0066CC"><u><invitation form="Team Rosters" project="">Assign Players to Teams</invitation></u></font></division></cell></row><row><cell width="200"></cell><cell width="1855"><division indent="0" align="center"><font color="0066CC"><u><invitation form="EditTeam" project="">Edit a Team</invitation></u></font></division></cell><cell width="285"></cell><cell width="1935"><division indent="0" align="center"><font color="0066CC"><u><invitation form="EditCoach" project="">Edit a Coach</invitation></u></font></division></cell><cell width="200"></cell><cell width="3325"><division indent="0" align="center"><font color="0066CC"><u><invitation form="UnassignCoachFromTeam" project="">Un-assign Coach from Team</invitation></u></font></division></cell><cell width="200"></cell><cell width="2752"></cell></row><row><cell width="200"></cell><cell width="1855"><division indent="0" align="center"><font color="0066CC"><u><invitation form="DeleteTeam" project="">Delete a Team</invitation></u></font></division></cell><cell width="285"></cell><cell width="1935"><division indent="0" align="center"><font color="0066CC"><u><invitation form="DeleteCoach" project="">Delete a Coach</invitation></u></font></division></cell><cell width="200"></cell><cell width="3325"></cell><cell width="200"></cell><cell width="2752"></cell></row></table><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font size="240" color="000000"><b>Teams:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="Name"/>
</header><contents><field name="Record:Team:TeamId" /></contents></column><column><header><string value="Coach Name"/>
</header><contents><field name="Record:Team:CoachFullName" /></contents></column><conditions><form name="Team" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="center"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font size="240" color="000000"><b>Coaches:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><tab/><font color="000000"><itemization-table version="2"><show-print-control>false</show-print-control><column><header><string value="First Name"/>
</header><contents><field name="Record:Coach:FirstName" /></contents></column><column><header><string value="Last Name"/>
</header><contents><field name="Record:Coach:LastName" /></contents></column><column><header><string value="Email"/>
</header><contents><field name="Record:Coach:Email" /></contents></column><conditions><form name="Coach" /></conditions></itemization-table></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font><sp/><sp/><sp/><sp/><sp/><sp/><sp/><font color="000080"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></paragraph>
</xmlData>
</document>
<document name="TeamAssignment">
<xmlData>
<paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font size="280" color="000000"><b>Team Assignment</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><table indent="0"><row><cell width="4800"><division indent="0" align="left"><font color="000080"><u><invitation form="Preseason" project="">Back to Preseason Menu</invitation></u></font></division></cell><cell width="6000"><division indent="0" align="left"><font color="0066CC"><u><invitation form="AdminDash" project="">Back to Administrator Dashboard</invitation></u></font></division></cell></row></table><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font color="C10000"><i>Note: You </i></font><font color="C10000"><b><i>must</i></b></font><font color="C10000"><i> press the "Save Changes" button below the Team Assignment table to record your actions.</i></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><b>Use "Drag and Drop" to sort players into teams:</b></font></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions></paragraph><paragraph indent="0" align="left"><tabPositions><tabStop position="2880"/></tabPositions><font><categorizer version="2"><category-names>Record:Team:TeamId</category-names><category-ids>Record:Team:TeamId</category-ids><category-storage-field>Record:Registration:TeamId</category-storage-field><navigate-to>Team Rosters</navigate-to><column><header><string value="First"/>
</header><contents><field name="Record:Registration:FirstName" /></contents></column><column><header><string value="Last"/>
</header><contents><field name="Record:Registration:LastName" /></contents></column><column><header><string value="League Age"/>
</header><contents><field name="Record:Registration:PlayerAge" /></contents></column><column><header><string value="Sex"/>
</header><contents><field name="Record:Registration:Sex" /></contents></column><column><header><string value="Coach"/>
</header><contents><field name="Record:Registration:PreferredCoach" /></contents><display-conditions><equals field="AskCoachPreference">
<string value="Yes"/>
</equals>
</display-conditions></column><column><header><string value="Preferred Teammates"/>
</header><contents><field name="Record:Registration:FriendsList" /></contents><display-conditions><equals field="AskFriendsName">
<string value="Yes"/>
</equals>
</display-conditions></column><column><header><string value="Division"/>
</header><contents><field name="Record:Registration:DivisionId" /></contents><display-conditions><equals field="AskDesiredDivision">
<string value="Yes"/>
</equals>
</display-conditions></column><conditions><form name="Team" /><form name="Registration" /><form name="Team Rosters" /></conditions></categorizer></font></paragraph>
</xmlData>
</document>
